# Banco de dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/genesis?schema=public"

# Sandbox de relatórios (Gerador de Relatórios): conexão SOMENTE-LEITURA dedicada,
# com uma role que só tem SELECT nas views rel_* (ver prisma/sql/report_role.sql).
# Sem esta variável, a execução de relatórios fica DESABILITADA (com erro claro).
REPORT_DB_URL="postgresql://genesis_report_ro:senha@localhost:5432/genesis?schema=public"

# JWT — gere com: openssl rand -hex 32
JWT_SECRET=

# URL pública usada nos links enviados por e-mail (sem barra no final)
BASE_URL=http://localhost:3000

# Gmail — use uma App Password (não a senha normal da conta)
# Gerar em: https://myaccount.google.com/apppasswords
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=

# Twilio (SMS) — deixe em branco para usar o mock em desenvolvimento
# Configurar em: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+5511999999999

# Token de serviço da data API read-only dos memoriais (LRF) p/ o Oxy Dashboards.
# Sem ele, a API responde 503 (desligada). Defina o mesmo valor no conector do Oxy.
GENESIS_API_TOKEN=
