generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Sistema {
  id           String          @id @default(uuid())
  nome         String          @unique
  descricao    String?
  ativo        Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
  admins       AdminSistema[]
  modulos      Modulo[]
  relatorios   RelatorioFixo[]

  @@map("sistemas")
}

model Modulo {
  id           String        @id @default(uuid())
  nome         String
  descricao    String?
  ativo        Boolean       @default(true)
  ordem        Int           @default(0)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt
  sistemaId    String
  admins       AdminModulo[]
  menus        Menu[]
  sistema      Sistema       @relation(fields: [sistemaId], references: [id])

  @@unique([nome, sistemaId])
  @@map("modulos")
}

model Menu {
  id           String               @id @default(uuid())
  nome         String
  icone        String?
  ordem        Int                  @default(0)
  ativo        Boolean              @default(true)
  criadoEm     DateTime             @default(now())
  atualizadoEm DateTime             @updatedAt
  moduloId     String
  itens        ItemFuncionalidade[]
  modulo       Modulo               @relation(fields: [moduloId], references: [id])

  @@unique([nome, moduloId])
  @@map("menus")
}

model ItemFuncionalidade {
  id                 String               @id @default(uuid())
  nome               String
  descricao          String?
  tipo               TipoItem
  tipoFuncionalidade TipoFuncionalidade?
  rota               String?
  icone              String?
  ordem              Int                  @default(0)
  ativo              Boolean              @default(true)
  criadoEm           DateTime             @default(now())
  atualizadoEm       DateTime             @updatedAt
  menuId             String
  parentId           String?
  referenciaId       String?
  menu               Menu                 @relation(fields: [menuId], references: [id])
  parent             ItemFuncionalidade?  @relation("SubItens", fields: [parentId], references: [id])
  subItens           ItemFuncionalidade[] @relation("SubItens")
  referencia         ItemFuncionalidade?  @relation("Atalhos", fields: [referenciaId], references: [id])
  atalhos            ItemFuncionalidade[] @relation("Atalhos")
  permissoes         PermissaoAcesso[]
  favoritos          FavoritoItem[]

  @@map("itens_funcionalidade")
}

model Usuario {
  id                       String                   @id @default(uuid())
  cpf                      String?                  @unique
  idEstrangeiro            String?                  @unique
  nomeCompleto             String
  nomeSocial               String
  dataNascimento           DateTime                 @db.Date
  emailPrincipal           String                   @unique
  emailAlternativo         String?
  telefonePrincipal        String
  telefoneAlternativo      String?
  emailValidado            Boolean                  @default(false)
  celularValidado          Boolean                  @default(false)
  ativo                    Boolean                  @default(false)
  criadoEm                 DateTime                 @default(now())
  atualizadoEm             DateTime                 @updatedAt
  senhaHash                String?
  adminModulos             AdminModulo[]
  adminSistemas            AdminSistema[]
  acessosEntidade          AcessoEntidade[]
  codigosValidacao         CodigoValidacao[]
  favoritos                FavoritoRelatorio[]
  favoritosItem            FavoritoItem[]
  lixeira                  Lixeira[]
  pastas                   PastaFavorito[]
  permissoes               PermissaoAcesso[]
  relatoriosPersonalizados RelatorioPersonalizado[]
  cabecalhosRelatorio      CabecalhoRelatorio[]
  rodapesRelatorio         RodapeRelatorio[]

  @@map("usuarios")
}

model Lixeira {
  id            String   @id @default(uuid())
  tipo          String
  nome          String
  estrutura     Json
  excluidoEm    DateTime @default(now())
  excluidoPorId String
  excluidoPor   Usuario  @relation(fields: [excluidoPorId], references: [id])

  @@map("lixeira")
}

model CodigoValidacao {
  id         String        @id @default(uuid())
  codigo     String
  tipo       TipoValidacao
  expiradoEm DateTime
  usadoEm    DateTime?
  tentativas Int           @default(0)
  criadoEm   DateTime      @default(now())
  usuarioId  String
  usuario    Usuario       @relation(fields: [usuarioId], references: [id])

  @@map("codigos_validacao")
}

model AdminSistema {
  id        String   @id @default(uuid())
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  usuarioId String
  sistemaId String
  sistema   Sistema  @relation(fields: [sistemaId], references: [id])
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, sistemaId])
  @@map("admins_sistema")
}

model AdminModulo {
  id        String   @id @default(uuid())
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  usuarioId String
  moduloId  String
  modulo    Modulo   @relation(fields: [moduloId], references: [id])
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, moduloId])
  @@map("admins_modulo")
}

model PermissaoAcesso {
  id           String             @id @default(uuid())
  nivel        NivelAcesso
  ativo        Boolean            @default(true)
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt
  usuarioId    String
  itemId       String
  item         ItemFuncionalidade @relation(fields: [itemId], references: [id])
  usuario      Usuario            @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, itemId])
  @@map("permissoes_acesso")
}

model RelatorioFixo {
  id        String              @id @default(uuid())
  nome      String
  descricao String?
  rota      String
  ativo     Boolean             @default(true)
  criadoEm  DateTime            @default(now())
  sistemaId String
  favoritos FavoritoRelatorio[]
  sistema   Sistema             @relation(fields: [sistemaId], references: [id])

  @@map("relatorios_fixos")
}

model RelatorioPersonalizado {
  id           String              @id @default(uuid())
  nome         String
  descricao    String?
  configuracao Json
  query        String?
  ativo        Boolean             @default(true)
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt
  usuarioId    String
  entidadeId   String?
  cabecalhoId  String?
  rodapeId     String?
  favoritos    FavoritoRelatorio[]
  usuario      Usuario             @relation(fields: [usuarioId], references: [id])
  entidade     Entidade?           @relation(fields: [entidadeId], references: [id])
  cabecalho    CabecalhoRelatorio? @relation(fields: [cabecalhoId], references: [id])
  rodape       RodapeRelatorio?    @relation(fields: [rodapeId], references: [id])

  @@map("relatorios_personalizados")
}

model PastaFavorito {
  id         String              @id @default(uuid())
  nome       String
  ordem      Int                 @default(0)
  criadoEm   DateTime            @default(now())
  parentId   String?
  usuarioId  String
  entidadeId String?
  favoritos  FavoritoRelatorio[]
  parent     PastaFavorito?      @relation("SubPastas", fields: [parentId], references: [id])
  subPastas  PastaFavorito[]     @relation("SubPastas")
  usuario    Usuario             @relation(fields: [usuarioId], references: [id])
  entidade   Entidade?           @relation(fields: [entidadeId], references: [id])

  @@map("pastas_favorito")
}

model FavoritoItem {
  id        String             @id @default(uuid())
  criadoEm  DateTime           @default(now())
  usuarioId String
  itemId    String
  item      ItemFuncionalidade @relation(fields: [itemId], references: [id])
  usuario   Usuario            @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, itemId])
  @@map("favoritos_item")
}

model FavoritoRelatorio {
  id                       String                  @id @default(uuid())
  ordem                    Int                     @default(0)
  criadoEm                 DateTime                @default(now())
  usuarioId                String
  pastaId                  String?
  relatorioFixoId          String?
  relatorioPersonalizadoId String?
  pasta                    PastaFavorito?          @relation(fields: [pastaId], references: [id])
  relatorioFixo            RelatorioFixo?          @relation(fields: [relatorioFixoId], references: [id])
  relatorioPersonalizado   RelatorioPersonalizado? @relation(fields: [relatorioPersonalizadoId], references: [id])
  usuario                  Usuario                 @relation(fields: [usuarioId], references: [id])

  @@map("favoritos_relatorio")
}

// Template de cabeçalho de relatório, escopado por Entidade (contexto do /app).
// `layout` é a lista de elementos posicionados livremente pelo editor WYSIWYG:
// [{ tipo, x, y }] com x/y em porcentagem (0-100) da faixa, para escalar em
// qualquer largura de saída. `criadoPor` é só auditoria — o template é
// compartilhado entre os operadores da entidade.
model CabecalhoRelatorio {
  id           String                   @id @default(uuid())
  nome         String
  altura       Int                      @default(120)
  layout       Json
  ativo        Boolean                  @default(true)
  criadoEm     DateTime                 @default(now())
  atualizadoEm DateTime                 @updatedAt
  entidadeId   String
  criadoPorId  String
  entidade     Entidade                 @relation(fields: [entidadeId], references: [id])
  criadoPor    Usuario                  @relation(fields: [criadoPorId], references: [id])
  relatorios   RelatorioPersonalizado[]

  @@unique([entidadeId, nome])
  @@map("cabecalhos_relatorio")
}

// Template de rodapé de relatório. Mesma mecânica do cabeçalho; difere apenas
// no conjunto de elementos permitidos (ver service).
model RodapeRelatorio {
  id           String                   @id @default(uuid())
  nome         String
  altura       Int                      @default(80)
  layout       Json
  ativo        Boolean                  @default(true)
  criadoEm     DateTime                 @default(now())
  atualizadoEm DateTime                 @updatedAt
  entidadeId   String
  criadoPorId  String
  entidade     Entidade                 @relation(fields: [entidadeId], references: [id])
  criadoPor    Usuario                  @relation(fields: [criadoPorId], references: [id])
  relatorios   RelatorioPersonalizado[]

  @@unique([entidadeId, nome])
  @@map("rodapes_relatorio")
}

enum TipoItem {
  FUNCIONALIDADE
  SUBMENU
}

enum TipoFuncionalidade {
  CRUD
  TELA
  RELATORIO
}

enum TipoValidacao {
  EMAIL
  CELULAR
}

enum NivelAcesso {
  VISUALIZAR
  CRIAR
  EDITAR
  EXCLUIR
  TOTAL
}

// Nível do acesso de um usuário a uma Entidade. Hierarquia:
// ADMIN ⊃ ESCRITA ⊃ LEITURA. Usado por AcessoEntidade.
enum NivelAcessoEntidade {
  LEITURA
  ESCRITA
  ADMIN
}

// ─────────────────────────────────────────────────────────────
// Módulo Contábil
// Estado/Município → ModeloContabil → PlanoDeContas (1/ano) → Conta (árvore 6 níveis)
// Lançamento (partida dobrada, por município) → ResumoMensalConta (agregado)
// SaldoInicialAno é populado por procedimento de virada de ano (fase posterior).
// ─────────────────────────────────────────────────────────────

model ModeloContabil {
  id            String               @id @default(uuid())
  descricao     String               @unique
  ativo         Boolean              @default(true)
  criadoEm      DateTime             @default(now())
  atualizadoEm  DateTime             @updatedAt
  planos        PlanoDeContas[]
  planosReceita PlanoContasReceita[]
  planosDespesa PlanoContasDespesa[]
  fontesRecurso FonteRecurso[]
  eventos       EventoContabil[]
  estados       Estado[]
  municipios    Municipio[]

  @@map("modelos_contabeis")
}

model Estado {
  id               String          @id @default(uuid())
  nome             String          @unique
  sigla            String          @unique @db.Char(2)
  modeloContabilId String?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt
  modeloContabil   ModeloContabil? @relation(fields: [modeloContabilId], references: [id])
  municipios       Municipio[]

  @@map("estados")
}

model Municipio {
  id               String          @id @default(uuid())
  nome             String
  estadoId         String
  modeloContabilId String?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt
  estado           Estado          @relation(fields: [estadoId], references: [id])
  modeloContabil   ModeloContabil? @relation(fields: [modeloContabilId], references: [id])
  entidades        Entidade[]

  @@unique([nome, estadoId])
  @@map("municipios")
}

model PlanoDeContas {
  id               String         @id @default(uuid())
  descricao        String
  ano              Int
  modeloContabilId String
  criadoEm         DateTime       @default(now())
  atualizadoEm     DateTime       @updatedAt
  modeloContabil   ModeloContabil @relation(fields: [modeloContabilId], references: [id])
  contas           Conta[]

  @@unique([modeloContabilId, ano])
  @@map("planos_de_contas")
}

model Conta {
  id              String        @id @default(uuid())
  codigo          String
  descricao       String
  nivel           Int // 1..9 (PCASP Estendido TCE-PR)
  admiteMovimento Boolean       @default(false)
  // Atributos PCASP (origem: planilha TCE-PR; nullable pois contas criadas à mão
  // ou planos não-importados podem não tê-los). Só no plano-modelo contábil.
  naturezaInformacao  NaturezaInformacao?
  naturezaSaldo       NaturezaSaldo?
  superavitFinanceiro SuperavitFinanceiro?
  funcao              String?       @db.Text
  planoId         String
  parentId        String?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt
  plano           PlanoDeContas @relation(fields: [planoId], references: [id])
  parent          Conta?        @relation("Subcontas", fields: [parentId], references: [id])
  filhos          Conta[]       @relation("Subcontas")

  @@unique([planoId, codigo])
  @@index([planoId, parentId])
  @@map("contas")
}

/// Natureza da Informação (PCASP): classifica a conta. Patrimonial (classes
/// 1-4), Orçamentária (5-6), Controle (7-8).
enum NaturezaInformacao {
  PATRIMONIAL
  ORCAMENTARIA
  CONTROLE
}

/// Natureza do saldo da conta (PCASP). Mista admite inversão de saldo.
enum NaturezaSaldo {
  DEVEDORA
  CREDORA
  MISTA
}

/// Indicador de superávit financeiro / outros controles (PCASP TCE-PR).
enum SuperavitFinanceiro {
  FINANCEIRO
  PATRIMONIAL
  MISTA
  OUTROS_CONTROLES
}

// Lançamento patrimonial: vive na ENTIDADE (não mais no município). As contas
// referenciadas são as cópias da entidade (ContaContabilEntidade), nunca as
// contas-modelo do TCE.
model Lancamento {
  id          String           @id @default(uuid())
  entidadeId  String
  data        DateTime         @db.Date
  historico   String
  valor       Decimal          @db.Decimal(18, 2) // soma dos itens; invariante D = C
  criadoEm    DateTime         @default(now())
  criadoPorId String
  entidade    Entidade         @relation(fields: [entidadeId], references: [id])
  itens       LancamentoItem[]

  @@index([entidadeId, data])
  @@map("lancamentos")
}

model LancamentoItem {
  id           String                @id @default(uuid())
  lancamentoId String
  contaId      String // FK em ContaContabilEntidade (cópia da entidade)
  tipo         TipoLancamento
  valor        Decimal               @db.Decimal(18, 2)
  lancamento   Lancamento            @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  conta        ContaContabilEntidade @relation(fields: [contaId], references: [id])

  @@index([contaId])
  @@map("lancamento_itens")
}

// Agregado mensal por (entidade × conta-da-entidade × ano × mês). Atualizado
// na mesma transação do lançamento.
model ResumoMensalConta {
  entidadeId   String
  contaId      String
  ano          Int
  mes          Int // 1..12
  totalDebito  Decimal               @default(0) @db.Decimal(18, 2)
  totalCredito Decimal               @default(0) @db.Decimal(18, 2)
  entidade     Entidade              @relation(fields: [entidadeId], references: [id])
  conta        ContaContabilEntidade @relation(fields: [contaId], references: [id])

  @@id([entidadeId, contaId, ano, mes])
  @@map("resumos_mensais_conta")
}

model SaldoInicialAno {
  entidadeId String
  contaId    String
  ano        Int
  valor      Decimal               @default(0) @db.Decimal(18, 2)
  entidade   Entidade              @relation(fields: [entidadeId], references: [id])
  conta      ContaContabilEntidade @relation(fields: [contaId], references: [id])

  @@id([entidadeId, contaId, ano])
  @@map("saldos_iniciais_ano")
}

enum TipoLancamento {
  DEBITO
  CREDITO
}

// ─── Plano de Contas da Receita (orçamentário) ───────────────────────────────
// Árvore própria por modelo contábil × ano (cada TCE estadual define o seu).
model PlanoContasReceita {
  id               String         @id @default(uuid())
  descricao        String
  ano              Int
  modeloContabilId String
  criadoEm         DateTime       @default(now())
  atualizadoEm     DateTime       @updatedAt
  modeloContabil   ModeloContabil @relation(fields: [modeloContabilId], references: [id])
  contas           ContaReceita[]

  @@unique([modeloContabilId, ano])
  @@map("planos_contas_receita")
}

model ContaReceita {
  id              String             @id @default(uuid())
  codigo          String
  descricao       String
  nivel           Int // derivado do parent
  admiteMovimento Boolean            @default(false) // true = analítica (folha)
  planoId         String
  parentId        String?
  criadoEm        DateTime           @default(now())
  atualizadoEm    DateTime           @updatedAt
  plano           PlanoContasReceita @relation(fields: [planoId], references: [id])
  parent          ContaReceita?      @relation("SubReceita", fields: [parentId], references: [id])
  filhos          ContaReceita[]     @relation("SubReceita")

  @@unique([planoId, codigo])
  @@index([planoId, parentId])
  @@map("contas_receita")
}

// ─── Plano de Contas da Despesa (orçamentário) ───────────────────────────────
model PlanoContasDespesa {
  id               String         @id @default(uuid())
  descricao        String
  ano              Int
  modeloContabilId String
  criadoEm         DateTime       @default(now())
  atualizadoEm     DateTime       @updatedAt
  modeloContabil   ModeloContabil @relation(fields: [modeloContabilId], references: [id])
  contas           ContaDespesa[]

  @@unique([modeloContabilId, ano])
  @@map("planos_contas_despesa")
}

model ContaDespesa {
  id              String             @id @default(uuid())
  codigo          String
  descricao       String
  nivel           Int // derivado do parent
  admiteMovimento Boolean            @default(false) // true = analítica (folha)
  planoId         String
  parentId        String?
  criadoEm        DateTime           @default(now())
  atualizadoEm    DateTime           @updatedAt
  plano           PlanoContasDespesa @relation(fields: [planoId], references: [id])
  parent          ContaDespesa?      @relation("SubDespesa", fields: [parentId], references: [id])
  filhos          ContaDespesa[]     @relation("SubDespesa")

  @@unique([planoId, codigo])
  @@index([planoId, parentId])
  @@map("contas_despesa")
}

// ─── Fonte ou Destinação de Recursos ─────────────────────────────────────────
// Lista plana versionada por modelo contábil × ano (NÃO é árvore). Elo
// integrador receita↔despesa; o vínculo com a execução vem em fase posterior.
model FonteRecurso {
  id               String         @id @default(uuid())
  codigo           String // 3 dígitos (Estados/DF/Municípios: 500-999)
  ano              Int
  nomenclatura     String
  especificacao    String?
  vinculada        Boolean        @default(true) // false = Recursos Livres
  grupo            String? // "Livres", "Educação", "Saúde", "Assistência Social"...
  modeloContabilId String
  criadoEm         DateTime       @default(now())
  atualizadoEm     DateTime       @updatedAt
  modeloContabil   ModeloContabil @relation(fields: [modeloContabilId], references: [id])

  @@unique([modeloContabilId, ano, codigo])
  @@index([modeloContabilId, ano])
  @@map("fontes_recurso")
}

// ─── Entidade (prefeitura, câmara, adm. indireta) ────────────────────────────
// Vive sob o Município e é a dona da execução. Na criação recebe uma CÓPIA das
// árvores do modelo do estado (contábil/receita/despesa) + fontes, por exercício.
enum TipoEntidade {
  PREFEITURA
  CAMARA
  ADM_INDIRETA
}

// Procedência de cada conta/fonte copiada: veio do modelo do TCE (imutável para
// a entidade) ou foi um desdobramento criado pela própria entidade.
enum OrigemConta {
  MODELO
  DESDOBRAMENTO
}

model Entidade {
  id           String       @id @default(uuid())
  nome         String
  tipo         TipoEntidade
  cnpj         String?      @unique
  endereco     String?
  brasao       String?      @db.Text // imagem do brasão como data URL (base64)
  municipioId  String
  ativo        Boolean      @default(true)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt
  municipio    Municipio    @relation(fields: [municipioId], references: [id])

  contasContabil           ContaContabilEntidade[]
  contasReceita            ContaReceitaEntidade[]
  contasDespesa            ContaDespesaEntidade[]
  fontesRecurso            FonteRecursoEntidade[]
  unidadesOrcamentaria     UnidadeOrcamentaria[]
  programas                Programa[]
  orcamentos               Orcamento[]
  acessos                  AcessoEntidade[]
  lancamentos              Lancamento[]
  resumos                  ResumoMensalConta[]
  saldosIniciais           SaldoInicialAno[]
  planosContratacao        PlanoContratacaoAnual[]
  documentosDemanda        DocumentoDemanda[]
  reservasDotacao          ReservaDotacao[]
  processos                Processo[]
  contratos                Contrato[]
  atasRegistroPreco        AtaRegistroPreco[]
  empenhos                 Empenho[]
  liquidacoes              Liquidacao[]
  ordensPagamento          OrdemPagamento[]
  cabecalhosRelatorio      CabecalhoRelatorio[]
  rodapesRelatorio         RodapeRelatorio[]
  relatoriosPersonalizados RelatorioPersonalizado[]
  pastasFavorito           PastaFavorito[]
  contasBancarias          ContaBancaria[]

  @@unique([municipioId, nome])
  @@map("entidades")
}

// ─── Conta bancária (padrão Febraban) ────────────────────────────────────────
// Vinculada à fonte de recurso POR CÓDIGO (não por FK à cópia do exercício):
// o código TCE/STN é estável entre anos, então a conta sobrevive à virada de
// exercício sem revinculação. Regra: pagamentos de uma fonte só podem sair
// pelas contas bancárias daquela fonte (validado na emissão da OP).
model ContaBancaria {
  id          String   @id @default(uuid())
  entidadeId  String
  fonteCodigo String
  bancoCodigo String // código Febraban/COMPE, 3 dígitos (ex.: 001, 104, 341)
  bancoNome   String?
  agencia     String
  agenciaDv   String?
  numero      String
  numeroDv    String?
  descricao   String?
  ativa       Boolean  @default(true)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  entidade    Entidade @relation(fields: [entidadeId], references: [id])

  ordensPagamento OrdemPagamento[]

  @@unique([entidadeId, bancoCodigo, agencia, numero])
  @@index([entidadeId, fonteCodigo])
  @@map("contas_bancarias")
}

// As contas de entidade são cópias por exercício (ano). `modeloContaId` é uma
// referência fraca (sem FK) à conta-fonte do modelo, para rastreio/sincronização.
model ContaContabilEntidade {
  id              String                  @id @default(uuid())
  entidadeId      String
  ano             Int
  codigo          String
  descricao       String
  nivel           Int
  admiteMovimento Boolean                 @default(false)
  origem          OrigemConta             @default(MODELO)
  modeloContaId   String?
  parentId        String?
  criadoEm        DateTime                @default(now())
  atualizadoEm    DateTime                @updatedAt
  entidade        Entidade                @relation(fields: [entidadeId], references: [id])
  parent          ContaContabilEntidade?  @relation("SubContabilEnt", fields: [parentId], references: [id])
  filhos          ContaContabilEntidade[] @relation("SubContabilEnt")
  lancamentoItens LancamentoItem[]
  resumos         ResumoMensalConta[]
  saldosIniciais  SaldoInicialAno[]

  @@unique([entidadeId, ano, codigo])
  @@index([entidadeId, ano, parentId])
  @@map("contas_contabil_entidade")
}

model ContaReceitaEntidade {
  id              String                 @id @default(uuid())
  entidadeId      String
  ano             Int
  codigo          String
  descricao       String
  nivel           Int
  admiteMovimento Boolean                @default(false)
  origem          OrigemConta            @default(MODELO)
  modeloContaId   String?
  parentId        String?
  criadoEm        DateTime               @default(now())
  atualizadoEm    DateTime               @updatedAt
  entidade        Entidade               @relation(fields: [entidadeId], references: [id])
  parent          ContaReceitaEntidade?  @relation("SubReceitaEnt", fields: [parentId], references: [id])
  filhos          ContaReceitaEntidade[] @relation("SubReceitaEnt")
  previsoes       PrevisaoReceita[]

  @@unique([entidadeId, ano, codigo])
  @@index([entidadeId, ano, parentId])
  @@map("contas_receita_entidade")
}

model ContaDespesaEntidade {
  id              String                 @id @default(uuid())
  entidadeId      String
  ano             Int
  codigo          String
  descricao       String
  nivel           Int
  admiteMovimento Boolean                @default(false)
  origem          OrigemConta            @default(MODELO)
  modeloContaId   String?
  parentId        String?
  criadoEm        DateTime               @default(now())
  atualizadoEm    DateTime               @updatedAt
  entidade        Entidade               @relation(fields: [entidadeId], references: [id])
  parent          ContaDespesaEntidade?  @relation("SubDespesaEnt", fields: [parentId], references: [id])
  filhos          ContaDespesaEntidade[] @relation("SubDespesaEnt")
  dotacoes        DotacaoDespesa[]

  @@unique([entidadeId, ano, codigo])
  @@index([entidadeId, ano, parentId])
  @@map("contas_despesa_entidade")
}

model FonteRecursoEntidade {
  id            String            @id @default(uuid())
  entidadeId    String
  ano           Int
  codigo        String
  nomenclatura  String
  especificacao String?
  vinculada     Boolean           @default(true)
  grupo         String?
  origem        OrigemConta       @default(MODELO)
  modeloFonteId String?
  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt
  entidade      Entidade          @relation(fields: [entidadeId], references: [id])
  dotacoes      DotacaoDespesa[]
  previsoes     PrevisaoReceita[]

  @@unique([entidadeId, ano, codigo])
  @@index([entidadeId, ano])
  @@map("fontes_recurso_entidade")
}

// ─── Classificação Funcional (Portaria MOG nº 42/1999) ────────────────────────
// Função e Subfunção são tabelas de referência globais — a portaria define a
// lista fechada (28 funções + ~109 subfunções). Aplica-se ao Brasil inteiro;
// não há cópia por entidade. Códigos: 2 dígitos (função), 3 dígitos (subfunção).
model Funcao {
  id         String           @id @default(uuid())
  codigo     String           @unique // "01".."28"
  nome       String
  subfuncoes Subfuncao[]
  dotacoes   DotacaoDespesa[]

  @@map("funcoes")
}

model Subfuncao {
  id       String           @id @default(uuid())
  codigo   String           @unique // 3 dígitos
  nome     String
  funcaoId String
  funcao   Funcao           @relation(fields: [funcaoId], references: [id])
  dotacoes DotacaoDespesa[]

  @@index([funcaoId])
  @@map("subfuncoes")
}

// ─── Unidade Orçamentária ─────────────────────────────────────────────────────
// Estrutura orgânica da entidade (secretarias, fundos, autarquias). Cadastrada
// pelo município, não vem do modelo do TCE. Código livre (ex.: "02.001").
model UnidadeOrcamentaria {
  id                String             @id @default(uuid())
  entidadeId        String
  codigo            String
  nome              String
  ativa             Boolean            @default(true)
  criadoEm          DateTime           @default(now())
  atualizadoEm      DateTime           @updatedAt
  entidade          Entidade           @relation(fields: [entidadeId], references: [id])
  dotacoes          DotacaoDespesa[]
  documentosDemanda DocumentoDemanda[]

  @@unique([entidadeId, codigo])
  @@index([entidadeId])
  @@map("unidades_orcamentarias")
}

// ─── Tabela de Eventos Contábeis ──────────────────────────────────────────────
// Receita do "como contabilizar" cada movimento de execução orçamentária.
// Cada evento, ao ser disparado por uma execução (empenho, liquidação, etc.),
// gera N pares D-C de lançamentos contábeis. As contas dos lançamentos podem
// conter máscaras (X = classificação contábil; Y = classificação orçamentária),
// preenchidas no momento da execução pelo Tipo de Inscrição do evento.
// Inspirado no modelo SIGGo (GDF) — apenas UG Origem nesta fase.
model EventoContabil {
  id                               String             @id @default(uuid())
  modeloContabilId                 String
  codigo                           String // 6 dígitos (1xxxxx receita, 3xxxxx despesa)
  descricao                        String
  tipoInscricao                    String? // ex.: "11 - Natureza da Receita". Define o significado dos X.
  classificacaoContabilMascara     String? // ex.: "52121XXXX"
  classificacaoOrcamentariaMascara String? // ex.: "YYYYYYY"
  ativo                            Boolean            @default(true)
  criadoEm                         DateTime           @default(now())
  atualizadoEm                     DateTime           @updatedAt
  modeloContabil                   ModeloContabil     @relation(fields: [modeloContabilId], references: [id])
  lancamentos                      EventoLancamento[]

  @@unique([modeloContabilId, codigo])
  @@index([modeloContabilId])
  @@map("eventos_contabeis")
}

model EventoLancamento {
  id                  String         @id @default(uuid())
  eventoId            String
  ordem               Int // sequência de exibição (1, 2, 3...)
  contaDebitoMascara  String // ex.: "521920100" ou "52121XXXX"
  contaCreditoMascara String // ex.: "521929900"
  evento              EventoContabil @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@index([eventoId, ordem])
  @@map("eventos_lancamentos")
}

// ─── Programa e Ação (PPA-LOA) ────────────────────────────────────────────────
// Programa = unidade que articula um conjunto de Ações em torno de um objetivo
// de governo. Cadastrado por entidade × ano (a entidade define seus próprios
// programas para cada exercício orçamentário).
enum TipoPrograma {
  FINALISTICO // resultados para a sociedade
  GESTAO // suporte/manutenção da máquina pública
  OPERACOES_ESPECIAIS // amortização de dívida, transferências etc.
}

// Tipo da Ação: deriva da convenção de código (Projeto 1xxx, Atividade 2xxx,
// Operação Especial 0xxx/9xxx). Mantemos como enum para queries e UI.
enum TipoAcao {
  PROJETO
  ATIVIDADE
  OPERACAO_ESPECIAL
}

model Programa {
  id           String           @id @default(uuid())
  entidadeId   String
  ano          Int
  codigo       String // 4 dígitos (ex.: "0001")
  nome         String
  objetivo     String?
  tipo         TipoPrograma
  ativo        Boolean          @default(true)
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt
  entidade     Entidade         @relation(fields: [entidadeId], references: [id])
  acoes        Acao[]
  dotacoes     DotacaoDespesa[]

  @@unique([entidadeId, ano, codigo])
  @@index([entidadeId, ano])
  @@map("programas")
}

model Acao {
  id            String           @id @default(uuid())
  programaId    String
  codigo        String // 4 dígitos (ex.: "1001" projeto, "2001" atividade)
  nome          String
  tipo          TipoAcao
  unidadeMedida String? // ex.: "escola construída"
  metaFisica    Decimal?         @db.Decimal(18, 2)
  ativa         Boolean          @default(true)
  criadoEm      DateTime         @default(now())
  atualizadoEm  DateTime         @updatedAt
  programa      Programa         @relation(fields: [programaId], references: [id])
  dotacoes      DotacaoDespesa[]

  @@unique([programaId, codigo])
  @@index([programaId])
  @@map("acoes")
}

// ─── LOA: Orçamento + Dotação de Despesa + Previsão de Receita ────────────────
// Orcamento = cabeçalho da LOA (Lei Orçamentária Anual) por entidade × ano.
// Ciclo: RASCUNHO → APROVADO → EM_EXECUCAO. Após APROVADO o conteúdo é
// imutável (cláusula pétrea); ajustes durante execução virão depois via
// créditos adicionais (fora deste PR).
enum StatusOrcamento {
  RASCUNHO
  APROVADO
  EM_EXECUCAO
}

model Orcamento {
  id            String            @id @default(uuid())
  entidadeId    String
  ano           Int
  status        StatusOrcamento   @default(RASCUNHO)
  leiNumero     String?
  dataAprovacao DateTime?
  observacoes   String?
  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt
  entidade      Entidade          @relation(fields: [entidadeId], references: [id])
  dotacoes      DotacaoDespesa[]
  previsoes     PrevisaoReceita[]
  creditos      CreditoAdicional[]

  @@unique([entidadeId, ano])
  @@index([entidadeId])
  @@map("orcamentos")
}

// Dotação de despesa: linha LOA com TODAS as dimensões do padrão SIAFI cheio
// obrigatórias (UO + Função + Subfunção + Programa + Ação + ContaDespesa +
// Fonte). A combinação dessas 7 dimensões é única por Orçamento.
model DotacaoDespesa {
  id                     String               @id @default(uuid())
  orcamentoId            String
  unidadeOrcamentariaId  String
  funcaoId               String
  subfuncaoId            String
  programaId             String
  acaoId                 String
  contaDespesaEntidadeId String
  fonteRecursoEntidadeId String
  valorAutorizado        Decimal              @db.Decimal(18, 2)
  // Saldo materializado da execução: disponível = autorizado − reservado − empenhado.
  // Atualizado transacionalmente por reservas (pré-empenho) e empenhos.
  valorReservado         Decimal              @default(0) @db.Decimal(18, 2)
  valorEmpenhado         Decimal              @default(0) @db.Decimal(18, 2)
  criadoEm               DateTime             @default(now())
  atualizadoEm           DateTime             @updatedAt
  orcamento              Orcamento            @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  unidadeOrcamentaria    UnidadeOrcamentaria  @relation(fields: [unidadeOrcamentariaId], references: [id])
  funcao                 Funcao               @relation(fields: [funcaoId], references: [id])
  subfuncao              Subfuncao            @relation(fields: [subfuncaoId], references: [id])
  programa               Programa             @relation(fields: [programaId], references: [id])
  acao                   Acao                 @relation(fields: [acaoId], references: [id])
  contaDespesa           ContaDespesaEntidade @relation(fields: [contaDespesaEntidadeId], references: [id])
  fonteRecurso           FonteRecursoEntidade @relation(fields: [fonteRecursoEntidadeId], references: [id])
  reservas               ReservaDotacao[]
  empenhos               Empenho[]
  creditosItens          CreditoAdicionalItem[]

  @@unique([orcamentoId, unidadeOrcamentariaId, funcaoId, subfuncaoId, programaId, acaoId, contaDespesaEntidadeId, fonteRecursoEntidadeId], name: "dotacao_unica")
  @@index([orcamentoId])
  @@map("dotacoes_despesa")
}

// Previsão de receita: linha LOA por (ContaReceita × Fonte). Granularidade
// padrão da maioria dos municípios; sem dimensão extra (UO/Programa).
model PrevisaoReceita {
  id                     String               @id @default(uuid())
  orcamentoId            String
  contaReceitaEntidadeId String
  fonteRecursoEntidadeId String
  valorPrevisto          Decimal              @db.Decimal(18, 2)
  /// Materializado: soma das arrecadações − estornos (atualizado na mesma transação do movimento).
  valorArrecadado        Decimal              @default(0) @db.Decimal(18, 2)
  criadoEm               DateTime             @default(now())
  atualizadoEm           DateTime             @updatedAt
  orcamento              Orcamento            @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  contaReceita           ContaReceitaEntidade @relation(fields: [contaReceitaEntidadeId], references: [id])
  fonteRecurso           FonteRecursoEntidade @relation(fields: [fonteRecursoEntidadeId], references: [id])
  arrecadacoes           Arrecadacao[]

  @@unique([orcamentoId, contaReceitaEntidadeId, fonteRecursoEntidadeId], name: "previsao_unica")
  @@index([orcamentoId])
  @@map("previsoes_receita")
}

/// Movimento de arrecadação da receita (gap #5 PR-3): incide sobre uma
/// previsão (conta analítica × fonte) do orçamento APROVADO. ESTORNO reverte
/// arrecadação já registrada. Imutável após criado — correção é por estorno.
model Arrecadacao {
  id         String          @id @default(uuid())
  previsaoId String
  tipo       ArrecadacaoTipo
  data       DateTime        @db.Date
  valor      Decimal         @db.Decimal(18, 2)
  historico  String?
  criadoEm   DateTime        @default(now())
  previsao   PrevisaoReceita @relation(fields: [previsaoId], references: [id])

  @@index([previsaoId])
  @@map("arrecadacoes")
}

enum ArrecadacaoTipo {
  ARRECADACAO
  ESTORNO
}

/// Crédito adicional (Lei 4.320/1964): altera o orçamento já aprovado/em
/// execução. Aplicado de imediato na criação — cada item reforça (+) a dotação
/// alvo ou anula (−) saldo de uma dotação-fonte. valorTotal = soma dos reforços.
model CreditoAdicional {
  id            String               @id @default(uuid())
  orcamentoId   String
  tipo          CreditoAdicionalTipo
  numero        String
  data          DateTime             @db.Date
  atoLegal      String // lei/decreto que autorizou
  justificativa String?
  valorTotal    Decimal              @db.Decimal(18, 2)
  criadoEm      DateTime             @default(now())
  atualizadoEm  DateTime             @updatedAt
  orcamento     Orcamento            @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  itens         CreditoAdicionalItem[]

  @@unique([orcamentoId, numero])
  @@index([orcamentoId])
  @@map("creditos_adicionais")
}

model CreditoAdicionalItem {
  id                 String           @id @default(uuid())
  creditoAdicionalId String
  dotacaoDespesaId   String
  operacao           CreditoOperacao
  valor              Decimal          @db.Decimal(18, 2)
  credito            CreditoAdicional @relation(fields: [creditoAdicionalId], references: [id], onDelete: Cascade)
  dotacaoDespesa     DotacaoDespesa   @relation(fields: [dotacaoDespesaId], references: [id], onDelete: Cascade)

  @@index([creditoAdicionalId])
  @@map("creditos_adicionais_itens")
}

/// Tipos legais de crédito adicional (Lei 4.320, art. 41).
enum CreditoAdicionalTipo {
  SUPLEMENTAR
  ESPECIAL
  EXTRAORDINARIO
}

/// Operação de um item de crédito sobre a dotação alvo.
enum CreditoOperacao {
  REFORCO
  ANULACAO
}

// ─── Acesso de Usuário a Entidade ────────────────────────────────────────────
// Define se um usuário pode operar em uma Entidade e em qual nível
// (LEITURA/ESCRITA/ADMIN). Base do login de usuário comum (não-admin do
// sistema): após autenticar, lista as entidades acessíveis e o usuário
// escolhe contexto. Único por (usuarioId, entidadeId) — um nível por par.
model AcessoEntidade {
  id           String              @id @default(uuid())
  usuarioId    String
  entidadeId   String
  nivel        NivelAcessoEntidade
  ativo        Boolean             @default(true)
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt
  usuario      Usuario             @relation(fields: [usuarioId], references: [id])
  entidade     Entidade            @relation(fields: [entidadeId], references: [id])

  @@unique([usuarioId, entidadeId])
  @@index([usuarioId])
  @@index([entidadeId])
  @@map("acessos_entidade")
}

// ══════════════════════════════════════════════════════════════════════════════
// COMPRAS PÚBLICAS — Fase 1: Planejamento e Requisição (fase interna)
// Lei nº 14.133/2021 + Lei nº 4.320/1964. Fluxo: PCA → DOD → TR → Reserva de
// Dotação (pré-empenho) → Parecer Jurídico. As fases de Seleção do Fornecedor e
// Execução Financeira (Empenho/Liquidação/Pagamento) virão em PRs seguintes.
// ══════════════════════════════════════════════════════════════════════════════

// ─── Catálogo de Itens (CATMAT/CATSER) ────────────────────────────────────────
// Cadastro central e global de materiais e serviços, reutilizado por todas as
// entidades (espelha o catálogo federal CATMAT/CATSER). Itens de PCA, DOD e TR
// referenciam o catálogo para padronizar descrições e unidades. Código único
// por tipo (a numeração de material e de serviço é independente).
enum TipoItemCatalogo {
  MATERIAL
  SERVICO
}

model ItemCatalogo {
  id            String                 @id @default(uuid())
  tipo          TipoItemCatalogo
  codigo        String // CATMAT (material) ou CATSER (serviço)
  descricao     String
  unidadeMedida String // ex.: "UN", "CX", "HORA", "MÊS"
  ativo         Boolean                @default(true)
  criadoEm      DateTime               @default(now())
  atualizadoEm  DateTime               @updatedAt
  itensPca      ItemPca[]
  itensDemanda  ItemDemanda[]
  itensTermo    ItemTermoReferencia[]
  itensProcesso ItemProcesso[]
  itensContrato ItemContrato[]
  itensAta      ItemAtaRegistroPreco[]

  @@unique([tipo, codigo])
  @@index([tipo])
  @@map("itens_catalogo")
}

// ─── PCA — Plano de Contratações Anual ─────────────────────────────────────────
// Consolida tudo que a entidade pretende contratar no exercício. Por
// entidade × ano (único). O DOD nasce vinculado a um PCA.
enum StatusPca {
  RASCUNHO
  APROVADO
}

model PlanoContratacaoAnual {
  id           String             @id @default(uuid())
  entidadeId   String
  ano          Int
  status       StatusPca          @default(RASCUNHO)
  observacoes  String?
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt
  entidade     Entidade           @relation(fields: [entidadeId], references: [id])
  itens        ItemPca[]
  demandas     DocumentoDemanda[]

  @@unique([entidadeId, ano])
  @@index([entidadeId])
  @@map("planos_contratacao_anual")
}

model ItemPca {
  id                    String                @id @default(uuid())
  pcaId                 String
  itemCatalogoId        String
  quantidadeEstimada    Decimal               @db.Decimal(18, 4)
  valorUnitarioEstimado Decimal               @db.Decimal(18, 2)
  criadoEm              DateTime              @default(now())
  atualizadoEm          DateTime              @updatedAt
  pca                   PlanoContratacaoAnual @relation(fields: [pcaId], references: [id], onDelete: Cascade)
  itemCatalogo          ItemCatalogo          @relation(fields: [itemCatalogoId], references: [id])

  @@unique([pcaId, itemCatalogoId])
  @@index([pcaId])
  @@map("itens_pca")
}

// ─── DOD — Documento de Oficialização da Demanda ───────────────────────────────
// Pedido originário criado pelo setor requisitante (Unidade Orçamentária),
// vinculado opcionalmente ao PCA. O parecer jurídico (passo 4) é modelado como
// status + campos do próprio DOD, não como tabela separada.
enum StatusDemanda {
  RASCUNHO
  AGUARDANDO_PARECER
  APROVADA
  REPROVADA
}

model DocumentoDemanda {
  id                    String                 @id @default(uuid())
  entidadeId            String
  ano                   Int
  numero                String // ex.: "2026/0001"
  unidadeOrcamentariaId String // setor requisitante
  pcaId                 String?
  justificativa         String
  status                StatusDemanda          @default(RASCUNHO)
  parecerData           DateTime?
  parecerResponsavel    String?
  parecerObservacao     String?
  criadoEm              DateTime               @default(now())
  atualizadoEm          DateTime               @updatedAt
  entidade              Entidade               @relation(fields: [entidadeId], references: [id])
  unidadeOrcamentaria   UnidadeOrcamentaria    @relation(fields: [unidadeOrcamentariaId], references: [id])
  pca                   PlanoContratacaoAnual? @relation(fields: [pcaId], references: [id])
  itens                 ItemDemanda[]
  termoReferencia       TermoReferencia?

  @@unique([entidadeId, ano, numero])
  @@index([entidadeId, ano])
  @@map("documentos_demanda")
}

model ItemDemanda {
  id                 String           @id @default(uuid())
  documentoDemandaId String
  itemCatalogoId     String
  quantidade         Decimal          @db.Decimal(18, 4)
  criadoEm           DateTime         @default(now())
  atualizadoEm       DateTime         @updatedAt
  documentoDemanda   DocumentoDemanda @relation(fields: [documentoDemandaId], references: [id], onDelete: Cascade)
  itemCatalogo       ItemCatalogo     @relation(fields: [itemCatalogoId], references: [id])

  @@unique([documentoDemandaId, itemCatalogoId])
  @@index([documentoDemandaId])
  @@map("itens_demanda")
}

// ─── TR — Termo de Referência ──────────────────────────────────────────────────
// Detalhamento técnico do DOD + pesquisa de preço de mercado. Cada item recebe
// um preço unitário estimado; o Preço Máximo Aceitável do item é
// quantidade × precoUnitarioEstimado (calculado no service). 1:1 com o DOD.
model TermoReferencia {
  id                 String                @id @default(uuid())
  documentoDemandaId String                @unique
  objeto             String
  observacoes        String?
  criadoEm           DateTime              @default(now())
  atualizadoEm       DateTime              @updatedAt
  documentoDemanda   DocumentoDemanda      @relation(fields: [documentoDemandaId], references: [id], onDelete: Cascade)
  itens              ItemTermoReferencia[]
  reservas           ReservaDotacao[]
  processos          Processo[]

  @@map("termos_referencia")
}

model ItemTermoReferencia {
  id                    String          @id @default(uuid())
  termoReferenciaId     String
  itemCatalogoId        String
  quantidade            Decimal         @db.Decimal(18, 4)
  precoUnitarioEstimado Decimal         @db.Decimal(18, 2)
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt
  termoReferencia       TermoReferencia @relation(fields: [termoReferenciaId], references: [id], onDelete: Cascade)
  itemCatalogo          ItemCatalogo    @relation(fields: [itemCatalogoId], references: [id])

  @@unique([termoReferenciaId, itemCatalogoId])
  @@index([termoReferenciaId])
  @@map("itens_termo_referencia")
}

// ─── Reserva de Dotação (Pré-Empenho) ──────────────────────────────────────────
// Bloqueia saldo orçamentário da Dotação para a futura contratação.
// REGRA 1 (Garantia de Saldo): valor da reserva não pode exceder o saldo
// disponível da dotação (autorizado − reservado − empenhado). O service soma
// `valorReservado` na DotacaoDespesa dentro da mesma transação. Será baixada na
// geração do Empenho (PR-3, REGRA 2 de conversão de saldo).
enum StatusReserva {
  ATIVA
  BAIXADA
  CANCELADA
}

model ReservaDotacao {
  id                String           @id @default(uuid())
  entidadeId        String
  dotacaoDespesaId  String
  termoReferenciaId String?
  numero            String
  valor             Decimal          @db.Decimal(18, 2)
  status            StatusReserva    @default(ATIVA)
  data              DateTime         @default(now())
  observacoes       String?
  criadoEm          DateTime         @default(now())
  atualizadoEm      DateTime         @updatedAt
  entidade          Entidade         @relation(fields: [entidadeId], references: [id])
  dotacaoDespesa    DotacaoDespesa   @relation(fields: [dotacaoDespesaId], references: [id])
  termoReferencia   TermoReferencia? @relation(fields: [termoReferenciaId], references: [id])
  empenhos          Empenho[]

  @@unique([entidadeId, numero])
  @@index([dotacaoDespesaId])
  @@index([entidadeId])
  @@map("reservas_dotacao")
}

// ══════════════════════════════════════════════════════════════════════════════
// COMPRAS PÚBLICAS — Fase 2: Seleção do Fornecedor (fase externa)
// Edital/Processo → Julgamento/Homologação → Contrato / Ata de Registro de Preços.
// Fornecedor é cadastro global (CNPJ/CPF único). A execução financeira
// (Empenho/Liquidação/Pagamento) virá no PR-3.
// ══════════════════════════════════════════════════════════════════════════════

// ─── Fornecedor (cadastro global) ──────────────────────────────────────────────
enum TipoPessoa {
  PJ
  PF
}

model Fornecedor {
  id           String     @id @default(uuid())
  tipoPessoa   TipoPessoa
  cnpj         String?    @unique // PJ
  cpf          String?    @unique // PF (MEI/autônomo)
  razaoSocial  String
  nomeFantasia String?
  email        String?
  telefone     String?
  ativo        Boolean    @default(true)
  criadoEm     DateTime   @default(now())
  atualizadoEm DateTime   @updatedAt

  lotesVencidos Lote[]
  itensVencidos ItemProcesso[]
  contratos     Contrato[]
  atas          AtaRegistroPreco[]
  empenhos      Empenho[]

  @@map("fornecedores")
}

// ─── Processo Licitatório (Edital/Certame) ─────────────────────────────────────
enum ModalidadeLicitacao {
  PREGAO
  CONCORRENCIA
  DISPENSA
  INEXIGIBILIDADE
}

enum CriterioJulgamento {
  POR_ITEM
  POR_LOTE
}

enum StatusProcesso {
  ABERTO
  HOMOLOGADO
  CANCELADO
}

model Processo {
  id                 String              @id @default(uuid())
  entidadeId         String
  ano                Int
  numero             String
  modalidade         ModalidadeLicitacao
  criterioJulgamento CriterioJulgamento  @default(POR_ITEM)
  objeto             String
  termoReferenciaId  String?
  status             StatusProcesso      @default(ABERTO)
  dataAbertura       DateTime?
  dataHomologacao    DateTime?
  observacoes        String?
  criadoEm           DateTime            @default(now())
  atualizadoEm       DateTime            @updatedAt
  entidade           Entidade            @relation(fields: [entidadeId], references: [id])
  termoReferencia    TermoReferencia?    @relation(fields: [termoReferenciaId], references: [id])
  lotes              Lote[]
  contratos          Contrato[]
  atas               AtaRegistroPreco[]

  @@unique([entidadeId, ano, numero])
  @@index([entidadeId, ano])
  @@map("processos")
}

// Lote agrupa itens do processo. No julgamento POR_LOTE o vencedor é registrado
// aqui; no POR_ITEM, em cada ItemProcesso.
model Lote {
  id                   String         @id @default(uuid())
  processoId           String
  numero               String
  descricao            String?
  fornecedorVencedorId String?
  criadoEm             DateTime       @default(now())
  atualizadoEm         DateTime       @updatedAt
  processo             Processo       @relation(fields: [processoId], references: [id], onDelete: Cascade)
  fornecedorVencedor   Fornecedor?    @relation(fields: [fornecedorVencedorId], references: [id])
  itens                ItemProcesso[]

  @@unique([processoId, numero])
  @@index([processoId])
  @@map("lotes")
}

// Item disputado. precoEstimadoUnitario vem do TR; após o julgamento recebe
// fornecedor vencedor + precoAdjudicadoUnitario.
// REGRA 3 (service): precoAdjudicadoUnitario ≤ precoEstimadoUnitario.
model ItemProcesso {
  id                      String       @id @default(uuid())
  loteId                  String
  itemCatalogoId          String
  quantidade              Decimal      @db.Decimal(18, 4)
  precoEstimadoUnitario   Decimal      @db.Decimal(18, 2)
  fornecedorVencedorId    String?
  precoAdjudicadoUnitario Decimal?     @db.Decimal(18, 2)
  criadoEm                DateTime     @default(now())
  atualizadoEm            DateTime     @updatedAt
  lote                    Lote         @relation(fields: [loteId], references: [id], onDelete: Cascade)
  itemCatalogo            ItemCatalogo @relation(fields: [itemCatalogoId], references: [id])
  fornecedorVencedor      Fornecedor?  @relation(fields: [fornecedorVencedorId], references: [id])

  @@unique([loteId, itemCatalogoId])
  @@index([loteId])
  @@map("itens_processo")
}

// ─── Contrato ──────────────────────────────────────────────────────────────────
enum StatusContrato {
  VIGENTE
  ENCERRADO
  RESCINDIDO
}

model Contrato {
  id             String         @id @default(uuid())
  entidadeId     String
  processoId     String?
  fornecedorId   String
  numero         String
  objeto         String
  vigenciaInicio DateTime
  vigenciaFim    DateTime
  valorTotal     Decimal        @db.Decimal(18, 2)
  status         StatusContrato @default(VIGENTE)
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt
  entidade       Entidade       @relation(fields: [entidadeId], references: [id])
  processo       Processo?      @relation(fields: [processoId], references: [id])
  fornecedor     Fornecedor     @relation(fields: [fornecedorId], references: [id])
  itens          ItemContrato[]
  empenhos       Empenho[]

  @@unique([entidadeId, numero])
  @@index([entidadeId])
  @@map("contratos")
}

// quantidadeEmpenhada: saldo materializado para o PR-3 (o empenho consome o
// saldo contratado). Saldo = quantidadeContratada − quantidadeEmpenhada.
model ItemContrato {
  id                   String       @id @default(uuid())
  contratoId           String
  itemCatalogoId       String
  quantidadeContratada Decimal      @db.Decimal(18, 4)
  precoUnitario        Decimal      @db.Decimal(18, 2)
  quantidadeEmpenhada  Decimal      @default(0) @db.Decimal(18, 4)
  criadoEm             DateTime     @default(now())
  atualizadoEm         DateTime     @updatedAt
  contrato             Contrato     @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  itemCatalogo         ItemCatalogo @relation(fields: [itemCatalogoId], references: [id])

  @@unique([contratoId, itemCatalogoId])
  @@index([contratoId])
  @@map("itens_contrato")
}

// ─── Ata de Registro de Preços (ARP) ───────────────────────────────────────────
enum StatusAta {
  VIGENTE
  ENCERRADA
}

model AtaRegistroPreco {
  id             String                 @id @default(uuid())
  entidadeId     String
  processoId     String?
  fornecedorId   String
  numero         String
  objeto         String
  vigenciaInicio DateTime
  vigenciaFim    DateTime
  status         StatusAta              @default(VIGENTE)
  criadoEm       DateTime               @default(now())
  atualizadoEm   DateTime               @updatedAt
  entidade       Entidade               @relation(fields: [entidadeId], references: [id])
  processo       Processo?              @relation(fields: [processoId], references: [id])
  fornecedor     Fornecedor             @relation(fields: [fornecedorId], references: [id])
  itens          ItemAtaRegistroPreco[]
  empenhos       Empenho[]

  @@unique([entidadeId, numero])
  @@index([entidadeId])
  @@map("atas_registro_preco")
}

// quantidadeUtilizada: saldo materializado (consumo por contratos/empenhos no PR-3).
model ItemAtaRegistroPreco {
  id                   String           @id @default(uuid())
  ataId                String
  itemCatalogoId       String
  quantidadeRegistrada Decimal          @db.Decimal(18, 4)
  precoUnitario        Decimal          @db.Decimal(18, 2)
  quantidadeUtilizada  Decimal          @default(0) @db.Decimal(18, 4)
  criadoEm             DateTime         @default(now())
  atualizadoEm         DateTime         @updatedAt
  ata                  AtaRegistroPreco @relation(fields: [ataId], references: [id], onDelete: Cascade)
  itemCatalogo         ItemCatalogo     @relation(fields: [itemCatalogoId], references: [id])

  @@unique([ataId, itemCatalogoId])
  @@index([ataId])
  @@map("itens_ata_registro_preco")
}

// ══════════════════════════════════════════════════════════════════════════════
// COMPRAS PÚBLICAS — Fase 3: Execução Financeira (3 estágios da despesa)
// Empenho → Liquidação → Pagamento. Granularidade por valor (saldos
// materializados). REGRA 2 (conversão reserva→empenho), REGRA 4 (Σ liquidações ≤
// empenho), REGRA 5 (precedência: OP exige liquidação; liquidação exige empenho).
// ══════════════════════════════════════════════════════════════════════════════

// ─── Empenho (1º estágio) ──────────────────────────────────────────────────────
enum TipoEmpenho {
  ORDINARIO
  GLOBAL
  ESTIMATIVO
}

enum StatusEmpenho {
  ATIVO
  ANULADO
}

model Empenho {
  id                 String            @id @default(uuid())
  entidadeId         String
  dotacaoDespesaId   String
  fornecedorId       String
  reservaDotacaoId   String? // reserva convertida (REGRA 2)
  contratoId         String? // vínculo informativo
  ataRegistroPrecoId String? // vínculo informativo
  numero             String
  tipo               TipoEmpenho
  data               DateTime          @default(now())
  valor              Decimal           @db.Decimal(18, 2)
  valorLiquidado     Decimal           @default(0) @db.Decimal(18, 2)
  historico          String?
  status             StatusEmpenho     @default(ATIVO)
  criadoEm           DateTime          @default(now())
  atualizadoEm       DateTime          @updatedAt
  entidade           Entidade          @relation(fields: [entidadeId], references: [id])
  dotacaoDespesa     DotacaoDespesa    @relation(fields: [dotacaoDespesaId], references: [id])
  fornecedor         Fornecedor        @relation(fields: [fornecedorId], references: [id])
  reservaDotacao     ReservaDotacao?   @relation(fields: [reservaDotacaoId], references: [id])
  contrato           Contrato?         @relation(fields: [contratoId], references: [id])
  ataRegistroPreco   AtaRegistroPreco? @relation(fields: [ataRegistroPrecoId], references: [id])
  liquidacoes        Liquidacao[]

  @@unique([entidadeId, numero])
  @@index([dotacaoDespesaId])
  @@index([entidadeId])
  @@map("empenhos")
}

// ─── Liquidação (2º estágio) ────────────────────────────────────────────────────
enum StatusLiquidacao {
  ATIVA
  CANCELADA
}

model Liquidacao {
  id                String           @id @default(uuid())
  entidadeId        String
  empenhoId         String
  numero            String
  data              DateTime         @default(now())
  valor             Decimal          @db.Decimal(18, 2)
  valorPago         Decimal          @default(0) @db.Decimal(18, 2)
  notaFiscal        String?
  atesteResponsavel String?
  status            StatusLiquidacao @default(ATIVA)
  criadoEm          DateTime         @default(now())
  atualizadoEm      DateTime         @updatedAt
  entidade          Entidade         @relation(fields: [entidadeId], references: [id])
  empenho           Empenho          @relation(fields: [empenhoId], references: [id])
  ordensPagamento   OrdemPagamento[]

  @@unique([entidadeId, numero])
  @@index([empenhoId])
  @@index([entidadeId])
  @@map("liquidacoes")
}

// ─── Ordem de Pagamento (3º estágio) ─────────────────────────────────────────────
enum StatusOrdemPagamento {
  EMITIDA
  PAGA
  CANCELADA
}

model OrdemPagamento {
  id              String               @id @default(uuid())
  entidadeId      String
  liquidacaoId    String
  numero          String
  data            DateTime             @default(now())
  valor           Decimal              @db.Decimal(18, 2)
  contaBancaria   String // rótulo da conta p/ exibição (OPs antigas: texto livre)
  contaBancariaId String? // FK ao cadastro Febraban (nulo só em OPs legadas)
  comprovante     String?
  status          StatusOrdemPagamento @default(EMITIDA)
  criadoEm        DateTime             @default(now())
  atualizadoEm    DateTime             @updatedAt
  entidade        Entidade             @relation(fields: [entidadeId], references: [id])
  liquidacao      Liquidacao           @relation(fields: [liquidacaoId], references: [id])
  contaBancariaRef ContaBancaria?      @relation(fields: [contaBancariaId], references: [id])

  @@unique([entidadeId, numero])
  @@index([liquidacaoId])
  @@index([entidadeId])
  @@index([contaBancariaId])
  @@map("ordens_pagamento")
}
