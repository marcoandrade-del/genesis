node_modules
dist/
coverage/

# Environment (segredos — NUNCA versionar; .env.example é o template público)
.env
.env.*
!.env.example

# Chaves, certificados e keystores
*.pem
*.key
*.p12
*.pfx
*.jks
id_rsa
id_rsa.*
secrets/

# Config local de dev com SEGREDO (NÃO versionar)
run-dev.sh
*.local.sh

# Prisma
/generated/prisma

# Claude Code — configurações LOCAIS ficam fora; memória e o deny compartilhado são versionados
.claude/*
!.claude/memory/
!.claude/settings.json
claude.md.bkp

# Documentos de requisitos / melhorias (fora do versionamento)
*.pdf
/Regras*
/Requisitos*
/Spec*

# Saídas locais de testes e cobertura (geradas, não versionar)
coverage-tmp/
test-results/
test-reporter/

# Rascunhos experimentais pessoais
/wise/

# Python (scripts auxiliares: extração de PDF, etc.)
.venv/
__pycache__/
*.pyc

# Artefatos gerados pelos scripts (regeneráveis via scripts/*.py / pdftotext)
PCASP.txt
pcasp_*.xlsx
pcasp_*.csv

# Artefatos de compilação TS emitidos junto ao fonte (regeneráveis via tsc)
scripts/*.js
scripts/*.js.map
scripts/*.d.ts
scripts/*.d.ts.map
prisma/seed.js
prisma/seed.js.map
prisma/seed.d.ts
prisma/seed.d.ts.map

# Fontes de dados para importação (planilhas/CSVs baixados localmente)
/data/

# Locks temporários do LibreOffice
.~lock.*#

# Dados capturados do portal (regeneráveis; consumidos pela outra sessão)
scripts/dados/
data/empenhos-elotech/
