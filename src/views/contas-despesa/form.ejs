<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-diagram-3 me-2 text-primary"></i><%= conta ? 'Editar Conta' : (parent ? 'Nova Conta-filha' : 'Nova Conta-raiz') %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (conta) { %>
    hx-put="/admin/contas-despesa/<%= conta.id %>"
  <% } else { %>
    hx-post="/admin/contas-despesa"
  <% } %>
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <% if (!conta) { %>
    <input type="hidden" name="planoId" value="<%= plano.id %>">
    <% if (parent) { %>
      <input type="hidden" name="parentId" value="<%= parent.id %>">
    <% } %>
  <% } %>

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <div class="mb-2 small text-muted">
      <strong>Plano:</strong> <%= plano.descricao %> — <%= plano.modeloContabil.descricao %> · <%= plano.ano %>
    </div>

    <% if (parent) { %>
      <div class="mb-3 small text-muted">
        <strong>Conta-pai:</strong> <span class="font-monospace"><%= parent.codigo %></span> — <%= parent.descricao %>
      </div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Código <span class="text-danger">*</span></label>
      <% if (conta) { %>
        <input type="text" class="form-control form-control-sm font-monospace" readonly
          value="<%= conta.codigo %>">
        <div class="form-text">O código é imutável após criação.</div>
      <% } else { %>
        <input type="text" name="codigo" class="form-control form-control-sm font-monospace"
          placeholder="<%= parent ? parent.codigo + '.X' : 'ex.: 3' %>"
          required maxlength="50">
      <% } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Descrição <span class="text-danger">*</span></label>
      <input type="text" name="descricao" class="form-control form-control-sm"
        value="<%= conta ? conta.descricao : '' %>"
        required maxlength="200">
    </div>

    <div class="form-check">
      <input type="hidden" name="admiteMovimento" id="ct-mov-val"
        value="<%= conta && conta.admiteMovimento ? 'true' : 'false' %>">
      <input type="checkbox" class="form-check-input" id="ct-chk-mov"
        <%= conta && conta.admiteMovimento ? 'checked' : '' %>
        onchange="document.getElementById('ct-mov-val').value = this.checked ? 'true' : 'false'">
      <label for="ct-chk-mov" class="form-check-label small">
        Admite movimento (conta analítica/folha)
      </label>
    </div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), this.closest('form').querySelector('[name=codigo]')?.value || this.closest('form').querySelector('[name=descricao]')?.value)">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>
