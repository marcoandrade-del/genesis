<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Funcionando — Gênesis</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    html, body { height: 100%; margin: 0; overflow: hidden; }
    body { display: flex; flex-direction: column; background: #f8f9fa; }

    .sidebar {
      width: 280px;
      flex-shrink: 0;
      background: #212529;
      overflow-y: auto;
    }

    .section-label {
      font-size: .7rem;
      letter-spacing: .08em;
      color: rgba(255,255,255,.35);
      padding: .5rem .75rem .25rem;
      text-transform: uppercase;
    }

    .sistema-item {
      color: rgba(255,255,255,.7);
      padding: .4rem .75rem;
      border-radius: .375rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      user-select: none;
    }
    .sistema-item:hover { color: #fff; background: rgba(255,255,255,.08); }
    .sistema-item.expanded { color: #fff; }

    .sistema-item .chevron {
      font-size: .7rem;
      transition: transform .15s ease;
      color: rgba(255,255,255,.35);
    }
    .sistema-item.expanded .chevron { transform: rotate(90deg); color: rgba(255,255,255,.6); }

    .modulos-container { display: none; }
    .modulos-container.show { display: block; }

    .modulo-item {
      color: rgba(255,255,255,.6);
      padding: .3rem .75rem .3rem 2.25rem;
      font-size: .85rem;
      cursor: pointer;
      border-radius: .375rem;
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .modulo-item:hover { color: #fff; background: rgba(255,255,255,.08); }
    .modulo-item i { font-size: .85rem; }

    .empty-hint {
      color: rgba(255,255,255,.3);
      font-size: .8rem;
      padding: .25rem .75rem .25rem 2.25rem;
    }

    /* Modal overlay */
    #modulo-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.65);
      backdrop-filter: blur(3px);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    #modulo-overlay.show { display: flex; }

    #modulo-box {
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
      width: 92vw;
      height: 88vh;
      overflow: hidden;
      position: relative;
    }

    #modulo-iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    #modulo-fechar {
      position: absolute;
      top: 10px;
      right: 12px;
      z-index: 10;
      background: rgba(255,255,255,.15);
      border: none;
      color: #fff;
      border-radius: 50%;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: .85rem;
      line-height: 1;
      transition: background .15s;
    }
    #modulo-fechar:hover { background: rgba(255,255,255,.3); }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-dark bg-dark px-3 py-0 flex-shrink-0" style="height:56px">
    <div class="d-flex align-items-center gap-3">
      <a class="navbar-brand fw-bold fs-6 mb-0" href="/admin">
        <i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis
      </a>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 small" style="--bs-breadcrumb-divider-color: rgba(255,255,255,.35)">
          <li class="breadcrumb-item"><a href="/admin" class="text-white-50 text-decoration-none">Admin</a></li>
          <li class="breadcrumb-item active text-white" aria-current="page">Funcionamento</li>
        </ol>
      </nav>
    </div>
    <div class="d-flex align-items-center gap-3">
      <span class="text-white-50 small d-none d-md-inline"><%= userEmail %></span>
      <a href="/admin" class="btn btn-sm btn-outline-secondary text-white border-secondary">
        <i class="bi bi-arrow-left me-1"></i>Voltar ao Admin
      </a>
    </div>
  </nav>

  <!-- Layout principal -->
  <div class="d-flex flex-grow-1" style="overflow:hidden">

    <!-- Sidebar: árvore de sistemas e módulos -->
    <nav class="sidebar p-2">
      <div class="section-label">Sistemas</div>

      <% if (sistemas.length === 0) { %>
        <div class="empty-hint" style="padding-left:.75rem">Nenhum sistema ativo.</div>
      <% } else { %>
        <% sistemas.forEach(function(sistema) { %>
          <div>
            <div class="sistema-item" data-sistema-id="<%= sistema.id %>" onclick="toggleSistema(this)">
              <span class="d-flex align-items-center gap-2">
                <i class="bi bi-grid-3x3-gap" style="width:16px;font-size:.9rem"></i>
                <%= sistema.nome %>
              </span>
              <i class="bi bi-chevron-right chevron"></i>
            </div>
            <div id="modulos-<%= sistema.id %>" class="modulos-container">
              <% if (sistema.modulos.length === 0) { %>
                <div class="empty-hint">Nenhum módulo ativo</div>
              <% } else { %>
                <% sistema.modulos.forEach(function(modulo) { %>
                  <div class="modulo-item"
                       data-modulo-id="<%= modulo.id %>"
                       onclick="abrirModulo(this.dataset.moduloId)">
                    <i class="bi bi-boxes"></i><%= modulo.nome %>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </nav>

    <!-- Área principal -->
    <main class="flex-grow-1 p-4 overflow-auto">
      <div class="text-center pt-5 mt-4">
        <i class="bi bi-play-circle text-success" style="font-size:5rem;opacity:.3"></i>
        <h5 class="mt-4 fw-semibold text-secondary">Visualização de Funcionamento</h5>
        <p class="text-muted" style="max-width:420px;margin:0 auto">
          Selecione um <strong>sistema</strong> no painel à esquerda para ver seus módulos.<br>
          Clique em um <strong>módulo</strong> para abrir sua tela de funcionamento.
        </p>
      </div>
    </main>
  </div>

  <!-- Modal overlay do módulo -->
  <div id="modulo-overlay" onclick="fecharSeFora(event)">
    <div id="modulo-box">
      <button id="modulo-fechar" onclick="fecharModal()" title="Fechar">
        <i class="bi bi-x-lg"></i>
      </button>
      <iframe id="modulo-iframe" src="" title="Módulo"></iframe>
    </div>
  </div>

  <script>
    function toggleSistema(el) {
      const sistemaId = el.dataset.sistemaId
      const container = document.getElementById('modulos-' + sistemaId)
      const isOpen = container.classList.contains('show')

      document.querySelectorAll('.modulos-container').forEach(c => c.classList.remove('show'))
      document.querySelectorAll('.sistema-item').forEach(s => s.classList.remove('expanded'))

      if (!isOpen) {
        container.classList.add('show')
        el.classList.add('expanded')
      }
    }

    function abrirModulo(moduloId) {
      const iframe = document.getElementById('modulo-iframe')
      iframe.src = '/admin/funcionando/modulo/' + moduloId
      document.getElementById('modulo-overlay').classList.add('show')
      document.body.style.overflow = 'hidden'
    }

    function fecharModal() {
      document.getElementById('modulo-overlay').classList.remove('show')
      document.getElementById('modulo-iframe').src = ''
      document.body.style.overflow = ''
    }

    function fecharSeFora(e) {
      if (e.target === document.getElementById('modulo-overlay')) fecharModal()
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') fecharModal()
    })
  </script>
</body>
</html>
