<% const TIPOS = [['PREFEITURA','Prefeitura'],['CAMARA','Câmara'],['ADM_INDIRETA','Administração Indireta']] %>
<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-building me-2 text-primary"></i><%= entidade ? 'Editar Entidade' : 'Nova Entidade' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (entidade) { %>
    hx-put="/admin/entidades/<%= entidade.id %>"
  <% } else { %>
    hx-post="/admin/entidades"
  <% } %>
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <% if (entidade) { %>
      <div class="mb-3 small text-muted">
        <strong>Município:</strong> <%= entidade.municipio.nome %>/<%= entidade.municipio.estado.sigla %>
        <div class="form-text">O município é definido na criação e não pode ser alterado.</div>
      </div>
    <% } else { %>
      <div class="mb-3">
        <label class="form-label small fw-semibold">Município <span class="text-danger">*</span></label>
        <select name="municipioId" class="form-select form-select-sm" required>
          <option value="">— Selecione —</option>
          <% municipios.forEach(function(m) { %>
            <option value="<%= m.id %>"><%= m.nome %>/<%= m.estado.sigla %></option>
          <% }) %>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold">Exercício (ano) <span class="text-danger">*</span></label>
        <input type="number" name="ano" class="form-control form-control-sm"
          value="<%= new Date().getFullYear() %>" min="1900" max="9999" required>
        <div class="form-text">
          Ao criar, o sistema copia as árvores (contábil, receita, despesa) e as fontes
          do modelo do estado para este exercício.
        </div>
      </div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Nome <span class="text-danger">*</span></label>
      <input type="text" name="nome" class="form-control form-control-sm"
        value="<%= entidade ? entidade.nome : '' %>"
        placeholder="ex.: Prefeitura Municipal de Curitiba" required maxlength="200">
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Tipo <span class="text-danger">*</span></label>
      <select name="tipo" class="form-select form-select-sm" required>
        <option value="">— Selecione —</option>
        <% TIPOS.forEach(function(t) { %>
          <option value="<%= t[0] %>" <%= entidade && entidade.tipo === t[0] ? 'selected' : '' %>><%= t[1] %></option>
        <% }) %>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">CNPJ</label>
      <input type="text" name="cnpj" class="form-control form-control-sm font-monospace"
        value="<%= entidade && entidade.cnpj ? entidade.cnpj : '' %>"
        placeholder="00.000.000/0000-00" maxlength="20">
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Brasão / Logotipo</label>
      <input type="hidden" name="brasao" id="ent-bras-val"
        value="<%= entidade && entidade.brasao ? entidade.brasao : '' %>">
      <div class="d-flex align-items-center gap-3">
        <img id="ent-bras-preview" alt="Brasão"
          <% if (entidade && entidade.brasao) { %>src="<%= entidade.brasao %>"<% } %>
          class="border rounded bg-light p-1 <%= entidade && entidade.brasao ? '' : 'd-none' %>"
          style="height:56px;max-width:120px;object-fit:contain">
        <div class="flex-grow-1">
          <input type="file" id="ent-bras-file" class="form-control form-control-sm"
            accept="image/png,image/jpeg,image/gif,image/webp"
            onchange="entBrasaoSelecionar(this)">
          <button type="button" id="ent-bras-remover"
            class="btn btn-sm btn-link text-danger p-0 mt-1 <%= entidade && entidade.brasao ? '' : 'd-none' %>"
            onclick="entBrasaoRemover()">
            <i class="bi bi-x-lg me-1"></i>Remover brasão
          </button>
        </div>
      </div>
      <div class="form-text">PNG, JPG, GIF ou WEBP até 1 MB. Aparece nos cabeçalhos de relatório.</div>
      <div id="ent-bras-erro" class="small text-danger mt-1 d-none"></div>
    </div>

    <% if (entidade) { %>
      <div class="mb-3">
        <label class="form-label small fw-semibold">Assinatura dos documentos oficiais</label>
        <select name="assinaturaModo" class="form-select form-select-sm">
          <option value="MANUAL" <%= entidade.assinaturaModo === 'ELETRONICA' ? '' : 'selected' %>>Manual (assinatura física)</option>
          <option value="ELETRONICA" <%= entidade.assinaturaModo === 'ELETRONICA' ? 'selected' : '' %>>Eletrônica</option>
        </select>
        <div class="form-text">A assinatura eletrônica será habilitada futuramente; por ora os anexos saem para assinatura manual.</div>
      </div>

      <div class="mb-2">
        <label class="form-label small fw-semibold">Carimbo de emissão (data/hora) nos anexos</label>
        <select name="emissaoLocal" class="form-select form-select-sm">
          <option value="RODAPE" <%= entidade.emissaoLocal === 'RODAPE' ? 'selected' : '' %>>No rodapé ("Relatório gerado em…")</option>
          <option value="CABECALHO" <%= entidade.emissaoLocal === 'CABECALHO' ? 'selected' : '' %>>No cabeçalho</option>
          <option value="NENHUM" <%= entidade.emissaoLocal === 'NENHUM' ? 'selected' : '' %>>Não imprimir</option>
        </select>
        <div class="d-flex gap-3 mt-2">
          <div class="form-check">
            <input type="checkbox" class="form-check-input" id="ent-emite-data" name="emitirData" value="true"
              <%= entidade.emitirData ? 'checked' : '' %>>
            <label for="ent-emite-data" class="form-check-label small">Incluir data</label>
          </div>
          <div class="form-check">
            <input type="checkbox" class="form-check-input" id="ent-emite-hora" name="emitirHora" value="true"
              <%= entidade.emitirHora ? 'checked' : '' %>>
            <label for="ent-emite-hora" class="form-check-label small">Incluir hora</label>
          </div>
        </div>
      </div>

      <div class="form-check">
        <input type="hidden" name="ativo" value="<%= entidade.ativo ? 'true' : 'false' %>" id="ent-ativo-val">
        <input type="checkbox" class="form-check-input" id="ent-chk-ativo"
          <%= entidade.ativo ? 'checked' : '' %>
          onchange="document.getElementById('ent-ativo-val').value = this.checked ? 'true' : 'false'">
        <label for="ent-chk-ativo" class="form-check-label small">Ativa</label>
      </div>
    <% } %>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), this.closest('form').querySelector('[name=nome]')?.value)">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>

<script>
// Lê o arquivo escolhido como data URL base64 e guarda no hidden `brasao`, que é
// o formato que o gerador de relatórios consome (<img src="data:image/...">).
function entBrasaoErro(msg) {
  var el = document.getElementById('ent-bras-erro')
  el.textContent = msg || ''
  el.classList.toggle('d-none', !msg)
}
function entBrasaoDefinir(dataUrl) {
  document.getElementById('ent-bras-val').value = dataUrl || ''
  var img = document.getElementById('ent-bras-preview')
  var btn = document.getElementById('ent-bras-remover')
  if (dataUrl) {
    img.src = dataUrl
    img.classList.remove('d-none')
    btn.classList.remove('d-none')
  } else {
    img.removeAttribute('src')
    img.classList.add('d-none')
    btn.classList.add('d-none')
  }
}
function entBrasaoSelecionar(input) {
  entBrasaoErro('')
  var file = input.files && input.files[0]
  if (!file) return
  if (!/^image\/(png|jpeg|gif|webp)$/.test(file.type)) {
    entBrasaoErro('Formato não suportado. Use PNG, JPG, GIF ou WEBP.')
    input.value = ''
    return
  }
  if (file.size > 1024 * 1024) {
    entBrasaoErro('Imagem muito grande (' + (file.size / 1024 / 1024).toFixed(1) + ' MB). Máximo 1 MB.')
    input.value = ''
    return
  }
  var reader = new FileReader()
  reader.onload = function () { entBrasaoDefinir(reader.result) }
  reader.onerror = function () { entBrasaoErro('Falha ao ler o arquivo.') }
  reader.readAsDataURL(file)
}
function entBrasaoRemover() {
  document.getElementById('ent-bras-file').value = ''
  entBrasaoErro('')
  entBrasaoDefinir('')
}
</script>
