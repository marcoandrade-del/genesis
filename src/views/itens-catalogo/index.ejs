<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Catálogo de Itens</h2>
  <div class="d-flex gap-2">
    <button class="btn btn-outline-secondary btn-sm"
      hx-get="/admin/itens-catalogo/importar"
      hx-target="#modal-body"
      hx-swap="innerHTML">
      <i class="bi bi-upload me-1"></i>Importar CSV
    </button>
    <button class="btn btn-primary btn-sm"
      hx-get="/admin/itens-catalogo/form"
      hx-target="#modal-body"
      hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Novo Item
    </button>
  </div>
</div>

<%
  function qs(over) {
    over = over || {};
    var t = over.tipo !== undefined ? over.tipo : tipoFiltro;
    var q = over.q !== undefined ? over.q : busca;
    var pg = over.pagina !== undefined ? over.pagina : 1;
    var p = new URLSearchParams();
    if (t) p.set('tipo', t);
    if (q) p.set('q', q);
    if (pg && pg > 1) p.set('pagina', pg);
    var s = p.toString();
    return '/admin/itens-catalogo' + (s ? '?' + s : '');
  }
%>

<div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
  <div class="btn-group btn-group-sm" role="group">
    <a href="<%= qs({ tipo: '', pagina: 1 }) %>" class="btn btn-outline-secondary <%= tipoFiltro === '' ? 'active' : '' %>">Todos</a>
    <a href="<%= qs({ tipo: 'MATERIAL', pagina: 1 }) %>" class="btn btn-outline-secondary <%= tipoFiltro === 'MATERIAL' ? 'active' : '' %>">Materiais</a>
    <a href="<%= qs({ tipo: 'SERVICO', pagina: 1 }) %>" class="btn btn-outline-secondary <%= tipoFiltro === 'SERVICO' ? 'active' : '' %>">Serviços</a>
  </div>
  <form method="GET" action="/admin/itens-catalogo" class="d-flex" style="max-width:420px;flex:1">
    <% if (tipoFiltro) { %><input type="hidden" name="tipo" value="<%= tipoFiltro %>"><% } %>
    <div class="input-group input-group-sm">
      <span class="input-group-text"><i class="bi bi-search"></i></span>
      <input type="text" name="q" class="form-control" placeholder="Buscar código ou descrição…" value="<%= busca %>">
      <button class="btn btn-primary" type="submit">Buscar</button>
      <% if (busca) { %><a class="btn btn-outline-secondary" href="<%= qs({ q: '', pagina: 1 }) %>">Limpar</a><% } %>
    </div>
  </form>
</div>

<div class="small text-muted mb-2">
  <strong><%= total.toLocaleString('pt-BR') %></strong> item(ns)<% if (busca) { %> para "<strong><%= busca %></strong>"<% } %>
  · página <%= pagina %> de <%= totalPaginas %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Tipo</th>
          <th>Código</th>
          <th>Descrição</th>
          <th>Unid.</th>
          <th>Status</th>
          <th class="text-end pe-3">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-5">
            <i class="bi bi-inbox fs-4 d-block mb-2"></i><%= busca ? 'Nenhum item encontrado para a busca.' : 'Nenhum item cadastrado.' %>
          </td></tr>
        <% } %>
        <% items.forEach(function(item) { %>
          <tr id="item-catalogo-<%= item.id %>">
            <td class="ps-3">
              <span class="badge rounded-pill <%= item.tipo === 'MATERIAL' ? 'bg-primary' : 'bg-info' %> bg-opacity-75">
                <%= item.tipo === 'MATERIAL' ? 'Material' : 'Serviço' %>
              </span>
            </td>
            <td class="font-monospace"><%= item.codigo %></td>
            <td class="fw-semibold"><%= item.descricao %></td>
            <td><%= item.unidadeMedida %></td>
            <td>
              <span class="badge rounded-pill <%= item.ativo ? 'bg-success' : 'bg-secondary' %> bg-opacity-75">
                <%= item.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </td>
            <td class="text-end pe-3">
              <button class="btn btn-sm btn-outline-secondary me-1"
                hx-get="/admin/itens-catalogo/<%= item.id %>/form"
                hx-target="#modal-body"
                hx-swap="innerHTML"
                title="Editar">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-sm btn-outline-danger"
                hx-delete="/admin/itens-catalogo/<%= item.id %>"
                hx-target="#item-catalogo-<%= item.id %>"
                hx-swap="outerHTML"
                hx-confirm="Excluir '<%= item.descricao %>'?"
                title="Excluir">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPaginas > 1) { %>
  <nav class="mt-3 d-flex justify-content-center" aria-label="Paginação do catálogo">
    <ul class="pagination pagination-sm mb-0">
      <li class="page-item <%= pagina <= 1 ? 'disabled' : '' %>">
        <a class="page-link" href="<%= qs({ pagina: pagina - 1 }) %>"><i class="bi bi-chevron-left"></i> Anterior</a>
      </li>
      <li class="page-item disabled"><span class="page-link"><%= pagina %> / <%= totalPaginas %></span></li>
      <li class="page-item <%= pagina >= totalPaginas ? 'disabled' : '' %>">
        <a class="page-link" href="<%= qs({ pagina: pagina + 1 }) %>">Próxima <i class="bi bi-chevron-right"></i></a>
      </li>
    </ul>
  </nav>
<% } %>
