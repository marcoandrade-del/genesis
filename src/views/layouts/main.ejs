    .sidebar { width: 230px; min-height: calc(100vh - 56px); flex-shrink: 0; }
    .sidebar .nav-link { color: rgba(255,255,255,.65); padding: .4rem .75rem; border-radius: .375rem; }
    .sidebar .nav-link:hover { color: #fff; background: rgba(255,255,255,.08); }
    .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.15); }
