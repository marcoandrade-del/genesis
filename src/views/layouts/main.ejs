    .sidebar .section-label { font-size: .7rem; letter-spacing: .08em; color: rgba(255,255,255,.35); padding: .5rem .75rem .2rem; text-transform: uppercase; }
    .main-content { min-height: calc(100vh - 56px); }
    .htmx-indicator { display: none; }
    .htmx-request .htmx-indicator { display: inline-block; }


    /* Offcanvas lookup must float above Bootstrap modal (z-index 1055) */
    #offcanvas-lookup { z-index: 1060; }
    .offcanvas-backdrop { z-index: 1059; }

    #bloqueio-overlay {
      display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(0,0,0,.75); backdrop-filter: blur(4px);
      align-items: center; justify-content: center;
    }
    #bloqueio-overlay.ativo { display: flex; }
  </style>
  <%# Wise design system — sobrescreve Bootstrap. Carregar por último. %>
