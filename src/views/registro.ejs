<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Criar Conta — Gênesis Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="bg-dark d-flex min-vh-100 align-items-center justify-content-center py-4">
  <div class="card shadow-lg border-0" style="width:480px">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <i class="bi bi-heptagon-fill text-primary" style="font-size:2.5rem"></i>
        <h5 class="fw-bold mt-2 mb-0">Criar Conta</h5>
        <p class="text-muted small">Gênesis Admin</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger py-2 small"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/registro">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label small fw-semibold">Nome completo *</label>
            <input type="text" name="nomeCompleto" class="form-control form-control-sm"
              value="<%= dados?.nomeCompleto ?? '' %>" required>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Nome social</label>
            <input type="text" name="nomeSocial" class="form-control form-control-sm"
              value="<%= dados?.nomeSocial ?? '' %>">
          </div>
          <div class="col-6">
            <label class="form-label small fw-semibold">CPF</label>
            <input type="text" name="cpf" class="form-control form-control-sm"
              placeholder="000.000.000-00" value="<%= dados?.cpf ?? '' %>">
          </div>
          <div class="col-6">
            <label class="form-label small fw-semibold">Data de nascimento *</label>
            <input type="date" name="dataNascimento" class="form-control form-control-sm"
              value="<%= dados?.dataNascimento ?? '' %>" required>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">E-mail principal *</label>
            <input type="email" name="emailPrincipal" class="form-control form-control-sm"
              value="<%= dados?.emailPrincipal ?? '' %>" required>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Telefone principal *</label>
            <input type="tel" name="telefonePrincipal" class="form-control form-control-sm"
              placeholder="(44) 99999-9999" value="<%= dados?.telefonePrincipal ?? '' %>" required>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Senha *</label>
            <input type="password" name="senha" class="form-control form-control-sm" required minlength="8">
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Confirmar senha *</label>
            <input type="password" name="confirmarSenha" class="form-control form-control-sm" required>
          </div>
        </div>

        <div class="d-grid mt-4">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-person-plus me-2"></i>Criar conta e verificar
          </button>
        </div>
        <p class="text-center small text-muted mt-3 mb-0">
          Já tem conta? <a href="/admin/login">Entrar</a>
        </p>
      </form>
    </div>
  </div>
</body>
</html>
