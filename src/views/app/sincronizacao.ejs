<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sincronização · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<%
  const fmtValor = (v) => v == null ? '—' : Number(v).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
  const TIPO = { ARRECADACAO: 'Receita (arrecadação)', DESPESA_EXECUCAO: 'Despesa (execução)', DECRETOS: 'Decretos (créditos)' }
  const BADGE = { OK: 'text-bg-success', DIVERGENTE: 'text-bg-warning', ERRO: 'text-bg-danger' }
%>

<div class="container py-4" style="max-width:900px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Sincronização</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1"><i class="bi bi-arrow-repeat me-1 text-primary"></i>Sincronização com o Portal da Transparência</h2>
  <p class="text-muted small mb-3">Captura a arrecadação e a execução da despesa do mês corrente direto do portal (tempo real), sempre nesta ordem: <strong>receita antes da despesa</strong>. Cada execução é validada contra o painel oficial antes de gravar — divergência acima de 0,5% não grava nada e fica registrada no log.</p>

  <% if (erro) { %><div class="alert alert-warning py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div><% } %>
  <% if (aviso) { %><div class="alert alert-success py-2 small"><i class="bi bi-check-circle me-1"></i><%= aviso %></div><% } %>

  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-3 d-flex flex-wrap align-items-center gap-3">
    <form method="post" action="/app/sincronizacao/rodar" class="m-0">
      <button type="submit" class="btn btn-primary" <%= podeEscrever && !rodando ? '' : 'disabled' %>>
        <i class="bi bi-arrow-repeat me-1"></i>Sincronizar agora
      </button>
    </form>
    <div class="small text-muted">
      <% if (rodando) { %>
        <span class="badge text-bg-info"><span class="spinner-border spinner-border-sm me-1" role="status"></span>Em andamento…</span> atualize a página para acompanhar.
      <% } else if (!podeEscrever) { %>
        Acesso somente leitura — o botão fica disponível para níveis Escrita e Admin.
      <% } else { %>
        Roda a receita e a despesa do mês corrente. Leva alguns minutos.
      <% } %>
    </div>
    <div class="ms-auto small text-muted">
      <i class="bi bi-clock-history me-1"></i>Agendamento diário (04h):
      <% if (agendado) { %><span class="badge text-bg-success">ligado</span><% } else { %><span class="badge text-bg-secondary">desligado</span><% } %>
    </div>
  </div></div>

  <div class="card border-0 shadow-sm"><div class="card-body py-3">
    <h6 class="fw-semibold mb-2"><i class="bi bi-journal-text me-1 text-primary"></i>Últimas execuções</h6>
    <% if (!execucoes.length) { %>
      <div class="small text-muted">Nenhuma sincronização registrada ainda para esta entidade.</div>
    <% } else { %>
      <div class="table-responsive"><table class="table table-sm align-middle mb-0">
        <thead><tr class="small text-muted">
          <th>Quando</th><th>Tipo</th><th>Competência</th><th>Status</th>
          <th class="text-end">Portal (R$)</th><th class="text-end">Gravado (R$)</th><th>Mensagem</th>
        </tr></thead>
        <tbody>
          <% for (const ex of execucoes) { %>
            <tr class="small">
              <td class="text-nowrap"><%= ex.criadoEm.toLocaleString('pt-BR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' }) %></td>
              <td><%= TIPO[ex.tipo] || ex.tipo %></td>
              <td><%= String(ex.mes).padStart(2, '0') %>/<%= ex.ano %></td>
              <td><span class="badge <%= BADGE[ex.status] || 'text-bg-secondary' %>"><%= ex.status %></span></td>
              <td class="text-end text-nowrap"><%= fmtValor(ex.valorPortal) %></td>
              <td class="text-end text-nowrap"><%= fmtValor(ex.valorGravado) %></td>
              <td class="text-muted" style="max-width:280px"><%= ex.mensagem || '—' %></td>
            </tr>
          <% } %>
        </tbody>
      </table></div>
    <% } %>
  </div></div>
</div>
</body>
</html>
