<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lançamento tributário · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<% var fmt = function(n){ return Number(n).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}) } %>
<% var dbr = function(d){ return d ? new Date(d).toLocaleDateString('pt-BR',{timeZone:'UTC'}) : '—' } %>
<% var v = valores || {} %>
<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">Lançamento tributário</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Lançamento tributário <span class="font-monospace fs-6 text-muted"><%= ano %></span></h2>
  <p class="text-muted small mb-3">Constitui o crédito tributário (direito a receber) por competência — reconhece o ativo e a VPA no fato gerador. A arrecadação posterior baixa o ativo.</p>

  <% if (erro) { %><div class="alert alert-warning py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div><% } %>

  <% if (podeEscrever) { %>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-3">
    <h6 class="fw-semibold mb-2"><i class="bi bi-file-earmark-ruled me-1 text-primary"></i>Constituir crédito</h6>
    <% if (previsoes.length === 0) { %>
      <div class="text-muted small">Não há previsões de receita tributária (1.1.x) neste orçamento.</div>
    <% } else { %>
    <form method="post" action="/app/orcamento/lancamento-tributario" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small fw-semibold mb-0">Tipo</label>
        <select name="tipo" class="form-select form-select-sm">
          <option value="LANCAMENTO" <%= v.tipo === 'INSCRICAO_DIVIDA_ATIVA' ? '' : 'selected' %>>Lançamento (constitui)</option>
          <option value="INSCRICAO_DIVIDA_ATIVA" <%= v.tipo === 'INSCRICAO_DIVIDA_ATIVA' ? 'selected' : '' %>>Inscrição em dívida ativa</option>
        </select>
      </div>
      <div class="col-md-5">
        <label class="form-label small fw-semibold mb-0">Natureza tributária (× fonte)</label>
        <select name="previsaoId" class="form-select form-select-sm" required>
          <option value="">— selecione —</option>
          <% previsoes.forEach(function(p){ %>
            <option value="<%= p.id %>" <%= v.previsaoId === p.id ? 'selected' : '' %>><%= p.contaReceita.codigo %> · <%= p.contaReceita.descricao %> — FR <%= p.fonteRecurso.codigo %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Data</label><input type="date" name="data" class="form-control form-control-sm" required value="<%= v.data || '' %>"></div>
      <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Valor R$</label><input type="number" name="valor" step="0.01" min="0.01" class="form-control form-control-sm" required value="<%= v.valor || '' %>"></div>
      <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Vencimento</label><input type="date" name="vencimento" class="form-control form-control-sm" value="<%= v.vencimento || '' %>"></div>
      <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-check-lg"></i></button></div>
      <div class="col-md-4"><input type="text" name="devedorNome" class="form-control form-control-sm" placeholder="Devedor (opcional)" value="<%= v.devedorNome || '' %>"></div>
      <div class="col-md-3"><input type="text" name="devedorDocumento" class="form-control form-control-sm" placeholder="CPF/CNPJ" value="<%= v.devedorDocumento || '' %>"></div>
      <div class="col-md-2"><input type="text" name="documento" class="form-control form-control-sm" placeholder="Doc/auto/carnê" value="<%= v.documento || '' %>"></div>
      <div class="col-md-3"><input type="text" name="historico" class="form-control form-control-sm" placeholder="Histórico" value="<%= v.historico || '' %>"></div>
    </form>
    <% } %>
  </div></div>
  <% } %>

  <div class="card border-0 shadow-sm"><div class="card-header bg-white border-bottom py-2 small fw-semibold"><i class="bi bi-list-ul me-1"></i>Créditos lançados (<%= lancamentos.length %>)</div>
  <div class="card-body p-0"><table class="table table-sm table-hover align-middle mb-0">
    <thead class="table-light"><tr><th class="ps-3">Data</th><th>Natureza</th><th>Devedor</th><th>Venc.</th><th class="text-end">Valor R$</th><th class="text-end" style="width:48px">Trilha</th><% if (podeEscrever) { %><th></th><% } %></tr></thead>
    <tbody>
      <% if (lancamentos.length === 0) { %><tr><td colspan="7" class="text-center text-muted py-3">Nenhum crédito lançado.</td></tr><% } %>
      <% lancamentos.forEach(function(l){ %>
        <tr>
          <td class="ps-3 small text-muted"><%= dbr(l.data) %>
            <% if (l.tipo === 'INSCRICAO_DIVIDA_ATIVA') { %><span class="badge bg-warning bg-opacity-10 text-warning-emphasis">Dívida ativa</span><% } %>
          </td>
          <td class="small font-monospace"><%= l.previsao.contaReceita.codigo %> <span class="text-muted"><%= l.previsao.contaReceita.descricao %></span></td>
          <td class="small"><%= l.devedorNome || '—' %><% if (l.devedorDocumento) { %> <span class="text-muted">(<%= l.devedorDocumento %>)</span><% } %></td>
          <td class="small text-muted"><%= dbr(l.vencimento) %></td>
          <td class="text-end font-monospace"><%= fmt(l.valor) %></td>
          <td class="text-end"><a href="/app/orcamento/lancamento-tributario/<%= l.id %>/lancamentos" class="text-decoration-none" title="Ver lançamentos contábeis"><i class="bi bi-diagram-3"></i></a></td>
          <% if (podeEscrever) { %>
          <td class="text-end pe-3">
            <form method="post" action="/app/orcamento/lancamento-tributario/<%= l.id %>/excluir" class="d-inline" onsubmit="return confirm('Excluir o lançamento e reverter os contábeis?')">
              <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Excluir"><i class="bi bi-trash"></i></button>
            </form>
          </td>
          <% } %>
        </tr>
      <% }) %>
    </tbody>
  </table></div></div>
</div>
</body>
</html>
