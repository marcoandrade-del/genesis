<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Compras · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Compras</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-1">
    <h2 class="h4 fw-bold mb-0">Compras <span class="font-monospace fs-6 text-muted"><%= ano %></span></h2>
    <span class="badge bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-eye me-1"></i>Somente leitura</span>
  </div>
  <p class="text-muted small mb-4">
    Fluxo da Lei 14.133 — escopo: <strong><%= entidade.nome %></strong>, exercício <strong><%= ano %></strong>.
  </p>

  <%# ── Fase 1: Planejamento ──────────────────────────────────────────────── %>
  <h3 class="h6 fw-bold text-uppercase text-muted mb-2" style="letter-spacing:.04em">
    <i class="bi bi-1-circle me-1"></i>Planejamento
  </h3>
  <div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/catalogo" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-box-seam fs-4 text-primary"></i><span class="fw-semibold text-dark">Catálogo</span></div>
          <div class="small text-muted">Itens (CATMAT/CATSER) ativos</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.catalogo %></div>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/pca" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-card-checklist fs-4 text-primary"></i><span class="fw-semibold text-dark">PCA</span></div>
          <div class="small text-muted">Plano de Contratações <%= ano %></div>
          <% if (counts.pcaExiste) { %>
            <div class="h4 fw-bold mb-0 mt-1"><%= counts.pcaItens %> <span class="fs-6 fw-normal text-muted">itens</span></div>
          <% } else { %>
            <div class="text-muted mt-2"><i class="bi bi-dash-circle me-1"></i>Sem PCA neste exercício</div>
          <% } %>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/demandas" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-file-earmark-text fs-4 text-primary"></i><span class="fw-semibold text-dark">Demandas (DOD)</span></div>
          <div class="small text-muted">Oficialização da demanda <%= ano %></div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.demandas %></div>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/reservas" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-bookmark-check fs-4 text-primary"></i><span class="fw-semibold text-dark">Reservas</span></div>
          <div class="small text-muted">Pré-empenho (dotação)</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.reservas %></div>
        </div></div>
      </a>
    </div>
  </div>

  <%# ── Fase 2: Seleção ───────────────────────────────────────────────────── %>
  <h3 class="h6 fw-bold text-uppercase text-muted mb-2" style="letter-spacing:.04em">
    <i class="bi bi-2-circle me-1"></i>Seleção do fornecedor
  </h3>
  <div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/fornecedores" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-truck fs-4 text-primary"></i><span class="fw-semibold text-dark">Fornecedores</span></div>
          <div class="small text-muted">Cadastro global</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.fornecedores %></div>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/processos" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-gavel fs-4 text-primary"></i><span class="fw-semibold text-dark">Processos</span></div>
          <div class="small text-muted">Licitações da entidade</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.processos %></div>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/contratos" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-file-earmark-ruled fs-4 text-primary"></i><span class="fw-semibold text-dark">Contratos</span></div>
          <div class="small text-muted">Instrumentos contratuais</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.contratos %></div>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/app/compras/atas" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-journal-bookmark fs-4 text-primary"></i><span class="fw-semibold text-dark">Atas (ARP)</span></div>
          <div class="small text-muted">Registro de preço</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.atas %></div>
        </div></div>
      </a>
    </div>
  </div>

  <%# ── Fase 3: Execução ──────────────────────────────────────────────────── %>
  <h3 class="h6 fw-bold text-uppercase text-muted mb-2" style="letter-spacing:.04em">
    <i class="bi bi-3-circle me-1"></i>Execução financeira
  </h3>
  <div class="row g-3">
    <div class="col-md-6 col-lg-4">
      <a href="/app/compras/empenhos" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-pen fs-4 text-primary"></i><span class="fw-semibold text-dark">Empenhos</span></div>
          <div class="small text-muted">1º estágio — reserva do orçamento</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.empenhos %></div>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-4">
      <a href="/app/compras/liquidacoes" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-clipboard-check fs-4 text-primary"></i><span class="fw-semibold text-dark">Liquidações</span></div>
          <div class="small text-muted">2º estágio — ateste de entrega</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.liquidacoes %></div>
        </div></div>
      </a>
    </div>
    <div class="col-md-6 col-lg-4">
      <a href="/app/compras/ordens-pagamento" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-cash-coin fs-4 text-primary"></i><span class="fw-semibold text-dark">Ordens de Pagamento</span></div>
          <div class="small text-muted">3º estágio — pagamento</div>
          <div class="h4 fw-bold mb-0 mt-1"><%= counts.ordensPagamento %></div>
        </div></div>
      </a>
    </div>
  </div>
</div>
</body>
</html>
