<%# Painel "Configurar totais" — usado no preview e no design do relatório.
    Espera: totais (montarPainelTotais), relatorioId, voltar ('editor' | null —
    para onde o POST redireciona de volta). %>
<details class="no-print card border-0 shadow-sm mt-3" id="painel-totais">
  <summary class="card-body py-2 small fw-semibold">
    <i class="bi bi-sliders me-1"></i>Configurar totais
    <span class="text-muted fw-normal">(<%= totais.automatico ? 'automático: soma das colunas numéricas' : 'personalizado' %>)</span>
  </summary>
  <div class="card-body pt-0">
    <p class="form-text mt-0">
      Marque as agregações desejadas por coluna — cada uma vira uma linha no fim do relatório, com rótulo editável.
      Sem configuração, toda coluna numérica recebe soma automaticamente.
    </p>
    <form method="post" action="/app/relatorios/meus/<%= relatorioId %>/totais" id="form-totais">
      <input type="hidden" name="totais" id="campo-totais">
      <% if (voltar) { %><input type="hidden" name="voltar" value="<%= voltar %>"><% } %>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-2">
          <thead class="table-light">
            <tr>
              <th>Coluna</th>
              <% totais.aggTipos.forEach(function(a) { %><th class="text-center small"><%= a.label %></th><% }) %>
            </tr>
          </thead>
          <tbody>
            <% totais.colunas.forEach(function(c, i) { %>
              <tr>
                <td class="font-monospace small"><%= c %></td>
                <% totais.aggTipos.forEach(function(a) { %>
                  <td class="text-center">
                    <input type="checkbox" class="form-check-input agg-check" data-coluna="<%= c %>" data-agg="<%= a.id %>"
                      <%= a.id === 'CONTAGEM' || totais.numericas[i] ? '' : 'disabled' %>>
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div id="rotulos-totais" class="mb-2"></div>
      <div class="form-check mb-3">
        <input type="checkbox" class="form-check-input" id="chk-subtotal">
        <label class="form-check-label small" for="chk-subtotal">Subtotal de soma ao fim de cada página (prévia e PDF)</label>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar totais</button>
        <button type="submit" class="btn btn-sm btn-outline-secondary" id="btn-totais-auto">Voltar ao automático</button>
      </div>
    </form>
  </div>
</details>
<script>
  (function () {
    var CFG = <%- JSON.stringify(totais.cfg) %>
    var ROTULOS_PADRAO = <%- JSON.stringify(totais.rotulosPadrao) %>
    var AGGS = <%- JSON.stringify(totais.aggTipos) %>
    var form = document.getElementById('form-totais')
    var campo = document.getElementById('campo-totais')
    var chkSubtotal = document.getElementById('chk-subtotal')
    var painelRotulos = document.getElementById('rotulos-totais')
    var checks = Array.prototype.slice.call(form.querySelectorAll('.agg-check'))
    var chave = function (col, agg) { return col + ' ' + agg }
    // Rótulos digitados pelo usuário (sobrevivem a marcar/desmarcar).
    var rotulos = {}

    function aggLabel(id) {
      for (var i = 0; i < AGGS.length; i++) if (AGGS[i].id === id) return AGGS[i].label
      return id
    }
    function rotuloDefault(col, agg) {
      return (ROTULOS_PADRAO[col] || {})[agg] || agg + ' de ' + col
    }

    function montarRotulos() {
      painelRotulos.replaceChildren()
      checks.forEach(function (ch) {
        if (!ch.checked) return
        var col = ch.dataset.coluna
        var agg = ch.dataset.agg
        var linha = document.createElement('div')
        linha.className = 'row g-2 align-items-center mb-1'
        var rot = document.createElement('div')
        rot.className = 'col-md-4 small text-muted font-monospace'
        rot.textContent = col + ' · ' + aggLabel(agg)
        var celula = document.createElement('div')
        celula.className = 'col-md-8'
        var input = document.createElement('input')
        input.type = 'text'
        input.className = 'form-control form-control-sm rotulo-total'
        input.maxLength = 120
        input.value = rotulos[chave(col, agg)] || rotuloDefault(col, agg)
        input.addEventListener('input', function () { rotulos[chave(col, agg)] = input.value })
        celula.appendChild(input)
        linha.appendChild(rot)
        linha.appendChild(celula)
        painelRotulos.appendChild(linha)
      })
    }

    // Preenche a partir da config efetiva (salva ou default automático).
    CFG.itens.forEach(function (it) {
      if (it.rotulo) rotulos[chave(it.coluna, it.agg)] = it.rotulo
      checks.forEach(function (ch) {
        if (ch.dataset.coluna === it.coluna && ch.dataset.agg === it.agg && !ch.disabled) ch.checked = true
      })
    })
    chkSubtotal.checked = CFG.subtotalPagina !== false
    montarRotulos()
    checks.forEach(function (ch) { ch.addEventListener('change', montarRotulos) })

    var voltarAuto = false
    document.getElementById('btn-totais-auto').addEventListener('click', function () { voltarAuto = true })
    form.addEventListener('submit', function () {
      if (voltarAuto) {
        campo.value = ''
        return
      }
      var itens = []
      checks.forEach(function (ch) {
        if (!ch.checked) return
        var col = ch.dataset.coluna
        var agg = ch.dataset.agg
        var rot = (rotulos[chave(col, agg)] || '').trim()
        var item = { coluna: col, agg: agg }
        if (rot && rot !== rotuloDefault(col, agg)) item.rotulo = rot
        itens.push(item)
      })
      campo.value = JSON.stringify({ subtotalPagina: chkSubtotal.checked, itens: itens })
    })
  })()
</script>
