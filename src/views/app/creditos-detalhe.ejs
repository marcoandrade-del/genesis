<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Crédito <%= credito.numero %> · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<% const TIPO = { SUPLEMENTAR: 'Suplementar', ESPECIAL: 'Especial', EXTRAORDINARIO: 'Extraordinário' } %>
<div class="container py-4" style="max-width:900px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento/creditos" class="text-decoration-none">Créditos Adicionais</a></li>
      <li class="breadcrumb-item active" aria-current="page">Nº <%= credito.numero %></li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 fw-bold mb-0">Crédito <span class="font-monospace"><%= credito.numero %></span>
      <span class="badge bg-primary bg-opacity-10 text-primary ms-1"><%= TIPO[credito.tipo] || credito.tipo %></span>
    </h2>
    <div class="text-end">
      <div class="small text-muted">Valor total (reforço)</div>
      <div class="h5 fw-bold mb-0 font-monospace">R$ <%= Number(credito.valorTotal).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3"><div class="card-body">
    <div class="row small">
      <div class="col-md-4 mb-2"><div class="text-muted">Data</div><div><%= new Date(credito.data).toLocaleDateString('pt-BR') %></div></div>
      <div class="col-md-8 mb-2"><div class="text-muted">Ato legal</div><div><%= credito.atoLegal %></div></div>
      <% if (credito.justificativa) { %>
        <div class="col-12"><div class="text-muted">Justificativa</div><div><%= credito.justificativa %></div></div>
      <% } %>
    </div>
  </div></div>

  <h3 class="h6 fw-bold mb-2">Itens aplicados</h3>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3">Dotação (UO · Conta · Fonte)</th><th>Operação</th><th class="text-end pe-3">Valor R$</th></tr></thead>
      <tbody>
        <% credito.itens.forEach(function(it) { const d = it.dotacaoDespesa %>
          <tr>
            <td class="ps-3 font-monospace small">UO <%= d.unidadeOrcamentaria.codigo %> · <%= d.contaDespesa.codigo %> · Fonte <%= d.fonteRecurso.codigo %></td>
            <td>
              <% if (it.operacao === 'REFORCO') { %><span class="badge bg-success bg-opacity-10 text-success">Reforço (+)</span>
              <% } else { %><span class="badge bg-danger bg-opacity-10 text-danger">Anulação (−)</span><% } %>
            </td>
            <td class="text-end pe-3 font-monospace"><%= Number(it.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>
</div>
</body>
</html>
