<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PCA <%= ano %> · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/compras" class="text-decoration-none">Compras</a></li>
      <li class="breadcrumb-item active" aria-current="page">PCA</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 fw-bold mb-0">Plano de Contratações Anual — <span class="font-monospace"><%= ano %></span></h2>
    <% if (pca) { %>
      <% if (pca.status === 'APROVADO') { %><span class="badge bg-success bg-opacity-10 text-success">Aprovado</span>
      <% } else { %><span class="badge bg-secondary bg-opacity-10 text-secondary">Rascunho</span><% } %>
    <% } %>
  </div>

  <% if (!pca) { %>
    <div class="alert alert-info py-3">
      <i class="bi bi-info-circle me-1"></i>
      Não há PCA cadastrado para <strong><%= entidade.nome %></strong> no exercício <strong><%= ano %></strong>.
    </div>
  <% } else { %>
    <% if (pca.observacoes) { %><p class="text-muted small mb-3"><%= pca.observacoes %></p><% } %>
    <% var total = pca.itens.reduce(function(s, it){ return s + Number(it.quantidadeEstimada) * Number(it.valorUnitarioEstimado) }, 0); %>
    <div class="card border-0 shadow-sm"><div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Item</th><th class="text-end">Qtd. estimada</th><th class="text-end">Valor unit. R$</th><th class="text-end pe-3">Estimado R$</th></tr></thead>
        <tbody>
          <% if (pca.itens.length === 0) { %><tr><td colspan="4" class="text-center text-muted py-4">Sem itens.</td></tr><% } %>
          <% pca.itens.forEach(function(it) { %>
            <tr>
              <td class="ps-3"><span class="font-monospace small text-muted"><%= it.itemCatalogo.codigo %></span> — <%= it.itemCatalogo.descricao %></td>
              <td class="text-end font-monospace"><%= Number(it.quantidadeEstimada).toLocaleString('pt-BR', { maximumFractionDigits: 4 }) %></td>
              <td class="text-end font-monospace"><%= Number(it.valorUnitarioEstimado).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
              <td class="text-end pe-3 font-monospace"><%= (Number(it.quantidadeEstimada) * Number(it.valorUnitarioEstimado)).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            </tr>
          <% }) %>
        </tbody>
        <% if (pca.itens.length > 0) { %>
        <tfoot class="table-light"><tr><th class="ps-3" colspan="3">Total estimado</th><th class="text-end pe-3 font-monospace">R$ <%= total.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></th></tr></tfoot>
        <% } %>
      </table>
    </div></div>
  <% } %>
</div>
</body>
</html>
