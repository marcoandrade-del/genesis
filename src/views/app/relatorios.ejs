<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relatórios · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<%- include('_navbar') %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Relatórios</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Relatórios</h2>
  <p class="text-muted mb-4">Seus relatórios desta entidade e os modelos de cabeçalho/rodapé usados na geração.</p>

  <% if (erro) { %>
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="h6 fw-bold mb-0"><i class="bi bi-file-earmark-bar-graph me-1"></i>Meus Relatórios</h3>
    <% if (podeEscrever) { %>
      <a href="/app/relatorios/meus/novo" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Novo relatório</a>
    <% } %>
  </div>

  <% if (podeEscrever) { %>
    <details class="mb-2">
      <summary class="text-primary small" style="cursor:pointer"><i class="bi bi-folder-plus me-1"></i>Nova pasta</summary>
      <form method="post" action="/app/relatorios/pastas" class="card card-body py-2 mt-2">
        <div class="row g-2 align-items-center">
          <div class="col"><input name="nome" class="form-control form-control-sm" placeholder="Nome da pasta" maxlength="80" required></div>
          <div class="col-auto">
            <select name="parentId" class="form-select form-select-sm">
              <option value="">— pasta raiz —</option>
              <% pastas.forEach(function(p) { %><option value="<%= p.id %>"><%= p.nome %></option><% }) %>
            </select>
          </div>
          <div class="col-auto"><button class="btn btn-sm btn-primary">Criar pasta</button></div>
        </div>
      </form>
    </details>
  <% } %>

  <div class="card border-0 shadow-sm mb-4"><div class="card-body py-2">
    <% if (arvore.raizes.length === 0 && arvore.semPasta.length === 0) { %>
      <div class="text-center text-muted py-3">Nenhum relatório criado.</div>
    <% } %>
    <% arvore.raizes.forEach(function(no) { %><%- include('_relatorios-pasta', { no: no, pastas: pastas, podeEscrever: podeEscrever }) %><% }) %>
    <% if (arvore.semPasta.length > 0) { %>
      <div class="mt-2 pt-2 <%= arvore.raizes.length ? 'border-top' : '' %>">
        <div class="small text-uppercase text-muted fw-bold mb-1" style="letter-spacing:.05em">Sem pasta</div>
        <% arvore.semPasta.forEach(function(r) { %><%- include('_relatorios-linha', { r: r, pastas: pastas, podeEscrever: podeEscrever, pastaAtual: '' }) %><% }) %>
      </div>
    <% } %>
  </div></div>

  <h3 class="h6 fw-bold text-muted text-uppercase mt-4 mb-3" style="letter-spacing:.05em">Modelos</h3>

  <% [
       { titulo: 'Cabeçalhos', icone: 'bi-layout-text-window', base: '/app/relatorios/cabecalhos', lista: cabecalhos },
       { titulo: 'Rodapés', icone: 'bi-layout-text-window-reverse', base: '/app/relatorios/rodapes', lista: rodapes }
     ].forEach(function(sec) { %>
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h3 class="h6 fw-bold mb-0"><i class="bi <%= sec.icone %> me-1"></i><%= sec.titulo %> <span class="text-muted">(<%= sec.lista.length %>)</span></h3>
      <% if (podeEscrever) { %>
        <a href="<%= sec.base %>/novo" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Novo</a>
      <% } %>
    </div>
    <div class="card border-0 shadow-sm mb-4"><div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Nome</th><th class="text-center">Elementos</th><th class="text-center">Altura</th><th class="text-end pe-3">Ações</th></tr></thead>
        <tbody>
          <% if (sec.lista.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-4">Nenhum modelo cadastrado.</td></tr>
          <% } %>
          <% sec.lista.forEach(function(t) { var qtd = Array.isArray(t.layout) ? t.layout.length : 0; %>
            <tr>
              <td class="ps-3"><%= t.nome %></td>
              <td class="text-center"><span class="badge bg-secondary bg-opacity-10 text-secondary"><%= qtd %></span></td>
              <td class="text-center font-monospace small"><%= t.altura %>px</td>
              <td class="text-end pe-3">
                <% if (podeEscrever) { %>
                  <a href="<%= sec.base %>/<%= t.id %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                  <form method="post" action="<%= sec.base %>/<%= t.id %>/excluir" class="d-inline" onsubmit="return confirm('Excluir o modelo «' + <%- JSON.stringify(t.nome) %> + '»?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                <% } else { %>
                  <span class="text-muted small">somente leitura</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div></div>
  <% }) %>
</div>
</body>
</html>
