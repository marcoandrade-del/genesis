<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relatórios · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6" href="/app">
    <i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis
  </a>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">
      <%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> ·
      <strong class="text-white"><%= entidade.nome %></strong> ·
      <strong class="text-white font-monospace"><%= ano %></strong>
    </span>
    <a href="/app/contexto" class="btn btn-sm btn-outline-secondary text-white border-secondary">
      <i class="bi bi-arrow-left-right me-1"></i>Trocar contexto
    </a>
    <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary">
      <i class="bi bi-box-arrow-right me-1"></i>Sair
    </a>
  </div>
</nav>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Relatórios</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Relatórios</h2>
  <p class="text-muted mb-4">Seus relatórios desta entidade e os modelos de cabeçalho/rodapé usados na geração.</p>

  <% if (erro) { %>
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="h6 fw-bold mb-0"><i class="bi bi-file-earmark-bar-graph me-1"></i>Meus Relatórios <span class="text-muted">(<%= relatorios.length %>)</span></h3>
    <% if (podeEscrever) { %>
      <a href="/app/relatorios/meus/novo" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Novo relatório</a>
    <% } %>
  </div>
  <div class="card border-0 shadow-sm mb-4"><div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3">Nome</th><th>Cabeçalho/Rodapé</th><th class="text-end pe-3">Ações</th></tr></thead>
      <tbody>
        <% if (relatorios.length === 0) { %>
          <tr><td colspan="3" class="text-center text-muted py-4">Nenhum relatório criado.</td></tr>
        <% } %>
        <% relatorios.forEach(function(r) { %>
          <tr>
            <td class="ps-3">
              <div class="fw-semibold"><%= r.nome %></div>
              <% if (r.descricao) { %><div class="small text-muted"><%= r.descricao %></div><% } %>
            </td>
            <td class="small text-muted">
              <i class="bi <%= r.cabecalhoId ? 'bi-check-circle text-success' : 'bi-dash-circle' %>"></i> Cabeçalho
              · <i class="bi <%= r.rodapeId ? 'bi-check-circle text-success' : 'bi-dash-circle' %>"></i> Rodapé
            </td>
            <td class="text-end pe-3">
              <a href="/app/relatorios/meus/<%= r.id %>/executar" class="btn btn-sm btn-outline-primary"><i class="bi bi-play-fill me-1"></i>Executar</a>
              <% if (podeEscrever) { %>
                <a href="/app/relatorios/meus/<%= r.id %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                <form method="post" action="/app/relatorios/meus/<%= r.id %>/excluir" class="d-inline" onsubmit="return confirm('Excluir o relatório «' + <%- JSON.stringify(r.nome) %> + '»?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>

  <h3 class="h6 fw-bold text-muted text-uppercase mt-4 mb-3" style="letter-spacing:.05em">Modelos</h3>

  <% [
       { titulo: 'Cabeçalhos', icone: 'bi-layout-text-window', base: '/app/relatorios/cabecalhos', lista: cabecalhos },
       { titulo: 'Rodapés', icone: 'bi-layout-text-window-reverse', base: '/app/relatorios/rodapes', lista: rodapes }
     ].forEach(function(sec) { %>
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h3 class="h6 fw-bold mb-0"><i class="bi <%= sec.icone %> me-1"></i><%= sec.titulo %> <span class="text-muted">(<%= sec.lista.length %>)</span></h3>
      <% if (podeEscrever) { %>
        <a href="<%= sec.base %>/novo" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Novo</a>
      <% } %>
    </div>
    <div class="card border-0 shadow-sm mb-4"><div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Nome</th><th class="text-center">Elementos</th><th class="text-center">Altura</th><th class="text-end pe-3">Ações</th></tr></thead>
        <tbody>
          <% if (sec.lista.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-4">Nenhum modelo cadastrado.</td></tr>
          <% } %>
          <% sec.lista.forEach(function(t) { var qtd = Array.isArray(t.layout) ? t.layout.length : 0; %>
            <tr>
              <td class="ps-3"><%= t.nome %></td>
              <td class="text-center"><span class="badge bg-secondary bg-opacity-10 text-secondary"><%= qtd %></span></td>
              <td class="text-center font-monospace small"><%= t.altura %>px</td>
              <td class="text-end pe-3">
                <% if (podeEscrever) { %>
                  <a href="<%= sec.base %>/<%= t.id %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                  <form method="post" action="<%= sec.base %>/<%= t.id %>/excluir" class="d-inline" onsubmit="return confirm('Excluir o modelo «' + <%- JSON.stringify(t.nome) %> + '»?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                <% } else { %>
                  <span class="text-muted small">somente leitura</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div></div>
  <% }) %>
</div>
</body>
</html>
