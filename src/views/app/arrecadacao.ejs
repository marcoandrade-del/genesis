<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Arrecadação · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<%
  var fmt = function(n) { return Number(n).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) }
  var v = valores || {}
%>
<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">Arrecadação</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-3">Arrecadação da Receita <span class="font-monospace fs-6 text-muted"><%= ano %></span>
    <% if (typeof granularidade !== 'undefined' && granularidade === 'PADRAO') { %>
      <a href="/app/configuracao" class="badge bg-info bg-opacity-10 text-info-emphasis text-decoration-none align-middle ms-1" style="font-size:.6em" title="Por conta: só o plano padrão (desdobramentos colapsados)"><i class="bi bi-diagram-2 me-1"></i>Plano padrão</a>
    <% } %>
  </h2>

  <% if (erro) { %>
    <div class="alert alert-warning py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>

  <% if (!orcamento) { %>
    <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-1"></i>Não há orçamento (LOA) cadastrado para este exercício.</div>
  <% } else { %>

    <div class="row g-3 mb-3">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm"><div class="card-body py-3">
          <div class="small text-muted">Previsto</div>
          <div class="h5 fw-bold font-monospace mb-0"><%= fmt(resumo.resumo.previsto) %></div>
        </div></div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm"><div class="card-body py-3">
          <div class="small text-muted">Arrecadado<%= resumo.resumo.previsto > 0 ? ' (' + Math.round(resumo.resumo.arrecadado / resumo.resumo.previsto * 100) + '%)' : '' %></div>
          <div class="h5 fw-bold font-monospace mb-0"><%= fmt(resumo.resumo.arrecadado) %></div>
        </div></div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm"><div class="card-body py-3">
          <div class="small text-muted">A arrecadar</div>
          <div class="h5 fw-bold font-monospace mb-0 <%= resumo.resumo.saldo < 0 ? 'text-danger' : '' %>"><%= fmt(resumo.resumo.saldo) %></div>
        </div></div>
      </div>
    </div>

    <% if (podeEscrever) { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white border-bottom py-2"><span class="fw-semibold small"><i class="bi bi-cash-coin me-2"></i>Registrar movimento</span></div>
      <div class="card-body py-3">
        <% if (previsoes.length === 0) { %>
          <div class="text-muted small">Não há previsões de receita neste orçamento — cadastre-as na LOA antes de arrecadar.</div>
        <% } else { %>
        <form method="post" action="/app/orcamento/arrecadacao">
          <div class="row g-2 align-items-end">
            <div class="col-md-5">
              <label class="form-label small fw-semibold mb-0">Previsão (conta × fonte)</label>
              <select name="previsaoId" id="previsaoSel" class="form-select form-select-sm" required>
                <option value="" data-fonte="">— selecione —</option>
                <% previsoes.forEach(function(p) { %>
                  <option value="<%= p.id %>" data-fonte="<%= p.fonteRecurso.codigo %>" <%= v.previsaoId === p.id ? 'selected' : '' %>>
                    <%= p.contaReceita.codigo %> · <%= p.contaReceita.descricao %> — FR <%= p.fonteRecurso.codigo %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label small fw-semibold mb-0">Tipo</label>
              <select name="tipo" class="form-select form-select-sm">
                <option value="ARRECADACAO" <%= v.tipo === 'ARRECADACAO' || !v.tipo ? 'selected' : '' %>>Arrecadação</option>
                <option value="ESTORNO" <%= v.tipo === 'ESTORNO' ? 'selected' : '' %>>Estorno</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label small fw-semibold mb-0">Data</label>
              <input type="date" name="data" class="form-control form-control-sm" required value="<%= v.data || '' %>">
            </div>
            <div class="col-md-2">
              <label class="form-label small fw-semibold mb-0">Valor R$</label>
              <input type="number" name="valor" class="form-control form-control-sm" min="0.01" step="0.01" required value="<%= v.valor || '' %>">
            </div>
            <div class="col-md-1">
              <button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-check-lg"></i></button>
            </div>
          </div>
          <div class="row g-2 mt-1">
            <div class="col-md-6">
              <input type="text" name="historico" class="form-control form-control-sm" maxlength="200" placeholder="Histórico (opcional)" value="<%= v.historico || '' %>">
            </div>
            <div class="col-md-6">
              <select name="contaBancariaId" id="contaBancariaSel" class="form-select form-select-sm">
                <option value="" data-fonte="">— conta bancária (opcional; deriva o caixa do E300) —</option>
                <% contasBancarias.forEach(function(cb) { %>
                  <option value="<%= cb.id %>" data-fonte="<%= cb.fonteCodigo %>" <%= v.contaBancariaId === cb.id ? 'selected' : '' %>><%= cb.rotulo %> · FR <%= cb.fonteCodigo %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </form>
        <script>
          // Filtra as contas bancárias pela fonte da previsão selecionada (DOM puro).
          (function () {
            var prev = document.getElementById('previsaoSel')
            var cb = document.getElementById('contaBancariaSel')
            if (!prev || !cb) return
            function filtrar() {
              var opt = prev.options[prev.selectedIndex]
              var fonte = opt ? opt.getAttribute('data-fonte') : ''
              for (var i = 0; i < cb.options.length; i++) {
                var o = cb.options[i]
                var of = o.getAttribute('data-fonte')
                var ok = of === '' || of === fonte
                o.hidden = !ok
                o.disabled = !ok
              }
              if (cb.selectedIndex >= 0 && cb.options[cb.selectedIndex].hidden) cb.value = ''
            }
            prev.addEventListener('change', filtrar)
            filtrar()
          })()
        </script>
        <% } %>
      </div>
    </div>
    <% } %>

    <%
      function tabela(titulo, icone, rotuloCol, linhas, arvore) { %>
        <div class="card border-0 shadow-sm mb-3">
          <div class="card-header bg-white border-bottom py-2"><span class="fw-semibold small"><i class="bi bi-<%= icone %> me-2"></i><%= titulo %></span></div>
          <div class="card-body p-0">
            <table class="table table-hover table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3" style="width:160px">Código</th>
                  <th><%= rotuloCol %></th>
                  <th class="text-end">Previsto</th>
                  <th class="text-end">Arrecadado</th>
                  <th class="text-end pe-3">A arrecadar</th>
                </tr>
              </thead>
              <tbody>
                <% if (linhas.length === 0) { %>
                  <tr><td colspan="5" class="text-center text-muted py-3">Sem previsões.</td></tr>
                <% } %>
                <% linhas.forEach(function(l) { %>
                  <tr>
                    <td class="ps-3 font-monospace small"><%= l.codigo %></td>
                    <td class="small" <% if (arvore) { %>style="padding-left: calc(<%= (l.nivel - 1) * 1.1 %>rem + 0.5rem)"<% } %>><%= l.rotulo %></td>
                    <td class="text-end font-monospace small"><%= fmt(l.previsto) %></td>
                    <td class="text-end font-monospace small"><%= fmt(l.arrecadado) %></td>
                    <td class="text-end font-monospace small pe-3 fw-semibold <%= l.saldo < 0 ? 'text-danger' : '' %>"><%= fmt(l.saldo) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
    <% }
    %>
    <% tabela('Por fonte de recurso', 'droplet', 'Fonte', resumo.porFonte, false) %>
    <% tabela('Por conta de receita (com roll-up na árvore)', 'diagram-3', 'Conta', resumo.porConta, true) %>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white border-bottom py-2"><span class="fw-semibold small"><i class="bi bi-clock-history me-2"></i>Movimentos</span></div>
      <div class="card-body p-0">
        <table class="table table-hover table-sm align-middle mb-0">
          <thead class="table-light">
            <tr><th class="ps-3">Data</th><th>Tipo</th><th>Conta</th><th>Fonte</th><th>Histórico</th><th class="text-end">Valor R$</th><th class="text-end pe-3" style="width:48px">Trilha</th></tr>
          </thead>
          <tbody>
            <% if (movimentos.length === 0) { %>
              <tr><td colspan="7" class="text-center text-muted py-3">Nenhum movimento registrado.</td></tr>
            <% } %>
            <% movimentos.forEach(function(m) { %>
              <tr>
                <td class="ps-3 small text-muted"><%= new Date(m.data).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %></td>
                <td>
                  <% if (m.tipo === 'ESTORNO') { %>
                    <span class="badge bg-danger bg-opacity-10 text-danger">Estorno</span>
                  <% } else { %>
                    <span class="badge bg-primary bg-opacity-10 text-primary">Arrecadação</span>
                  <% } %>
                </td>
                <td class="small font-monospace"><%= m.previsao.contaReceita.codigo %> <span class="text-muted"><%= m.previsao.contaReceita.descricao %></span></td>
                <td class="small font-monospace"><%= m.previsao.fonteRecurso.codigo %></td>
                <td class="small text-muted"><%= m.historico || '—' %></td>
                <td class="text-end font-monospace fw-semibold <%= m.tipo === 'ESTORNO' ? 'text-danger' : '' %>"><%= m.tipo === 'ESTORNO' ? '−' : '' %><%= fmt(m.valor) %></td>
                <td class="text-end pe-3">
                  <a href="/app/orcamento/arrecadacao/<%= m.id %>/lancamentos" class="text-decoration-none" title="Ver lançamentos contábeis gerados"><i class="bi bi-diagram-3"></i></a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>
</body>
</html>
