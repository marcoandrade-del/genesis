<%# ─────────────────────────────────────────────────────────────────────────────
   GÊNESIS · CHROME do /app  (faixa superior fina + SIDEBAR lateral)
   A navegação principal virou uma sidebar vertical (`_sidebar.ejs`) que escala sem
   overflow. Este arquivo é a "casca": faixa superior com o contexto (entidade ·
   exercício) e ações, mais o command palette (⌘K), os favoritos e o comportamento
   da sidebar (colapso, rota ativa, off-canvas mobile). Segue incluído por TODAS as
   44 views do /app, então mantém o bundle Bootstrap e o offset global do body.

   Requer: entidade (com municipio.estado), ano.
   Opcional: menuApp (árvore permitida), nivel (LEITURA|ESCRITA|ADMIN), favoritoIds. %>

<%
  // Achata as folhas navegáveis (com rota) para o command palette e os favoritos.
  const _favSet = new Set(typeof favoritoIds !== 'undefined' && favoritoIds ? favoritoIds : []);
  const _gxFlat = [];
  (typeof menuApp !== 'undefined' && menuApp ? menuApp : []).forEach(function (area) {
    if (area.rota && area.rota.charAt(0) === '/') _gxFlat.push({ id: area.id, nome: area.nome, grupo: 'Áreas', rota: area.rota, icone: area.icone || 'bi-grid' });
    (area.filhos || []).forEach(function (f) {
      if (f.rota && f.rota.charAt(0) === '/') _gxFlat.push({ id: f.id, nome: f.nome, grupo: area.nome, rota: f.rota, icone: f.icone || 'bi-dot' });
    });
  });
  // Favoritos = itens achatados marcados pelo usuário (já filtrados pela permissão).
  const _gxFav = _gxFlat.filter(function (it) { return _favSet.has(it.id); });
%>

<style>
  /* ── Offset global (Opção A): abre espaço para a sidebar fixa + a faixa ──── */
  :root { --gx-side-w: 264px; --gx-strip-h: 56px; }
  body { padding-left: var(--gx-side-w); padding-top: var(--gx-strip-h); }
  @media (max-width: 991.98px) { body { padding-left: 0; } }

  /* ── Faixa superior (contexto + ações) ────────────────────────────────── */
  .gx-strip {
    position: fixed; top: 0; left: var(--gx-side-w); right: 0; height: var(--gx-strip-h);
    z-index: 1040; display: flex; align-items: center; gap: .8rem; padding: 0 1rem;
    background:
      radial-gradient(120% 180% at 100% 0%, rgba(159,232,112,.08), transparent 50%),
      linear-gradient(180deg, #14160f 0%, var(--ink, #0e0f0c) 100%);
    border-bottom: 1px solid rgba(159,232,112,.18);
    box-shadow: 0 1px 0 rgba(159,232,112,.28);
  }
  @media (max-width: 991.98px) { .gx-strip { left: 0; } }

  .gx-burger {
    display: none; width: 40px; height: 40px; flex-shrink: 0; border: 0; border-radius: 9999px;
    place-items: center; cursor: pointer; background: rgba(255,255,255,.06); color: rgba(232,235,230,.85);
  }
  .gx-burger:hover { background: rgba(255,255,255,.1); }
  .gx-burger .bi { font-size: 1.15rem; }
  @media (max-width: 991.98px) { .gx-burger { display: grid; } }

  .gx-strip-spacer { flex: 1 1 auto; min-width: 0; }

  .gx-workspace {
    display: inline-flex; align-items: center; gap: .6rem;
    padding: .3rem .3rem .3rem .75rem; border-radius: 9999px; text-decoration: none;
    background: rgba(159,232,112,.08); border: 1px solid rgba(159,232,112,.28);
    transition: border-color .15s, background .15s;
  }
  .gx-workspace:hover { border-color: var(--primary, #9fe870); background: rgba(159,232,112,.14); }
  .gx-ws-meta { display: flex; flex-direction: column; line-height: 1.05; min-width: 0; }
  .gx-ws-top { font-size: .62rem; letter-spacing: .08em; text-transform: uppercase; color: rgba(232,235,230,.5); }
  .gx-ws-name { font-size: .8rem; font-weight: 700; color: #fff;
    max-width: 20ch; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .gx-ws-year {
    flex-shrink: 0; display: inline-grid; place-items: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-weight: 700; font-size: .76rem;
    color: var(--ink, #0e0f0c); background: var(--primary, #9fe870); padding: .2rem .5rem; border-radius: 9999px;
  }
  .gx-ws-swap { color: rgba(232,235,230,.6); font-size: .9rem; padding-right: .25rem; }

  .gx-icon-btn {
    width: 40px; height: 40px; flex-shrink: 0; border-radius: 9999px; border: 0;
    display: grid; place-items: center; cursor: pointer; text-decoration: none;
    background: rgba(255,255,255,.06); color: rgba(232,235,230,.78);
    transition: background .15s, color .15s;
  }
  .gx-icon-btn:hover { background: rgba(208,50,56,.18); color: #ffb4b7; }
  .gx-icon-btn .bi { font-size: 1.05rem; }

  @media (max-width: 991.98px) { .gx-ws-meta { display: none; } .gx-workspace { padding: .3rem; } }

  /* ── Command palette (⌘K) ─────────────────────────────────────────────── */
  #gx-palette { position: fixed; inset: 0; z-index: 2000; display: none;
    align-items: flex-start; justify-content: center; padding-top: 12vh;
    background: rgba(14,15,12,.55); backdrop-filter: blur(4px); }
  #gx-palette.open { display: flex; }
  .gx-pal-card { width: min(560px, 92vw); background: var(--canvas, #fff);
    border-radius: 24px; box-shadow: 0 24px 64px rgba(0,0,0,.35); overflow: hidden; }
  .gx-pal-search { display: flex; align-items: center; gap: .6rem; padding: 1rem 1.15rem;
    border-bottom: 1px solid var(--bs-border-color, rgba(14,15,12,.08)); }
  .gx-pal-search .bi { color: var(--mute, #868685); font-size: 1.15rem; }
  .gx-pal-search input { border: 0; outline: 0; width: 100%; font-size: 1rem;
    color: var(--ink, #0e0f0c); background: transparent; font-family: 'Inter', sans-serif; }
  .gx-pal-list { max-height: 52vh; overflow-y: auto; padding: .5rem; }
  .gx-pal-item { display: flex; align-items: center; gap: .7rem; padding: .6rem .7rem;
    border-radius: 14px; text-decoration: none; color: var(--ink, #0e0f0c); cursor: pointer; }
  .gx-pal-item .gx-ico { width: 32px; height: 32px; border-radius: 10px; flex-shrink: 0;
    display: grid; place-items: center; background: var(--primary-pale, #e2f6d5); color: var(--ink-deep, #163300); }
  .gx-pal-item.active, .gx-pal-item:hover { background: var(--canvas-soft, #e8ebe6); }
  .gx-pal-item.active .gx-ico { background: var(--primary, #9fe870); }
  .gx-pal-grp { font-size: .72rem; color: var(--mute, #868685); margin-left: auto; }
  .gx-pal-empty { padding: 1.5rem; text-align: center; color: var(--mute, #868685); font-size: .9rem; }
</style>

<%# ── Sidebar lateral (navegação principal) ──────────────────────────────── %>
<%- include('_sidebar', { favSet: _favSet, favList: _gxFav }) %>

<%# ── Faixa superior: hambúrguer (mobile) + contexto + ações ──────────────── %>
<div class="gx-strip">
  <button class="gx-burger" type="button" id="gx-burger" aria-label="Abrir menu">
    <i class="bi bi-list"></i>
  </button>
  <div class="gx-strip-spacer"></div>

  <a href="/app/contexto" class="gx-workspace" title="Trocar contexto de trabalho">
    <div class="gx-ws-meta">
      <span class="gx-ws-top"><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %></span>
      <span class="gx-ws-name"><%= entidade.nome %></span>
    </div>
    <span class="gx-ws-year"><%= ano %></span>
    <i class="bi bi-arrow-left-right gx-ws-swap"></i>
  </a>

  <% if (typeof nivel !== 'undefined' && nivel === 'ADMIN') { %>
    <a href="/app/entidade/acessos" class="gx-icon-btn" title="Acessos da entidade" aria-label="Acessos da entidade">
      <i class="bi bi-people"></i>
    </a>
  <% } %>

  <a href="/app/logout" class="gx-icon-btn" title="Sair" aria-label="Sair">
    <i class="bi bi-box-arrow-right"></i>
  </a>
</div>

<% if (_gxFlat.length) { %>
<%# ── Command palette: busca/navegação rápida por qualquer item permitido ── %>
<div id="gx-palette" role="dialog" aria-modal="true" aria-label="Buscar navegação">
  <div class="gx-pal-card" role="document">
    <div class="gx-pal-search">
      <i class="bi bi-search"></i>
      <input type="text" id="gx-pal-input" placeholder="Ir para… (digite o nome de uma tela)" autocomplete="off">
    </div>
    <div class="gx-pal-list" id="gx-pal-list"></div>
  </div>
</div>
<script>
  (function () {
    var ITEMS = <%- JSON.stringify(_gxFlat) %>;
    var pal = document.getElementById('gx-palette');
    var input = document.getElementById('gx-pal-input');
    var list = document.getElementById('gx-pal-list');
    var trigger = document.getElementById('gx-search-trigger');
    var cursor = 0, filtered = ITEMS;

    // Render por métodos DOM (sem innerHTML) — os rótulos vêm do banco, mas evitamos
    // qualquer superfície de injeção montando os nós e usando textContent.
    function render() {
      list.textContent = '';
      if (!filtered.length) {
        var empty = document.createElement('div');
        empty.className = 'gx-pal-empty'; empty.textContent = 'Nada encontrado.';
        list.appendChild(empty);
        return;
      }
      filtered.forEach(function (it, i) {
        var a = document.createElement('a');
        a.className = 'gx-pal-item' + (i === cursor ? ' active' : '');
        a.href = it.rota; a.setAttribute('data-i', i);
        var ico = document.createElement('span'); ico.className = 'gx-ico';
        var icoI = document.createElement('i'); icoI.className = 'bi ' + it.icone; ico.appendChild(icoI);
        var nome = document.createElement('span'); nome.textContent = it.nome;
        var grp = document.createElement('span'); grp.className = 'gx-pal-grp'; grp.textContent = it.grupo;
        a.appendChild(ico); a.appendChild(nome); a.appendChild(grp);
        list.appendChild(a);
      });
      var active = list.querySelector('.gx-pal-item.active');
      if (active) active.scrollIntoView({ block: 'nearest' });
    }

    function filter() {
      var q = input.value.trim().toLowerCase();
      filtered = !q ? ITEMS : ITEMS.filter(function (it) {
        return (it.nome + ' ' + it.grupo).toLowerCase().indexOf(q) !== -1;
      });
      cursor = 0; render();
    }

    function open() { pal.classList.add('open'); input.value = ''; filter(); setTimeout(function () { input.focus(); }, 30); }
    function close() { pal.classList.remove('open'); }

    if (trigger) trigger.addEventListener('click', open);
    input.addEventListener('input', filter);

    input.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowDown') { e.preventDefault(); cursor = Math.min(cursor + 1, filtered.length - 1); render(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); cursor = Math.max(cursor - 1, 0); render(); }
      else if (e.key === 'Enter') { e.preventDefault(); if (filtered[cursor]) window.location.href = filtered[cursor].rota; }
      else if (e.key === 'Escape') { close(); }
    });

    list.addEventListener('mousemove', function (e) {
      var el = e.target.closest('.gx-pal-item'); if (!el) return;
      var i = parseInt(el.dataset.i, 10); if (i !== cursor) { cursor = i; render(); }
    });

    pal.addEventListener('click', function (e) { if (e.target === pal) close(); });

    document.addEventListener('keydown', function (e) {
      if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')) { e.preventDefault(); pal.classList.contains('open') ? close() : open(); }
    });
  })();
</script>
<% } %>

<%# ── Marca o link ativo (rota) e auto-expande o grupo que o contém ───────── %>
<script>
  (function () {
    var path = window.location.pathname.replace(/\/$/, '');
    var best = null, bestLen = -1;
    document.querySelectorAll('.gx-side-link[data-gx-route]').forEach(function (el) {
      var r = (el.getAttribute('data-gx-route') || '').replace(/\/$/, '');
      if (!r || r === '/app') return;
      if ((path === r || path.indexOf(r + '/') === 0) && r.length > bestLen) { best = el; bestLen = r.length; }
    });
    if (!best) return;
    var route = best.getAttribute('data-gx-route');
    document.querySelectorAll('.gx-side-link[data-gx-route="' + route + '"]').forEach(function (el) { el.classList.add('is-active'); });
    var grp = best.closest('.gx-side-group');
    if (!grp) { var inGrp = document.querySelector('.gx-side-group .gx-side-link[data-gx-route="' + route + '"]'); if (inGrp) grp = inGrp.closest('.gx-side-group'); }
    if (grp) grp.classList.add('is-open');
  })();
</script>

<%# ── Colapso dos grupos (persistido em localStorage) ─────────────────────── %>
<script>
  (function () {
    var KEY = 'gx_side_groups';
    var groups = Array.prototype.slice.call(document.querySelectorAll('.gx-side-group'));
    function load() { try { return JSON.parse(localStorage.getItem(KEY) || '[]'); } catch (e) { return []; } }
    function save() {
      var open = groups.filter(function (g) { return g.classList.contains('is-open'); })
        .map(function (g) { return g.getAttribute('data-gx-group'); });
      try { localStorage.setItem(KEY, JSON.stringify(open)); } catch (e) {}
    }
    // restaura o salvo (sem fechar o grupo ativo, já aberto pelo script de rota)
    var saved = load();
    groups.forEach(function (g) {
      if (saved.indexOf(g.getAttribute('data-gx-group')) !== -1) g.classList.add('is-open');
      var hd = g.querySelector('.gx-side-group-hd');
      if (hd) hd.setAttribute('aria-expanded', g.classList.contains('is-open') ? 'true' : 'false');
    });
    document.addEventListener('click', function (e) {
      var hd = e.target.closest('.gx-side-group-hd'); if (!hd) return;
      var g = hd.closest('.gx-side-group'); if (!g) return;
      g.classList.toggle('is-open');
      hd.setAttribute('aria-expanded', g.classList.contains('is-open') ? 'true' : 'false');
      save();
    });
  })();
</script>

<%# ── Off-canvas mobile (hambúrguer) ──────────────────────────────────────── %>
<script>
  (function () {
    var side = document.getElementById('gx-side');
    var scrim = document.getElementById('gx-side-scrim');
    var burger = document.getElementById('gx-burger');
    if (!side) return;
    function abrir() { side.classList.add('gx-side-open'); if (scrim) scrim.hidden = false; }
    function fechar() { side.classList.remove('gx-side-open'); if (scrim) scrim.hidden = true; }
    if (burger) burger.addEventListener('click', function () { side.classList.contains('gx-side-open') ? fechar() : abrir(); });
    if (scrim) scrim.addEventListener('click', fechar);
    side.addEventListener('click', function (e) {
      if (e.target.closest('.gx-side-link') && window.matchMedia('(max-width: 991.98px)').matches) fechar();
    });
  })();
</script>

<%# ── Favoritar/desfavoritar via estrela + atualização da seção em tempo real ─ %>
<script>
  (function () {
    var sec = document.getElementById('gx-side-fav-sec');
    var listEl = document.getElementById('gx-side-fav-list');

    function pintarEstrela(btn, fav) {
      btn.classList.toggle('is-fav', fav);
      var i = btn.querySelector('i'); if (i) i.className = 'bi ' + (fav ? 'bi-star-fill' : 'bi-star');
      btn.title = fav ? 'Remover dos favoritos' : 'Favoritar';
    }
    function adicionarAtalho(d) {
      if (!listEl || listEl.querySelector('.gx-side-fav[data-fav-id="' + d.id + '"]')) return;
      var a = document.createElement('a');
      a.className = 'gx-side-link gx-side-fav'; a.href = d.rota;
      a.setAttribute('data-fav-id', d.id); a.setAttribute('data-gx-route', d.rota);
      var ico = document.createElement('i'); ico.className = 'bi ' + d.icone;
      var txt = document.createElement('span'); txt.textContent = d.nome;
      a.appendChild(ico); a.appendChild(txt); listEl.appendChild(a);
    }
    function removerAtalho(id) {
      if (!listEl) return;
      var el = listEl.querySelector('.gx-side-fav[data-fav-id="' + id + '"]'); if (el) el.remove();
    }
    function sincronizar() { if (sec) sec.hidden = !(listEl && listEl.querySelector('.gx-side-fav')); }

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.gx-side-star');
      if (!btn) return;
      e.preventDefault(); e.stopPropagation();
      var id = btn.getAttribute('data-fav-id');
      btn.disabled = true;
      fetch('/app/favoritos/' + encodeURIComponent(id) + '/toggle', {
        method: 'POST', headers: { 'X-Requested-With': 'fetch' },
      })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
        .then(function (res) {
          document.querySelectorAll('.gx-side-star[data-fav-id="' + id + '"]').forEach(function (b) { pintarEstrela(b, res.favoritado); });
          if (res.favoritado) {
            adicionarAtalho({ id: id, nome: btn.getAttribute('data-fav-nome'), rota: btn.getAttribute('data-fav-rota'), icone: btn.getAttribute('data-fav-icone') });
          } else {
            removerAtalho(id);
          }
          sincronizar();
        })
        .catch(function () { /* silencioso — mantém o estado atual */ })
        .finally(function () { btn.disabled = false; });
    });
  })();
</script>

<% if (typeof menuApp !== 'undefined' && menuApp && menuApp.length) { %>
<%# Bundle Bootstrap (Popper + dropdowns/modais usados pelas telas). As views só carregam o CSS. %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<% } %>

<%# ─────────────────────────────────────────────────────────────────────────────
   ESCAPADAS CONSCIENTES DO DESIGN.md:
   • A sidebar/faixa usam fundo ink com fio lime (chrome de produto), não o nav
     branco do marketing. O lime segue como único acento (item ativo/CTA).
   • Command palette (⌘K) e a estrela de favoritos são padrões de app coerentes
     com os tokens (rounded 24px, primary-pale, ink-deep), fora do DESIGN.md.
   • O "workspace switcher" usa lime como borda/realce de pílula informativa.
   ───────────────────────────────────────────────────────────────────────────── %>
