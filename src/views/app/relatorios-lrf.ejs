<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relatórios da LRF · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
  <style>
    .loa-card { transition: transform .12s ease, box-shadow .12s ease; }
    .loa-card:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.10) !important; }
    .loa-ico {
      flex: 0 0 auto; width: 44px; height: 44px; border-radius: 12px;
      display: grid; place-items: center; font-size: 1.25rem;
      background: var(--primary, #1b5e20); color: #fff;
    }
    .loa-grupo { font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; color: #888; }
  </style>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1000px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">LRF</li>
    </ol>
  </nav>

  <div class="mb-4">
    <h2 class="h4 fw-bold mb-1">Relatórios da LRF <span class="text-muted fw-normal">· exercício <%= ano %></span></h2>
    <div class="text-muted small"><i class="bi bi-building me-1"></i><%= entidade.nome %></div>
  </div>

  <% function cards(lista) { %>
    <div class="row g-3 mb-4">
      <% lista.forEach(function(a) { %>
        <div class="col-md-6 col-lg-4">
          <a href="<%= a.rota %>" class="card h-100 border-0 shadow-sm text-reset text-decoration-none loa-card">
            <div class="card-body d-flex gap-3 align-items-start">
              <div class="loa-ico"><i class="bi <%= a.icone %>"></i></div>
              <div>
                <div class="fw-semibold lh-sm"><%= a.nome %></div>
                <div class="small text-muted mt-1"><%= a.desc %></div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="loa-grupo mb-2">LRF — Lei de Responsabilidade Fiscal</div>
  <% cards([
    { rota: '/app/orcamento/relatorios/rcl', icone: 'bi-percent', nome: 'Receita Corrente Líquida', desc: 'RREO Anexo 3 — base dos limites da LRF' },
    { rota: '/app/orcamento/relatorios/rcl-consolidada', icone: 'bi-bank2', nome: 'RCL Consolidada do Município', desc: 'Soma das entidades do ente (Prefeitura, Câmara, RPPS…)' },
    { rota: '/app/orcamento/relatorios/despesa-pessoal', icone: 'bi-people', nome: 'Despesa com Pessoal (projeção)', desc: 'DTP pela dotação autorizada (inclusões − exclusões) e % da RCL (limite 54%)' },
    { rota: '/app/orcamento/relatorios/indices-constitucionais', icone: 'bi-mortarboard', nome: 'Índices constitucionais', desc: 'MDE 25% (CF art. 212) e ASPS 15% (LC 141) — aplicação por fonte vinculada' },
    { rota: '/app/orcamento/relatorios/despesa-funcao-rreo', icone: 'bi-columns-gap', nome: 'Despesa por função (RREO)', desc: 'Execução por função de governo — autorizado, empenhado, disponível e %' },
    { rota: '/app/orcamento/relatorios/disponibilidade-fonte', icone: 'bi-safe', nome: 'Disponibilidade de caixa e RP', desc: 'RGF Anexo 5 — caixa por fonte − restos a pagar = disponibilidade líquida' },
    { rota: '/app/orcamento/relatorios/metas-fiscais', icone: 'bi-bullseye', nome: 'Metas fiscais', desc: 'LDO × projetado da LOA — receita, despesa, resultados e dívida' },
    { rota: '/app/orcamento/relatorios/guardiao', icone: 'bi-shield-check', nome: 'Guardião LRF', desc: 'Indicadores fiscais: RCL, Despesa com Pessoal, índices MDE/ASPS' },
  ]) %>

  <div class="loa-grupo mb-2">RGF — Relatório de Gestão Fiscal (MDF 9ª ed.)</div>
  <% cards([
    { rota: '/app/orcamento/relatorios/rgf/anexo1', icone: 'bi-people-fill', nome: 'Anexo 1 — Despesa com Pessoal', desc: 'DTP executada mês a mês por quadrimestre; limites máximo, prudencial e de alerta em R$ e %' },
    { rota: '/app/orcamento/relatorios/rgf/anexo2', icone: 'bi-bank', nome: 'Anexo 2 — Dívida Consolidada Líquida', desc: 'DC do cadastro − deduções de caixa/RP = DCL viva; limite 120% da RCL + comparativo com a LDO' },
    { rota: '/app/orcamento/relatorios/rgf/anexo3', icone: 'bi-shield-lock', nome: 'Anexo 3 — Garantias e Contragarantias', desc: 'Garantias concedidas por tipo × limite de 22% da RCL' },
    { rota: '/app/orcamento/rgf/cadastros', icone: 'bi-journal-bookmark', nome: 'Cadastros do RGF', desc: 'Dívida consolidada, garantias e operações de crédito — os dados que alimentam os anexos' },
  ]) %>
</div>
</body>
</html>
