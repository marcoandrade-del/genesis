<!DOCTYPE html>
<html lang="pt-BR">
<%
  var ehCabecalho = tipo === 'CABECALHO'
  var titulo = ehCabecalho ? 'cabeçalho' : 'rodapé'
  var actionUrl = (registro && registro.id) ? ('/app' + base + '/' + registro.id) : ('/app' + base)
  var alturaAtual = (registro && Number(registro.altura)) ? registro.altura : (ehCabecalho ? 120 : 80)
  var layoutInicial = (registro && Array.isArray(registro.layout)) ? registro.layout : []
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= registro && registro.id ? 'Editar' : 'Novo' %> <%= titulo %> · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
  <style>
    #canvas { position: relative; border: 1px dashed var(--bs-border-color, #ccc); background: #fff; overflow: hidden; }
    #canvas .el { position: absolute; cursor: move; padding: 2px 6px; white-space: nowrap; font-size: 13px; background: rgba(159,232,112,.12); border: 1px solid rgba(0,0,0,.12); border-radius: 4px; user-select: none; touch-action: none; }
    #canvas .el .rm { margin-left: 6px; color: #c00; cursor: pointer; font-weight: bold; }
    #canvas .el .ph { color: #999; font-style: italic; }
    .paleta .chip { cursor: pointer; }
    .paleta .chip.ativo { opacity: .4; pointer-events: none; }
  </style>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6" href="/app">
    <i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis
  </a>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">
      <%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> ·
      <strong class="text-white"><%= entidade.nome %></strong> ·
      <strong class="text-white font-monospace"><%= ano %></strong>
    </span>
    <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary">
      <i class="bi bi-box-arrow-right me-1"></i>Sair
    </a>
  </div>
</nav>

<div class="container py-4" style="max-width:980px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/relatorios" class="text-decoration-none">Relatórios</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= registro && registro.id ? 'Editar' : 'Novo' %> <%= titulo %></li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-3"><%= registro && registro.id ? 'Editar' : 'Novo' %> modelo de <%= titulo %></h2>

  <% if (erro) { %>
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>

  <form method="post" action="<%= actionUrl %>" id="form">
    <input type="hidden" name="layout" id="layout">
    <div class="row g-3 mb-3">
      <div class="col-md-8">
        <label class="form-label small fw-semibold">Nome do modelo</label>
        <input type="text" class="form-control" name="nome" maxlength="120" required
               value="<%= registro ? registro.nome : '' %>" placeholder="Ex.: Cabeçalho padrão da prefeitura">
      </div>
      <div class="col-md-4">
        <label class="form-label small fw-semibold">Altura da faixa (px)</label>
        <input type="number" class="form-control" name="altura" id="altura" min="40" max="400" step="10" value="<%= alturaAtual %>">
      </div>
    </div>

    <label class="form-label small fw-semibold">Elementos disponíveis <span class="text-muted fw-normal">— clique para adicionar; arraste para posicionar</span></label>
    <div class="paleta d-flex flex-wrap gap-2 mb-3" id="paleta">
      <% elementos.forEach(function(el) { %>
        <span class="chip badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary-subtle px-3 py-2" data-tipo="<%= el.tipo %>">
          <i class="bi bi-plus-circle me-1"></i><%= el.label %>
        </span>
      <% }) %>
    </div>

    <label class="form-label small fw-semibold">Pré-visualização da faixa</label>
    <div id="canvas" style="height: <%= alturaAtual %>px"></div>
    <div class="form-text mb-3">As posições são relativas à faixa, então o modelo se adapta à largura da página na geração.</div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
      <a href="/app/relatorios" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>

<script>
  const DADOS = <%- JSON.stringify({
    entidade: { nome: entidade.nome, endereco: entidade.endereco, brasao: entidade.brasao },
    layout: layoutInicial
  }).replace(/</g, '\\u003c') %>;

  const canvas = document.getElementById('canvas')
  const inputLayout = document.getElementById('layout')
  const paleta = document.getElementById('paleta')
  const inputAltura = document.getElementById('altura')

  // Estado: lista de { tipo, x, y } (x/y em % da faixa). Fonte da verdade.
  let layout = Array.isArray(DADOS.layout) ? DADOS.layout.map(function(e) {
    return { tipo: e.tipo, x: Number(e.x) || 0, y: Number(e.y) || 0 }
  }) : []

  function placeholder(texto) {
    const s = document.createElement('span'); s.className = 'ph'; s.textContent = texto; return s
  }

  // Conteúdo de amostra de cada elemento (data/hora/página são exemplos).
  function conteudo(tipo) {
    const agora = new Date()
    if (tipo === 'BRASAO') {
      if (DADOS.entidade.brasao) {
        const img = document.createElement('img'); img.src = DADOS.entidade.brasao
        img.style.maxHeight = '56px'; img.style.maxWidth = '120px'; img.alt = 'Brasão'
        return img
      }
      return placeholder('Brasão')
    }
    const s = document.createElement('span')
    switch (tipo) {
      case 'NOME_ENTIDADE': DADOS.entidade.nome ? s.textContent = DADOS.entidade.nome : s.appendChild(placeholder('Nome da entidade')); break
      case 'NOME_RELATORIO': s.appendChild(placeholder('Nome do relatório')); break
      case 'DATA_GERACAO': s.textContent = agora.toLocaleDateString('pt-BR'); break
      case 'HORA_GERACAO': s.textContent = agora.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }); break
      case 'NUMERO_PAGINA': s.textContent = 'Página 1 de 1'; break
      case 'ENDERECO_ENTIDADE': DADOS.entidade.endereco ? s.textContent = DADOS.entidade.endereco : s.appendChild(placeholder('Endereço da entidade')); break
      default: s.textContent = tipo
    }
    return s
  }

  function rotuloChip(tipo, ativo) {
    const chip = paleta.querySelector('[data-tipo="' + tipo + '"]')
    if (chip) chip.classList.toggle('ativo', ativo)
  }

  function render() {
    canvas.textContent = ''
    layout.forEach(function(item) {
      const el = document.createElement('div')
      el.className = 'el'
      el.style.left = item.x + '%'
      el.style.top = item.y + '%'
      el.appendChild(conteudo(item.tipo))
      const rm = document.createElement('span')
      rm.className = 'rm'; rm.textContent = '×'; rm.title = 'Remover'
      rm.addEventListener('pointerdown', function(ev) { ev.stopPropagation() })
      rm.addEventListener('click', function(ev) { ev.stopPropagation(); remover(item.tipo) })
      el.appendChild(rm)
      arrastavel(el, item)
      canvas.appendChild(el)
    })
    // Atualiza estado visual da paleta.
    paleta.querySelectorAll('.chip').forEach(function(c) {
      rotuloChip(c.dataset.tipo, layout.some(function(i) { return i.tipo === c.dataset.tipo }))
    })
    inputLayout.value = JSON.stringify(layout)
  }

  function adicionar(tipo) {
    if (layout.some(function(i) { return i.tipo === tipo })) return
    layout.push({ tipo: tipo, x: 4, y: 40 })
    render()
  }

  function remover(tipo) {
    layout = layout.filter(function(i) { return i.tipo !== tipo })
    render()
  }

  function arrastavel(el, item) {
    el.addEventListener('pointerdown', function(ev) {
      ev.preventDefault()
      const rect = canvas.getBoundingClientRect()
      const elRect = el.getBoundingClientRect()
      const offX = ev.clientX - elRect.left
      const offY = ev.clientY - elRect.top
      el.setPointerCapture(ev.pointerId)
      function mover(e) {
        let x = (e.clientX - offX - rect.left) / rect.width * 100
        let y = (e.clientY - offY - rect.top) / rect.height * 100
        item.x = Math.min(100, Math.max(0, Math.round(x * 100) / 100))
        item.y = Math.min(100, Math.max(0, Math.round(y * 100) / 100))
        el.style.left = item.x + '%'
        el.style.top = item.y + '%'
        inputLayout.value = JSON.stringify(layout)
      }
      function soltar(e) {
        el.releasePointerCapture(ev.pointerId)
        el.removeEventListener('pointermove', mover)
        el.removeEventListener('pointerup', soltar)
      }
      el.addEventListener('pointermove', mover)
      el.addEventListener('pointerup', soltar)
    })
  }

  paleta.addEventListener('click', function(ev) {
    const chip = ev.target.closest('.chip')
    if (chip && !chip.classList.contains('ativo')) adicionar(chip.dataset.tipo)
  })

  inputAltura.addEventListener('input', function() {
    const h = parseInt(inputAltura.value, 10)
    if (Number.isFinite(h) && h >= 40 && h <= 400) canvas.style.height = h + 'px'
  })

  // Garante o hidden preenchido mesmo se o usuário salvar sem mexer no canvas.
  document.getElementById('form').addEventListener('submit', function() {
    inputLayout.value = JSON.stringify(layout)
  })

  render()
</script>
</body>
</html>
