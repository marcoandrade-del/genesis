<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Configuração do dashboard · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:760px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Configuração do dashboard</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Configuração do dashboard</h2>
  <p class="text-muted small mb-3">Vale para esta entidade e todos os painéis que exibem os planos (contas, receita, despesa).</p>

  <% if (erro) { %><div class="alert alert-warning py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div><% } %>
  <% if (aviso) { %><div class="alert alert-success py-2 small"><i class="bi bi-check-circle me-1"></i><%= aviso %></div><% } %>

  <div class="card border-0 shadow-sm"><div class="card-body py-3">
    <h6 class="fw-semibold mb-2"><i class="bi bi-diagram-3 me-1 text-primary"></i>Granularidade dos planos nos painéis</h6>
    <form method="post" action="/app/configuracao">
      <div class="form-check mb-2">
        <input class="form-check-input" type="radio" name="granularidadePlano" id="gPadrao" value="PADRAO" <%= granularidade === 'PADRAO' ? 'checked' : '' %> <%= podeEscrever ? '' : 'disabled' %>>
        <label class="form-check-label" for="gPadrao">
          <strong>Plano padrão (modelo)</strong>
          <div class="small text-muted">Os painéis mostram só as contas do plano padrão; os desdobramentos locais ficam colapsados na conta-modelo (os valores continuam somados). <em>Para gerenciar desdobramentos, use o modo abaixo.</em></div>
        </label>
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="radio" name="granularidadePlano" id="gDesdobrado" value="DESDOBRADO" <%= granularidade === 'DESDOBRADO' ? 'checked' : '' %> <%= podeEscrever ? '' : 'disabled' %>>
        <label class="form-check-label" for="gDesdobrado">
          <strong>Com desdobramentos locais</strong>
          <div class="small text-muted">Mostra a árvore completa, incluindo as contas desdobradas localmente no município (padrão).</div>
        </label>
      </div>
      <% if (podeEscrever) { %>
        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
      <% } else { %>
        <div class="small text-muted">Acesso somente leitura — não é possível alterar.</div>
      <% } %>
    </form>
  </div></div>

  <div class="card border-0 shadow-sm mt-3"><div class="card-body py-3">
    <h6 class="fw-semibold mb-1"><i class="bi bi-robot me-1 text-primary"></i>Inteligência Artificial</h6>
    <p class="small text-muted mb-2">Escolha o motor de pesquisa. A preferência fica salva no seu usuário e pode ser trocada a qualquer momento.</p>
    <div class="mb-2">
      <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="iaEngine" id="iaRapida" value="rapida" <%= iaPref.engine === 'rapida' ? 'checked' : '' %> onchange="iaSalvar()">
        <label class="form-check-label" for="iaRapida">Pesquisa rápida <span class="text-muted small">(local, instantânea)</span></label>
      </div>
      <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="iaEngine" id="iaProfunda" value="profunda" <%= iaPref.engine === 'profunda' ? 'checked' : '' %> onchange="iaSalvar()">
        <label class="form-check-label" for="iaProfunda">Pesquisa profunda <span class="text-muted small">(IA)</span></label>
      </div>
    </div>
    <div id="ia-motor-box" style="<%= iaPref.engine === 'profunda' ? '' : 'display:none' %>">
      <label class="form-label small mb-1">Motor da pesquisa profunda</label>
      <select id="iaMotor" class="form-select form-select-sm" style="max-width:340px" onchange="iaSalvar()">
        <% iaMotores.forEach(function(m){ %>
          <option value="<%= m.id %>" <%= iaPref.motor === m.id ? 'selected' : '' %>><%= m.especialista ? '★ ' : '' %><%= m.rotulo %></option>
        <% }) %>
      </select>
      <div class="form-text">★ = especialista fiscal. A chamada à IA liga quando a chave do provedor estiver configurada.</div>
    </div>
    <div id="ia-salvo" class="small text-success mt-2" style="display:none"><i class="bi bi-check-circle me-1"></i>Preferência salva.</div>
  </div></div>
</div>

<script>
function iaSalvar() {
  var engine = document.querySelector('input[name=iaEngine]:checked').value
  var motor = document.getElementById('iaMotor').value
  document.getElementById('ia-motor-box').style.display = engine === 'profunda' ? '' : 'none'
  fetch('/app/configuracao/ia', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: new URLSearchParams({ engine: engine, motor: motor }),
  }).then(function () {
    var s = document.getElementById('ia-salvo'); s.style.display = ''
    setTimeout(function () { s.style.display = 'none' }, 1800)
  })
}
</script>
</body>
</html>
