<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Minhas propostas de memoriais — Gênesis</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6">
    <i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis
  </a>
  <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary">
    <i class="bi bi-box-arrow-right me-1"></i>Sair
  </a>
</nav>

<div class="container py-5" style="max-width:860px">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">Minhas propostas de memoriais</h2>
    <a href="/app/memoriais/bancada" class="btn btn-sm btn-primary">
      <i class="bi bi-sliders me-1"></i>Abrir a bancada
    </a>
  </div>

  <% if (solicitacoes.length === 0) { %>
    <div class="alert alert-secondary small">
      Você ainda não enviou nenhuma proposta.
      <a href="/app/memoriais/bancada">Abrir a bancada de memoriais</a>.
    </div>
  <% } else { %>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="small">Estado</th>
              <th class="small">Memoriais</th>
              <th class="small">Status</th>
              <th class="small">Decisão</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% solicitacoes.forEach(function(s) { %>
              <tr>
                <td>
                  <div class="fw-semibold small"><%= s.estado.sigla %> — <%= s.estado.nome %></div>
                  <% if (s.ano) { %><div class="text-muted" style="font-size:.75rem">testado no exercício <%= s.ano %></div><% } %>
                </td>
                <td class="small">
                  <% if (s.rclComposicao) { %><span class="badge bg-primary bg-opacity-10 text-primary me-1">RCL</span><% } %>
                  <% if (s.pessoalComposicao) { %><span class="badge bg-primary bg-opacity-10 text-primary me-1">Pessoal</span><% } %>
                  <% if (s.fonteClassificacao) { %><span class="badge bg-primary bg-opacity-10 text-primary">Fonte</span><% } %>
                </td>
                <td>
                  <% if (s.status === 'PENDENTE') { %>
                    <span class="badge bg-warning bg-opacity-10 text-warning">Pendente</span>
                  <% } else if (s.status === 'APROVADA') { %>
                    <span class="badge bg-success bg-opacity-10 text-success">Aprovada</span>
                  <% } else if (s.status === 'REJEITADA') { %>
                    <span class="badge bg-danger bg-opacity-10 text-danger">Rejeitada</span>
                  <% } else { %>
                    <span class="badge bg-secondary bg-opacity-10 text-secondary">Cancelada</span>
                  <% } %>
                </td>
                <td class="small">
                  <% if (s.observacaoDecisao) { %>
                    <div class="text-muted" style="font-size:.75rem"><%= s.observacaoDecisao %></div>
                  <% } %>
                </td>
                <td class="text-end">
                  <% if (s.status === 'PENDENTE') { %>
                    <form method="POST" action="/app/memoriais/minhas-solicitacoes/<%= s.id %>/cancelar"
                      onsubmit="return confirm('Cancelar esta proposta?')">
                      <button class="btn btn-sm btn-outline-danger" type="submit">Cancelar</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <div class="mt-4">
    <a href="/app/memoriais/bancada" class="small text-decoration-none">
      <i class="bi bi-arrow-left me-1"></i>Voltar à bancada
    </a>
  </div>
</div>
</body>
</html>
