<!DOCTYPE html>
<html lang="pt-BR">
<%
  var editando = registro && registro.id
  var actionUrl = editando ? ('/app/relatorios/meus/' + registro.id) : '/app/relatorios/meus'
  var reg = registro || {}
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= editando ? 'Editar' : 'Novo' %> relatório · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6" href="/app"><i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis</a>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">
      <%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> ·
      <strong class="text-white"><%= entidade.nome %></strong> · <strong class="text-white font-monospace"><%= ano %></strong>
    </span>
    <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
  </div>
</nav>

<div class="container py-4" style="max-width:860px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/relatorios" class="text-decoration-none">Relatórios</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= editando ? 'Editar' : 'Novo' %> relatório</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-3"><%= editando ? 'Editar' : 'Novo' %> relatório</h2>

  <% if (erro) { %>
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>

  <form method="post" action="<%= actionUrl %>">
    <div class="row g-3 mb-3">
      <div class="col-md-7">
        <label class="form-label small fw-semibold">Nome do relatório</label>
        <input type="text" class="form-control" name="nome" maxlength="120" required value="<%= reg.nome || '' %>" placeholder="Ex.: Lançamentos do exercício">
      </div>
      <div class="col-md-5">
        <label class="form-label small fw-semibold">Descrição <span class="text-muted fw-normal">(opcional)</span></label>
        <input type="text" class="form-control" name="descricao" value="<%= reg.descricao || '' %>">
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-6">
        <label class="form-label small fw-semibold">Cabeçalho</label>
        <select class="form-select" name="cabecalhoId">
          <option value="">— sem cabeçalho —</option>
          <% cabecalhos.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= reg.cabecalhoId === c.id ? 'selected' : '' %>><%= c.nome %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label small fw-semibold">Rodapé</label>
        <select class="form-select" name="rodapeId">
          <option value="">— sem rodapé —</option>
          <% rodapes.forEach(function(r) { %>
            <option value="<%= r.id %>" <%= reg.rodapeId === r.id ? 'selected' : '' %>><%= r.nome %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <% if (views.length) { %>
    <div class="card mb-3">
      <div class="card-body py-3">
        <label class="form-label small fw-semibold mb-1"><i class="bi bi-magic me-1"></i>Montar a query a partir de uma view</label>
        <div class="form-text mt-0 mb-2">Escolha uma view, marque as colunas desejadas e clique em "Usar na query".</div>
        <div class="row g-2">
          <div class="col-md-5">
            <select class="form-select" id="picker-view">
              <option value="">— escolha uma view —</option>
              <% views.forEach(function(v) { %>
                <option value="<%= v.nome %>"><%= v.nome %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-7">
            <div id="picker-colunas" class="d-none border rounded p-2 bg-white" style="max-height:180px;overflow-y:auto"></div>
          </div>
        </div>
        <button type="button" class="btn btn-sm btn-outline-primary mt-2 d-none" id="picker-usar">
          <i class="bi bi-arrow-down-square me-1"></i>Usar na query
        </button>
      </div>
    </div>
    <% } %>

    <label class="form-label small fw-semibold">Query (somente leitura)</label>
    <textarea class="form-control font-monospace" name="query" id="campo-query" rows="8" required placeholder="SELECT data, historico, valor FROM rel_lancamentos ORDER BY data"><%= reg.query || '' %></textarea>
    <div class="form-text">
      Consulte apenas as <strong>views de relatório</strong> (já filtradas pela sua entidade):
      <code>rel_lancamentos</code>, <code>rel_contas_contabeis</code>, <code>rel_orcamento_dotacoes</code>, <code>rel_orcamento_previsoes</code>.
      Placeholders disponíveis: <code>:entidadeId</code>, <code>:ano</code>. Apenas <code>SELECT</code> é permitido.
    </div>

    <div class="d-flex gap-2 mt-3">
      <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
      <a href="/app/relatorios" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>

  <%# Painel de totais no design: as colunas vêm da execução da query salva —
      sem query válida (relatório novo/query quebrada) o painel não aparece. %>
  <% if (totais) { %>
    <%- include('_relatorios-painel-totais', { totais: totais, relatorioId: registro.id, voltar: 'editor' }) %>
  <% } %>
</div>

<% if (views.length) { %>
<script>
  (function () {
    var VIEWS = <%- JSON.stringify(views) %>
    var sel = document.getElementById('picker-view')
    var painel = document.getElementById('picker-colunas')
    var botao = document.getElementById('picker-usar')
    var campo = document.getElementById('campo-query')

    function montarCheckbox(col, i) {
      var div = document.createElement('div')
      div.className = 'form-check'
      var input = document.createElement('input')
      input.className = 'form-check-input'
      input.type = 'checkbox'
      input.checked = true
      input.value = col.nome
      input.id = 'picker-col-' + i
      var label = document.createElement('label')
      label.className = 'form-check-label small font-monospace'
      label.htmlFor = input.id
      label.textContent = col.nome + ' '
      var tipo = document.createElement('span')
      tipo.className = 'text-muted'
      tipo.textContent = '(' + col.tipo + ')'
      label.appendChild(tipo)
      div.appendChild(input)
      div.appendChild(label)
      return div
    }

    sel.addEventListener('change', function () {
      var view = VIEWS.find(function (v) { return v.nome === sel.value })
      painel.replaceChildren()
      painel.classList.toggle('d-none', !view)
      botao.classList.toggle('d-none', !view)
      if (!view) return
      view.colunas.forEach(function (c, i) { painel.appendChild(montarCheckbox(c, i)) })
    })

    botao.addEventListener('click', function () {
      var cols = Array.prototype.slice.call(painel.querySelectorAll('input:checked'))
        .map(function (el) { return el.value })
      if (!cols.length) {
        alert('Marque ao menos uma coluna.')
        return
      }
      if (campo.value.trim() && !confirm('Substituir a query atual pela gerada?')) return
      campo.value = 'SELECT ' + cols.join(', ') + '\nFROM ' + sel.value
      campo.focus()
    })
  })()
</script>
<% } %>
</body>
</html>
