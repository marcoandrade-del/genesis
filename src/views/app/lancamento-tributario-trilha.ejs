<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lançamentos do crédito · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<% var fmt = function(n){ return Number(n).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}) } %>
<% var dbr = function(d){ return d ? new Date(d).toLocaleDateString('pt-BR',{timeZone:'UTC'}) : '—' } %>
<div class="container py-4" style="max-width:880px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento/lancamento-tributario" class="text-decoration-none">Lançamento tributário</a></li>
      <li class="breadcrumb-item active" aria-current="page">Trilha contábil</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="h4 fw-bold mb-0">Trilha contábil do lançamento</h2>
    <a href="/app/orcamento/lancamento-tributario" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Voltar</a>
  </div>

  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-3">
    <div class="d-flex align-items-center gap-2 mb-2">
      <span class="badge bg-primary bg-opacity-10 text-primary">Lançamento tributário</span>
      <span class="text-muted small"><%= dbr(lancamento.data) %></span>
      <span class="ms-auto font-monospace fw-bold fs-5">R$ <%= fmt(lancamento.valor) %></span>
    </div>
    <div class="row small g-2">
      <div class="col-md-7"><div class="text-muted">Natureza</div><div class="font-monospace"><%= lancamento.previsao.contaReceita.codigo %> · <%= lancamento.previsao.contaReceita.descricao %></div></div>
      <div class="col-md-5"><div class="text-muted">Fonte</div><div class="font-monospace"><%= lancamento.previsao.fonteRecurso.codigo %> · <%= lancamento.previsao.fonteRecurso.nomenclatura %></div></div>
      <% if (lancamento.devedorNome) { %><div class="col-md-7"><div class="text-muted">Devedor</div><div><%= lancamento.devedorNome %><% if (lancamento.devedorDocumento) { %> (<%= lancamento.devedorDocumento %>)<% } %></div></div><% } %>
      <% if (lancamento.vencimento) { %><div class="col-md-5"><div class="text-muted">Vencimento</div><div><%= dbr(lancamento.vencimento) %></div></div><% } %>
    </div>
  </div></div>

  <% eventos.forEach(function(ev){ %>
    <div class="card border-0 shadow-sm mb-2"><div class="card-body py-2">
      <div class="d-flex align-items-center gap-2 mb-1"><span class="badge bg-dark bg-opacity-10 text-dark font-monospace">E<%= ev.eventoCodigo %></span><span class="small text-muted"><%= ev.historico %></span></div>
      <table class="table table-sm align-middle mb-0"><tbody>
        <% ev.itens.forEach(function(it){ %>
          <tr>
            <td style="width:34px" class="text-center"><% if (it.tipo==='DEBITO'){ %><span class="badge bg-primary bg-opacity-10 text-primary">D</span><% } else { %><span class="badge bg-success bg-opacity-10 text-success">C</span><% } %></td>
            <td class="small"><span class="font-monospace"><%= it.conta ? it.conta.codigo : '—' %></span> <span class="text-muted"><%= it.conta ? it.conta.descricao : '' %></span><% if (it.naturezaReceitaCodigo) { %><span class="badge bg-light text-muted ms-1">nat <%= it.naturezaReceitaCodigo %></span><% } %></td>
            <td class="text-end font-monospace small" style="white-space:nowrap"><%= fmt(it.valor) %></td>
          </tr>
        <% }) %>
      </tbody></table>
    </div></div>
  <% }) %>
</div>
</body>
</html>
