<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plano de Contas · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6" href="/app"><i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis</a>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">
      <%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> ·
      <strong class="text-white"><%= entidade.nome %></strong> ·
      <strong class="text-white font-monospace"><%= ano %></strong>
    </span>
    <a href="/app/contexto" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="bi bi-arrow-left-right me-1"></i>Trocar contexto</a>
    <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
  </div>
</nav>

<div class="container py-4" style="max-width:1000px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Plano de Contas</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 fw-bold mb-0">Plano de Contas (contábil) — <span class="font-monospace"><%= ano %></span></h2>
    <span class="badge bg-light text-dark"><%= contas.length %> conta(s)</span>
  </div>

  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3">Código / Descrição</th><th style="width:120px">Tipo</th><th style="width:130px">Origem</th></tr></thead>
      <tbody>
        <% if (contas.length === 0) { %>
          <tr><td colspan="3" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Plano de contas não copiado para o exercício <%= ano %>.</td></tr>
        <% } %>
        <% contas.forEach(function(c) { %>
          <tr>
            <td class="ps-3">
              <span style="padding-left: <%= (c.nivel - 1) * 18 %>px" class="d-inline-block">
                <span class="font-monospace small text-muted"><%= c.codigo %></span>
                <span class="<%= c.admiteMovimento ? '' : 'fw-semibold' %>"><%= c.descricao %></span>
              </span>
            </td>
            <td>
              <% if (c.admiteMovimento) { %><span class="badge bg-primary bg-opacity-10 text-primary">Analítica</span>
              <% } else { %><span class="badge bg-secondary bg-opacity-10 text-secondary">Sintética</span><% } %>
            </td>
            <td>
              <% if (c.origem === 'DESDOBRAMENTO') { %><span class="badge bg-info bg-opacity-10 text-info-emphasis">Desdobramento</span>
              <% } else { %><span class="badge bg-light text-muted">Modelo</span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>
</div>
</body>
</html>
