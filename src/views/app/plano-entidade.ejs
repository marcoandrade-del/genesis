<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
  <style>
    table.ocultar-detalhe .col-detalhe { display: none; }
    .valor { font-variant-numeric: tabular-nums; white-space: nowrap; text-align: right; }
    .valor.neg { color: var(--bs-danger); }
  </style>
</head>
<body class="bg-light">

<%- include('_navbar') %>

<% const brl = (n) => (Number(n) || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %>
<% const nat = { DEVEDORA: 'Devedora', CREDORA: 'Credora', MISTA: 'Mista' } %>
<% /* saldo vem com sinal (+ devedor, − credor): exibe módulo + lado D/C */ %>
<% const sal = (n) => { const v = Number(n) || 0; return v === 0 ? brl(0) : brl(Math.abs(v)) + (v < 0 ? ' C' : ' D') } %>

<div class="container py-4" style="max-width:<%= (comSaldos || saldoColunas) ? 1280 : 1000 %>px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= titulo %></li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="h4 fw-bold mb-0"><%= titulo %> — <span class="font-monospace"><%= ano %></span></h2>
    <div class="d-flex align-items-center gap-2">
      <% if (comSaldos || saldoColunas) { %>
        <%- include('_seletor-posicao', { base, dataRef, ano }) %>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('tbl').classList.toggle('ocultar-detalhe')" title="Mostrar/ocultar detalhes">
          <i class="bi bi-arrows-collapse"></i>
        </button>
      <% } %>
      <%- include('_seletor-granularidade') %>
      <div class="btn-group btn-group-sm" role="group" aria-label="Nível de detalhe das contas">
        <button type="button" id="nivel-menos" class="btn btn-outline-secondary" title="Recolher um nível">
          <i class="bi bi-dash-lg"></i>
        </button>
        <span class="btn btn-outline-secondary disabled" style="pointer-events:none">Nível <span id="nivel-atual">–</span></span>
        <button type="button" id="nivel-mais" class="btn btn-outline-secondary" title="Expandir um nível">
          <i class="bi bi-plus-lg"></i>
        </button>
      </div>
      <span class="badge bg-light text-dark"><%= contas.length %> conta(s)</span>
    </div>
  </div>

  <% if (erro) { %>
    <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>

  <% if (!podeEscrever) { %>
    <div class="alert alert-secondary py-2 small"><i class="bi bi-eye me-1"></i>Acesso somente leitura nesta entidade — desdobramento desabilitado.</div>
  <% } %>

  <% /* Form de desdobramento — aparece ao clicar "Desdobrar" numa conta analítica */ %>
  <% if (desdobrar && podeEscrever) { %>
    <% const pai = contas.find(function(c){ return c.id === desdobrar.id }) %>
    <div class="card border-primary shadow-sm mb-3">
      <div class="card-header bg-primary bg-opacity-10 py-2 small fw-semibold">
        Desdobrar conta
        <% if (pai) { %><span class="font-monospace text-muted">· <%= pai.codigo %></span> <%= pai.descricao %><% } %>
      </div>
      <div class="card-body">
        <p class="small text-muted mb-3">A nova conta filha nasce <strong>analítica</strong> (origem: desdobramento). Você pode desdobrar a mesma conta em <strong>vários filhos</strong> — repita a ação.</p>
        <form method="post" action="<%= base %>/<%= desdobrar.id %>/desdobrar" class="row g-2 align-items-end">
          <div class="col-sm-4">
            <label class="form-label small mb-1">Código</label>
            <input name="codigo" class="form-control form-control-sm font-monospace" maxlength="50" required
              value="<%= desdobrar.codigo || sugestao %>">
          </div>
          <div class="col-sm-6">
            <label class="form-label small mb-1">Descrição</label>
            <input name="descricao" class="form-control form-control-sm" maxlength="200" required
              value="<%= desdobrar.descricao || '' %>">
          </div>
          <div class="col-sm-2 d-flex gap-1">
            <button type="submit" class="btn btn-primary btn-sm flex-grow-1">Salvar</button>
            <a href="<%= base %>" class="btn btn-outline-secondary btn-sm">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  <% } %>

  <% /* Form de edição de descrição — só para desdobramentos (contas não-padrão) */ %>
  <% if (editar && podeEscrever) { %>
    <% const alvoEd = contas.find(function(c){ return c.id === editar.id }) %>
    <div class="card border-warning shadow-sm mb-3">
      <div class="card-header bg-warning bg-opacity-10 py-2 small fw-semibold">
        Editar descrição <% if (alvoEd) { %><span class="font-monospace text-muted">· <%= alvoEd.codigo %></span><% } %>
      </div>
      <div class="card-body">
        <form method="post" action="<%= base %>/<%= editar.id %>/editar" class="row g-2 align-items-end">
          <div class="col-sm-10">
            <label class="form-label small mb-1">Descrição</label>
            <input name="descricao" class="form-control form-control-sm" maxlength="200" required value="<%= editar.descricao %>">
          </div>
          <div class="col-sm-2 d-flex gap-1">
            <button type="submit" class="btn btn-warning btn-sm flex-grow-1">Salvar</button>
            <a href="<%= base %>" class="btn btn-outline-secondary btn-sm">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <table id="tbl" class="table table-hover table-sm align-middle mb-0">
      <thead class="table-light"><tr>
        <th class="ps-3">Código / Descrição</th>
        <% if (comSaldos) { %>
          <th class="col-detalhe">Natureza</th>
          <th class="valor">Saldo inicial</th>
          <th class="valor">Total débito</th>
          <th class="valor">Total crédito</th>
          <th class="valor">Saldo atual</th>
        <% } %>
        <% if (saldoColunas) { saldoColunas.forEach(function(col){ %><th class="valor"><%= col.rotulo %></th><% }) } %>
        <th class="col-detalhe" style="width:110px">Tipo</th>
        <% if (podeEscrever) { %><th class="col-detalhe text-end pe-3" style="width:180px">Ações</th><% } %>
      </tr></thead>
      <tbody>
        <% if (contas.length === 0) { %>
          <tr><td colspan="12" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Plano não copiado para o exercício <%= ano %>.</td></tr>
        <% } %>
        <% contas.forEach(function(c) { %>
          <tr data-nivel="<%= c.nivel %>">
            <td class="ps-3">
              <span style="padding-left: <%= (c.nivel - 1) * 18 %>px" class="d-inline-block">
                <span class="font-monospace small text-muted"><%= c.codigo %></span>
                <span class="<%= c.admiteMovimento ? '' : 'fw-semibold' %>"><%= c.descricao %></span>
                <% if (c.redutora) { %><span class="badge bg-warning bg-opacity-10 text-warning-emphasis ms-1" title="Conta redutora/retificadora (PCASP) — subtrai do saldo do grupo">redutora</span><% } %>
                <% if (comSaldos && c.admiteMovimento) { %>
                  <a href="<%= base %>/<%= c.id %>/razao" class="ms-1 text-decoration-none small" title="Ver razão (movimentações)"><i class="bi bi-journal-text"></i></a>
                <% } %>
              </span>
            </td>
            <% if (comSaldos) { %>
              <td class="col-detalhe small text-muted" title="<%= c.saldo ? [c.saldo.superavit ? 'Superávit: ' + c.saldo.superavit : '', c.saldo.funcao || ''].filter(Boolean).join(' — ') : '' %>">
                <%= c.saldo && c.saldo.natureza ? nat[c.saldo.natureza] : '—' %>
                <% if (c.saldo && c.saldo.naturezaInformacao) { %><span class="badge bg-light text-muted" style="font-size:.65rem"><%= ({PATRIMONIAL:'Patrim.',ORCAMENTARIA:'Orçam.',CONTROLE:'Controle'})[c.saldo.naturezaInformacao] || c.saldo.naturezaInformacao %></span><% } %>
              </td>
              <td class="valor small"><%= c.saldo ? sal(c.saldo.inicial) : '—' %></td>
              <td class="valor small"><%= brl(c.saldo && c.saldo.debito) %></td>
              <td class="valor small"><%= brl(c.saldo && c.saldo.credito) %></td>
              <td class="valor small fw-semibold <%= c.saldo && c.saldo.atual < 0 ? 'text-secondary' : '' %>"><%= c.saldo ? sal(c.saldo.atual) : '—' %></td>
            <% } %>
            <% if (saldoColunas) { saldoColunas.forEach(function(col){ %><td class="valor small <%= col.chave === 'saldo' ? 'fw-semibold' : '' %>"><%= c.saldoGen ? brl(c.saldoGen[col.chave]) : '—' %></td><% }) } %>
            <td class="col-detalhe">
              <% if (c.admiteMovimento) { %><span class="badge bg-primary bg-opacity-10 text-primary">Analítica</span>
              <% } else { %><span class="badge bg-secondary bg-opacity-10 text-secondary">Sintética</span><% } %>
            </td>
            <% if (podeEscrever) { %>
              <td class="col-detalhe text-end pe-3">
                <% const temValor = comSaldos && c.admiteMovimento && c.saldo && (c.saldo.debito || c.saldo.credito || c.saldo.inicial) %>
                <% if (c.podeDesdobrar && !temValor) { %>
                  <a href="<%= base %>?desdobrar=<%= c.id %>" class="btn btn-outline-primary btn-sm py-0 px-2" title="Desdobrar (adicionar conta filha)"><i class="bi bi-diagram-2"></i></a>
                <% } %>
                <% if (temValor) { %>
                  <a href="<%= base %>/<%= c.id %>/distribuir" class="btn btn-outline-info btn-sm py-0 px-2" title="Desdobrar redistribuindo os valores (desde 1º/jan)"><i class="bi bi-diagram-3"></i></a>
                <% } %>
                <% if (c.podeEditar) { %>
                  <a href="<%= base %>?editar=<%= c.id %>" class="btn btn-outline-warning btn-sm py-0 px-2" title="Editar descrição"><i class="bi bi-pencil"></i></a>
                <% } %>
                <% if (c.origem === 'DESDOBRAMENTO' && !c.temFilhos) { %>
                  <form method="post" action="<%= base %>/<%= c.id %>/excluir" class="d-inline" onsubmit="return confirm('Excluir este desdobramento?')">
                    <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-2" title="Excluir desdobramento"><i class="bi bi-trash"></i></button>
                  </form>
                <% } %>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>

  <% if (!comSaldos) { %>
    <p class="small text-muted mt-2">Contas do modelo padrão não podem ser excluídas — só desdobradas. Desdobramentos que você criou podem ser removidos enquanto não tiverem filhos nem movimento.</p>
  <% } %>
</div>

<script>
// Colapsar/expandir a árvore por nível: mostra as contas até a profundidade
// escolhida (− recolhe um nível, + expande um nível). Puramente visual.
(function () {
  var rows = Array.prototype.slice.call(document.querySelectorAll('#tbl tbody tr[data-nivel]'))
  var menos = document.getElementById('nivel-menos')
  var mais = document.getElementById('nivel-mais')
  var label = document.getElementById('nivel-atual')
  if (!rows.length || !menos || !mais || !label) return
  var maxN = rows.reduce(function (m, r) { return Math.max(m, +r.getAttribute('data-nivel')) }, 1)
  var cur = maxN
  function aplicar() {
    rows.forEach(function (r) { r.style.display = +r.getAttribute('data-nivel') > cur ? 'none' : '' })
    label.textContent = cur
    menos.disabled = cur <= 1
    mais.disabled = cur >= maxN
  }
  menos.addEventListener('click', function () { if (cur > 1) { cur--; aplicar() } })
  mais.addEventListener('click', function () { if (cur < maxN) { cur++; aplicar() } })
  aplicar()
})()
</script>
</body>
</html>
