<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Conciliação bancária · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<% var fmt = function(n){ return Number(n).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}) } %>
<% var dbr = function(d){ return new Date(d).toLocaleDateString('pt-BR',{timeZone:'UTC'}) } %>
<div class="container py-4" style="max-width:1180px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">Conciliação bancária</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Conciliação bancária <span class="font-monospace fs-6 text-muted"><%= ano %></span></h2>
  <p class="text-muted small mb-3">Casa os créditos do extrato de uma conta com as arrecadações já registradas nela. A conciliação audita — não cria arrecadação.</p>

  <% if (erro) { %><div class="alert alert-warning py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div><% } %>

  <%# Seletor de conta bancária %>
  <form method="get" action="/app/orcamento/conciliacao" class="card border-0 shadow-sm mb-3"><div class="card-body py-2 d-flex align-items-center gap-2">
    <label class="form-label small fw-semibold mb-0">Conta bancária</label>
    <select name="conta" class="form-select form-select-sm" style="max-width:520px" onchange="this.form.submit()">
      <option value="">— selecione —</option>
      <% contas.forEach(function(c){ %>
        <option value="<%= c.id %>" <%= contaId === c.id ? 'selected' : '' %>><%= c.rotulo %> · FR <%= c.fonteCodigo %></option>
      <% }) %>
    </select>
    <% if (contas.length === 0) { %><span class="small text-muted">Nenhuma conta bancária ativa — cadastre em “Contas bancárias”.</span><% } %>
  </div></form>

  <% if (painel) { %>
    <% var t = painel.totais %>
    <%# Totais %>
    <div class="row g-2 mb-3">
      <div class="col"><div class="card border-0 shadow-sm"><div class="card-body py-2"><div class="small text-muted">Extrato (créditos)</div><div class="fw-bold font-monospace">R$ <%= fmt(t.extrato) %></div></div></div></div>
      <div class="col"><div class="card border-0 shadow-sm"><div class="card-body py-2"><div class="small text-muted">Arrecadado (conta)</div><div class="fw-bold font-monospace">R$ <%= fmt(t.arrecadado) %></div></div></div></div>
      <div class="col"><div class="card border-0 shadow-sm"><div class="card-body py-2"><div class="small text-muted">Conciliado</div><div class="fw-bold font-monospace text-success">R$ <%= fmt(t.conciliado) %></div></div></div></div>
      <div class="col"><div class="card border-0 shadow-sm"><div class="card-body py-2"><div class="small text-muted">Diferença (extrato − arrec.)</div><div class="fw-bold font-monospace <%= t.diferenca !== 0 ? 'text-danger' : '' %>">R$ <%= fmt(t.diferenca) %></div></div></div></div>
    </div>

    <% if (podeEscrever) { %>
    <div class="row g-2 mb-3">
      <%# Importar extrato %>
      <div class="col-lg-6"><div class="card border-0 shadow-sm h-100"><div class="card-body py-3">
        <h6 class="fw-semibold mb-2"><i class="bi bi-upload me-1 text-primary"></i>Importar extrato</h6>
        <form method="post" action="/app/orcamento/conciliacao/importar">
          <input type="hidden" name="contaBancariaId" value="<%= contaId %>">
          <div class="d-flex gap-2 mb-2">
            <select name="formato" class="form-select form-select-sm" style="max-width:120px">
              <option value="OFX">OFX</option>
              <option value="CSV">CSV</option>
            </select>
            <button type="submit" class="btn btn-sm btn-primary">Importar</button>
          </div>
          <textarea name="conteudo" class="form-control form-control-sm font-monospace" rows="3" placeholder="Cole aqui o conteúdo do extrato (OFX ou CSV: data;valor;histórico)"></textarea>
        </form>
      </div></div></div>
      <%# Manual + auto %>
      <div class="col-lg-6"><div class="card border-0 shadow-sm h-100"><div class="card-body py-3">
        <h6 class="fw-semibold mb-2"><i class="bi bi-plus-circle me-1 text-primary"></i>Lançar crédito manual</h6>
        <form method="post" action="/app/orcamento/conciliacao/manual" class="row g-1 align-items-end">
          <input type="hidden" name="contaBancariaId" value="<%= contaId %>">
          <input type="hidden" name="sentido" value="CREDITO">
          <div class="col-4"><label class="form-label small mb-0">Data</label><input type="date" name="data" class="form-control form-control-sm" required></div>
          <div class="col-3"><label class="form-label small mb-0">Valor</label><input type="number" name="valor" step="0.01" min="0.01" class="form-control form-control-sm" required></div>
          <div class="col-3"><label class="form-label small mb-0">Histórico</label><input type="text" name="historico" class="form-control form-control-sm"></div>
          <div class="col-2"><button type="submit" class="btn btn-sm btn-outline-primary w-100">+</button></div>
        </form>
        <form method="post" action="/app/orcamento/conciliacao/sugerir" class="mt-2">
          <input type="hidden" name="contaBancariaId" value="<%= contaId %>">
          <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-magic me-1"></i>Auto-conciliar (valor + data)</button>
        </form>
      </div></div></div>
    </div>
    <% } %>

    <%# Extrato pendente %>
    <div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white border-bottom py-2 small fw-semibold"><i class="bi bi-bank2 me-1"></i>Extrato pendente (<%= painel.extratoPendente.length %>)</div>
    <div class="card-body p-0"><table class="table table-sm table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3">Data</th><th>Histórico</th><th class="text-end">Valor R$</th><% if (podeEscrever) { %><th style="min-width:320px">Conciliar com arrecadação</th><th></th><% } %></tr></thead>
      <tbody>
        <% if (painel.extratoPendente.length === 0) { %><tr><td colspan="5" class="text-center text-muted py-3">Sem créditos pendentes.</td></tr><% } %>
        <% painel.extratoPendente.forEach(function(m){ %>
          <tr>
            <td class="ps-3 small text-muted"><%= dbr(m.data) %></td>
            <td class="small"><%= m.historico || '—' %> <span class="badge bg-light text-muted"><%= m.origemImport %></span></td>
            <td class="text-end font-monospace"><%= fmt(m.valor) %></td>
            <% if (podeEscrever) { %>
            <td>
              <form method="post" action="/app/orcamento/conciliacao/conciliar" class="d-flex gap-1">
                <input type="hidden" name="contaBancariaId" value="<%= contaId %>">
                <input type="hidden" name="movimentoId" value="<%= m.id %>">
                <select name="arrecadacaoId" class="form-select form-select-sm" required>
                  <option value="">— arrecadação —</option>
                  <% painel.arrecadacoesPendentes.forEach(function(a){ %>
                    <option value="<%= a.id %>"><%= dbr(a.data) %> · R$ <%= fmt(a.valor) %> · <%= a.previsao.contaReceita.codigo %></option>
                  <% }) %>
                </select>
                <button type="submit" class="btn btn-sm btn-outline-success" title="Conciliar"><i class="bi bi-link"></i></button>
              </form>
            </td>
            <td class="text-end pe-3">
              <form method="post" action="/app/orcamento/conciliacao/excluir" class="d-inline" onsubmit="return confirm('Excluir este movimento do extrato?')">
                <input type="hidden" name="contaBancariaId" value="<%= contaId %>"><input type="hidden" name="movimentoId" value="<%= m.id %>">
                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Excluir"><i class="bi bi-trash"></i></button>
              </form>
            </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table></div></div>

    <div class="row g-3">
      <%# Conciliados %>
      <div class="col-lg-7"><div class="card border-0 shadow-sm"><div class="card-header bg-white border-bottom py-2 small fw-semibold"><i class="bi bi-check2-circle me-1 text-success"></i>Conciliados (<%= painel.conciliados.length %>)</div>
      <div class="card-body p-0"><table class="table table-sm align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Extrato</th><th>Arrecadação</th><th class="text-end pe-3">R$</th></tr></thead>
        <tbody>
          <% if (painel.conciliados.length === 0) { %><tr><td colspan="3" class="text-center text-muted py-3">Nada conciliado ainda.</td></tr><% } %>
          <% painel.conciliados.forEach(function(m){ %>
            <tr>
              <td class="ps-3 small text-muted"><%= dbr(m.data) %><div><%= m.historico || '' %></div></td>
              <td class="small"><span class="font-monospace"><%= m.arrecadacao.previsao.contaReceita.codigo %></span> <span class="text-muted"><%= m.arrecadacao.previsao.contaReceita.descricao %></span><div class="text-muted"><%= dbr(m.arrecadacao.data) %> · FR <%= m.arrecadacao.previsao.fonteRecurso.codigo %></div></td>
              <td class="text-end pe-3 font-monospace">
                <%= fmt(m.valor) %>
                <% if (podeEscrever) { %>
                  <form method="post" action="/app/orcamento/conciliacao/desconciliar" class="d-inline" onsubmit="return confirm('Desfazer a conciliação?')">
                    <input type="hidden" name="contaBancariaId" value="<%= contaId %>"><input type="hidden" name="movimentoId" value="<%= m.id %>">
                    <button type="submit" class="btn btn-sm btn-link text-danger p-0 ms-1" title="Desconciliar"><i class="bi bi-x-circle"></i></button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table></div></div></div>

      <%# Arrecadações pendentes (sem extrato) %>
      <div class="col-lg-5"><div class="card border-0 shadow-sm"><div class="card-header bg-white border-bottom py-2 small fw-semibold"><i class="bi bi-cash-stack me-1 text-warning"></i>Arrecadações sem extrato (<%= painel.arrecadacoesPendentes.length %>)</div>
      <div class="card-body p-0"><table class="table table-sm align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Data</th><th>Natureza</th><th class="text-end pe-3">R$</th></tr></thead>
        <tbody>
          <% if (painel.arrecadacoesPendentes.length === 0) { %><tr><td colspan="3" class="text-center text-muted py-3">Todas casadas.</td></tr><% } %>
          <% painel.arrecadacoesPendentes.forEach(function(a){ %>
            <tr><td class="ps-3 small text-muted"><%= dbr(a.data) %></td><td class="small font-monospace"><%= a.previsao.contaReceita.codigo %></td><td class="text-end pe-3 font-monospace"><%= fmt(a.valor) %></td></tr>
          <% }) %>
        </tbody>
      </table></div></div></div>
    </div>
  <% } %>
</div>
</body>
</html>
