<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Catálogo de Itens · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<%
  var qEnc = encodeURIComponent(busca || '');
  var inicio = total === 0 ? 0 : (pagina - 1) * porPagina + 1;
  var fim = Math.min(pagina * porPagina, total);
%>
<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/compras" class="text-decoration-none">Compras</a></li>
      <li class="breadcrumb-item active" aria-current="page">Catálogo</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Catálogo de Itens</h2>
  <p class="text-muted small mb-3">Cadastro central (CATMAT/CATSER), compartilhado por todas as entidades.</p>

  <form method="GET" action="/app/compras/catalogo" class="mb-3">
    <div class="input-group">
      <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
      <input type="text" name="q" class="form-control" placeholder="Buscar por código ou descrição…" value="<%= busca %>" autofocus>
      <button class="btn btn-primary" type="submit">Buscar</button>
      <% if (busca) { %><a class="btn btn-outline-secondary" href="/app/compras/catalogo">Limpar</a><% } %>
    </div>
  </form>

  <div class="d-flex justify-content-between align-items-center mb-2 small text-muted">
    <div>
      <% if (busca) { %>Resultados para "<strong><%= busca %></strong>": <% } %>
      <strong><%= total.toLocaleString('pt-BR') %></strong> item(ns)
      <% if (total > 0) { %><span class="text-muted">· exibindo <%= inicio %>–<%= fim %></span><% } %>
    </div>
    <div>Página <%= pagina %> de <%= totalPaginas %></div>
  </div>

  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3">Tipo</th><th>Código</th><th>Descrição</th><th>Unidade</th></tr></thead>
      <tbody>
        <% if (itens.length === 0) { %>
          <tr><td colspan="4" class="text-center text-muted py-4"><%= busca ? 'Nenhum item encontrado para a busca.' : 'Catálogo vazio.' %></td></tr>
        <% } %>
        <% itens.forEach(function(i) { %>
          <tr>
            <td class="ps-3">
              <% if (i.tipo === 'MATERIAL') { %><span class="badge bg-primary bg-opacity-10 text-primary">Material</span>
              <% } else { %><span class="badge bg-info bg-opacity-10 text-info">Serviço</span><% } %>
            </td>
            <td class="font-monospace small"><%= i.codigo %></td>
            <td class="small"><%= i.descricao %></td>
            <td class="small text-muted"><%= i.unidadeMedida %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>

  <% if (totalPaginas > 1) { %>
    <nav class="mt-3 d-flex justify-content-center" aria-label="Paginação do catálogo">
      <ul class="pagination pagination-sm mb-0">
        <li class="page-item <%= pagina <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="/app/compras/catalogo?q=<%= qEnc %>&pagina=<%= pagina - 1 %>"><i class="bi bi-chevron-left"></i> Anterior</a>
        </li>
        <li class="page-item disabled"><span class="page-link"><%= pagina %> / <%= totalPaginas %></span></li>
        <li class="page-item <%= pagina >= totalPaginas ? 'disabled' : '' %>">
          <a class="page-link" href="/app/compras/catalogo?q=<%= qEnc %>&pagina=<%= pagina + 1 %>">Próxima <i class="bi bi-chevron-right"></i></a>
        </li>
      </ul>
    </nav>
  <% } %>
</div>
</body>
</html>
