<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Arrecadação — acumulado diário · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<%
  var brl = function(v) { return (Number(v) || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) }
  var prevT = Number(previstoTotal) || 0
  var pct = function(v) { return prevT > 0 ? (Number(v) / prevT * 100) : 0 }
  var pctTotal = pct(arrecadadoTotal)
%>

<div class="container py-4" style="max-width:1000px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento/arrecadacao" class="text-decoration-none">Arrecadação</a></li>
      <li class="breadcrumb-item active" aria-current="page">Acumulado diário</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="h4 fw-bold mb-0">Arrecadação — acumulado diário <span class="font-monospace fs-6 text-muted"><%= ano %></span></h2>
    <a href="/app/orcamento/arrecadacao" class="btn btn-sm btn-outline-secondary"><i class="bi bi-cash-stack me-1"></i>Voltar à arrecadação</a>
  </div>

  <% if (!temOrcamento) { %>
    <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-1"></i>Não há orçamento (LOA) cadastrado para este exercício.</div>
  <% } else { %>

    <div class="row g-3 mb-3">
      <div class="col-md-4"><div class="card border-0 shadow-sm h-100"><div class="card-body py-3">
        <div class="small text-muted">Previsto</div><div class="h5 fw-bold font-monospace mb-0"><%= brl(previstoTotal) %></div>
      </div></div></div>
      <div class="col-md-4"><div class="card border-0 shadow-sm h-100"><div class="card-body py-3">
        <div class="small text-muted">Arrecadado<%= prevT > 0 ? ' (' + Math.round(pctTotal) + '%)' : '' %></div>
        <div class="h5 fw-bold font-monospace mb-0"><%= brl(arrecadadoTotal) %></div>
      </div></div></div>
      <div class="col-md-4"><div class="card border-0 shadow-sm h-100" style="background:var(--canvas-soft)"><div class="card-body py-3">
        <div class="small text-muted">A arrecadar</div>
        <div class="h5 fw-bold font-monospace mb-0 <%= (prevT - Number(arrecadadoTotal)) < 0 ? 'text-danger' : '' %>"><%= brl(prevT - Number(arrecadadoTotal)) %></div>
      </div></div></div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom py-2"><span class="fw-semibold small"><i class="bi bi-graph-up-arrow me-2"></i>Evolução do arrecadado por dia (acumulado vs previsto)</span></div>
      <div class="card-body p-0">
        <table class="table table-hover table-sm align-middle mb-0">
          <thead class="table-light">
            <tr><th class="ps-3" style="width:110px">Data</th><th class="text-end">Arrecadado no dia</th><th class="text-end">Acumulado</th><th class="text-end pe-3" style="width:90px">% prev.</th><th style="width:34%"></th></tr>
          </thead>
          <tbody>
            <% if (dias.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox fs-5 d-block mb-1"></i>Nenhuma arrecadação registrada no exercício.</td></tr>
            <% } %>
            <% dias.forEach(function (d) { var w = Math.min(100, Math.round(pct(d.acumulado))); %>
              <tr>
                <td class="ps-3 small text-muted"><%= d.data %></td>
                <td class="text-end font-monospace small <%= d.dia < 0 ? 'text-danger' : '' %>"><%= d.dia < 0 ? '−' : '' %><%= brl(Math.abs(d.dia)) %></td>
                <td class="text-end font-monospace small fw-semibold pe-0"><%= brl(d.acumulado) %></td>
                <td class="text-end font-monospace small pe-3 text-muted"><%= prevT > 0 ? Math.round(pct(d.acumulado)) + '%' : '—' %></td>
                <td>
                  <div style="background:var(--canvas-soft, #e8ebe6); border-radius:6px; height:10px; overflow:hidden">
                    <div style="height:10px; width:<%= w %>%; background:var(--primary, #9fe870)"></div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <p class="small text-muted mt-2">Líquido por dia (arrecadação − estorno), acumulado no exercício, a partir das arrecadações registradas. A barra é o acumulado sobre o previsto total.</p>
  <% } %>
</div>
</body>
</html>
