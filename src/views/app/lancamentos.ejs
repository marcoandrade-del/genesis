<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lançamentos · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6" href="/app"><i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis</a>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">
      <%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> ·
      <strong class="text-white"><%= entidade.nome %></strong> ·
      <strong class="text-white font-monospace"><%= ano %></strong>
    </span>
    <a href="/app/contexto" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="bi bi-arrow-left-right me-1"></i>Trocar contexto</a>
    <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
  </div>
</nav>

<div class="container py-4" style="max-width:1000px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Lançamentos</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 fw-bold mb-0">Lançamentos — <span class="font-monospace"><%= ano %></span></h2>
    <div class="text-end">
      <div class="small text-muted">Total do exercício</div>
      <div class="h5 fw-semibold mb-0 font-monospace">R$ <%= total.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
    </div>
  </div>

  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3" style="width:120px">Data</th><th>Histórico</th><th class="text-end pe-3" style="width:160px">Valor R$</th></tr></thead>
      <tbody>
        <% if (lancamentos.length === 0) { %>
          <tr><td colspan="3" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum lançamento no exercício <%= ano %>.</td></tr>
        <% } %>
        <% lancamentos.forEach(function(l) { %>
          <tr>
            <td class="ps-3 font-monospace small"><%= new Date(l.data).toLocaleDateString('pt-BR') %></td>
            <td><%= l.historico %></td>
            <td class="text-end pe-3 font-monospace"><%= Number(l.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>
  <% if (lancamentos.length >= 500) { %>
    <div class="small text-muted mt-2"><i class="bi bi-info-circle me-1"></i>Mostrando os 500 lançamentos mais recentes do exercício.</div>
  <% } %>
</div>
</body>
</html>
