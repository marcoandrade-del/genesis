<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Execução da Despesa · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1280px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">Execução da Despesa</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-1 flex-wrap gap-2">
    <h2 class="h4 fw-bold mb-0">Execução da Despesa <span class="font-monospace fs-6 text-muted"><%= ano %></span></h2>
    <div class="d-flex align-items-center gap-2">
      <%- include('_seletor-posicao', { base: '/app/orcamento/despesa/execucao', dataRef, ano }) %>
      <a href="/app/orcamento/saldo" class="btn btn-sm btn-outline-secondary"><i class="bi bi-wallet2 me-1"></i>Saldo (autorização)</a>
      <a href="/app/orcamento/despesa/diario" class="btn btn-sm btn-outline-secondary"><i class="bi bi-graph-up-arrow me-1"></i>Acumulado diário</a>
      <span class="badge bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-eye me-1"></i>Somente leitura</span>
    </div>
  </div>
  <p class="text-muted small mb-4">
    Codificação orçamentária completa (funcional-programática + natureza), por fonte e por função.
    A empenhar = Autorizado − Empenhado · A liquidar = Empenhado − Liquidado · A pagar = Liquidado − Pago.
    <% if (posicaoData) { %><span class="badge bg-info bg-opacity-10 text-info ms-1">posição em <%= dataRef.split('-').reverse().join('/') %></span> <span class="text-muted">(execução até a data)</span><% } %>
  </p>

  <% if (!execucao.temOrcamento) { %>
    <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-1"></i>Não há orçamento (LOA) cadastrado para este exercício.</div>
  <% } else { %>
    <%# Resumo geral: os 4 estágios %>
    <div class="row g-3 mb-4">
      <% [['Autorizado','autorizado'],['Empenhado','empenhado'],['Liquidado','liquidado'],['Pago','pago']].forEach(function(c){ %>
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="small text-muted"><%= c[0] %></div>
            <div class="h5 fw-bold mb-0 font-monospace"><%= Number(execucao.resumo[c[1]]).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
          </div></div>
        </div>
      <% }) %>
    </div>

    <%- include('_execucao-tabela', { titulo: 'Por Funcional-programática + Natureza', icone: 'diagram-3', rotuloCol: 'Órgão · Função · Programa · Ação · Natureza', linhas: execucao.porFP, arvore: true }) %>
    <%- include('_execucao-tabela', { titulo: 'Por Fonte de Recurso', icone: 'cash-stack', rotuloCol: 'Fonte', linhas: execucao.porFonte, arvore: false }) %>
    <%- include('_execucao-tabela', { titulo: 'Por Função', icone: 'diagram-2', rotuloCol: 'Função', linhas: execucao.porFuncao, arvore: false }) %>
    <%- include('_execucao-tabela', { titulo: 'Por Natureza (com roll-up)', icone: 'list-nested', rotuloCol: 'Natureza', linhas: execucao.porNatureza, arvore: true }) %>
  <% } %>
</div>
</body>
</html>
