<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Execução da Despesa · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
  <style>
    #tbl-dot td, #tbl-dot th { white-space: nowrap; }
    .exec-chevron { border: 0; background: transparent; padding: 0 .35rem 0 0; color: var(--bs-secondary, #6c757d); cursor: pointer; }
    .exec-chevron:hover { color: var(--bs-primary, #0d6efd); }
    .exec-saldo { font-size: .72rem; }
  </style>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container-fluid py-4" style="max-width:1320px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">Execução da Despesa</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-1 flex-wrap gap-2">
    <h2 class="h4 fw-bold mb-0">Execução da Despesa <span class="font-monospace fs-6 text-muted"><%= ano %></span></h2>
    <div class="d-flex align-items-center gap-2">
      <%- include('_seletor-posicao', { base: '/app/orcamento/despesa/execucao', dataRef, ano }) %>
      <a href="/app/orcamento/saldo" class="btn btn-sm btn-outline-secondary"><i class="bi bi-wallet2 me-1"></i>Saldo</a>
      <a href="/app/orcamento/despesa/diario" class="btn btn-sm btn-outline-secondary"><i class="bi bi-graph-up-arrow me-1"></i>Diário</a>
      <span class="badge bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-eye me-1"></i>Somente leitura</span>
    </div>
  </div>
  <p class="text-muted small mb-4">
    Codificação completa — Unidade → Função/Subfunção → Programa/Ação → Natureza/Fonte. A empenhar = Autorizado − Empenhado · A liquidar = Empenhado − Liquidado · A pagar = Liquidado − Pago.
    <% if (posicaoData) { %><span class="badge bg-info bg-opacity-10 text-info ms-1">posição em <%= dataRef.split('-').reverse().join('/') %></span><% } %>
  </p>

  <% if (!execucao.temOrcamento) { %>
    <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-1"></i>Não há orçamento (LOA) cadastrado para este exercício.</div>
  <% } else {
       var brl = function (n) { return Number(n).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) } %>
    <%# Resumo geral: os 4 estágios %>
    <div class="row g-3 mb-4">
      <% [['Autorizado','autorizado'],['Empenhado','empenhado'],['Liquidado','liquidado'],['Pago','pago']].forEach(function(c){ %>
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="small text-muted"><%= c[0] %></div>
            <div class="h5 fw-bold mb-0 font-monospace"><%= brl(execucao.resumo[c[1]]) %></div>
          </div></div>
        </div>
      <% }) %>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold small"><i class="bi bi-diagram-3 me-2"></i>Dotações de despesa (<%= execucao.totalDotacoes.toLocaleString('pt-BR') %>)</span>
        <div class="d-flex align-items-center gap-2">
          <div class="btn-group btn-group-sm" role="group" aria-label="Desdobrar/colapsar tudo">
            <button type="button" class="btn btn-outline-secondary py-0" onclick="execColapsarTudo()" title="Colapsar tudo"><i class="bi bi-chevron-bar-up"></i></button>
            <button type="button" class="btn btn-outline-secondary py-0" onclick="execExpandirTudo()" title="Desdobrar tudo"><i class="bi bi-chevron-bar-down"></i></button>
          </div>
          <input type="search" id="exec-busca" class="form-control form-control-sm" style="width:230px" placeholder="buscar código/descrição…" oninput="execBuscar(this.value)" aria-label="Buscar dotações">
        </div>
      </div>
      <div class="card-body p-0 table-responsive">
        <table id="tbl-dot" class="table table-hover table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3" style="width:120px">Unid. Orç.</th>
              <th style="width:120px">Função/Subf.</th>
              <th style="width:130px">Programa/Ação</th>
              <th style="width:170px">Natureza</th>
              <th style="width:70px">Fonte</th>
              <th class="text-end">Autorizado</th>
              <th class="text-end">Empenhado<br><span class="text-muted fw-normal exec-saldo">a empenhar</span></th>
              <th class="text-end">Liquidado<br><span class="text-muted fw-normal exec-saldo">a liquidar</span></th>
              <th class="text-end">Pago<br><span class="text-muted fw-normal exec-saldo">a pagar</span></th>
              <th class="pe-3" style="width:64px"></th>
            </tr>
          </thead>
          <tbody>
            <% execucao.dotacoes.forEach(function(l) {
                 var busca = ((l.uo + ' ' + l.funcaoSubf + ' ' + l.programaAcao + ' ' + l.natureza + ' ' + l.fonte + ' ' + l.rotulo).trim()).toLowerCase()
                 function celCod(cod, mostraChevron) { %>
                   <% if (cod) { %><% if (mostraChevron) { %><button type="button" class="exec-chevron" onclick="toggleExecRow(this)"><i class="bi bi-chevron-<%= l.nivel <= 2 ? 'up' : 'down' %>"></i></button><% } %><span class="font-monospace small" title="<%= l.rotulo %>"><%= cod %></span><% } %>
                 <% } %>
              %>
              <tr data-path="<%= l.path %>" data-parent="<%= l.parentPath || '' %>" data-nivel="<%= l.nivel %>" data-busca="<%= busca %>" data-rotulo="<%= l.rotulo %>" data-aberto="<%= l.nivel <= 2 ? '1' : '0' %>"<% if (l.nivel > 3) { %> style="display:none"<% } %>>
                <td class="ps-3"><% celCod(l.uo, l.nivel === 1 && l.temFilhos) %></td>
                <td><% celCod(l.funcaoSubf, l.nivel === 2 && l.temFilhos) %></td>
                <td><% celCod(l.programaAcao, l.nivel === 3 && l.temFilhos) %></td>
                <td><span class="font-monospace small" title="<%= l.rotulo %>"><%= l.natureza %></span></td>
                <td class="font-monospace small text-muted"><%= l.fonte %></td>
                <td class="text-end font-monospace small"><%= brl(l.autorizado) %></td>
                <td class="text-end font-monospace small"><%= brl(l.empenhado) %><br><span class="text-muted exec-saldo <%= l.aEmpenhar < 0 ? 'text-danger' : '' %>"><%= brl(l.aEmpenhar) %></span></td>
                <td class="text-end font-monospace small"><%= brl(l.liquidado) %><br><span class="text-muted exec-saldo <%= l.aLiquidar < 0 ? 'text-danger' : '' %>"><%= brl(l.aLiquidar) %></span></td>
                <td class="text-end font-monospace small"><%= brl(l.pago) %><br><span class="text-muted exec-saldo <%= l.aPagar < 0 ? 'text-danger' : '' %>"><%= brl(l.aPagar) %></span></td>
                <td class="text-end pe-3 text-nowrap">
                  <button type="button" class="btn btn-link btn-sm p-0 me-2 align-baseline" title="Ver por mês" onclick="abrirMensalExec(this)"><i class="bi bi-calendar3"></i></button>
                  <% if (l.dotacaoId) { %><a href="/app/orcamento/despesa/execucao/<%= l.dotacaoId %>/lancamentos" class="align-baseline text-decoration-none" title="Ver lançamentos"><i class="bi bi-list-ul"></i></a><% } %>
                </td>
              </tr>
            <% }) %>
            <% if (execucao.dotacoes.length === 0) { %><tr><td colspan="10" class="text-center text-muted py-4">Sem dotações neste exercício.</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
  <!-- Modal ▸ mensal: empenhado/liquidado/pago por período do nó (buscado sob demanda) -->
  <div class="modal fade" id="modalExecMensal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header py-2">
          <div>
            <h6 class="modal-title fw-semibold mb-0" id="emTitulo"></h6>
            <small class="text-muted">Empenhado · Liquidado · Pago por período</small>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div class="btn-group btn-group-sm mb-3" role="group" aria-label="Período">
            <button type="button" class="btn btn-outline-primary active" onclick="setGranExec(this, 12)">Mensal</button>
            <button type="button" class="btn btn-outline-primary" onclick="setGranExec(this, 6)">Bimestral</button>
            <button type="button" class="btn btn-outline-primary" onclick="setGranExec(this, 3)">Quadrimestral</button>
          </div>
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light"><tr><th>Período</th><th class="text-end">Empenhado</th><th class="text-end">Liquidado</th><th class="text-end">Pago</th></tr></thead>
            <tbody id="emCorpo"></tbody>
            <tfoot><tr class="fw-semibold border-top"><td>Total</td><td class="text-end font-monospace small" id="emTotEmp"></td><td class="text-end font-monospace small" id="emTotLiq"></td><td class="text-end font-monospace small" id="emTotPag"></td></tr></tfoot>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Árvore de dotações: desdobrar/colapsar por linha (chevron ▾ desdobra / ▴ colapsa).
// Entra colapsada (só as Unidades Orçamentárias); descendentes ocultos até expandir.
function _execRows() { return document.querySelectorAll('#tbl-dot tbody tr[data-path]') }
function _execChevron(tr, aberto) { var i = tr.querySelector('.exec-chevron i'); if (i) i.className = aberto ? 'bi bi-chevron-up' : 'bi bi-chevron-down' }
function toggleExecRow(btn) {
  var tr = btn.closest('tr'); var path = tr.getAttribute('data-path')
  var aberto = tr.getAttribute('data-aberto') === '1'
  if (aberto) {
    _execRows().forEach(function (r) {
      var p = r.getAttribute('data-path')
      if (p !== path && p.indexOf(path + '|') === 0) { r.style.display = 'none'; r.setAttribute('data-aberto', '0'); _execChevron(r, false) }
    })
    tr.setAttribute('data-aberto', '0'); _execChevron(tr, false)
  } else {
    _execRows().forEach(function (r) { if (r.getAttribute('data-parent') === path) r.style.display = '' })
    tr.setAttribute('data-aberto', '1'); _execChevron(tr, true)
  }
}
function execExpandirTudo() {
  _execRows().forEach(function (r) { r.style.display = ''; if (r.getAttribute('data-nivel') !== '4') { r.setAttribute('data-aberto', '1'); _execChevron(r, true) } })
}
function execColapsarTudo() {
  _execRows().forEach(function (r) {
    var n1 = r.getAttribute('data-nivel') === '1'
    r.style.display = n1 ? '' : 'none'
    r.setAttribute('data-aberto', '0'); _execChevron(r, false)
  })
}
// Estado padrão: funcional-programática aberta (UO→Função→Programa/Ação), natureza colapsada.
function execEstadoPadrao() {
  _execRows().forEach(function (r) {
    var n = +r.getAttribute('data-nivel')
    r.style.display = n <= 3 ? '' : 'none'
    var aberto = n <= 2
    r.setAttribute('data-aberto', aberto ? '1' : '0'); _execChevron(r, aberto)
  })
}
function execBuscar(q) {
  q = (q || '').trim().toLowerCase()
  if (!q) { execEstadoPadrao(); return }
  var mostrar = {}
  _execRows().forEach(function (r) {
    if ((r.getAttribute('data-busca') || '').indexOf(q) >= 0) {
      var segs = r.getAttribute('data-path').split('|'); var acc = ''
      for (var i = 0; i < segs.length; i++) { acc = i === 0 ? segs[0] : acc + '|' + segs[i]; mostrar[acc] = true }
    }
  })
  _execRows().forEach(function (r) {
    var on = !!mostrar[r.getAttribute('data-path')]
    r.style.display = on ? '' : 'none'
    if (on && r.getAttribute('data-nivel') !== '4') { r.setAttribute('data-aberto', '1'); _execChevron(r, true) }
  })
}

// ▸ mensal: busca empenhado/liquidado/pago por mês do nó (path) e abre o modal.
var granExec = 12
var emDados = null
var MESES_EX = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez']
function _grpEx(vals, g) {
  if (g === 6) { var b = []; for (var i = 0; i < 6; i++) b.push({ rot: i + 1 + 'º bim', val: (vals[i * 2] || 0) + (vals[i * 2 + 1] || 0) }); return b }
  if (g === 3) { var q = []; for (var j = 0; j < 3; j++) { var s = 0; for (var k = 0; k < 4; k++) s += vals[j * 4 + k] || 0; q.push({ rot: j + 1 + 'º quad', val: s }) } return q }
  return MESES_EX.map(function (m, i) { return { rot: m, val: vals[i] || 0 } })
}
function _fmtEx(n) { return n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) }
function _renderEx() {
  var corpo = document.getElementById('emCorpo'); if (!corpo || !emDados) return
  corpo.textContent = ''
  var ge = _grpEx(emDados.empenhadoMensal || [], granExec), gl = _grpEx(emDados.liquidadoMensal || [], granExec), gp = _grpEx(emDados.pagoMensal || [], granExec)
  var te = 0, tl = 0, tp = 0
  for (var i = 0; i < ge.length; i++) {
    te += ge[i].val; tl += gl[i].val; tp += gp[i].val
    var tr = document.createElement('tr')
    var c0 = document.createElement('td'); c0.textContent = ge[i].rot
    var c1 = document.createElement('td'); c1.className = 'text-end font-monospace small'; c1.textContent = _fmtEx(ge[i].val)
    var c2 = document.createElement('td'); c2.className = 'text-end font-monospace small'; c2.textContent = _fmtEx(gl[i].val)
    var c3 = document.createElement('td'); c3.className = 'text-end font-monospace small'; c3.textContent = _fmtEx(gp[i].val)
    tr.appendChild(c0); tr.appendChild(c1); tr.appendChild(c2); tr.appendChild(c3); corpo.appendChild(tr)
  }
  document.getElementById('emTotEmp').textContent = _fmtEx(te)
  document.getElementById('emTotLiq').textContent = _fmtEx(tl)
  document.getElementById('emTotPag').textContent = _fmtEx(tp)
}
function setGranExec(btn, g) {
  granExec = g
  Array.prototype.forEach.call(btn.parentNode.children, function (b) { b.classList.toggle('active', b === btn) })
  _renderEx()
}
function abrirMensalExec(btn) {
  var tr = btn.closest('tr')
  var path = tr.getAttribute('data-path')
  document.getElementById('emTitulo').textContent = tr.getAttribute('data-rotulo') || ''
  emDados = null
  var corpo = document.getElementById('emCorpo'); if (corpo) corpo.textContent = ''
  fetch('/app/orcamento/despesa/execucao/mensal?path=' + encodeURIComponent(path), { headers: { Accept: 'application/json' } })
    .then(function (r) { return r.ok ? r.json() : null })
    .then(function (d) { emDados = d || { empenhadoMensal: [], liquidadoMensal: [], pagoMensal: [] }; _renderEx() })
    .catch(function () { emDados = { empenhadoMensal: [], liquidadoMensal: [], pagoMensal: [] }; _renderEx() })
  if (window.bootstrap) bootstrap.Modal.getOrCreateInstance(document.getElementById('modalExecMensal')).show()
}
</script>
</body>
</html>
