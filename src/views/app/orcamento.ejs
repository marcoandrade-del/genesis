<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orçamento · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<%- include('_navbar') %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item active" aria-current="page">Orçamento</li>
    </ol>
  </nav>

  <% if (typeof erro !== 'undefined' && erro) { %>
    <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>
  <% if (typeof ok !== 'undefined' && ok) { %>
    <div class="alert alert-success py-2 small"><i class="bi bi-check-circle me-1"></i><%= ok %></div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 fw-bold mb-0">Orçamento (LOA) — <span class="font-monospace"><%= ano %></span></h2>
    <div class="d-flex align-items-center gap-2">
      <% if (orcamento) { %>
        <%
          var sb = ({
            RASCUNHO: ['secondary', 'Rascunho'],
            ENVIADO_AO_LEGISLATIVO: ['info', 'No Legislativo'],
            APROVADO: ['primary', 'Aprovado'],
            PUBLICADO: ['warning', 'Publicado'],
            EM_EXECUCAO: ['success', 'Em Execução'],
          })[orcamento.status] || ['secondary', orcamento.status]
        %>
        <span class="badge bg-<%= sb[0] %> bg-opacity-10 text-<%= sb[0] %>"><%= sb[1] %></span>
      <% } %>
      <a href="/app/orcamento/saldo" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-wallet2 me-1"></i>Ver saldos
      </a>
      <a href="/app/orcamento/creditos" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-plus-slash-minus me-1"></i>Créditos adicionais
      </a>
      <a href="/app/orcamento/arrecadacao" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-cash-stack me-1"></i>Arrecadação
      </a>
      <a href="/app/orcamento/relatorios/receita-prevista" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-file-earmark-text me-1"></i>Receita orçada (LOA)
      </a>
      <a href="/app/orcamento/relatorios/despesa-fixada" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-file-earmark-text me-1"></i>Despesa fixada (LOA)
      </a>
      <a href="/app/orcamento/relatorios/programa-trabalho" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-diagram-3 me-1"></i>Programa de trabalho (LOA)
      </a>
      <a href="/app/orcamento/relatorios/programa-governo" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-diagram-2 me-1"></i>Programa de trabalho de governo (LOA)
      </a>
      <a href="/app/orcamento/relatorios/despesa-funcoes-programas" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-bar-chart-steps me-1"></i>Despesa por funções/programas (LOA)
      </a>
      <a href="/app/orcamento/relatorios/sumario" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-list-columns me-1"></i>Sumário geral (LOA)
      </a>
    </div>
  </div>

  <% if (typeof abertura !== 'undefined' && abertura && abertura.status !== 'SEM_ORCAMENTO') { %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
          <div class="fw-semibold"><i class="bi bi-journal-check me-1"></i>Abertura do exercício (PCASP)</div>
          <div class="small text-muted">
            <% if (abertura.status === 'PUBLICADO') { %>
              Gera os lançamentos de abertura (previsão da receita + fixação da despesa) e transporta os saldos do exercício anterior. Inicia a execução.
            <% } else if (abertura.status === 'EM_EXECUCAO') { %>
              Abertura contabilizada — orçamento <strong>em execução</strong><% if (abertura.temExecucao) { %>, com movimentos no exercício<% } %>.
            <% } else { %>
              A LOA precisa estar <strong>Publicada</strong> antes de contabilizar a abertura.
            <% } %>
          </div>
        </div>
        <div>
          <% if (abertura.podeContabilizar && podeEscrever) { %>
            <form method="post" action="/app/orcamento/abertura/contabilizar" onsubmit="return confirm('Contabilizar a abertura do exercício? Os lançamentos de abertura serão gerados e o orçamento entrará em execução.')">
              <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-play-circle me-1"></i>Contabilizar abertura</button>
            </form>
          <% } else if (abertura.contabilizada) { %>
            <span class="badge bg-success bg-opacity-10 text-success me-1"><i class="bi bi-check-circle me-1"></i>Contabilizada</span>
            <% if (abertura.podeEstornar && podeEscrever) { %>
              <form method="post" action="/app/orcamento/abertura/estornar" class="d-inline" onsubmit="return confirm('Estornar a abertura? Os lançamentos de abertura serão removidos e o orçamento voltará a Publicado.')">
                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>Estornar</button>
              </form>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <% if (!orcamento) { %>
    <div class="alert alert-info py-3">
      <i class="bi bi-info-circle me-1"></i>
      Não há orçamento cadastrado para <strong><%= entidade.nome %></strong> no exercício <strong><%= ano %></strong>.
      <div class="small text-muted mt-1">Use "Trocar contexto" para escolher outro exercício.</div>
    </div>
  <% } else { %>
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="small text-muted mb-1">Total despesa autorizada</div>
          <div class="h5 fw-semibold mb-0 font-monospace">R$ <%= totalDespesa.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
        </div></div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="small text-muted mb-1">Total receita prevista</div>
          <div class="h5 fw-semibold mb-0 font-monospace">R$ <%= totalReceita.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
        </div></div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="small text-muted mb-1">Equilíbrio</div>
          <% var dif = totalReceita - totalDespesa; %>
          <div class="h5 fw-semibold mb-0 font-monospace <%= Math.abs(dif) < 0.005 ? 'text-success' : 'text-danger' %>">
            R$ <%= dif.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
          </div>
        </div></div>
      </div>
    </div>

    <h3 class="h6 fw-bold mb-2">Dotações de despesa <span class="text-muted">(<%= dotacoes.length %>)</span></h3>
    <div class="card border-0 shadow-sm mb-4"><div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Unid. Orç.</th><th>Função/Subf.</th><th>Programa/Ação</th><th>Natureza</th><th>Fonte</th><th class="text-end pe-3">Autorizado R$</th></tr></thead>
        <tbody>
          <% if (dotacoes.length === 0) { %><tr><td colspan="6" class="text-center text-muted py-4">Sem dotações.</td></tr><% } %>
          <% dotacoes.forEach(function(d) { %>
            <tr>
              <td class="ps-3 font-monospace small"><%= d.unidadeOrcamentaria.codigo %></td>
              <td class="font-monospace small"><%= d.funcao.codigo %>.<%= d.subfuncao.codigo %></td>
              <td class="font-monospace small"><%= d.programa.codigo %>.<%= d.acao.codigo %></td>
              <td class="font-monospace small"><%= d.contaDespesa.codigo %></td>
              <td class="font-monospace small"><%= d.fonteRecurso.codigo %></td>
              <td class="text-end pe-3 font-monospace"><%= Number(d.valorAutorizado).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div></div>

    <h3 class="h6 fw-bold mb-2">Previsões de receita <span class="text-muted">(<%= previsoes.length %>)</span></h3>
    <div class="card border-0 shadow-sm"><div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Conta de receita</th><th>Fonte</th><th class="text-end pe-3">Previsto R$</th></tr></thead>
        <tbody>
          <% if (previsoes.length === 0) { %><tr><td colspan="3" class="text-center text-muted py-4">Sem previsões.</td></tr><% } %>
          <% previsoes.forEach(function(p) { %>
            <tr>
              <td class="ps-3 small"><span class="font-monospace"><%= p.contaReceita.codigo %></span> — <%= p.contaReceita.descricao %></td>
              <td class="font-monospace small"><%= p.fonteRecurso.codigo %></td>
              <td class="text-end pe-3 font-monospace"><%= Number(p.valorPrevisto).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div></div>
  <% } %>
</div>
</body>
</html>
