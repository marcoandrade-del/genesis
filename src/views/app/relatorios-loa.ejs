<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Anexos da LOA · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
  <style>
    .loa-card { transition: transform .12s ease, box-shadow .12s ease; }
    .loa-card:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.10) !important; }
    .loa-ico {
      flex: 0 0 auto; width: 44px; height: 44px; border-radius: 12px;
      display: grid; place-items: center; font-size: 1.25rem;
      background: var(--primary, #1b5e20); color: #fff;
    }
    .loa-grupo { font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; color: #888; }
  </style>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1000px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">Anexos da LOA</li>
    </ol>
  </nav>

  <div class="mb-4">
    <h2 class="h4 fw-bold mb-1">Anexos da LOA <span class="text-muted fw-normal">· exercício <%= ano %></span></h2>
    <div class="text-muted small"><i class="bi bi-building me-1"></i><%= entidade.nome %></div>
  </div>

  <% function cards(lista) { %>
    <div class="row g-3 mb-4">
      <% lista.forEach(function(a) { %>
        <div class="col-md-6 col-lg-4">
          <a href="<%= a.rota %>" class="card h-100 border-0 shadow-sm text-reset text-decoration-none loa-card">
            <div class="card-body d-flex gap-3 align-items-start">
              <div class="loa-ico"><i class="bi <%= a.icone %>"></i></div>
              <div>
                <div class="fw-semibold lh-sm"><%= a.nome %></div>
                <div class="small text-muted mt-1"><%= a.desc %></div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="loa-grupo mb-2">Lei nº 4.320/64</div>
  <% cards([
    { rota: '/app/orcamento/relatorios/receita-prevista', icone: 'bi-cash-coin', nome: 'Receita orçada', desc: 'Anexo 2 — Resumo Geral da Receita' },
    { rota: '/app/orcamento/relatorios/despesa-fixada', icone: 'bi-graph-down', nome: 'Despesa fixada', desc: 'Anexo 2 e 9 — natureza, unidade e função' },
    { rota: '/app/orcamento/relatorios/programa-trabalho', icone: 'bi-diagram-3', nome: 'Programa de trabalho', desc: 'Anexo 6 — UO → função → ação' },
    { rota: '/app/orcamento/relatorios/programa-governo', icone: 'bi-diagram-2', nome: 'Programa de trabalho de governo', desc: 'Anexo 7 — consolidado por função' },
    { rota: '/app/orcamento/relatorios/despesa-funcoes-programas', icone: 'bi-bar-chart-steps', nome: 'Despesa por funções e programas', desc: 'Função → programa → subfunção' },
  ]) %>

  <div class="loa-grupo mb-2">Resumos</div>
  <% cards([
    { rota: '/app/orcamento/relatorios/sumario', icone: 'bi-list-columns', nome: 'Sumário geral', desc: 'Receita por fontes × despesa por funções' },
  ]) %>

  <div class="loa-grupo mb-2">LRF — Lei de Responsabilidade Fiscal</div>
  <% cards([
    { rota: '/app/orcamento/relatorios/rcl', icone: 'bi-percent', nome: 'Receita Corrente Líquida', desc: 'RREO Anexo 3 — base dos limites da LRF' },
    { rota: '/app/orcamento/relatorios/rcl-consolidada', icone: 'bi-bank2', nome: 'RCL Consolidada do Município', desc: 'Soma das entidades do ente (Prefeitura, Câmara, RPPS…)' },
    { rota: '/app/orcamento/relatorios/guardiao', icone: 'bi-shield-check', nome: 'Guardião LRF', desc: 'Indicadores fiscais: RCL, Despesa com Pessoal, aplicação em Educação/Saúde' },
  ]) %>
</div>
</body>
</html>
