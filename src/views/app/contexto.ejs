<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Escolher Contexto — Gênesis</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6">
    <i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis
  </a>
  <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary">
    <i class="bi bi-box-arrow-right me-1"></i>Sair
  </a>
</nav>

<div class="container py-5" style="max-width:720px">
  <h2 class="h4 fw-bold mb-1">Escolha o contexto de trabalho</h2>
  <p class="text-muted small mb-4">
    Selecione a entidade e o exercício que deseja consultar/editar. Você pode trocar a qualquer momento.
  </p>

  <% if (grupos.length === 0) { %>
    <div class="alert alert-warning small">
      <i class="bi bi-exclamation-triangle me-1"></i>
      Você não tem nenhum acesso ativo. Procure o administrador do sistema.
    </div>
  <% } else { %>
    <form method="POST" action="/app/contexto">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold small">Entidade</div>
        <div class="card-body p-0">
          <% grupos.forEach(function(g) { %>
            <div class="px-3 pt-3 pb-1">
              <div class="small text-muted fw-semibold">
                <%= g.estado %> · <%= g.municipio %>
              </div>
            </div>
            <% g.entidades.forEach(function(a) { %>
              <label class="d-flex align-items-center px-3 py-2 border-top" style="cursor:pointer">
                <input type="radio" name="entidadeId" value="<%= a.entidadeId %>"
                  class="form-check-input me-2"
                  <%= atual && atual.entidadeId === a.entidadeId ? 'checked' : '' %>
                  required>
                <div class="flex-grow-1">
                  <div class="fw-semibold small"><%= a.entidade.nome %></div>
                </div>
                <span class="small">
                  <% if (a.nivel === 'ADMIN') { %>
                    <span class="badge bg-danger bg-opacity-10 text-danger">Admin</span>
                  <% } else if (a.nivel === 'ESCRITA') { %>
                    <span class="badge bg-primary bg-opacity-10 text-primary">Escrita</span>
                  <% } else { %>
                    <span class="badge bg-secondary bg-opacity-10 text-secondary">Leitura</span>
                  <% } %>
                </span>
              </label>
            <% }) %>
          <% }) %>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold small">Exercício</div>
        <div class="card-body">
          <select name="ano" class="form-select form-select-sm" required>
            <% anos.forEach(function(a) { %>
              <option value="<%= a %>"
                <%= (atual && atual.ano === a) || (!atual && a === anoCorrente) ? 'selected' : '' %>>
                <%= a %> <% if (a === anoCorrente) { %>(corrente)<% } %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-arrow-right-circle me-1"></i>Entrar no contexto
        </button>
      </div>
    </form>
  <% } %>
</div>
</body>
</html>
