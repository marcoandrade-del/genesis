<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Demandas (DOD) <%= ano %> · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/compras" class="text-decoration-none">Compras</a></li>
      <li class="breadcrumb-item active" aria-current="page">Demandas (DOD)</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Documentos de Oficialização da Demanda — <span class="font-monospace"><%= ano %></span></h2>
  <p class="text-muted small mb-3"><%= lista.length %> demanda(s) no exercício.</p>

  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3">Nº</th><th>Unidade Orçamentária</th><th>Status</th><th class="text-center">Itens</th><th class="text-center pe-3">TR</th></tr></thead>
      <tbody>
        <% if (lista.length === 0) { %><tr><td colspan="5" class="text-center text-muted py-4">Sem demandas neste exercício.</td></tr><% } %>
        <% lista.forEach(function(d) { %>
          <tr>
            <td class="ps-3 font-monospace"><%= d.numero %></td>
            <td class="small"><span class="font-monospace text-muted"><%= d.unidadeOrcamentaria.codigo %></span> — <%= d.unidadeOrcamentaria.nome %></td>
            <td>
              <% if (d.status === 'APROVADA') { %><span class="badge bg-success bg-opacity-10 text-success">Aprovada</span>
              <% } else if (d.status === 'REPROVADA') { %><span class="badge bg-danger bg-opacity-10 text-danger">Reprovada</span>
              <% } else if (d.status === 'AGUARDANDO_PARECER') { %><span class="badge bg-warning bg-opacity-10 text-warning">Aguardando parecer</span>
              <% } else { %><span class="badge bg-secondary bg-opacity-10 text-secondary">Rascunho</span><% } %>
            </td>
            <td class="text-center"><%= d._count.itens %></td>
            <td class="text-center pe-3">
              <% if (d.termoReferencia) { %><i class="bi bi-check-circle-fill text-success" title="Possui Termo de Referência"></i>
              <% } else { %><span class="text-muted">—</span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>
</div>
</body>
</html>
