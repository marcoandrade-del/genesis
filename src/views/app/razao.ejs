<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Razão · <%= conta.codigo %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
  <style>.valor{font-variant-numeric:tabular-nums;white-space:nowrap;text-align:right}.valor.neg{color:var(--bs-danger)}</style>
</head>
<body class="bg-light">

<%- include('_navbar') %>

<% const brl = (n) => (Number(n) || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %>
<% const nat = { DEVEDORA: 'Devedora', CREDORA: 'Credora', MISTA: 'Mista' } %>
<% const base = '/app/contas/' + conta.id + '/razao' %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/contas" class="text-decoration-none">Plano de Contas</a></li>
      <li class="breadcrumb-item active" aria-current="page">Razão</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
      <h2 class="h5 fw-bold mb-1"><span class="font-monospace text-muted"><%= conta.codigo %></span> <%= conta.descricao %></h2>
      <span class="badge bg-secondary bg-opacity-10 text-secondary">Natureza: <%= natureza ? nat[natureza] : '—' %></span>
      <span class="badge bg-light text-dark">Exercício <%= ano %></span>
    </div>
    <a href="/app/contas/<%= conta.id %>/diario" class="btn btn-sm btn-outline-primary"><i class="bi bi-graph-up me-1"></i>Acumulado diário</a>
  </div>

  <%# Seletor de mês %>
  <div class="btn-group btn-group-sm flex-wrap mb-3" role="group">
    <% meses.forEach(function(nome, i) { %>
      <a href="<%= base %>?mes=<%= i + 1 %>" class="btn <%= (i + 1) === mes ? 'btn-primary' : 'btn-outline-secondary' %>"><%= nome %></a>
    <% }) %>
  </div>

  <div class="row g-3">
    <%# Resumo mensal + total por dia %>
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm mb-3"><div class="card-body p-0">
        <div class="px-3 py-2 small fw-semibold text-muted border-bottom">Resumo mensal</div>
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light"><tr><th class="ps-3">Mês</th><th class="valor">Débito</th><th class="valor pe-3">Crédito</th></tr></thead>
          <tbody>
            <% resumo.forEach(function(m) { %>
              <tr class="<%= m.mes === mes ? 'table-active' : '' %>">
                <td class="ps-3"><a href="<%= base %>?mes=<%= m.mes %>" class="text-decoration-none"><%= m.nome %></a></td>
                <td class="valor small"><%= m.debito ? brl(m.debito) : '–' %></td>
                <td class="valor small pe-3"><%= m.credito ? brl(m.credito) : '–' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div></div>

      <div class="card border-0 shadow-sm"><div class="card-body p-0">
        <div class="px-3 py-2 small fw-semibold text-muted border-bottom">Total por dia — <%= meses[mes - 1] %></div>
        <table class="table table-sm mb-0">
          <thead class="table-light"><tr><th class="ps-3">Dia</th><th class="valor">Débito</th><th class="valor pe-3">Crédito</th></tr></thead>
          <tbody>
            <% if (totaisPorDia.length === 0) { %>
              <tr><td colspan="3" class="text-center text-muted small py-3">Sem movimento no mês.</td></tr>
            <% } %>
            <% totaisPorDia.forEach(function(t) { %>
              <tr><td class="ps-3 font-monospace small"><%= t.dia %></td><td class="valor small"><%= brl(t.debito) %></td><td class="valor small pe-3"><%= brl(t.credito) %></td></tr>
            <% }) %>
          </tbody>
        </table>
      </div></div>
    </div>

    <%# Razão (movimentos com saldo corrente) %>
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm"><div class="card-body p-0">
        <div class="px-3 py-2 small fw-semibold text-muted border-bottom d-flex justify-content-between">
          <span>Razão — <%= meses[mes - 1] %>/<%= ano %></span>
          <span>Saldo anterior: <strong class="<%= saldoAnterior < 0 ? 'text-danger' : '' %>"><%= brl(saldoAnterior) %></strong></span>
        </div>
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light"><tr>
            <th class="ps-3" style="width:60px">Dia</th><th>Histórico</th>
            <th class="valor">Débito</th><th class="valor">Crédito</th><th class="valor pe-3">Saldo</th>
          </tr></thead>
          <tbody>
            <% if (movimentos.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox d-block fs-5 mb-1"></i>Nenhuma movimentação neste mês.</td></tr>
            <% } %>
            <% movimentos.forEach(function(m) { %>
              <tr>
                <td class="ps-3 font-monospace small"><%= m.dia %></td>
                <td class="small"><%= m.historico %>
                  <% if (m.origemTipo === 'ARRECADACAO' && m.origemId) { %>
                    <a href="/app/orcamento/arrecadacao/<%= m.origemId %>/lancamentos" class="badge bg-primary bg-opacity-10 text-primary text-decoration-none ms-1" title="Origem: arrecadação (ver movimento)"><i class="bi bi-link-45deg"></i>Arrecadação<% if (m.eventoCodigo) { %> · E<%= m.eventoCodigo %><% } %></a>
                  <% } else if (m.origemTipo === 'LANCAMENTO_TRIBUTARIO' && m.origemId) { %>
                    <a href="/app/orcamento/lancamento-tributario/<%= m.origemId %>/lancamentos" class="badge bg-info bg-opacity-10 text-info-emphasis text-decoration-none ms-1" title="Origem: lançamento tributário"><i class="bi bi-link-45deg"></i>Lançamento trib.<% if (m.eventoCodigo) { %> · E<%= m.eventoCodigo %><% } %></a>
                  <% } else if (m.origemTipo === 'INSCRICAO_DIVIDA_ATIVA' && m.origemId) { %>
                    <a href="/app/orcamento/lancamento-tributario/<%= m.origemId %>/lancamentos" class="badge bg-warning bg-opacity-10 text-warning-emphasis text-decoration-none ms-1" title="Origem: inscrição em dívida ativa"><i class="bi bi-link-45deg"></i>Inscrição DA<% if (m.eventoCodigo) { %> · E<%= m.eventoCodigo %><% } %></a>
                  <% } %>
                </td>
                <td class="valor small"><%= m.debito ? brl(m.debito) : '' %></td>
                <td class="valor small"><%= m.credito ? brl(m.credito) : '' %></td>
                <td class="valor small fw-semibold pe-3 <%= m.saldo < 0 ? 'neg' : '' %>"><%= brl(m.saldo) %></td>
              </tr>
            <% }) %>
          </tbody>
          <% if (movimentos.length) { %>
            <tfoot class="table-light"><tr class="fw-semibold">
              <td colspan="2" class="ps-3">Totais do mês</td>
              <td class="valor"><%= brl(totalDebito) %></td>
              <td class="valor"><%= brl(totalCredito) %></td>
              <td class="valor pe-3 <%= saldoFinal < 0 ? 'neg' : '' %>"><%= brl(saldoFinal) %></td>
            </tr></tfoot>
          <% } %>
        </table>
      </div></div>
    </div>
  </div>
</div>
</body>
</html>
