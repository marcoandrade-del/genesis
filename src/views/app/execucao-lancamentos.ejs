<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lançamentos · <%= dotacao.codigo %> · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:980px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento/despesa/execucao" class="text-decoration-none">Execução da Despesa</a></li>
      <li class="breadcrumb-item active" aria-current="page">Lançamentos</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
      <h2 class="h5 fw-bold mb-1"><%= dotacao.natureza %></h2>
      <div class="small text-muted font-monospace"><%= dotacao.codigo %></div>
      <div class="small text-muted"><%= dotacao.orgao %> · <%= dotacao.fonte %></div>
    </div>
    <a href="/app/orcamento/despesa/execucao" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Voltar à Execução</a>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover table-sm align-middle mb-0">
        <thead class="table-light">
          <tr><th class="ps-3" style="width:110px">Data</th><th>Tipo</th><th class="text-end">Valor</th><th class="pe-3">Documento</th></tr>
        </thead>
        <tbody>
          <% if (movimentos.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox d-block fs-5 mb-1"></i>Sem lançamentos nesta dotação.</td></tr>
          <% }
             var ROT = { EMPENHO: ['Empenho','primary'], ESTORNO_EMPENHO: ['Estorno de empenho','secondary'], LIQUIDACAO: ['Liquidação','info'], ESTORNO_LIQUIDACAO: ['Estorno de liquidação','secondary'], PAGAMENTO: ['Pagamento','success'], ESTORNO_PAGAMENTO: ['Estorno de pagamento','secondary'] }
             var estorno = function(t){ return t.indexOf('ESTORNO') === 0 }
             movimentos.forEach(function(m){ var r = ROT[m.tipo] || [m.tipo,'secondary'] %>
            <tr>
              <td class="ps-3 font-monospace small"><%= m.data %></td>
              <td><span class="badge bg-<%= r[1] %> bg-opacity-10 text-<%= r[1] %>-emphasis"><%= r[0] %></span></td>
              <td class="text-end font-monospace small <%= estorno(m.tipo) ? 'text-danger' : '' %>"><%= estorno(m.tipo) ? '−' : '' %><%= Number(m.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
              <td class="pe-3 small text-muted"><%= m.documento %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <p class="small text-muted mt-2">Ledger imutável (MovimentoEmpenho): cada correção é um estorno. Valores brutos; o tipo dá o sinal.</p>
</div>
</body>
</html>
