<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solicitar acesso — Gênesis</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6">
    <i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis
  </a>
  <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary">
    <i class="bi bi-box-arrow-right me-1"></i>Sair
  </a>
</nav>

<div class="container py-5" style="max-width:720px">
  <div class="d-flex justify-content-between align-items-center mb-1">
    <h2 class="h4 fw-bold mb-0">Solicitar acesso a uma entidade</h2>
    <a href="/app/minhas-solicitacoes" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-list-check me-1"></i>Minhas solicitações
    </a>
  </div>
  <p class="text-muted small mb-4">
    Busque a entidade, escolha o nível desejado e justifique. Um administrador
    vai avaliar e definir o nível concedido.
  </p>

  <% if (erro) { %>
    <div class="alert alert-danger small"><i class="bi bi-exclamation-circle me-1"></i><%= erro %></div>
  <% } %>

  <form method="GET" action="/app/solicitar-acesso" class="mb-3">
    <div class="input-group">
      <input type="text" name="q" value="<%= q %>" class="form-control"
        placeholder="Nome da entidade ou do município (mín. 2 letras)" autofocus>
      <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search me-1"></i>Buscar</button>
    </div>
  </form>

  <% if (q && q.length >= 2 && entidades.length === 0) { %>
    <div class="alert alert-secondary small">Nenhuma entidade ativa encontrada para "<%= q %>".</div>
  <% } %>

  <% if (entidades.length > 0) { %>
    <form method="POST" action="/app/solicitar-acesso">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold small">Entidade</div>
        <div class="card-body p-0">
          <% entidades.forEach(function(e) { %>
            <% if (e.situacao === 'disponivel') { %>
              <label class="d-flex align-items-center px-3 py-2 border-top" style="cursor:pointer">
                <input type="radio" name="entidadeId" value="<%= e.id %>" class="form-check-input me-2" required>
                <div class="flex-grow-1">
                  <div class="fw-semibold small"><%= e.nome %></div>
                  <div class="text-muted" style="font-size:.75rem"><%= e.estado %> · <%= e.municipio %></div>
                </div>
              </label>
            <% } else { %>
              <div class="d-flex align-items-center px-3 py-2 border-top text-muted">
                <i class="bi bi-lock me-2"></i>
                <div class="flex-grow-1">
                  <div class="fw-semibold small"><%= e.nome %></div>
                  <div style="font-size:.75rem"><%= e.estado %> · <%= e.municipio %></div>
                </div>
                <% if (e.situacao === 'tem_acesso') { %>
                  <span class="badge bg-success bg-opacity-10 text-success">Você já tem acesso</span>
                <% } else { %>
                  <span class="badge bg-warning bg-opacity-10 text-warning">Solicitação pendente</span>
                <% } %>
              </div>
            <% } %>
          <% }) %>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-sm-5">
          <label class="form-label small fw-semibold">Nível desejado</label>
          <select name="nivelSolicitado" class="form-select form-select-sm" required>
            <% niveis.forEach(function(n) { %>
              <option value="<%= n %>" <%= n === 'LEITURA' ? 'selected' : '' %>><%= n %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-sm-7">
          <label class="form-label small fw-semibold">Justificativa <span class="text-muted">(opcional)</span></label>
          <input type="text" name="justificativa" class="form-control form-control-sm"
            maxlength="500" placeholder="Por que precisa deste acesso?">
        </div>
      </div>

      <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-send me-1"></i>Enviar solicitação
        </button>
      </div>
    </form>
  <% } %>

  <div class="mt-4">
    <a href="/app/contexto" class="small text-decoration-none">
      <i class="bi bi-arrow-left me-1"></i>Voltar ao contexto
    </a>
  </div>
</div>
</body>
</html>
