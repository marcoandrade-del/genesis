<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Novo Crédito Adicional · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<%
  function rotuloDotacao(d) {
    return 'UO ' + d.unidadeOrcamentaria.codigo + ' · ' + d.contaDespesa.codigo + ' · Fonte ' + d.fonteRecurso.codigo
  }
  const itensPre = (valores.itens && valores.itens.length) ? valores.itens : [{ dotacaoId: '', operacao: 'REFORCO', valor: '' }]
%>
<div class="container py-4" style="max-width:900px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento/creditos" class="text-decoration-none">Créditos Adicionais</a></li>
      <li class="breadcrumb-item active" aria-current="page">Novo</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-3">Novo Crédito Adicional</h2>

  <% if (erro) { %>
    <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } %>

  <form method="post" action="/app/orcamento/creditos">
    <div class="row g-3 mb-3">
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Tipo <span class="text-danger">*</span></label>
        <select name="tipo" class="form-select form-select-sm" required>
          <% ['SUPLEMENTAR','ESPECIAL','EXTRAORDINARIO'].forEach(function(t) { %>
            <option value="<%= t %>" <%= valores.tipo === t ? 'selected' : '' %>><%= t.charAt(0) + t.slice(1).toLowerCase() %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Número <span class="text-danger">*</span></label>
        <input type="text" name="numero" class="form-control form-control-sm font-monospace" required maxlength="50" value="<%= valores.numero || '' %>" placeholder="ex.: 1/2026">
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Data <span class="text-danger">*</span></label>
        <input type="date" name="data" class="form-control form-control-sm" required value="<%= valores.data || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Ato legal <span class="text-danger">*</span></label>
        <input type="text" name="atoLegal" class="form-control form-control-sm" required maxlength="120" value="<%= valores.atoLegal || '' %>" placeholder="Lei 1.234/2026">
      </div>
      <div class="col-12">
        <label class="form-label small fw-semibold">Justificativa</label>
        <input type="text" name="justificativa" class="form-control form-control-sm" maxlength="300" value="<%= valores.justificativa || '' %>">
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
      <h3 class="h6 fw-bold mb-0">Itens</h3>
      <button type="button" class="btn btn-sm btn-outline-primary" onclick="addItem()"><i class="bi bi-plus me-1"></i>Adicionar item</button>
    </div>
    <p class="text-muted small mb-2">Reforço (+) soma na dotação; Anulação (−) abate saldo de uma dotação-fonte. O total anulado não pode superar o reforçado.</p>

    <div class="card border-0 shadow-sm mb-3"><div class="card-body p-0">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light"><tr><th class="ps-3">Dotação</th><th style="width:140px">Operação</th><th class="text-end" style="width:160px">Valor R$</th><th style="width:48px"></th></tr></thead>
        <tbody id="itens-tbody">
          <% itensPre.forEach(function(it) { %>
            <tr>
              <td class="ps-3">
                <select name="dotacaoId" class="form-select form-select-sm" required>
                  <option value="">— selecione —</option>
                  <% dotacoes.forEach(function(d) { %>
                    <option value="<%= d.id %>" <%= it.dotacaoId === d.id ? 'selected' : '' %>><%= rotuloDotacao(d) %></option>
                  <% }) %>
                </select>
              </td>
              <td>
                <select name="operacao" class="form-select form-select-sm">
                  <option value="REFORCO" <%= it.operacao !== 'ANULACAO' ? 'selected' : '' %>>Reforço (+)</option>
                  <option value="ANULACAO" <%= it.operacao === 'ANULACAO' ? 'selected' : '' %>>Anulação (−)</option>
                </select>
              </td>
              <td><input type="number" name="valor" step="0.01" min="0.01" class="form-control form-control-sm text-end font-monospace" required value="<%= it.valor || '' %>"></td>
              <td class="text-center"><button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="this.closest('tr').remove()" title="Remover"><i class="bi bi-x-lg"></i></button></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div></div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Lançar crédito</button>
      <a href="/app/orcamento/creditos" class="btn btn-sm btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>

<template id="row-tpl">
  <tr>
    <td class="ps-3">
      <select name="dotacaoId" class="form-select form-select-sm" required>
        <option value="">— selecione —</option>
        <% dotacoes.forEach(function(d) { %>
          <option value="<%= d.id %>"><%= rotuloDotacao(d) %></option>
        <% }) %>
      </select>
    </td>
    <td>
      <select name="operacao" class="form-select form-select-sm">
        <option value="REFORCO">Reforço (+)</option>
        <option value="ANULACAO">Anulação (−)</option>
      </select>
    </td>
    <td><input type="number" name="valor" step="0.01" min="0.01" class="form-control form-control-sm text-end font-monospace" required></td>
    <td class="text-center"><button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="this.closest('tr').remove()" title="Remover"><i class="bi bi-x-lg"></i></button></td>
  </tr>
</template>
<script>
  function addItem() {
    const tpl = document.getElementById('row-tpl')
    document.getElementById('itens-tbody').appendChild(tpl.content.cloneNode(true))
  }
</script>
</body>
</html>
