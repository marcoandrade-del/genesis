<!DOCTYPE html>
<html lang="pt-BR">
<%
  function esc(s) {
    return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]
    })
  }
  // Conteúdo (HTML escapado) de cada elemento de faixa, preenchido com os dados reais.
  function conteudoEl(el) {
    switch (el.tipo) {
      case 'BRASAO':
        return entidade.brasao
          ? '<img src="' + esc(entidade.brasao) + '" style="max-height:' + (Number(el.altura) || 48) + 'px" alt="Brasão">'
          : '<span class="text-muted fst-italic">Brasão</span>'
      case 'NOME_ENTIDADE': return esc(entidade.nome)
      case 'NOME_RELATORIO': return esc(relatorio.nome)
      case 'DATA_GERACAO': return esc(geradoEm.toLocaleDateString('pt-BR'))
      case 'HORA_GERACAO': return esc(geradoEm.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }))
      case 'NUMERO_PAGINA': return 'Página 1 de 1'
      case 'ENDERECO_ENTIDADE': return esc(entidade.endereco || '')
      default: return esc(el.tipo)
    }
  }
  // Estilo do elemento: posição + formatação opcional (mesmas regras do PDF —
  // estiloElemento em relatorio-pdf.ts; alinhamento muda a âncora do x).
  function estiloEl(el) {
    var s = 'left:' + (Number(el.x) || 0) + '%;top:' + (Number(el.y) || 0) + '%'
    if (el.alinhamento === 'centro') s += ';transform:translateX(-50%)'
    else if (el.alinhamento === 'dir') s += ';transform:translateX(-100%)'
    if (el.fonte === 'serif') s += ';font-family:serif'
    else if (el.fonte === 'mono') s += ';font-family:monospace'
    if (Number(el.tamanho)) s += ';font-size:' + Number(el.tamanho) + 'px'
    if (el.negrito) s += ';font-weight:bold'
    if (el.italico) s += ';font-style:italic'
    if (el.sublinhado) s += ';text-decoration:underline'
    return s
  }
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= relatorio.nome %> · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
  <style>
    .faixa { position: relative; }
    .faixa .el { position: absolute; font-size: 13px; white-space: nowrap; }
    .folha { background: #fff; }
    @media print { .no-print { display: none !important; } }
    /* Menu de exportação via <details> nativo (a prévia não carrega o JS do Bootstrap). */
    details.export-menu { position: relative; }
    details.export-menu > summary { list-style: none; cursor: pointer; }
    details.export-menu > summary::-webkit-details-marker { display: none; }
    details.export-menu .dropdown-menu { display: none; position: absolute; top: 100%; right: 0; left: auto; z-index: 10; }
    details.export-menu[open] .dropdown-menu { display: block; }
  </style>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0 no-print" style="height:56px">
  <a class="navbar-brand fw-bold fs-6" href="/app"><i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis</a>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">
      <%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> ·
      <strong class="text-white"><%= entidade.nome %></strong> · <strong class="text-white font-monospace"><%= ano %></strong>
    </span>
    <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
  </div>
</nav>

<div class="container py-4" style="max-width:1000px">
  <nav aria-label="breadcrumb" class="no-print">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/relatorios" class="text-decoration-none">Relatórios</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= relatorio.nome %></li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <h2 class="h4 fw-bold mb-0"><%= relatorio.nome %></h2>
    <div class="d-flex gap-2">
      <button class="btn btn-sm btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer me-1"></i>Imprimir</button>
      <details class="export-menu d-inline-block">
        <summary class="btn btn-sm btn-outline-secondary"><i class="bi bi-download me-1"></i>Exportar <i class="bi bi-caret-down-fill ms-1" style="font-size:.65em"></i></summary>
        <ul class="dropdown-menu shadow-sm mt-1 py-1">
          <% formatos.forEach(function(f) { %>
            <li><a class="dropdown-item small" href="/app/relatorios/meus/<%= relatorio.id %>/exportar/<%= f.id %>"<%- f.download ? ' download' : ' target="_blank"' %>><i class="bi <%= f.icone %> me-2"></i><%= f.label %></a></li>
          <% }) %>
        </ul>
      </details>
      <a href="/app/relatorios" class="btn btn-sm btn-outline-secondary">Voltar</a>
    </div>
  </div>

  <% if (erro) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i><%= erro %></div>
  <% } else { %>
    <div class="folha card border-0 shadow-sm">
      <div class="card-body">
        <% if (cabecalho) { var lc = Array.isArray(cabecalho.layout) ? cabecalho.layout : [] %>
          <div class="faixa border-bottom mb-3" style="height:<%= cabecalho.altura %>px">
            <% lc.forEach(function(el) { %>
              <div class="el" style="<%= estiloEl(el) %>"><%- conteudoEl(el) %></div>
            <% }) %>
          </div>
        <% } %>

        <div class="small text-muted mb-1">
          <%= resultado.total %> linha(s)<%= resultado.truncado ? ' — mostrando as primeiras ' + resultado.linhas.length : '' %>
        </div>
        <table class="table table-sm table-bordered align-middle">
          <thead class="table-light"><tr><% resultado.colunas.forEach(function(c) { %><th><%= c %></th><% }) %></tr></thead>
          <tbody>
            <% if (!render || render.linhas.length === 0) { %>
              <tr><td colspan="<%= resultado.colunas.length || 1 %>" class="text-center text-muted py-3">Sem resultados.</td></tr>
            <% } else { render.linhas.forEach(function(l) { %>
              <tr class="<%= l.tipo === 'detalhe' ? '' : 'fw-bold table-light' %>"><% l.celulas.forEach(function(c) { %><td class="font-monospace small"><%= c %></td><% }) %></tr>
            <% }) } %>
          </tbody>
        </table>

        <% if (render && render.resumo.length) { %>
          <div class="mt-2 font-monospace small" id="resumo-totais">
            <% render.resumo.forEach(function(it) { %>
              <div><%= it.rotulo %>: <strong><%= it.texto %></strong></div>
            <% }) %>
            <% if (render.parcial) { %>
              <div class="text-muted fst-italic">Valores parciais — o resultado foi truncado.</div>
            <% } %>
          </div>
        <% } %>

        <% if (rodape) { var lr = Array.isArray(rodape.layout) ? rodape.layout : [] %>
          <div class="faixa border-top mt-3" style="height:<%= rodape.altura %>px">
            <% lr.forEach(function(el) { %>
              <div class="el" style="<%= estiloEl(el) %>"><%- conteudoEl(el) %></div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <% if (totais && podeEscrever) { %>
    <details class="no-print card border-0 shadow-sm mt-3" id="painel-totais">
      <summary class="card-body py-2 small fw-semibold">
        <i class="bi bi-sliders me-1"></i>Configurar totais
        <span class="text-muted fw-normal">(<%= totais.automatico ? 'automático: soma das colunas numéricas' : 'personalizado' %>)</span>
      </summary>
      <div class="card-body pt-0">
        <p class="form-text mt-0">
          Marque as agregações desejadas por coluna — cada uma vira uma linha no fim do relatório, com rótulo editável.
          Sem configuração, toda coluna numérica recebe soma automaticamente.
        </p>
        <form method="post" action="/app/relatorios/meus/<%= relatorio.id %>/totais" id="form-totais">
          <input type="hidden" name="totais" id="campo-totais">
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-2">
              <thead class="table-light">
                <tr>
                  <th>Coluna</th>
                  <% totais.aggTipos.forEach(function(a) { %><th class="text-center small"><%= a.label %></th><% }) %>
                </tr>
              </thead>
              <tbody>
                <% resultado.colunas.forEach(function(c, i) { %>
                  <tr>
                    <td class="font-monospace small"><%= c %></td>
                    <% totais.aggTipos.forEach(function(a) { %>
                      <td class="text-center">
                        <input type="checkbox" class="form-check-input agg-check" data-coluna="<%= c %>" data-agg="<%= a.id %>"
                          <%= a.id === 'CONTAGEM' || totais.numericas[i] ? '' : 'disabled' %>>
                      </td>
                    <% }) %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div id="rotulos-totais" class="mb-2"></div>
          <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="chk-subtotal">
            <label class="form-check-label small" for="chk-subtotal">Subtotal de soma ao fim de cada página (prévia e PDF)</label>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar totais</button>
            <button type="submit" class="btn btn-sm btn-outline-secondary" id="btn-totais-auto">Voltar ao automático</button>
          </div>
        </form>
      </div>
    </details>
    <script>
      (function () {
        var CFG = <%- JSON.stringify(totais.cfg) %>
        var ROTULOS_PADRAO = <%- JSON.stringify(totais.rotulosPadrao) %>
        var AGGS = <%- JSON.stringify(totais.aggTipos) %>
        var form = document.getElementById('form-totais')
        var campo = document.getElementById('campo-totais')
        var chkSubtotal = document.getElementById('chk-subtotal')
        var painelRotulos = document.getElementById('rotulos-totais')
        var checks = Array.prototype.slice.call(form.querySelectorAll('.agg-check'))
        var chave = function (col, agg) { return col + '␀' + agg }
        // Rótulos digitados pelo usuário (sobrevivem a marcar/desmarcar).
        var rotulos = {}

        function aggLabel(id) {
          for (var i = 0; i < AGGS.length; i++) if (AGGS[i].id === id) return AGGS[i].label
          return id
        }
        function rotuloDefault(col, agg) {
          return (ROTULOS_PADRAO[col] || {})[agg] || agg + ' de ' + col
        }

        function montarRotulos() {
          painelRotulos.replaceChildren()
          checks.forEach(function (ch) {
            if (!ch.checked) return
            var col = ch.dataset.coluna
            var agg = ch.dataset.agg
            var linha = document.createElement('div')
            linha.className = 'row g-2 align-items-center mb-1'
            var rot = document.createElement('div')
            rot.className = 'col-md-4 small text-muted font-monospace'
            rot.textContent = col + ' · ' + aggLabel(agg)
            var celula = document.createElement('div')
            celula.className = 'col-md-8'
            var input = document.createElement('input')
            input.type = 'text'
            input.className = 'form-control form-control-sm rotulo-total'
            input.maxLength = 120
            input.value = rotulos[chave(col, agg)] || rotuloDefault(col, agg)
            input.addEventListener('input', function () { rotulos[chave(col, agg)] = input.value })
            celula.appendChild(input)
            linha.appendChild(rot)
            linha.appendChild(celula)
            painelRotulos.appendChild(linha)
          })
        }

        // Preenche a partir da config efetiva (salva ou default automático).
        CFG.itens.forEach(function (it) {
          if (it.rotulo) rotulos[chave(it.coluna, it.agg)] = it.rotulo
          checks.forEach(function (ch) {
            if (ch.dataset.coluna === it.coluna && ch.dataset.agg === it.agg && !ch.disabled) ch.checked = true
          })
        })
        chkSubtotal.checked = CFG.subtotalPagina !== false
        montarRotulos()
        checks.forEach(function (ch) { ch.addEventListener('change', montarRotulos) })

        var voltarAuto = false
        document.getElementById('btn-totais-auto').addEventListener('click', function () { voltarAuto = true })
        form.addEventListener('submit', function () {
          if (voltarAuto) {
            campo.value = ''
            return
          }
          var itens = []
          checks.forEach(function (ch) {
            if (!ch.checked) return
            var col = ch.dataset.coluna
            var agg = ch.dataset.agg
            var rot = (rotulos[chave(col, agg)] || '').trim()
            var item = { coluna: col, agg: agg }
            if (rot && rot !== rotuloDefault(col, agg)) item.rotulo = rot
            itens.push(item)
          })
          campo.value = JSON.stringify({ subtotalPagina: chkSubtotal.checked, itens: itens })
        })
      })()
    </script>
    <% } %>
  <% } %>
</div>
</body>
</html>
