<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Saldo Orçamentário · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/orcamento" class="text-decoration-none">Orçamento</a></li>
      <li class="breadcrumb-item active" aria-current="page">Saldo</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-1">
    <h2 class="h4 fw-bold mb-0">Saldo Orçamentário — Despesa <span class="font-monospace fs-6 text-muted"><%= ano %></span></h2>
    <span class="badge bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-eye me-1"></i>Somente leitura</span>
  </div>
  <p class="text-muted small mb-4">
    Disponível = Autorizado − Reservado − Empenhado · <strong><%= entidade.nome %></strong>, exercício <strong><%= ano %></strong>.
  </p>

  <% if (!saldo.temOrcamento) { %>
    <div class="alert alert-info py-2 small">
      <i class="bi bi-info-circle me-1"></i>Não há orçamento (LOA) cadastrado para este exercício.
    </div>
  <% } else { %>
    <%# Resumo geral %>
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="small text-muted">Autorizado</div>
          <div class="h5 fw-bold mb-0 font-monospace"><%= Number(saldo.resumo.autorizado).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
        </div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="small text-muted">Reservado</div>
          <div class="h5 fw-bold mb-0 font-monospace"><%= Number(saldo.resumo.reservado).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
        </div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
          <div class="small text-muted">Empenhado</div>
          <div class="h5 fw-bold mb-0 font-monospace"><%= Number(saldo.resumo.empenhado).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
        </div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100" style="background: var(--canvas-soft)"><div class="card-body">
          <div class="small text-muted">Disponível</div>
          <div class="h5 fw-bold mb-0 font-monospace <%= saldo.resumo.disponivel < 0 ? 'text-danger' : '' %>"><%= Number(saldo.resumo.disponivel).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
        </div></div>
      </div>
    </div>

    <%- include('_saldo-tabela', { titulo: 'Por Unidade Orçamentária', icone: 'building', rotuloCol: 'Unidade', linhas: saldo.porUnidade, arvore: false }) %>
    <%- include('_saldo-tabela', { titulo: 'Por Fonte de Recurso', icone: 'cash-stack', rotuloCol: 'Fonte', linhas: saldo.porFonte, arvore: false }) %>
    <%- include('_saldo-tabela', { titulo: 'Por Função', icone: 'diagram-2', rotuloCol: 'Função', linhas: saldo.porFuncao, arvore: false }) %>
    <%- include('_saldo-tabela', { titulo: 'Por Conta de Despesa (com roll-up)', icone: 'diagram-3', rotuloCol: 'Conta', linhas: saldo.porConta, arvore: true }) %>
  <% } %>
</div>
</body>
</html>
