<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ordens de Pagamento · <%= entidade.nome %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">
<%- include('_navbar') %>

<div class="container py-4" style="max-width:1100px">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/app" class="text-decoration-none">Painel</a></li>
      <li class="breadcrumb-item"><a href="/app/compras" class="text-decoration-none">Compras</a></li>
      <li class="breadcrumb-item active" aria-current="page">Ordens de Pagamento</li>
    </ol>
  </nav>

  <h2 class="h4 fw-bold mb-1">Ordens de Pagamento <span class="text-muted fs-6">(3º estágio da despesa)</span></h2>
  <p class="text-muted small mb-3">Ordens da entidade <strong><%= entidade.nome %></strong>. <%= lista.length %> ordem(ns).</p>

  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light"><tr><th class="ps-3">Nº</th><th>Liquidação / Empenho</th><th>Conta Bancária</th><th class="text-end">Valor R$</th><th>Status</th></tr></thead>
      <tbody>
        <% if (lista.length === 0) { %><tr><td colspan="5" class="text-center text-muted py-4">Sem ordens de pagamento.</td></tr><% } %>
        <% lista.forEach(function(o) { %>
          <tr>
            <td class="ps-3 font-monospace"><%= o.numero %></td>
            <td>
              <div class="small font-monospace"><%= o.liquidacao.numero %></div>
              <div class="text-muted font-monospace" style="font-size:.72rem">emp. <%= o.liquidacao.empenho.numero %></div>
            </td>
            <td class="small text-muted"><%= o.contaBancaria %></td>
            <td class="text-end font-monospace"><%= Number(o.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            <td>
              <% if (o.status === 'PAGA') { %><span class="badge bg-success bg-opacity-10 text-success">Paga</span>
              <% } else if (o.status === 'EMITIDA') { %><span class="badge bg-primary bg-opacity-10 text-primary">Emitida</span>
              <% } else { %><span class="badge bg-secondary bg-opacity-10 text-secondary">Cancelada</span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div></div>
</div>
</body>
</html>
