<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gênesis · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<%- include('_navbar') %>

<div class="container py-4" style="max-width:960px">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="h4 fw-bold mb-1"><%= entidade.nome %></h2>
      <div class="small text-muted">
        Exercício <strong><%= ano %></strong> ·
        <% if (nivel === 'ADMIN') { %>
          <span class="badge bg-danger bg-opacity-10 text-danger">Admin</span>
        <% } else if (nivel === 'ESCRITA') { %>
          <span class="badge bg-primary bg-opacity-10 text-primary">Escrita</span>
        <% } else { %>
          <span class="badge bg-secondary bg-opacity-10 text-secondary">Leitura</span>
        <% } %>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="h6 fw-bold text-muted text-uppercase mb-0" style="letter-spacing:.05em">Áreas de trabalho</h3>
    <button type="button" id="gx-areas-reset" class="btn btn-link btn-sm text-muted text-decoration-none p-0 <%= typeof temOrdemCustom !== 'undefined' && temOrdemCustom ? '' : 'd-none' %>" title="Voltar à ordem padrão">
      <i class="bi bi-arrow-counterclockwise me-1"></i>Restaurar ordem
    </button>
  </div>
  <p class="small text-muted mb-2" id="gx-areas-dica"><i class="bi bi-grip-vertical me-1"></i>Arraste pelo punho para reordenar as áreas do seu painel.</p>
  <div class="row g-3 mb-4" id="gx-areas-grid">
    <% (typeof menuApp !== 'undefined' ? menuApp : []).forEach(function (area) { %>
      <div class="col-md-3 col-sm-6 gx-area-col" data-item-id="<%= area.id %>">
        <div class="card border-0 shadow-sm h-100 position-relative gx-area-card">
          <button type="button" class="gx-area-grip" draggable="true" title="Arrastar para reordenar" aria-label="Reordenar área">
            <i class="bi bi-grip-vertical"></i>
          </button>
          <% if (area.rota) { %>
            <% const _fav = typeof favoritoIds !== 'undefined' && favoritoIds && favoritoIds.indexOf(area.id) !== -1 %>
            <button type="button" class="gx-fav-star gx-fav-star-card <%= _fav ? 'is-fav' : '' %>"
                    data-fav-id="<%= area.id %>" data-fav-nome="<%= area.nome %>"
                    data-fav-rota="<%= area.rota %>" data-fav-icone="<%= area.icone || 'bi-grid' %>"
                    title="<%= _fav ? 'Remover dos favoritos' : 'Favoritar' %>" aria-label="Favoritar">
              <i class="bi <%= _fav ? 'bi-star-fill' : 'bi-star' %>"></i>
            </button>
          <% } %>
          <a href="<%= area.rota || '#' %>" class="text-decoration-none">
            <div class="card-body d-flex align-items-center gap-3">
              <i class="bi <%= area.icone || 'bi-grid' %> fs-3 text-primary"></i>
              <div>
                <div class="fw-semibold text-dark"><%= area.nome %></div>
                <% if (area.descricao) { %><div class="small text-muted"><%= area.descricao %></div><% } %>
              </div>
            </div>
          </a>
        </div>
      </div>
    <% }) %>
  </div>

  <style>
    .gx-area-card { transition: box-shadow .15s, opacity .15s; }
    /* Estrela de favoritar no card (reusa .gx-fav-star do _navbar); fica no canto,
       sempre visível p/ descoberta; a alça de arrastar desloca p/ a esquerda dela. */
    .gx-fav-star-card { top: .4rem; right: .4rem; transform: none; z-index: 3; }
    .gx-area-grip {
      position: absolute; top: .35rem; right: 2.3rem; z-index: 2;
      width: 26px; height: 26px; border: 0; border-radius: 8px; background: transparent;
      color: var(--mute, #868685); cursor: grab; display: grid; place-items: center;
      opacity: 0; transition: opacity .12s, background .12s;
    }
    .gx-area-card:hover .gx-area-grip { opacity: 1; }
    .gx-area-grip:hover { background: rgba(14,15,12,.06); color: var(--ink, #0e0f0c); }
    .gx-area-grip:active { cursor: grabbing; }
    .gx-area-col.gx-dragging { opacity: .45; }
    .gx-area-col.gx-dragover .gx-area-card { box-shadow: 0 0 0 2px var(--primary, #9fe870); }
  </style>

  <script>
    (function () {
      var grid = document.getElementById('gx-areas-grid');
      if (!grid) return;
      var resetBtn = document.getElementById('gx-areas-reset');
      var arrastado = null;

      function colsOrdenadas() {
        return Array.prototype.slice.call(grid.querySelectorAll('.gx-area-col'));
      }

      function salvar() {
        var itens = colsOrdenadas().map(function (c) { return c.getAttribute('data-item-id'); });
        fetch('/app/dashboard/ordem', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'fetch' },
          body: JSON.stringify({ itens: itens }),
        }).then(function () { if (resetBtn) resetBtn.classList.remove('d-none'); }).catch(function () {});
      }

      grid.addEventListener('dragstart', function (e) {
        var grip = e.target.closest('.gx-area-grip');
        if (!grip) { e.preventDefault(); return; }
        arrastado = grip.closest('.gx-area-col');
        if (!arrastado) return;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', arrastado.getAttribute('data-item-id') || '');
        var card = arrastado.querySelector('.gx-area-card');
        if (card && e.dataTransfer.setDragImage) e.dataTransfer.setDragImage(card, 20, 20);
        // adia a classe p/ não sumir o drag image
        setTimeout(function () { arrastado.classList.add('gx-dragging'); }, 0);
      });

      grid.addEventListener('dragover', function (e) {
        if (!arrastado) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        var alvo = e.target.closest('.gx-area-col');
        if (!alvo || alvo === arrastado) return;
        var r = alvo.getBoundingClientRect();
        var depois = (e.clientX - r.left) > r.width / 2;
        grid.insertBefore(arrastado, depois ? alvo.nextSibling : alvo);
      });

      grid.addEventListener('dragend', function () {
        if (!arrastado) return;
        arrastado.classList.remove('gx-dragging');
        arrastado = null;
        salvar();
      });

      if (resetBtn) {
        resetBtn.addEventListener('click', function () {
          fetch('/app/dashboard/ordem', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'fetch' },
            body: JSON.stringify({ reset: true }),
          }).then(function () { window.location.reload(); }).catch(function () {});
        });
      }
    })();
  </script>

  <div class="row g-3">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted mb-1">Município</div>
          <div class="h5 fw-semibold mb-0">
            <%= entidade.municipio.nome %> <span class="text-muted">/ <%= entidade.municipio.estado.sigla %></span>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted mb-1">Exercício corrente</div>
          <div class="h5 fw-semibold mb-0 font-monospace"><%= ano %></div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
