<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gênesis · <%= entidade.nome %> · <%= ano %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <%- include('../layouts/_theme') %>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark px-3 py-0" style="height:56px">
  <a class="navbar-brand fw-bold fs-6" href="/app">
    <i class="bi bi-heptagon-fill text-primary me-2"></i>Gênesis
  </a>
  <div class="d-flex align-items-center gap-3">
    <span class="text-white-50 small">
      <%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> ·
      <strong class="text-white"><%= entidade.nome %></strong> ·
      <strong class="text-white font-monospace"><%= ano %></strong>
    </span>
    <a href="/app/contexto" class="btn btn-sm btn-outline-secondary text-white border-secondary">
      <i class="bi bi-arrow-left-right me-1"></i>Trocar contexto
    </a>
    <a href="/app/logout" class="btn btn-sm btn-outline-secondary text-white border-secondary">
      <i class="bi bi-box-arrow-right me-1"></i>Sair
    </a>
  </div>
</nav>

<div class="container py-4" style="max-width:960px">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="h4 fw-bold mb-1"><%= entidade.nome %></h2>
      <div class="small text-muted">
        Exercício <strong><%= ano %></strong> ·
        <% if (nivel === 'ADMIN') { %>
          <span class="badge bg-danger bg-opacity-10 text-danger">Admin</span>
        <% } else if (nivel === 'ESCRITA') { %>
          <span class="badge bg-primary bg-opacity-10 text-primary">Escrita</span>
        <% } else { %>
          <span class="badge bg-secondary bg-opacity-10 text-secondary">Leitura</span>
        <% } %>
      </div>
    </div>
  </div>

  <h3 class="h6 fw-bold text-muted text-uppercase mb-2" style="letter-spacing:.05em">Áreas de trabalho</h3>
  <div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
      <a href="/app/orcamento" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <i class="bi bi-journal-bookmark fs-3 text-primary"></i>
            <div>
              <div class="fw-semibold text-dark">Orçamento (LOA)</div>
              <div class="small text-muted">Dotações e previsões</div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3 col-sm-6">
      <a href="/app/lancamentos" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <i class="bi bi-receipt fs-3 text-primary"></i>
            <div>
              <div class="fw-semibold text-dark">Lançamentos</div>
              <div class="small text-muted">Execução contábil do exercício</div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3 col-sm-6">
      <a href="/app/contas" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex align-items-center gap-3">
            <i class="bi bi-diagram-3 fs-3 text-primary"></i>
            <div>
              <div class="fw-semibold text-dark">Plano de Contas</div>
              <div class="small text-muted">Contas contábeis do exercício</div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 shadow-sm h-100 opacity-50">
        <div class="card-body d-flex align-items-center gap-3">
          <i class="bi bi-file-earmark-bar-graph fs-3 text-secondary"></i>
          <div>
            <div class="fw-semibold">Relatórios <span class="badge bg-light text-muted ms-1">em breve</span></div>
            <div class="small text-muted">Demonstrativos e consultas</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted mb-1">Município</div>
          <div class="h5 fw-semibold mb-0">
            <%= entidade.municipio.nome %> <span class="text-muted">/ <%= entidade.municipio.estado.sigla %></span>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted mb-1">Exercício corrente</div>
          <div class="h5 fw-semibold mb-0 font-monospace"><%= ano %></div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
