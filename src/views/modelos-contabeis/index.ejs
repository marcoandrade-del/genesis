<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Modelos Contábeis</h2>
  <button class="btn btn-primary btn-sm"
    hx-get="/admin/modelos-contabeis/form"
    hx-target="#modal-body"
    hx-swap="innerHTML">
    <i class="bi bi-plus-lg me-1"></i>Novo Modelo
  </button>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Descrição</th>
          <th>Estados</th>
          <th>Municípios</th>
          <th>Planos</th>
          <th>Status</th>
          <th class="text-end pe-3">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (modelos.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-5">
            <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum modelo contábil cadastrado.
          </td></tr>
        <% } %>
        <% modelos.forEach(function(m) { %>
          <tr id="modelo-<%= m.id %>">
            <td class="ps-3 fw-semibold"><%= m.descricao %></td>
            <td class="text-muted small"><%= m._count.estados %></td>
            <td class="text-muted small"><%= m._count.municipios %></td>
            <td class="small">
              <a href="/admin/planos-de-contas?modeloContabilId=<%= m.id %>" class="text-decoration-none" title="Planos contábeis deste modelo"><%= m._count.planos %></a>
            </td>
            <td>
              <span class="badge rounded-pill <%= m.ativo ? 'bg-success' : 'bg-secondary' %> bg-opacity-75">
                <%= m.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </td>
            <td class="text-end pe-3">
              <div class="btn-group me-1">
                <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Planos de contas deste modelo">
                  <i class="bi bi-diagram-3 me-1"></i>Planos
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><h6 class="dropdown-header">Planos deste modelo</h6></li>
                  <li><a class="dropdown-item" href="/admin/planos-de-contas?modeloContabilId=<%= m.id %>"><i class="bi bi-bank me-2"></i>Contábil (PCASP)</a></li>
                  <li><a class="dropdown-item" href="/admin/planos-contas-receita?modeloContabilId=<%= m.id %>"><i class="bi bi-graph-down-arrow me-2"></i>Receita</a></li>
                  <li><a class="dropdown-item" href="/admin/planos-contas-despesa?modeloContabilId=<%= m.id %>"><i class="bi bi-graph-up-arrow me-2"></i>Despesa</a></li>
                  <li><a class="dropdown-item" href="/admin/fontes-recurso?modeloContabilId=<%= m.id %>"><i class="bi bi-cash-stack me-2"></i>Fontes de Recurso</a></li>
                </ul>
              </div>
              <button class="btn btn-sm btn-outline-secondary me-1"
                hx-get="/admin/modelos-contabeis/<%= m.id %>/form"
                hx-target="#modal-body"
                hx-swap="innerHTML"
                title="Editar">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-sm btn-outline-danger"
                data-id="<%= m.id %>" data-nome="<%= m.descricao %>"
                onclick="confirmarExclusaoAsync('modelo contábil', this.dataset.id, this.dataset.nome, { url: '/admin/modelos-contabeis/' + this.dataset.id, target: '#modelo-' + this.dataset.id, swap: 'outerHTML' })"
                title="Excluir">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
