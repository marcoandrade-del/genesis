<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-journal-text me-2 text-primary"></i><%= modelo ? 'Editar Modelo Contábil' : 'Novo Modelo Contábil' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (modelo) { %>
    hx-put="/admin/modelos-contabeis/<%= modelo.id %>"
  <% } else { %>
    hx-post="/admin/modelos-contabeis"
  <% } %>
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Descrição <span class="text-danger">*</span></label>
      <input type="text" name="descricao" class="form-control form-control-sm"
        value="<%= modelo ? modelo.descricao : '' %>"
        placeholder="ex.: PCASP — Plano de Contas Aplicado ao Setor Público"
        required maxlength="200">
      <div class="form-text">Identifica o conjunto de regras contábeis que vai ser usado por estados e municípios.</div>
    </div>

    <% if (modelo) { %>
      <div class="form-check">
        <input type="hidden" name="ativo" id="mc-ativo-val" value="<%= modelo.ativo ? 'true' : 'false' %>">
        <input type="checkbox" class="form-check-input" id="mc-chk-ativo"
          <%= modelo.ativo ? 'checked' : '' %>
          onchange="document.getElementById('mc-ativo-val').value = this.checked ? 'true' : 'false'">
        <label for="mc-chk-ativo" class="form-check-label small">Modelo ativo</label>
      </div>
    <% } %>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), this.closest('form').querySelector('[name=descricao]')?.value)">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>
