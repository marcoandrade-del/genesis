<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Dashboard</h2>
  <span class="text-muted small">Visão geral do sistema</span>
</div>

<div class="row g-3 mb-4">
  <%# KPI 1 — métrica-hero em lime; demais ficam em sage neutro (paleta Wise) %>
  <div class="col-6 col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded p-2" style="background: var(--primary)">
          <i class="bi bi-grid-3x3-gap fs-5" style="color: var(--ink)"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1"><%= totais.sistemas %></div>
          <div class="text-muted small">Sistemas</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded p-2" style="background: var(--canvas-soft)">
          <i class="bi bi-boxes fs-5" style="color: var(--ink)"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1"><%= totais.modulos %></div>
          <div class="text-muted small">Módulos</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded p-2" style="background: var(--canvas-soft)">
          <i class="bi bi-people fs-5" style="color: var(--ink)"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1"><%= totais.usuarios %></div>
          <div class="text-muted small">Usuários</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded p-2" style="background: var(--canvas-soft)">
          <i class="bi bi-list-check fs-5" style="color: var(--ink)"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1"><%= totais.itens %></div>
          <div class="text-muted small">Itens</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded p-2" style="background: var(--canvas-soft)">
          <i class="bi bi-file-earmark-bar-graph fs-5" style="color: var(--ink)"></i>
        </div>
        <div>
          <div class="fw-bold fs-4 lh-1"><%= totais.relatoriosFixos %></div>
          <div class="text-muted small">Rel. Fixos</div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom py-2 d-flex justify-content-between align-items-center">
        <span class="fw-semibold small">Sistemas Recentes</span>
        <a href="/admin/sistemas" class="btn btn-link btn-sm p-0 text-decoration-none">Ver todos</a>
      </div>
      <% if (sistemas.length === 0) { %>
        <div class="card-body text-muted small text-center py-4">Nenhum sistema cadastrado.</div>
      <% } else { %>
        <ul class="list-group list-group-flush">
          <% sistemas.forEach(function(s) { %>
            <li class="list-group-item d-flex justify-content-between align-items-center py-2">
              <span class="small"><%= s.nome %></span>
              <span class="badge rounded-pill <%= s.ativo ? 'bg-success' : 'bg-secondary' %> bg-opacity-75">
                <%= s.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom py-2 d-flex justify-content-between align-items-center">
        <span class="fw-semibold small">Usuários Recentes</span>
        <a href="/admin/usuarios" class="btn btn-link btn-sm p-0 text-decoration-none">Ver todos</a>
      </div>
      <% if (usuarios.length === 0) { %>
        <div class="card-body text-muted small text-center py-4">Nenhum usuário cadastrado.</div>
      <% } else { %>
        <ul class="list-group list-group-flush">
          <% usuarios.forEach(function(u) { %>
            <li class="list-group-item d-flex justify-content-between align-items-center py-2">
              <span class="small"><%= u.nomeCompleto %></span>
              <span class="text-muted" style="font-size:.75rem"><%= u.emailPrincipal %></span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom py-2 d-flex justify-content-between align-items-center">
        <span class="fw-semibold small">Relatórios Fixos Recentes</span>
        <a href="/admin/relatorios" class="btn btn-link btn-sm p-0 text-decoration-none">Ver todos</a>
      </div>
      <% if (relatorios.length === 0) { %>
        <div class="card-body text-muted small text-center py-4">Nenhum relatório cadastrado.</div>
      <% } else { %>
        <ul class="list-group list-group-flush">
          <% relatorios.forEach(function(r) { %>
            <li class="list-group-item d-flex justify-content-between align-items-center py-2">
              <div>
                <div class="small"><%= r.nome %></div>
                <div class="text-muted" style="font-size:.75rem"><%= r.sistema.nome %></div>
              </div>
              <span class="badge rounded-pill <%= r.ativo ? 'bg-success' : 'bg-secondary' %> bg-opacity-75">
                <%= r.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>
</div>
