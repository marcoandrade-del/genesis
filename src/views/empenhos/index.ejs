<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Empenhos</h2>
  <% if (entidade) { %>
    <button class="btn btn-primary btn-sm" hx-get="/admin/empenhos/form?entidadeId=<%= entidade.id %>" hx-target="#modal-body" hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Novo Empenho
    </button>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/empenhos">
  <div class="col-md-2"><label class="form-label small fw-semibold mb-1">Estado</label>
    <select name="estadoId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %><option value="<%= e.id %>" <%= estadoSelecionadoId === e.id ? 'selected' : '' %>><%= e.sigla %> — <%= e.nome %></option><% }) %>
    </select></div>
  <div class="col-md-3"><label class="form-label small fw-semibold mb-1">Município</label>
    <select name="municipioId" class="form-select form-select-sm" <%= estadoSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% municipios.forEach(function(m) { %><option value="<%= m.id %>" <%= municipioSelecionadoId === m.id ? 'selected' : '' %>><%= m.nome %></option><% }) %>
    </select></div>
  <div class="col-md-3"><label class="form-label small fw-semibold mb-1">Entidade</label>
    <select name="entidadeId" class="form-select form-select-sm" <%= municipioSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% entidades.forEach(function(e) { %><option value="<%= e.id %>" <%= entidade && e.id === entidade.id ? 'selected' : '' %>><%= e.nome %></option><% }) %>
    </select></div>
</form>

<% if (!entidade) { %>
  <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-1"></i>Selecione estado, município e entidade para listar os empenhos.</div>
<% } else { %>
  <div class="small text-muted mb-2"><strong><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> · <%= entidade.nome %></strong> · <%= empenhos.length %> empenho(s)</div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr><th class="ps-3" style="width:120px">Número</th><th style="width:90px">Tipo</th><th>Fornecedor / Dotação</th><th class="text-end" style="width:110px">Valor R$</th><th class="text-end" style="width:110px">Liquidado</th><th style="width:90px">Status</th><th class="text-end pe-3" style="width:90px">&nbsp;</th></tr>
        </thead>
        <tbody>
          <% if (empenhos.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum empenho para esta entidade.</td></tr>
          <% } %>
          <% empenhos.forEach(function(e) { %>
            <tr id="empenho-<%= e.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= e.numero %></td>
              <td class="small"><%= e.tipo.charAt(0) + e.tipo.slice(1).toLowerCase() %></td>
              <td><div class="fw-semibold small"><%= e.fornecedor.razaoSocial %></div>
                <div class="small text-muted font-monospace"><%= e.dotacaoDespesa.unidadeOrcamentaria.codigo %> · <%= e.dotacaoDespesa.contaDespesa.codigo %> · Fonte <%= e.dotacaoDespesa.fonteRecurso.codigo %></div></td>
              <td class="text-end font-monospace"><%= Number(e.valor).toFixed(2) %></td>
              <td class="text-end font-monospace"><%= Number(e.valorLiquidado).toFixed(2) %></td>
              <td>
                <% if (e.status === 'ATIVO') { %><span class="badge bg-success bg-opacity-10 text-success">Ativo</span>
                <% } else { %><span class="badge bg-secondary bg-opacity-10 text-secondary">Anulado</span><% } %>
              </td>
              <td class="text-end pe-3">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/empenhos/<%= e.id %>/ficha" title="Ficha de empenho (estorno aqui)"><i class="bi bi-card-list me-1"></i>Ficha</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
