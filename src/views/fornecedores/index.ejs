<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Fornecedores</h2>
  <button class="btn btn-primary btn-sm" hx-get="/admin/fornecedores/form" hx-target="#modal-body" hx-swap="innerHTML">
    <i class="bi bi-plus-lg me-1"></i>Novo Fornecedor
  </button>
</div>

<div class="btn-group btn-group-sm mb-3" role="group">
  <a href="/admin/fornecedores" class="btn btn-outline-secondary <%= tipoFiltro === '' ? 'active' : '' %>">Todos</a>
  <a href="/admin/fornecedores?tipo=PJ" class="btn btn-outline-secondary <%= tipoFiltro === 'PJ' ? 'active' : '' %>">Pessoa Jurídica</a>
  <a href="/admin/fornecedores?tipo=PF" class="btn btn-outline-secondary <%= tipoFiltro === 'PF' ? 'active' : '' %>">Pessoa Física</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Tipo</th>
          <th>Documento</th>
          <th>Razão social / Nome</th>
          <th>Nome fantasia</th>
          <th>Status</th>
          <th class="text-end pe-3">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-5">
            <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum fornecedor cadastrado.
          </td></tr>
        <% } %>
        <% items.forEach(function(f) { %>
          <tr id="fornecedor-<%= f.id %>">
            <td class="ps-3">
              <span class="badge rounded-pill <%= f.tipoPessoa === 'PJ' ? 'bg-primary' : 'bg-info' %> bg-opacity-75">
                <%= f.tipoPessoa %>
              </span>
            </td>
            <td class="font-monospace"><%= f.cnpj || f.cpf || '—' %></td>
            <td class="fw-semibold"><%= f.razaoSocial %></td>
            <td class="small text-muted"><%= f.nomeFantasia || '—' %></td>
            <td>
              <span class="badge rounded-pill <%= f.ativo ? 'bg-success' : 'bg-secondary' %> bg-opacity-75">
                <%= f.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </td>
            <td class="text-end pe-3">
              <button class="btn btn-sm btn-outline-secondary me-1"
                hx-get="/admin/fornecedores/<%= f.id %>/form" hx-target="#modal-body" hx-swap="innerHTML"
                title="Editar"><i class="bi bi-pencil"></i></button>
              <button class="btn btn-sm btn-outline-danger"
                hx-delete="/admin/fornecedores/<%= f.id %>"
                hx-target="#fornecedor-<%= f.id %>" hx-swap="outerHTML"
                hx-confirm="Excluir '<%= f.razaoSocial %>'?"
                data-confirm-titulo="Excluir fornecedor" data-confirm-tipo="danger" data-confirm-ok="Excluir"
                title="Excluir"><i class="bi bi-trash"></i></button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
