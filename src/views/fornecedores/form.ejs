<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-truck me-2 text-primary"></i><%= item && item.id ? 'Editar Fornecedor' : 'Novo Fornecedor' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (item && item.id) { %>hx-put="/admin/fornecedores/<%= item.id %>"<% } else { %>hx-post="/admin/fornecedores"<% } %>
  hx-target="#modal-body" hx-swap="innerHTML">

  <div class="modal-body">
    <% if (erro) { %><div class="alert alert-danger py-2 small"><%= erro %></div><% } %>

    <div class="row g-2">
      <div class="col-4 mb-2">
        <label class="form-label small fw-semibold">Tipo <span class="text-danger">*</span></label>
        <select name="tipoPessoa" id="forn-tipo" class="form-select form-select-sm" required onchange="fornToggleDoc()">
          <option value="PJ" <%= item && item.tipoPessoa === 'PF' ? '' : 'selected' %>>Pessoa Jurídica</option>
          <option value="PF" <%= item && item.tipoPessoa === 'PF' ? 'selected' : '' %>>Pessoa Física</option>
        </select>
      </div>
      <div class="col-8 mb-2" id="forn-campo-cnpj">
        <label class="form-label small fw-semibold">CNPJ <span class="text-danger">*</span></label>
        <input type="text" name="cnpj" class="form-control form-control-sm font-monospace"
          value="<%= item && item.cnpj ? item.cnpj : '' %>" maxlength="20">
      </div>
      <div class="col-8 mb-2" id="forn-campo-cpf">
        <label class="form-label small fw-semibold">CPF <span class="text-danger">*</span></label>
        <input type="text" name="cpf" class="form-control form-control-sm font-monospace"
          value="<%= item && item.cpf ? item.cpf : '' %>" maxlength="20">
      </div>

      <div class="col-12 mb-2">
        <label class="form-label small fw-semibold">Razão social / Nome <span class="text-danger">*</span></label>
        <input type="text" name="razaoSocial" class="form-control form-control-sm"
          value="<%= item && item.razaoSocial ? item.razaoSocial : '' %>" maxlength="150" required>
      </div>
      <div class="col-12 mb-2">
        <label class="form-label small fw-semibold">Nome fantasia</label>
        <input type="text" name="nomeFantasia" class="form-control form-control-sm"
          value="<%= item && item.nomeFantasia ? item.nomeFantasia : '' %>" maxlength="150">
      </div>
      <div class="col-7 mb-2">
        <label class="form-label small fw-semibold">E-mail</label>
        <input type="email" name="email" class="form-control form-control-sm"
          value="<%= item && item.email ? item.email : '' %>" maxlength="150">
      </div>
      <div class="col-5 mb-2">
        <label class="form-label small fw-semibold">Telefone</label>
        <input type="text" name="telefone" class="form-control form-control-sm"
          value="<%= item && item.telefone ? item.telefone : '' %>" maxlength="30">
      </div>

      <% if (item && item.id) { %>
        <div class="col-12 mt-1">
          <div class="form-check">
            <input type="checkbox" name="ativo" id="forn-ativo" class="form-check-input" value="true" <%= item.ativo ? 'checked' : '' %>>
            <label for="forn-ativo" class="form-check-label small">Ativo</label>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
  </div>
</form>

<script>
  function fornToggleDoc() {
    var pj = document.getElementById('forn-tipo').value === 'PJ';
    document.getElementById('forn-campo-cnpj').style.display = pj ? '' : 'none';
    document.getElementById('forn-campo-cpf').style.display = pj ? 'none' : '';
  }
  fornToggleDoc();
</script>
