<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Demandas (DOD)</h2>
  <% if (entidade) { %>
    <button class="btn btn-primary btn-sm"
      hx-get="/admin/documentos-demanda/form?entidadeId=<%= entidade.id %>"
      hx-target="#modal-body" hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Nova Demanda
    </button>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/documentos-demanda">
  <div class="col-md-2">
    <label class="form-label small fw-semibold mb-1">Estado</label>
    <select name="estadoId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= estadoSelecionadoId === e.id ? 'selected' : '' %>><%= e.sigla %> — <%= e.nome %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Município</label>
    <select name="municipioId" class="form-select form-select-sm" <%= estadoSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% municipios.forEach(function(m) { %>
        <option value="<%= m.id %>" <%= municipioSelecionadoId === m.id ? 'selected' : '' %>><%= m.nome %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Entidade</label>
    <select name="entidadeId" class="form-select form-select-sm" <%= municipioSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% entidades.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= entidade && e.id === entidade.id ? 'selected' : '' %>><%= e.nome %></option>
      <% }) %>
    </select>
  </div>
</form>

<% if (!entidade) { %>
  <div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle me-1"></i>Selecione estado, município e entidade para listar as demandas.
  </div>
<% } else { %>
  <div class="small text-muted mb-2">
    <strong><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> · <%= entidade.nome %></strong>
    · <%= demandas.length %> demanda(s)
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:120px">Número</th>
            <th>Requisitante</th>
            <th class="text-center" style="width:70px">Itens</th>
            <th style="width:150px">Status</th>
            <th class="text-center" style="width:60px">TR</th>
            <th class="text-end pe-3" style="width:230px">&nbsp;</th>
          </tr>
        </thead>
        <tbody>
          <% if (demandas.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhuma demanda para esta entidade.
            </td></tr>
          <% } %>
          <% demandas.forEach(function(d) { %>
            <tr id="dod-<%= d.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= d.numero %></td>
              <td class="small"><%= d.unidadeOrcamentaria.codigo %> — <%= d.unidadeOrcamentaria.nome %></td>
              <td class="text-center"><span class="badge bg-light text-dark"><%= d._count.itens %></span></td>
              <td class="small">
                <% if (d.status === 'RASCUNHO') { %>
                  <span class="badge bg-secondary bg-opacity-10 text-secondary">Rascunho</span>
                <% } else if (d.status === 'AGUARDANDO_PARECER') { %>
                  <span class="badge bg-warning bg-opacity-25 text-warning-emphasis">Aguardando parecer</span>
                <% } else if (d.status === 'APROVADA') { %>
                  <span class="badge bg-success bg-opacity-10 text-success">Aprovada</span>
                <% } else { %>
                  <span class="badge bg-danger bg-opacity-10 text-danger">Reprovada</span>
                <% } %>
              </td>
              <td class="text-center">
                <% if (d.termoReferencia) { %>
                  <i class="bi bi-check-circle-fill text-success" title="Possui TR"></i>
                <% } else { %>
                  <i class="bi bi-dash-circle text-muted" title="Sem TR"></i>
                <% } %>
              </td>
              <td class="text-end pe-3">
                <% if (d.status === 'RASCUNHO') { %>
                  <button class="btn btn-sm btn-outline-primary me-1"
                    hx-post="/admin/documentos-demanda/<%= d.id %>/status" hx-vals='{"status":"AGUARDANDO_PARECER"}'
                    title="Enviar para parecer"><i class="bi bi-send"></i></button>
                  <button class="btn btn-sm btn-outline-secondary me-1"
                    hx-get="/admin/documentos-demanda/<%= d.id %>/form" hx-target="#modal-body" hx-swap="innerHTML"
                    title="Editar"><i class="bi bi-pencil"></i></button>
                <% } else if (d.status === 'AGUARDANDO_PARECER') { %>
                  <button class="btn btn-sm btn-outline-success me-1"
                    hx-get="/admin/documentos-demanda/<%= d.id %>/parecer" hx-target="#modal-body" hx-swap="innerHTML"
                    title="Registrar parecer"><i class="bi bi-clipboard-check"></i></button>
                  <button class="btn btn-sm btn-outline-warning me-1"
                    hx-post="/admin/documentos-demanda/<%= d.id %>/status" hx-vals='{"status":"RASCUNHO"}'
                    title="Reabrir"><i class="bi bi-arrow-counterclockwise"></i></button>
                <% } else if (d.status === 'REPROVADA') { %>
                  <button class="btn btn-sm btn-outline-warning me-1"
                    hx-post="/admin/documentos-demanda/<%= d.id %>/status" hx-vals='{"status":"RASCUNHO"}'
                    title="Reabrir"><i class="bi bi-arrow-counterclockwise"></i></button>
                <% } %>
                <button class="btn btn-sm <%= d.termoReferencia ? 'btn-outline-info' : 'btn-outline-secondary' %> me-1"
                  hx-get="/admin/documentos-demanda/<%= d.id %>/termo/form" hx-target="#modal-body" hx-swap="innerHTML"
                  title="Termo de Referência"><i class="bi bi-file-earmark-ruled"></i></button>
                <% if (d.status === 'RASCUNHO' && !d.termoReferencia) { %>
                  <button class="btn btn-sm btn-outline-danger"
                    hx-delete="/admin/documentos-demanda/<%= d.id %>"
                    hx-target="#dod-<%= d.id %>" hx-swap="outerHTML"
                    hx-confirm="Excluir a demanda <%= d.numero %>?"
                    data-confirm-titulo="Excluir demanda" data-confirm-tipo="danger" data-confirm-ok="Excluir"
                    title="Excluir"><i class="bi bi-trash"></i></button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
