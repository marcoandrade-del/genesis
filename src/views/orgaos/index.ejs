<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Órgãos</h2>
  <% if (entidade) { %>
    <button class="btn btn-primary btn-sm" hx-get="/admin/orgaos/form?entidadeId=<%= entidade.id %>" hx-target="#modal-body" hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Novo Órgão
    </button>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/orgaos">
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Estado</label>
    <select name="estadoId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %><option value="<%= e.id %>" <%= estadoSelecionadoId === e.id ? 'selected' : '' %>><%= e.sigla %> — <%= e.nome %></option><% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Município</label>
    <select name="municipioId" class="form-select form-select-sm" <%= estadoSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% municipios.forEach(function(m) { %><option value="<%= m.id %>" <%= municipioSelecionadoId === m.id ? 'selected' : '' %>><%= m.nome %></option><% }) %>
    </select>
  </div>
  <div class="col-md-4">
    <label class="form-label small fw-semibold mb-1">Entidade</label>
    <select name="entidadeId" class="form-select form-select-sm" <%= municipioSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% entidades.forEach(function(e) { %><option value="<%= e.id %>" <%= entidade && e.id === entidade.id ? 'selected' : '' %>><%= e.nome %></option><% }) %>
    </select>
  </div>
</form>

<% if (!entidade) { %>
  <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-1"></i>Selecione estado, município e entidade para listar os órgãos.</div>
<% } else { %>
  <div class="small text-muted mb-2"><strong><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> · <%= entidade.nome %></strong> — <%= orgaos.length %> órgão(s)</div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:140px">Código</th>
            <th>Nome</th>
            <th class="text-center" style="width:100px">Status</th>
            <th class="text-end pe-3" style="width:120px">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (orgaos.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum órgão cadastrado.</td></tr>
          <% } %>
          <% orgaos.forEach(function(o) { %>
            <tr id="orgao-<%= o.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= o.codigo %></td>
              <td><%= o.nome %></td>
              <td class="text-center">
                <% if (o.ativo) { %><span class="badge rounded-pill bg-success bg-opacity-75">Ativo</span>
                <% } else { %><span class="badge rounded-pill bg-secondary bg-opacity-75">Inativo</span><% } %>
              </td>
              <td class="text-end pe-3">
                <button class="btn btn-sm btn-outline-secondary me-1" hx-get="/admin/orgaos/<%= o.id %>/form" hx-target="#modal-body" hx-swap="innerHTML" title="Editar"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-sm btn-outline-danger" data-id="<%= o.id %>" data-nome="<%= o.codigo %> — <%= o.nome %>"
                  onclick="confirmarExclusaoAsync('órgão', this.dataset.id, this.dataset.nome, { url: '/admin/orgaos/' + this.dataset.id, target: '#orgao-' + this.dataset.id, swap: 'outerHTML' })" title="Excluir"><i class="bi bi-trash"></i></button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
