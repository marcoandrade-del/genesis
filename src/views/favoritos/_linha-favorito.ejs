<ul class="list-group list-group-flush">
  <% favoritos.forEach(function(f) { %>
    <% var nomeRel = f.relatorioFixo ? f.relatorioFixo.nome : (f.relatorioPersonalizado ? f.relatorioPersonalizado.nome : '—') %>
    <% var isPersonalizado = !!f.relatorioPersonalizado %>
    <li class="list-group-item d-flex align-items-center gap-2 py-1 px-2">
      <i class="bi bi-file-earmark-bar-graph text-muted" style="font-size:.85rem;flex-shrink:0"></i>
      <span class="small flex-grow-1 text-truncate" style="max-width:220px" title="<%= nomeRel %>"><%= nomeRel %></span>
      <span class="badge <%= isPersonalizado ? 'bg-warning text-dark' : 'bg-secondary' %>" style="font-size:.6rem;flex-shrink:0">
        <%= isPersonalizado ? 'PERSONALIZADO' : 'FIXO' %>
      </span>
      <select class="form-select form-select-sm py-0 px-1"
        style="width:140px;font-size:.7rem;flex-shrink:0"
        hx-put="/admin/favoritos/fav/<%= f.id %>/mover"
        hx-target="#modal-body"
        hx-swap="innerHTML"
        hx-trigger="change"
        hx-vals='{"usuarioId": "<%= usuario.id %>"}'>
        <option value="" <%= !pastaAtualId ? 'selected' : '' %>>Mover para...</option>
        <option value="">— Sem pasta (raiz)</option>
        <% pastasPlanas.forEach(function(p) { %>
          <option value="<%= p.id %>" <%= p.id === pastaAtualId ? 'selected' : '' %>><%= p.label %></option>
        <% }) %>
      </select>
      <button class="btn btn-sm btn-outline-danger py-0 px-1"
        hx-delete="/admin/favoritos/fav/<%= f.id %>?usuarioId=<%= usuario.id %>"
        hx-target="#modal-body"
        hx-swap="innerHTML"
        hx-confirm="O favorito será removido da pasta."
        data-confirm-titulo="Remover Favorito"
        data-confirm-tipo="danger"
        data-confirm-ok="Remover"
        data-confirm-destaque="Remover: <%= nomeRel %>"
        title="Remover favorito"
        style="flex-shrink:0">
        <i class="bi bi-x-lg" style="font-size:.75rem"></i>
      </button>
    </li>
  <% }) %>
</ul>
