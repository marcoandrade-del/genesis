<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-file-earmark-person me-2 text-primary"></i><%= relatorio ? 'Editar Relatório' : 'Novo Relatório Personalizado' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (relatorio) { %>
    hx-put="/admin/relatorios-personalizados/<%= relatorio.id %>"
  <% } else { %>
    hx-post="/admin/relatorios-personalizados"
  <% } %>
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <% if (!relatorio) { %>
      <div class="mb-3">
        <label class="form-label small fw-semibold">Usuário <span class="text-danger">*</span></label>
        <input type="hidden" name="usuarioId" id="f-usuarioId" value="">
        <div class="input-group input-group-sm">
          <input type="text" id="f-usuarioId-display" class="form-control form-control-sm"
            placeholder="Selecione um usuário..."
            readonly>
          <button type="button" class="btn btn-outline-secondary" title="Consultar usuários"
            onclick="abrirLookup('usuarios', function(id, nome) {
              document.getElementById('f-usuarioId').value = id;
              document.getElementById('f-usuarioId-display').value = nome;
            })">
            <i class="bi bi-search"></i>
          </button>
        </div>
      </div>
    <% } else { %>
      <div class="mb-3">
        <label class="form-label small fw-semibold">Usuário</label>
        <input type="text" class="form-control form-control-sm" value="<%= usuarioNome %>" disabled>
      </div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Nome <span class="text-danger">*</span></label>
      <input type="text" name="nome" class="form-control form-control-sm"
        value="<%= relatorio ? relatorio.nome : '' %>" required>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Descrição</label>
      <textarea name="descricao" class="form-control form-control-sm" rows="2"><%= relatorio ? (relatorio.descricao || '') : '' %></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Configuração (JSON)</label>
      <textarea name="configuracao" class="form-control form-control-sm font-monospace" rows="5"
        placeholder='{ "colunas": [], "filtros": {} }'><%= relatorio ? JSON.stringify(relatorio.configuracao, null, 2) : '' %></textarea>
      <div class="form-text">Objeto JSON com os parâmetros do relatório.</div>
    </div>

    <% if (relatorio) { %>
      <div class="form-check">
        <input type="hidden" name="ativo" id="rp-ativo-val" value="<%= relatorio.ativo ? 'true' : 'false' %>">
        <input type="checkbox" class="form-check-input" id="chk-ativo"
          <%= relatorio.ativo ? 'checked' : '' %>
          onchange="document.getElementById('rp-ativo-val').value = this.checked ? 'true' : 'false'">
        <label for="chk-ativo" class="form-check-label small">Relatório ativo</label>
      </div>
    <% } %>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), this.closest('form').querySelector('[name=nome]')?.value)">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>
