<div class="offcanvas-header border-bottom py-2">
  <h6 class="offcanvas-title fw-semibold">
    <i class="bi bi-diagram-3 me-2 text-primary"></i>Selecionar Conta
  </h6>
  <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
</div>
<div class="p-2 border-bottom">
  <input type="text" name="q" class="form-control form-control-sm"
    placeholder="Buscar por código ou descrição..."
    value="<%= q %>"
    hx-get="/admin/lookup/contas?planoId=<%= planoId %>"
    hx-trigger="keyup changed delay:300ms"
    hx-target="#lookup-rows-contas"
    hx-swap="innerHTML"
    autofocus>
  <div class="form-text small mt-1">Apenas contas-folhas (que admitem movimento).</div>
</div>
<div id="lookup-rows-contas" class="list-group list-group-flush overflow-auto" style="max-height:calc(100vh - 150px)">
  <%- include('rows_contas', { contas: contas }) %>
</div>
