<% if (usuarios.length === 0) { %>
  <div class="text-center text-muted py-5 small">Nenhum usuário encontrado.</div>
<% } %>
<% usuarios.forEach(function(u) { %>
  <button type="button"
    class="list-group-item list-group-item-action px-3 py-2 border-0 border-bottom"
    data-id="<%= u.id %>" data-nome="<%= u.nomeCompleto %>"
    onclick="selecionarItem(this.dataset.id, this.dataset.nome)">
    <div class="fw-semibold small"><%= u.nomeCompleto %></div>
    <div class="d-flex gap-3 mt-1">
      <span class="text-muted" style="font-size:.75rem"><%= u.emailPrincipal %></span>
    </div>
  </button>
<% }) %>
