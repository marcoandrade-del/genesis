<div class="offcanvas-header border-bottom py-2">
  <h6 class="offcanvas-title fw-semibold">
    <i class="bi bi-lightning me-2 text-primary"></i>Selecionar Item / Funcionalidade
  </h6>
  <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
</div>
<div class="p-2 border-bottom">
  <input type="text" name="q" class="form-control form-control-sm"
    placeholder="Buscar por nome..."
    value="<%= q %>"
    hx-get="/admin/lookup/itens"
    hx-trigger="keyup changed delay:300ms"
    hx-target="#lookup-rows-itens"
    hx-swap="innerHTML"
    autofocus>
</div>
<div id="lookup-rows-itens" class="list-group list-group-flush overflow-auto" style="max-height:calc(100vh - 130px)">
  <%- include('rows_itens', { itens: itens }) %>
</div>
