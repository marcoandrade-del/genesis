<% if (modulos.length === 0) { %>
  <div class="text-center text-muted py-5 small">Nenhum módulo encontrado.</div>
<% } %>
<% modulos.forEach(function(m) { %>
  <button type="button"
    class="list-group-item list-group-item-action px-3 py-2 border-0 border-bottom"
    onclick="selecionarItem('<%= m.id %>', '<%= m.nome.replace(/'/g, `\\'`) %>')">
    <div class="fw-semibold small"><%= m.nome %></div>
    <div class="text-muted" style="font-size:.75rem"><%= m.sistema.nome %></div>
  </button>
<% }) %>
