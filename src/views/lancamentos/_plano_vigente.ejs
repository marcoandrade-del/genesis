<%# Substituído por HTMX sempre que a data muda. Contém badge + hidden planoId
   que o picker de contas lê para filtrar. Sem plano → hidden vazio e mensagem
   bloqueando submit. %>
<% if (plano) { %>
  <span class="badge bg-success-subtle text-success border border-success-subtle">
    <i class="bi bi-check-circle me-1"></i>Plano vigente: <%= plano.descricao %> (<%= plano.ano %>)
  </span>
  <input type="hidden" id="planoId" value="<%= plano.id %>">
<% } else if (ano) { %>
  <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
    <i class="bi bi-exclamation-triangle me-1"></i>Nenhum plano para <%= ano %>
  </span>
  <input type="hidden" id="planoId" value="">
<% } else { %>
  <span class="badge bg-secondary-subtle text-muted">
    <i class="bi bi-dash-circle me-1"></i>Defina uma data
  </span>
  <input type="hidden" id="planoId" value="">
<% } %>
