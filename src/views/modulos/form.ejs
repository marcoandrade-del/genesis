<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-boxes me-2 text-success"></i><%= modulo ? 'Editar Módulo' : 'Novo Módulo' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (modulo) { %>
    hx-put="/admin/modulos/<%= modulo.id %>"
  <% } else { %>
    hx-post="/admin/modulos"
  <% } %>
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Sistema <span class="text-danger">*</span></label>
      <% if (modulo) { %>
        <input type="hidden" name="sistemaId" value="<%= modulo.sistemaId %>">
        <input type="text" class="form-control form-control-sm" value="<%= sistemaNome || modulo.sistemaId %>" readonly>
      <% } else { %>
        <input type="hidden" name="sistemaId" id="f-sistemaId" value="">
        <div class="input-group input-group-sm">
          <input type="text" id="f-sistemaId-display" class="form-control form-control-sm"
            placeholder="Selecione um sistema..." readonly>
          <button type="button" class="btn btn-outline-secondary" title="Consultar sistemas"
            onclick="abrirLookup('sistemas', function(id, nome) {
              document.getElementById('f-sistemaId').value = id;
              document.getElementById('f-sistemaId-display').value = nome;
            })">
            <i class="bi bi-search"></i>
          </button>
        </div>
      <% } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Nome <span class="text-danger">*</span></label>
      <input type="text" name="nome" class="form-control form-control-sm"
        value="<%= modulo ? modulo.nome : '' %>" required>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Descrição</label>
      <textarea name="descricao" class="form-control form-control-sm" rows="2"><%= modulo ? (modulo.descricao || '') : '' %></textarea>
    </div>

    <% if (!modulo) { %>
      <div class="mb-3">
        <label class="form-label small fw-semibold">Administrador <span class="text-danger">*</span></label>
        <input type="hidden" name="adminUsuarioId" id="f-adminUsuarioId"
          value="<%= adminPadrao ? adminPadrao.id : '' %>">
        <div class="input-group input-group-sm">
          <input type="text" id="f-adminUsuarioId-display" class="form-control form-control-sm"
            value="<%= adminPadrao ? adminPadrao.nomeCompleto : '' %>"
            placeholder="Selecione um usuário..."
            readonly>
          <button type="button" class="btn btn-outline-secondary" title="Consultar usuários"
            onclick="abrirLookup('usuarios', function(id, nome) {
              document.getElementById('f-adminUsuarioId').value = id;
              document.getElementById('f-adminUsuarioId-display').value = nome;
            })">
            <i class="bi bi-search"></i>
          </button>
        </div>
        <div class="form-text">Por padrão preenchido com seu usuário. Clique na lupa para trocar.</div>
      </div>
    <% } %>

    <% if (modulo) { %>
      <div class="form-check">
        <input type="hidden" name="ativo" id="mf-ativo-val" value="<%= modulo.ativo ? 'true' : 'false' %>">
        <input type="checkbox" class="form-check-input" id="chk-ativo"
          <%= modulo.ativo ? 'checked' : '' %>
          onchange="document.getElementById('mf-ativo-val').value = this.checked ? 'true' : 'false'">
        <label for="chk-ativo" class="form-check-label small">Módulo ativo</label>
      </div>
    <% } %>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-success"
      onclick="confirmarGravacao(this.closest('form'), this.closest('form').querySelector('[name=nome]')?.value)">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>
