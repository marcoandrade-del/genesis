<style>
  .tree-label {
    cursor: pointer; border-radius: 4px; padding: 2px 4px;
    user-select: none; flex-grow: 1; min-width: 0;
  }
  .tree-label:hover { background: rgba(0,0,0,.06); }
  .tree-label.selecionado { background: rgba(13,110,253,.12); color: #0a58ca; font-weight: 600; }
  .tree-toggle {
    border: none; background: none; padding: 0; width: 18px; height: 18px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: #6c757d; cursor: pointer; border-radius: 3px; transition: background .1s;
  }
  .tree-toggle:hover { background: rgba(0,0,0,.08); }
  .tree-actions { opacity: 0; transition: opacity .15s; flex-shrink: 0; display: flex; align-items: center; gap: 2px; }
  .tree-row:hover .tree-actions { opacity: 1; }
  .tree-row { display: flex; align-items: center; gap: 2px; padding: 1px 6px; border-radius: 4px; }
  .tree-row:hover { background: rgba(0,0,0,.03); }
  .tree-children { padding-left: 16px; }
  #painel-detalhe { min-height: 400px; }
  /* Modo mover: item selecionado para reordenação */
  .tree-mover-ativo > .tree-row,
  .tree-row.tree-mover-ativo {
    background: rgba(13,110,253,.1) !important;
    outline: 2px solid rgba(13,110,253,.4);
    border-radius: 4px;
  }
  .tree-mover-ativo .tree-actions,
  .tree-row.tree-mover-ativo .tree-actions { opacity: 1 !important; }
  .tree-mover-hint { font-size: .65rem; color: #0d6efd; padding: 0 4px; }
  .card-painel-header {
    background: #f8f9fa; border-bottom: 1px solid rgba(0,0,0,.08);
    padding: .6rem 1rem; display: flex; align-items: center; gap: .5rem;
    border-radius: calc(.375rem - 1px) calc(.375rem - 1px) 0 0;
  }
  .dd-ghost { opacity: .4; background: #cfe2ff !important; border-radius: 4px; }
  .dd-chosen { background: rgba(13,110,253,.06) !important; border-radius: 4px; }
  .dd-grip { cursor: grab !important; }
  .dd-grip:active { cursor: grabbing !important; }
</style>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js"></script>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="h5 fw-bold mb-0">
    <i class="bi bi-diagram-3 me-2 text-primary"></i>Estrutura de Navegação
  </h2>
  <span class="text-muted small">Clique em um nó para ver detalhes ou criar filhos</span>
</div>

<div class="row g-3" style="min-height: calc(100vh - 180px)">

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
        <span class="small fw-semibold text-muted text-uppercase" style="letter-spacing:.05em; font-size:.7rem">
          <i class="bi bi-diagram-3 me-1"></i>Hierarquia
        </span>
        <button class="btn btn-outline-primary py-0 px-2" style="font-size:.7rem"
          hx-get="/admin/menus/novo/sistema"
          hx-target="#painel-detalhe"
          hx-swap="innerHTML">
          <i class="bi bi-plus"></i> Novo Sistema
        </button>
      </div>
      <div class="card-body p-2 overflow-auto" style="max-height: calc(100vh - 240px)">
        <div id="arvore-container"
          hx-get="/admin/menus/arvore"
          hx-trigger="refresh-tree from:body"
          hx-swap="innerHTML">
          <%- include('./arvore', { arvore }) %>
        </div>
        <% if (arvore.length === 0) { %>
          <div class="text-center text-muted py-4">
            <i class="bi bi-inbox fs-4 d-block mb-2 opacity-50"></i>
            <span class="small">Nenhum sistema cadastrado.</span>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div id="painel-detalhe" class="card border-0 shadow-sm h-100">
      <%- include('./painel-vazio') %>
    </div>
  </div>

</div>

<script>
  let _noSelecionado = null

  function selecionarNo(el, nodeId) {
    document.querySelectorAll('.tree-label.selecionado').forEach(n => n.classList.remove('selecionado'))
    el.classList.add('selecionado')
    _noSelecionado = nodeId
  }

  function toggleNo(btn, targetId) {
    const children = document.getElementById(targetId)
    if (!children) return
    const icon = btn.querySelector('i')
    const isOpen = children.style.display !== 'none' && children.style.display !== ''
    if (isOpen) {
      children.style.display = 'none'
      if (icon) icon.className = 'bi bi-chevron-right'
    } else {
      children.style.display = 'block'
      if (icon) icon.className = 'bi bi-chevron-down'
    }
  }

  // Restaura seleção visual, limpa modo mover e re-inicializa Sortable após refresh da árvore
  document.body.addEventListener('htmx:afterSwap', function(e) {
    if (e.detail.target.id === 'arvore-container') {
      if (window._moverState) { window._moverState = null }
      if (_noSelecionado) {
        const el = document.querySelector('[data-node="' + _noSelecionado + '"]')
        if (el) el.classList.add('selecionado')
      }
      if (typeof inicializarSortable === 'function') inicializarSortable()
    }
  })

  // ── Modal "Mover para..." ────────────────────────────────────────────────────
  // Inicialização lazy: o modal HTML está abaixo deste script, então só
  // instanciamos Bootstrap.Modal na primeira vez que abrirMoverPara é chamada.
  let _modalMoverPara = null
  function _getModalMoverPara() {
    if (!_modalMoverPara) _modalMoverPara = new bootstrap.Modal(document.getElementById('modal-mover-para'))
    return _modalMoverPara
  }

  let _moverParaItemId = null
  let _moverParaDestino = null
  let _todosDestinos = []

  async function abrirMoverPara(itemId) {
    _moverParaItemId = itemId
    _moverParaDestino = null
    document.getElementById('mover-para-confirmar').disabled = true
    document.getElementById('mover-para-filtro').value = ''
    const lista = document.getElementById('mover-para-lista')
    lista.textContent = ''
    const loading = document.createElement('div')
    loading.className = 'text-center text-muted py-3 small'
    loading.textContent = 'Carregando...'
    lista.appendChild(loading)
    _getModalMoverPara().show()
    try {
      const r = await fetch('/admin/menus/destinos-item/' + itemId)
      const destinos = await r.json()
      _todosDestinos = destinos
      _filtrarDestinos('')
    } catch {
      lista.textContent = ''
      const err = document.createElement('div')
      err.className = 'text-center text-danger py-3 small'
      err.textContent = 'Erro ao carregar destinos.'
      lista.appendChild(err)
    }
  }

  function _filtrarDestinos(filtro) {
    const lista = document.getElementById('mover-para-lista')
    lista.textContent = ''
    const f = filtro.toLowerCase().trim()
    const filtrados = f ? _todosDestinos.filter(function(d) { return d.label.toLowerCase().includes(f) }) : _todosDestinos
    if (filtrados.length === 0) {
      const empty = document.createElement('div')
      empty.className = 'text-center text-muted py-3 small'
      empty.textContent = 'Nenhum destino disponível.'
      lista.appendChild(empty)
      return
    }
    filtrados.forEach(function(d) {
      const el = document.createElement('div')
      el.className = 'mover-para-opcao px-3 py-2 border-bottom'
      el.style.cssText = 'cursor:pointer;font-size:.82rem'
      el.dataset.menuId = d.menuId
      el.dataset.parentId = d.parentId || ''
      const icon = document.createElement('i')
      icon.className = 'bi bi-folder2 text-warning me-2'
      icon.style.fontSize = '.75rem'
      el.appendChild(icon)
      el.appendChild(document.createTextNode(d.label))
      el.addEventListener('click', function() {
        lista.querySelectorAll('.mover-para-opcao').forEach(function(e) { e.classList.remove('bg-primary-subtle') })
        el.classList.add('bg-primary-subtle')
        _moverParaDestino = { menuId: el.dataset.menuId, parentId: el.dataset.parentId || null }
        document.getElementById('mover-para-confirmar').disabled = false
      })
      el.addEventListener('dblclick', function() { el.click(); _executarMoverPara() })
      lista.appendChild(el)
    })
  }

  async function _executarMoverPara() {
    if (!_moverParaItemId || !_moverParaDestino) return
    _getModalMoverPara().hide()
    if (window._moverState) _cancelarMover()
    try {
      const r = await fetch('/admin/menus/mover/item', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
          itemId: _moverParaItemId,
          mover: '1',
          menuId: _moverParaDestino.menuId,
          novoParentId: _moverParaDestino.parentId || '',
          idsOrdem: '[]',
        }),
      })
      if (r.ok) {
        htmx.trigger(document.body, 'refresh-tree')
      } else {
        const data = await r.json().catch(function() { return {} })
        _mostrarConfirmar({ titulo: 'Erro ao mover', texto: data.erro || 'Não foi possível mover o item.', tipo: 'danger', semCancelar: true, okTexto: 'Fechar' }, function() {})
      }
    } catch {
      _mostrarConfirmar({ titulo: 'Erro', texto: 'Erro de comunicação ao mover o item.', tipo: 'danger', semCancelar: true, okTexto: 'Fechar' }, function() {})
    }
  }

  // Event delegation: escuta no document para não depender da ordem do DOM
  document.addEventListener('input', function(e) {
    if (e.target && e.target.id === 'mover-para-filtro') _filtrarDestinos(e.target.value)
  })
  document.addEventListener('click', function(e) {
    if (e.target && (e.target.id === 'mover-para-confirmar' || e.target.closest('#mover-para-confirmar'))) _executarMoverPara()
  })
</script>

<!-- Modal: Mover para... (deve vir após o script para que lazy-init funcione) -->
<div class="modal fade" id="modal-mover-para" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-scrollable" style="max-width:480px">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title fw-semibold mb-0"><i class="bi bi-arrows-move me-2 text-primary"></i>Mover para...</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div class="px-3 py-2 border-bottom">
          <input type="text" id="mover-para-filtro" class="form-control form-control-sm" placeholder="Filtrar destinos...">
        </div>
        <div id="mover-para-lista" style="max-height:320px;overflow-y:auto"></div>
      </div>
      <div class="modal-footer py-2">
        <small class="text-muted me-auto">Clique duplo para confirmar rapidamente</small>
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-sm btn-primary" id="mover-para-confirmar" disabled>
          <i class="bi bi-check-lg me-1"></i>Mover
        </button>
      </div>
    </div>
  </div>
</div>
