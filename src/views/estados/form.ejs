<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-geo-alt me-2 text-primary"></i>Modelo Contábil — <%= estado.nome %> (<%= estado.sigla %>)
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  hx-put="/admin/estados/<%= estado.id %>"
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <% if (estado._count.municipios > 0) { %>
      <div class="alert alert-warning py-2 small mb-3">
        <i class="bi bi-exclamation-triangle me-1"></i>
        <strong>Atenção:</strong> alterar o modelo deste estado vai sobrescrever o modelo de
        <strong><%= estado._count.municipios %></strong> município(s), inclusive os que foram customizados.
      </div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Modelo Contábil</label>
      <select name="modeloContabilId" class="form-select form-select-sm">
        <option value="">— Nenhum (limpar) —</option>
        <% modelos.forEach(function(m) { %>
          <option value="<%= m.id %>" <%= estado.modeloContabilId === m.id ? 'selected' : '' %>>
            <%= m.descricao %>
          </option>
        <% }) %>
      </select>
      <% if (modelos.length === 0) { %>
        <div class="form-text text-warning-emphasis">
          Não há modelos contábeis cadastrados. <a href="/admin/modelos-contabeis">Cadastre um modelo</a> antes.
        </div>
      <% } %>
    </div>

    <hr class="my-3">
    <div class="mb-2">
      <label class="form-label small fw-semibold">Código nos relatórios da LOA — padrão do estado</label>
      <select name="loaCodigoModo" class="form-select form-select-sm"
        onchange="this.closest('form').querySelector('.est-nivel').style.display = this.value==='NIVEL' ? '' : 'none'">
        <option value="CURTO" <%= estado.loaCodigoModo === 'CURTO' ? 'selected' : '' %>>Sem zeros à direita</option>
        <option value="COMPLETO" <%= estado.loaCodigoModo === 'COMPLETO' ? 'selected' : '' %>>Completo</option>
        <option value="NIVEL" <%= estado.loaCodigoModo === 'NIVEL' ? 'selected' : '' %>>Até nível</option>
      </select>
      <div class="form-text">Cada município herda este padrão (pode sobrescrever no cadastro do município).</div>
    </div>
    <div class="mb-3 est-nivel" style="<%= estado.loaCodigoModo === 'NIVEL' ? '' : 'display:none' %>">
      <label class="form-label small">Nível (qtd. de segmentos)</label>
      <input type="number" name="loaCodigoNivel" min="1" max="12" value="<%= estado.loaCodigoNivel %>"
        class="form-control form-control-sm" style="width:90px">
    </div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), '<%= estado.sigla %>')">
      <i class="bi bi-check-lg me-1"></i>Aplicar
    </button>
  </div>
</form>
