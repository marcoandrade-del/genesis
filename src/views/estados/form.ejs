<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-geo-alt me-2 text-primary"></i>Modelo Contábil — <%= estado.nome %> (<%= estado.sigla %>)
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  hx-put="/admin/estados/<%= estado.id %>"
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <% if (estado._count.municipios > 0) { %>
      <div class="alert alert-warning py-2 small mb-3">
        <i class="bi bi-exclamation-triangle me-1"></i>
        <strong>Atenção:</strong> alterar o modelo deste estado vai sobrescrever o modelo de
        <strong><%= estado._count.municipios %></strong> município(s), inclusive os que foram customizados.
      </div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Modelo Contábil</label>
      <select name="modeloContabilId" class="form-select form-select-sm">
        <option value="">— Nenhum (limpar) —</option>
        <% modelos.forEach(function(m) { %>
          <option value="<%= m.id %>" <%= estado.modeloContabilId === m.id ? 'selected' : '' %>>
            <%= m.descricao %>
          </option>
        <% }) %>
      </select>
      <% if (modelos.length === 0) { %>
        <div class="form-text text-warning-emphasis">
          Não há modelos contábeis cadastrados. <a href="/admin/modelos-contabeis">Cadastre um modelo</a> antes.
        </div>
      <% } %>
    </div>

    <hr class="my-3">
    <div class="mb-2">
      <label class="form-label small fw-semibold">Código nos relatórios da LOA — padrão do estado</label>
      <select name="loaCodigoModo" class="form-select form-select-sm"
        onchange="this.closest('form').querySelector('.est-nivel').style.display = this.value==='NIVEL' ? '' : 'none'">
        <option value="CURTO" <%= estado.loaCodigoModo === 'CURTO' ? 'selected' : '' %>>Sem zeros à direita</option>
        <option value="COMPLETO" <%= estado.loaCodigoModo === 'COMPLETO' ? 'selected' : '' %>>Completo</option>
        <option value="NIVEL" <%= estado.loaCodigoModo === 'NIVEL' ? 'selected' : '' %>>Até nível</option>
      </select>
      <div class="form-text">Cada município herda este padrão (pode sobrescrever no cadastro do município).</div>
    </div>
    <div class="mb-3 est-nivel" style="<%= estado.loaCodigoModo === 'NIVEL' ? '' : 'display:none' %>">
      <label class="form-label small">Nível (qtd. de segmentos)</label>
      <input type="number" name="loaCodigoNivel" min="1" max="12" value="<%= estado.loaCodigoNivel %>"
        class="form-control form-control-sm" style="width:90px">
    </div>

    <hr class="my-3">
    <% if (typeof avisoIa !== 'undefined' && avisoIa) { %>
      <div class="alert alert-info py-2 small"><i class="bi bi-robot me-1"></i><%= avisoIa %> Confira as deduções e clique em <strong>Aplicar</strong> para salvar.</div>
    <% } %>
    <div class="mb-2">
      <input type="file" id="rcl-xlsx-file" accept=".xlsx" class="d-none" onchange="rclImportarIa(this)">
      <button type="button" class="btn btn-sm btn-outline-primary" onclick="document.getElementById('rcl-xlsx-file').click()">
        <i class="bi bi-robot me-1"></i>Importar por IA (planilha do TCE)
      </button>
      <span id="rcl-import-status" class="small text-muted ms-2"></span>
    </div>
    <% const rclInicial = (typeof propostaRcl !== 'undefined' && propostaRcl) ? propostaRcl : estado.rclComposicao %>
    <%- include('_rcl-editor', { rclInicial }) %>

    <hr class="my-3">
    <div class="mb-2">
      <label class="form-label small fw-semibold">Classificação de fonte → finalidade (controle por fonte / LRF)</label>
      <textarea name="fonteClassificacao" rows="6" class="form-control form-control-sm font-monospace" style="font-size:.75rem"
        placeholder='{"nome":"TCE-PR","regras":[{"finalidade":"MDE","prefixos":["1104"]}]}'><%= estado.fonteClassificacao ? JSON.stringify(estado.fonteClassificacao, null, 2) : '' %></textarea>
      <div class="form-text">Vazio = usa o padrão do código (STN, ou o delta do Estado). Finalidades: LIVRES, MDE, FUNDEB, ASPS, RPPS, DIVIDA, OUTRAS_VINCULADAS.</div>
    </div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), '<%= estado.sigla %>')">
      <i class="bi bi-check-lg me-1"></i>Aplicar
    </button>
  </div>
</form>

<script>
// Importar por IA: lê o xlsx no browser (FileReader → base64) e pede a proposta;
// o backend re-renderiza ESTE form com a composição proposta no editor (revisão).
function rclImportarIa(input) {
  var f = input.files[0]; if (!f) return
  var st = document.getElementById('rcl-import-status'); if (st) st.textContent = 'Lendo planilha e consultando a IA…'
  var reader = new FileReader()
  reader.onload = function () {
    var b64 = String(reader.result).split(',')[1] || ''
    htmx.ajax('POST', '/admin/estados/<%= estado.id %>/rcl-import', { target: '#modal-body', swap: 'innerHTML', values: { planilhaBase64: b64 } })
  }
  reader.readAsDataURL(f)
  input.value = ''
}
</script>
