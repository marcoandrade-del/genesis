<div class="d-flex justify-content-between align-items-center mb-4">
  <div class="d-flex align-items-center gap-2">
    <a href="/admin" class="btn btn-sm btn-outline-secondary" title="Voltar ao painel">
      <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
    <h2 class="h5 fw-bold mb-0">Estados</h2>
  </div>
  <div class="text-muted small">
    <i class="bi bi-info-circle me-1"></i>
    27 UFs do Brasil. Atribuir um modelo propaga automaticamente para os municípios.
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-bottom py-2 px-3">
    <div class="form-check form-switch mb-0">
      <input class="form-check-input" type="checkbox" id="filtro-com-entidade" onchange="filtrarComEntidade(this.checked)">
      <label class="form-check-label small" for="filtro-com-entidade">
        Somente com entidades ativas <span class="text-muted">(plano contábil cadastrado)</span>
      </label>
    </div>
  </div>
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3" style="width: 80px;">Sigla</th>
          <th>Nome</th>
          <th>Modelo Contábil</th>
          <th class="text-end" style="width: 120px;">Municípios</th>
          <th class="text-end pe-3" style="width: 260px;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% estados.forEach(function(e) { %>
          <tr data-tem-entidade="<%= estadosComEntidade.includes(e.id) %>">
            <td class="ps-3 fw-semibold font-monospace"><%= e.sigla %></td>
            <td><%= e.nome %></td>
            <td>
              <% if (e.modeloContabil) { %>
                <span class="badge bg-primary bg-opacity-10 text-primary"><%= e.modeloContabil.descricao %></span>
              <% } else { %>
                <span class="text-muted small fst-italic">Não atribuído</span>
              <% } %>
            </td>
            <td class="text-end">
              <a href="/admin/municipios?estadoId=<%= e.id %>" class="text-decoration-none" title="Ver municípios de <%= e.sigla %>">
                <%= e._count.municipios %> <i class="bi bi-chevron-right small"></i>
              </a>
            </td>
            <td class="text-end pe-3">
              <% if (e.modeloContabil && estadosComEntidade.includes(e.id)) { %>
                <button class="btn btn-sm btn-outline-success me-1"
                  hx-post="/admin/estados/<%= e.id %>/ressincronizar"
                  hx-swap="none"
                  hx-confirm="Ressincronizar TODAS as entidades de <%= e.sigla %> com o modelo &quot;<%= e.modeloContabil.descricao %>&quot;? As cópias do modelo serão recriadas a partir do plano atual. Entidades com desdobramento ou execução são preservadas (puladas)."
                  title="Ressincronizar entidades com o modelo do estado">
                  <i class="bi bi-arrow-repeat"></i>
                </button>
              <% } %>
              <% if (e.modeloContabil) { %>
                <div class="btn-group me-1">
                  <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Planos do modelo deste estado">
                    <i class="bi bi-diagram-3 me-1"></i>Planos
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">Padrão de <%= e.sigla %> · <%= e.modeloContabil.descricao %></h6></li>
                    <li><a class="dropdown-item" href="/admin/planos-de-contas?modeloContabilId=<%= e.modeloContabil.id %>"><i class="bi bi-bank me-2"></i>Plano de Contas (PCASP)</a></li>
                    <li><a class="dropdown-item" href="/admin/planos-contas-receita?modeloContabilId=<%= e.modeloContabil.id %>"><i class="bi bi-graph-down-arrow me-2"></i>Plano de Receita</a></li>
                    <li><a class="dropdown-item" href="/admin/planos-contas-despesa?modeloContabilId=<%= e.modeloContabil.id %>"><i class="bi bi-graph-up-arrow me-2"></i>Plano de Despesa</a></li>
                  </ul>
                </div>
              <% } %>
              <button class="btn btn-sm btn-outline-secondary"
                hx-get="/admin/estados/<%= e.id %>/form"
                hx-target="#modal-body"
                hx-swap="innerHTML"
                title="Atribuir modelo contábil">
                <i class="bi bi-pencil"></i>
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  // Toggle client-side: esconde linhas sem entidade ativa (plano contábil) quando marcado.
  function filtrarComEntidade(ativo) {
    document.querySelectorAll('tr[data-tem-entidade]').forEach(function (tr) {
      var tem = tr.getAttribute('data-tem-entidade') === 'true'
      tr.style.display = ativo && !tem ? 'none' : ''
    })
  }
</script>
