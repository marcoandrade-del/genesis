<div class="d-flex justify-content-between align-items-center mb-4">
  <div class="d-flex align-items-center gap-2">
    <a href="/admin/estados" class="btn btn-sm btn-outline-secondary" title="Voltar aos estados">
      <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
    <h2 class="h5 fw-bold mb-0">Municípios</h2>
  </div>
  <% if (estadoSelecionado) { %>
    <button class="btn btn-primary btn-sm"
      hx-get="/admin/municipios/form?estadoId=<%= estadoSelecionado.id %>"
      hx-target="#modal-body"
      hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Novo Município
    </button>
  <% } %>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-3">
    <label class="form-label small fw-semibold mb-1">Selecione o estado</label>
    <select class="form-select form-select-sm"
      onchange="window.location.href = this.value ? '/admin/municipios?estadoId=' + this.value : '/admin/municipios'">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= estadoSelecionado && estadoSelecionado.id === e.id ? 'selected' : '' %>>
          <%= e.sigla %> — <%= e.nome %>
          <% if (e.modeloContabil) { %> (modelo: <%= e.modeloContabil.descricao %>)<% } %>
        </option>
      <% }) %>
    </select>
  </div>
</div>

<% if (!estadoSelecionado) { %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-arrow-up fs-4 d-block mb-2"></i>
    Selecione um estado acima para listar seus municípios.
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-2 px-3">
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="filtro-com-entidade" onchange="filtrarComEntidade(this.checked)">
        <label class="form-check-label small" for="filtro-com-entidade">
          Somente com entidades ativas <span class="text-muted">(plano contábil cadastrado)</span>
        </label>
      </div>
    </div>
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3">Nome</th>
            <th>Modelo Contábil</th>
            <th class="text-end pe-3" style="width: 340px;">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (municipios.length === 0) { %>
            <tr><td colspan="3" class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum município cadastrado em <%= estadoSelecionado.nome %>.
            </td></tr>
          <% } %>
          <% municipios.forEach(function(m) { %>
            <tr id="municipio-<%= m.id %>" data-tem-entidade="<%= municipiosComEntidade.includes(m.id) %>">
              <td class="ps-3 fw-semibold"><%= m.nome %></td>
              <td>
                <% if (m.modeloContabil) { %>
                  <span class="badge bg-primary bg-opacity-10 text-primary"><%= m.modeloContabil.descricao %></span>
                <% } else if (estadoSelecionado.modeloContabil) { %>
                  <span class="text-muted small">
                    <i class="bi bi-link-45deg"></i>
                    <span class="fst-italic">Herdado de <%= estadoSelecionado.sigla %>:</span>
                    <%= estadoSelecionado.modeloContabil.descricao %>
                  </span>
                <% } else { %>
                  <span class="text-muted small fst-italic">Não atribuído</span>
                <% } %>
              </td>
              <td class="text-end pe-3">
                <% const modeloEfetivo = m.modeloContabil || estadoSelecionado.modeloContabil %>
                <% if (modeloEfetivo && municipiosComEntidade.includes(m.id)) { %>
                  <button class="btn btn-sm btn-outline-success me-1"
                    hx-post="/admin/municipios/<%= m.id %>/ressincronizar"
                    hx-swap="none"
                    hx-confirm="Ressincronizar as entidades de <%= m.nome %> com o modelo &quot;<%= modeloEfetivo.descricao %>&quot; do estado? As cópias do modelo serão recriadas a partir do plano atual. Entidades com desdobramento ou execução são preservadas (puladas)."
                    title="Ressincronizar entidades com o modelo do estado">
                    <i class="bi bi-arrow-repeat"></i>
                  </button>
                <% } %>
                <a href="/admin/entidades?municipioId=<%= m.id %>" class="btn btn-sm btn-outline-secondary me-1" title="Ver entidades deste município">
                  <i class="bi bi-building me-1"></i>Entidades
                </a>
                <% if (modeloEfetivo) { %>
                  <div class="btn-group me-1">
                    <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Planos do modelo deste município">
                      <i class="bi bi-diagram-3 me-1"></i>Planos
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><h6 class="dropdown-header">Padrão do município · <%= modeloEfetivo.descricao %></h6></li>
                      <li><a class="dropdown-item" href="/admin/planos-de-contas?modeloContabilId=<%= modeloEfetivo.id %>"><i class="bi bi-bank me-2"></i>Plano de Contas (PCASP)</a></li>
                      <li><a class="dropdown-item" href="/admin/planos-contas-receita?modeloContabilId=<%= modeloEfetivo.id %>"><i class="bi bi-graph-down-arrow me-2"></i>Plano de Receita</a></li>
                      <li><a class="dropdown-item" href="/admin/planos-contas-despesa?modeloContabilId=<%= modeloEfetivo.id %>"><i class="bi bi-graph-up-arrow me-2"></i>Plano de Despesa</a></li>
                    </ul>
                  </div>
                <% } %>
                <button class="btn btn-sm btn-outline-secondary me-1"
                  hx-get="/admin/municipios/<%= m.id %>/form"
                  hx-target="#modal-body"
                  hx-swap="innerHTML"
                  title="Editar">
                  <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger"
                  data-id="<%= m.id %>" data-nome="<%= m.nome %>"
                  onclick="confirmarExclusaoAsync('município', this.dataset.id, this.dataset.nome, { url: '/admin/municipios/' + this.dataset.id, target: '#municipio-' + this.dataset.id, swap: 'outerHTML' })"
                  title="Excluir">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    // Toggle client-side: esconde municípios sem entidade ativa (plano contábil) quando marcado.
    function filtrarComEntidade(ativo) {
      document.querySelectorAll('tr[data-tem-entidade]').forEach(function (tr) {
        var tem = tr.getAttribute('data-tem-entidade') === 'true'
        tr.style.display = ativo && !tem ? 'none' : ''
      })
    }
  </script>
<% } %>
