<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-pin-map me-2 text-primary"></i><%= municipio ? 'Editar Município' : 'Novo Município' %>
    <% if (estado) { %>
      <span class="text-muted small ms-1">— <%= estado.sigla %></span>
    <% } %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (municipio) { %>
    hx-put="/admin/municipios/<%= municipio.id %>"
  <% } else { %>
    hx-post="/admin/municipios"
  <% } %>
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <% if (!municipio && estado) { %>
    <input type="hidden" name="estadoId" value="<%= estado.id %>">
  <% } %>

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Nome <span class="text-danger">*</span></label>
      <input type="text" name="nome" class="form-control form-control-sm"
        value="<%= municipio ? municipio.nome : '' %>"
        placeholder="ex.: Belo Horizonte"
        required maxlength="200">
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Estado</label>
      <input type="text" class="form-control form-control-sm" readonly
        value="<%= estado ? estado.sigla + ' — ' + estado.nome : '' %>">
      <% if (!municipio) { %>
        <div class="form-text">Para criar em outro estado, troque o filtro na listagem.</div>
      <% } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Modelo Contábil</label>
      <select name="modeloContabilId" class="form-select form-select-sm">
        <option value="">
          — Herdar do estado
          <% if (estado && estado.modeloContabil) { %>(<%= estado.modeloContabil.descricao %>)<% } else { %>(nenhum atribuído)<% } %>
          —
        </option>
        <% modelos.forEach(function(m) { %>
          <option value="<%= m.id %>"
            <%= municipio && municipio.modeloContabilId === m.id ? 'selected' : '' %>>
            <%= m.descricao %>
          </option>
        <% }) %>
      </select>
      <div class="form-text">Sem modelo próprio, o município herda o do estado (incluindo mudanças futuras).</div>
    </div>

    <% if (municipio) { %>
    <hr class="my-2">
    <div class="mb-2">
      <label class="form-label small fw-semibold">Código nos relatórios da LOA</label>
      <select name="loaCodigoModo" class="form-select form-select-sm"
        onchange="this.closest('form').querySelector('.mun-nivel').style.display = this.value==='NIVEL' ? '' : 'none'">
        <option value="" <%= !municipio.loaCodigoModo ? 'selected' : '' %>>— Herdar do estado —</option>
        <option value="CURTO" <%= municipio.loaCodigoModo === 'CURTO' ? 'selected' : '' %>>Sem zeros à direita</option>
        <option value="COMPLETO" <%= municipio.loaCodigoModo === 'COMPLETO' ? 'selected' : '' %>>Completo</option>
        <option value="NIVEL" <%= municipio.loaCodigoModo === 'NIVEL' ? 'selected' : '' %>>Até nível</option>
      </select>
      <div class="form-text">Vazio = herda o padrão do estado.</div>
    </div>
    <div class="mb-3 mun-nivel" style="<%= municipio.loaCodigoModo === 'NIVEL' ? '' : 'display:none' %>">
      <label class="form-label small">Nível (qtd. de segmentos)</label>
      <input type="number" name="loaCodigoNivel" min="1" max="12"
        value="<%= municipio.loaCodigoNivel || (estado && estado.loaCodigoNivel) || 4 %>"
        class="form-control form-control-sm" style="width:90px">
    </div>

    <div class="mb-1">
      <label class="form-label small fw-semibold">Brasão do município</label>
      <input type="hidden" name="brasao" id="mun-bras-val" value="<%= municipio.brasao || '' %>">
      <div class="d-flex align-items-center gap-3">
        <img id="mun-bras-preview" alt="Brasão"
          <% if (municipio.brasao) { %>src="<%= municipio.brasao %>"<% } %>
          class="border rounded bg-light p-1 <%= municipio.brasao ? '' : 'd-none' %>"
          style="height:56px;max-width:120px;object-fit:contain">
        <div class="flex-grow-1">
          <input type="file" id="mun-bras-file" class="form-control form-control-sm"
            accept="image/png,image/jpeg,image/gif,image/webp" onchange="munBrasaoSelecionar(this)">
          <button type="button" id="mun-bras-remover"
            class="btn btn-sm btn-link text-danger p-0 mt-1 <%= municipio.brasao ? '' : 'd-none' %>"
            onclick="munBrasaoRemover()"><i class="bi bi-x-lg me-1"></i>Remover</button>
        </div>
      </div>
      <div class="form-text">PNG/JPG/GIF/WEBP até 1 MB. Aparece nos anexos da LOA das entidades deste município.</div>
      <div id="mun-bras-erro" class="small text-danger mt-1 d-none"></div>
    </div>
    <% } %>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), this.closest('form').querySelector('[name=nome]')?.value)">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>

<script>
// Lê o arquivo como data URL base64 e guarda no hidden `brasao` (mesmo formato
// que o gerador de anexos consome). Espelha o brasão da entidade.
function munBrasaoErro(msg) {
  var el = document.getElementById('mun-bras-erro')
  if (!el) return
  el.textContent = msg || ''
  el.classList.toggle('d-none', !msg)
}
function munBrasaoDefinir(dataUrl) {
  document.getElementById('mun-bras-val').value = dataUrl || ''
  var img = document.getElementById('mun-bras-preview')
  var btn = document.getElementById('mun-bras-remover')
  if (dataUrl) { img.src = dataUrl; img.classList.remove('d-none'); btn.classList.remove('d-none') }
  else { img.removeAttribute('src'); img.classList.add('d-none'); btn.classList.add('d-none') }
}
function munBrasaoSelecionar(input) {
  munBrasaoErro('')
  var file = input.files && input.files[0]
  if (!file) return
  if (!/^image\/(png|jpeg|gif|webp)$/.test(file.type)) { munBrasaoErro('Formato não suportado. Use PNG, JPG, GIF ou WEBP.'); input.value = ''; return }
  if (file.size > 1024 * 1024) { munBrasaoErro('Imagem muito grande (' + (file.size / 1024 / 1024).toFixed(1) + ' MB). Máximo 1 MB.'); input.value = ''; return }
  var reader = new FileReader()
  reader.onload = function () { munBrasaoDefinir(reader.result) }
  reader.onerror = function () { munBrasaoErro('Falha ao ler o arquivo.') }
  reader.readAsDataURL(file)
}
function munBrasaoRemover() {
  document.getElementById('mun-bras-file').value = ''
  munBrasaoErro('')
  munBrasaoDefinir('')
}
</script>
