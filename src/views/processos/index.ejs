<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Processos Licitatórios</h2>
  <% if (entidade) { %>
    <button class="btn btn-primary btn-sm" hx-get="/admin/processos/form?entidadeId=<%= entidade.id %>" hx-target="#modal-body" hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Novo Processo
    </button>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/processos">
  <div class="col-md-2">
    <label class="form-label small fw-semibold mb-1">Estado</label>
    <select name="estadoId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %><option value="<%= e.id %>" <%= estadoSelecionadoId === e.id ? 'selected' : '' %>><%= e.sigla %> — <%= e.nome %></option><% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Município</label>
    <select name="municipioId" class="form-select form-select-sm" <%= estadoSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% municipios.forEach(function(m) { %><option value="<%= m.id %>" <%= municipioSelecionadoId === m.id ? 'selected' : '' %>><%= m.nome %></option><% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Entidade</label>
    <select name="entidadeId" class="form-select form-select-sm" <%= municipioSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% entidades.forEach(function(e) { %><option value="<%= e.id %>" <%= entidade && e.id === entidade.id ? 'selected' : '' %>><%= e.nome %></option><% }) %>
    </select>
  </div>
</form>

<% if (!entidade) { %>
  <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-1"></i>Selecione estado, município e entidade para listar os processos.</div>
<% } else { %>
  <div class="small text-muted mb-2">
    <strong><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> · <%= entidade.nome %></strong> · <%= processos.length %> processo(s)
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:110px">Número</th>
            <th>Objeto</th>
            <th style="width:130px">Modalidade</th>
            <th style="width:90px">Critério</th>
            <th class="text-center" style="width:70px">Lotes</th>
            <th style="width:120px">Status</th>
            <th class="text-end pe-3" style="width:200px">&nbsp;</th>
          </tr>
        </thead>
        <tbody>
          <% if (processos.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum processo para esta entidade.</td></tr>
          <% } %>
          <% processos.forEach(function(p) { %>
            <tr id="proc-<%= p.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= p.numero %>/<%= p.ano %></td>
              <td class="small"><%= p.objeto %></td>
              <td class="small"><%= p.modalidade %></td>
              <td class="small"><%= p.criterioJulgamento === 'POR_LOTE' ? 'Lote' : 'Item' %></td>
              <td class="text-center"><span class="badge bg-light text-dark"><%= p._count.lotes %></span></td>
              <td>
                <% if (p.status === 'ABERTO') { %><span class="badge bg-primary bg-opacity-10 text-primary">Aberto</span>
                <% } else if (p.status === 'HOMOLOGADO') { %><span class="badge bg-success bg-opacity-10 text-success">Homologado</span>
                <% } else { %><span class="badge bg-secondary bg-opacity-10 text-secondary">Cancelado</span><% } %>
              </td>
              <td class="text-end pe-3">
                <% if (p.status === 'ABERTO') { %>
                  <button class="btn btn-sm btn-outline-success me-1" hx-get="/admin/processos/<%= p.id %>/julgar" hx-target="#modal-body" hx-swap="innerHTML" title="Julgar"><i class="bi bi-gavel"></i></button>
                  <button class="btn btn-sm btn-outline-primary me-1" hx-post="/admin/processos/<%= p.id %>/homologar" hx-confirm="Homologar o processo <%= p.numero %>?" data-confirm-titulo="Homologar" data-confirm-ok="Homologar" title="Homologar"><i class="bi bi-patch-check"></i></button>
                  <button class="btn btn-sm btn-outline-secondary me-1" hx-get="/admin/processos/<%= p.id %>/form" hx-target="#modal-body" hx-swap="innerHTML" title="Editar"><i class="bi bi-pencil"></i></button>
                  <button class="btn btn-sm btn-outline-danger" hx-delete="/admin/processos/<%= p.id %>" hx-target="#proc-<%= p.id %>" hx-swap="outerHTML" hx-confirm="Excluir o processo <%= p.numero %>?" data-confirm-titulo="Excluir processo" data-confirm-tipo="danger" data-confirm-ok="Excluir" title="Excluir"><i class="bi bi-trash"></i></button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
