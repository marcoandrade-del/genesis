<div class="modal-header">
  <h5 class="modal-title fw-semibold"><i class="bi bi-bank me-2 text-primary"></i>Nova Ordem de Pagamento</h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form hx-post="/admin/ordens-pagamento" hx-target="#modal-body" hx-swap="innerHTML">
  <div class="modal-body">
    <% if (erro) { %><div class="alert alert-danger py-2 small"><%= erro %></div><% } %>
    <input type="hidden" name="entidadeId" value="<%= entidadeId %>">

    <div class="row g-2">
      <div class="col-12 mb-1"><label class="form-label small fw-semibold">Liquidação <span class="text-danger">*</span></label>
        <% if (liquidacoes.length === 0) { %><div class="alert alert-warning py-2 small mb-1">Nenhuma liquidação ATIVA disponível.</div><% } %>
        <select name="liquidacaoId" id="op-liquidacao" class="form-select form-select-sm" required>
          <option value="" data-disp="" data-fonte="">— Selecione —</option>
          <% liquidacoes.forEach(function(l){ %><option value="<%= l.id %>" data-disp="<%= l.disponivel %>" data-fonte="<%= l.fonteCodigo %>" data-fontenome="<%= l.fonteNomenclatura %>" <%= op && op.liquidacaoId === l.id ? 'selected' : '' %>><%= l.rotulo %> — disp. R$ <%= l.disponivel %></option><% }) %>
        </select>
        <div id="op-saldo" class="form-text text-success fw-semibold"></div></div>

      <div class="col-5 mb-1"><label class="form-label small fw-semibold">Número <span class="text-danger">*</span></label>
        <input type="text" name="numero" class="form-control form-control-sm font-monospace" value="<%= op ? op.numero : '' %>" maxlength="30" required></div>
      <div class="col-4 mb-1"><label class="form-label small fw-semibold">Valor R$ <span class="text-danger">*</span></label>
        <input type="number" step="0.01" min="0.01" name="valor" class="form-control form-control-sm font-monospace" value="<%= op ? op.valor : '' %>" required></div>
      <div class="col-3 mb-1"><label class="form-label small fw-semibold">Data</label>
        <input type="date" name="data" class="form-control form-control-sm" value="<%= op && op.data ? op.data : '' %>"></div>

      <div class="col-8 mb-1"><label class="form-label small fw-semibold">Conta bancária <span class="text-danger">*</span></label>
        <select name="contaBancariaId" id="op-conta" class="form-select form-select-sm font-monospace" required disabled>
          <option value="">— escolha a liquidação primeiro —</option>
        </select>
        <div id="op-conta-aviso" class="form-text text-danger d-none">Nenhuma conta bancária ativa cadastrada para esta fonte — cadastre em Contas bancárias (área da entidade).</div></div>
      <div class="col-4 mb-1"><label class="form-label small fw-semibold">Comprovante</label>
        <input type="text" name="comprovante" class="form-control form-control-sm" value="<%= op && op.comprovante ? op.comprovante : '' %>" maxlength="60"></div>
    </div>
    <p class="small text-muted mb-0 mt-1"><i class="bi bi-info-circle me-1"></i>A OP exige uma liquidação ativa (REGRA 5), não pode exceder seu saldo e só paga por conta bancária da fonte do empenho.</p>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Emitir OP</button>
  </div>
</form>

<script>
  (function () {
    // Em <script> o JSON vai SEM escape HTML (<%- %>) — ver memória do projeto.
    var CONTAS = <%- JSON.stringify(contas) %>
    var CONTA_SALVA = <%- JSON.stringify(op && op.contaBancariaId ? op.contaBancariaId : null) %>
    var selLiq = document.getElementById('op-liquidacao')
    var selConta = document.getElementById('op-conta')
    var saldo = document.getElementById('op-saldo')
    var aviso = document.getElementById('op-conta-aviso')

    function atualizar() {
      var opt = selLiq.options[selLiq.selectedIndex]
      var fonte = opt ? opt.dataset.fonte : ''
      saldo.textContent = opt && opt.dataset.disp
        ? 'Saldo da liquidação: R$ ' + opt.dataset.disp + ' — fonte ' + fonte + ' (' + opt.dataset.fontenome + ')'
        : ''
      selConta.replaceChildren()
      if (!fonte) {
        selConta.disabled = true
        selConta.appendChild(new Option('— escolha a liquidação primeiro —', ''))
        aviso.classList.add('d-none')
        return
      }
      var daFonte = CONTAS.filter(function (c) { return c.fonteCodigo === fonte })
      aviso.classList.toggle('d-none', daFonte.length > 0)
      selConta.disabled = daFonte.length === 0
      selConta.appendChild(new Option(daFonte.length ? '— Selecione —' : '— sem contas da fonte ' + fonte + ' —', ''))
      daFonte.forEach(function (c) {
        var o = new Option(c.rotulo, c.id)
        if (c.id === CONTA_SALVA) o.selected = true
        selConta.appendChild(o)
      })
    }

    selLiq.addEventListener('change', atualizar)
    atualizar() // restaura a seleção ao re-renderizar com erro
  })()
</script>
