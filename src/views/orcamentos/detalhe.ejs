<%
  function fmt(v) { return Number(v).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) }
  function dataBR(d) { return new Date(d).toLocaleDateString('pt-BR') }
  const ent = orcamento.entidade
  const editavel = orcamento.status === 'RASCUNHO'
  const STATUS_BADGE = {
    RASCUNHO: ['secondary', 'Rascunho'],
    ENVIADO_AO_LEGISLATIVO: ['info', 'No Legislativo'],
    APROVADO: ['primary', 'Aprovado'],
    PUBLICADO: ['warning', 'Publicado'],
    EM_EXECUCAO: ['success', 'Em Execução'],
  }
  function statusBadge(s) { const b = STATUS_BADGE[s] || ['secondary', s]; return '<span class="badge bg-' + b[0] + ' bg-opacity-10 text-' + b[0] + '">' + b[1] + '</span>' }
%>

<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h2 class="h5 fw-bold mb-1">
      Orçamento <span class="font-monospace text-muted"><%= orcamento.ano %></span>
      <span class="ms-2"><%- statusBadge(orcamento.status) %></span>
    </h2>
    <div class="small text-muted">
      <%= ent.municipio.estado.sigla %> · <%= ent.municipio.nome %> · <%= ent.nome %>
      <% if (orcamento.leiNumero) { %> · <strong><%= orcamento.leiNumero %></strong><% } %>
      <% if (orcamento.dataAprovacao) { %> · aprovado em <%= dataBR(orcamento.dataAprovacao) %><% } %>
      <% if (orcamento.dataPublicacao) { %> · publicado em <%= dataBR(orcamento.dataPublicacao) %><% } %>
    </div>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin/orcamentos?entidadeId=<%= orcamento.entidadeId %>" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
    <% function botaoStatus(novo, classe, icone, rotulo) { %>
      <form method="post" action="/admin/orcamentos/<%= orcamento.id %>/status" class="d-inline">
        <input type="hidden" name="status" value="<%= novo %>">
        <button class="btn btn-sm <%= classe %>"><i class="bi <%= icone %> me-1"></i><%= rotulo %></button>
      </form>
    <% } %>
    <% if (orcamento.status === 'RASCUNHO') { %>
      <%- botaoStatus('ENVIADO_AO_LEGISLATIVO', 'btn-primary', 'bi-send', 'Encaminhar ao Legislativo') %>
    <% } else if (orcamento.status === 'ENVIADO_AO_LEGISLATIVO') { %>
      <%- botaoStatus('APROVADO', 'btn-primary', 'bi-check-circle', 'Aprovar') %>
      <%- botaoStatus('RASCUNHO', 'btn-outline-secondary', 'bi-arrow-counterclockwise', 'Devolver p/ rascunho') %>
    <% } else if (orcamento.status === 'APROVADO') { %>
      <%- botaoStatus('PUBLICADO', 'btn-success', 'bi-megaphone', 'Publicar') %>
      <%- botaoStatus('ENVIADO_AO_LEGISLATIVO', 'btn-outline-secondary', 'bi-arrow-counterclockwise', 'Devolver ao Legislativo') %>
    <% } else if (orcamento.status === 'PUBLICADO') { %>
      <%- botaoStatus('APROVADO', 'btn-outline-secondary', 'bi-arrow-counterclockwise', 'Despublicar') %>
    <% } %>
  </div>
</div>

<% if (orcamento.status === 'PUBLICADO') { %>
  <div class="alert alert-light border py-2 small mb-4"><i class="bi bi-info-circle me-1"></i>LOA publicada. A execução do exercício começa pela <strong>abertura contábil</strong> na Área de Trabalho (/app), que contabiliza a abertura e coloca o orçamento em execução.</div>
<% } %>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">Total Receita Prevista</div>
        <div class="h4 fw-bold mb-0 font-monospace">R$ <%= fmt(totalReceita) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="small text-muted">Total Despesa Autorizada</div>
        <div class="h4 fw-bold mb-0 font-monospace">R$ <%= fmt(totalDespesa) %></div>
        <% if (Math.abs(totalReceita - totalDespesa) > 0.01) { %>
          <div class="small text-warning mt-1">
            <i class="bi bi-exclamation-triangle me-1"></i>Diferença vs. receita: R$ <%= fmt(totalDespesa - totalReceita) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Dotações de Despesa ----------------------------------------------------->
<div class="d-flex justify-content-between align-items-center mb-2">
  <h3 class="h6 fw-bold mb-0">Dotações de Despesa (<%= dotacoes.length %>)</h3>
  <% if (editavel) { %>
    <button class="btn btn-sm btn-primary"
      hx-get="/admin/orcamentos/dotacoes/form?orcamentoId=<%= orcamento.id %>"
      hx-target="#modal-body" hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Nova Dotação
    </button>
  <% } %>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-0">
    <table class="table table-sm table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">UO</th>
          <th>Função / Subfunção</th>
          <th>Programa / Ação</th>
          <th>Conta · Fonte</th>
          <th class="text-end">Valor</th>
          <% if (editavel) { %><th class="text-end pe-3" style="width:90px">&nbsp;</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% if (dotacoes.length === 0) { %>
          <tr><td colspan="<%= editavel ? 6 : 5 %>" class="text-center text-muted py-4">
            <i class="bi bi-inbox d-block mb-1"></i>Sem dotações.
          </td></tr>
        <% } %>
        <% dotacoes.forEach(function(d) { %>
          <tr id="dot-<%= d.id %>">
            <td class="ps-3 small font-monospace"><%= d.unidadeOrcamentaria.codigo %></td>
            <td class="small"><%= d.funcao.codigo %>.<%= d.subfuncao.codigo %> — <%= d.subfuncao.nome %></td>
            <td class="small"><%= d.programa.codigo %>.<%= d.acao.codigo %> — <%= d.acao.nome %></td>
            <td class="small font-monospace"><%= d.contaDespesa.codigo %> · <%= d.fonteRecurso.codigo %></td>
            <td class="text-end font-monospace small">R$ <%= fmt(d.valorAutorizado) %></td>
            <% if (editavel) { %>
              <td class="text-end pe-3">
                <button class="btn btn-sm btn-outline-secondary"
                  hx-get="/admin/orcamentos/dotacoes/<%= d.id %>/form"
                  hx-target="#modal-body" hx-swap="innerHTML">
                  <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger"
                  data-id="<%= d.id %>"
                  onclick="confirmarExclusaoAsync('dotação', this.dataset.id, 'esta dotação', { url: '/admin/orcamentos/dotacoes/' + this.dataset.id, target: '#dot-' + this.dataset.id, swap: 'outerHTML' })">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Previsões de Receita ---------------------------------------------------->
<div class="d-flex justify-content-between align-items-center mb-2">
  <h3 class="h6 fw-bold mb-0">Previsões de Receita (<%= previsoes.length %>)</h3>
  <% if (editavel) { %>
    <button class="btn btn-sm btn-primary"
      hx-get="/admin/orcamentos/previsoes/form?orcamentoId=<%= orcamento.id %>"
      hx-target="#modal-body" hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Nova Previsão
    </button>
  <% } %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-sm table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Conta de Receita</th>
          <th>Fonte</th>
          <th class="text-end">Valor</th>
          <% if (editavel) { %><th class="text-end pe-3" style="width:90px">&nbsp;</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% if (previsoes.length === 0) { %>
          <tr><td colspan="<%= editavel ? 4 : 3 %>" class="text-center text-muted py-4">
            <i class="bi bi-inbox d-block mb-1"></i>Sem previsões.
          </td></tr>
        <% } %>
        <% previsoes.forEach(function(p) { %>
          <tr id="prev-<%= p.id %>">
            <td class="ps-3 small font-monospace"><%= p.contaReceita.codigo %> — <%= p.contaReceita.descricao %></td>
            <td class="small font-monospace"><%= p.fonteRecurso.codigo %> — <%= p.fonteRecurso.nomenclatura %></td>
            <td class="text-end font-monospace small">R$ <%= fmt(p.valorPrevisto) %></td>
            <% if (editavel) { %>
              <td class="text-end pe-3">
                <button class="btn btn-sm btn-outline-secondary"
                  hx-get="/admin/orcamentos/previsoes/<%= p.id %>/form"
                  hx-target="#modal-body" hx-swap="innerHTML">
                  <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger"
                  data-id="<%= p.id %>"
                  onclick="confirmarExclusaoAsync('previsão', this.dataset.id, 'esta previsão', { url: '/admin/orcamentos/previsoes/' + this.dataset.id, target: '#prev-' + this.dataset.id, swap: 'outerHTML' })">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Trilha de aprovação ----------------------------------------------------->
<h3 class="h6 fw-bold mb-2 mt-4">Trilha de aprovação (<%= trilha.length %>)</h3>
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-sm align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3" style="width:170px">Quando</th>
          <th>Transição</th>
          <th>Autor</th>
          <th class="pe-3">Observação</th>
        </tr>
      </thead>
      <tbody>
        <% if (trilha.length === 0) { %>
          <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-clock-history d-block mb-1"></i>Sem transições registradas.</td></tr>
        <% } %>
        <% trilha.forEach(function(t) { %>
          <tr>
            <td class="ps-3 small text-muted"><%= new Date(t.criadoEm).toLocaleString('pt-BR') %></td>
            <td class="small"><%- statusBadge(t.de) %> <i class="bi bi-arrow-right mx-1 text-muted"></i> <%- statusBadge(t.para) %></td>
            <td class="small"><%= t.autor.nomeCompleto || t.autor.emailPrincipal %></td>
            <td class="small text-muted pe-3"><%= t.observacao || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
