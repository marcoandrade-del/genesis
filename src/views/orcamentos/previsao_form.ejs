<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-cash-stack me-2 text-primary"></i><%= previsao && previsao.id ? 'Editar Previsão' : 'Nova Previsão de Receita' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (previsao && previsao.id) { %>
    hx-put="/admin/orcamentos/previsoes/<%= previsao.id %>"
  <% } else { %>
    hx-post="/admin/orcamentos/previsoes"
  <% } %>
  hx-target="#modal-body" hx-swap="innerHTML">

  <div class="modal-body">
    <% if (erro) { %><div class="alert alert-danger py-2 small"><%= erro %></div><% } %>
    <% if (!previsao || !previsao.id) { %>
      <input type="hidden" name="orcamentoId" value="<%= orcamentoId %>">
    <% } %>

    <div class="row g-2">
      <div class="col-12 mb-2">
        <label class="form-label small fw-semibold">Conta de Receita (analítica) <span class="text-danger">*</span></label>
        <select name="contaReceitaEntidadeId" class="form-select form-select-sm" required>
          <option value="">— Selecione —</option>
          <% contas.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= previsao && previsao.contaReceitaEntidadeId === c.id ? 'selected' : '' %>>
              <%= c.codigo %> — <%= c.descricao %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-8 mb-2">
        <label class="form-label small fw-semibold">Fonte de Recurso <span class="text-danger">*</span></label>
        <select name="fonteRecursoEntidadeId" class="form-select form-select-sm" required>
          <option value="">— Selecione —</option>
          <% fontes.forEach(function(f) { %>
            <option value="<%= f.id %>" <%= previsao && previsao.fonteRecursoEntidadeId === f.id ? 'selected' : '' %>>
              <%= f.codigo %> — <%= f.nomenclatura %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-4 mb-2">
        <label class="form-label small fw-semibold">Valor R$ <span class="text-danger">*</span></label>
        <input type="number" step="0.01" min="0" name="valorPrevisto" class="form-control form-control-sm font-monospace"
          value="<%= previsao && previsao.valorPrevisto != null ? previsao.valorPrevisto : '' %>" required>
      </div>
    </div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="submit" class="btn btn-sm btn-primary">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>
