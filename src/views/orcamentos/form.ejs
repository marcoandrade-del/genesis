<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-journal-bookmark me-2 text-primary"></i><%= orcamento && orcamento.id ? 'Editar Orçamento' : 'Novo Orçamento' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (orcamento && orcamento.id) { %>
    hx-put="/admin/orcamentos/<%= orcamento.id %>"
  <% } else { %>
    hx-post="/admin/orcamentos"
  <% } %>
  hx-target="#modal-body" hx-swap="innerHTML">

  <div class="modal-body">
    <% if (erro) { %><div class="alert alert-danger py-2 small"><%= erro %></div><% } %>

    <% if (!orcamento || !orcamento.id) { %>
      <input type="hidden" name="entidadeId" value="<%= entidadeId %>">
    <% } %>

    <div class="row g-2">
      <div class="col-4 mb-2">
        <label class="form-label small fw-semibold">Exercício <span class="text-danger">*</span></label>
        <% if (orcamento && orcamento.id) { %>
          <input type="text" class="form-control form-control-sm font-monospace" value="<%= orcamento.ano %>" disabled>
        <% } else { %>
          <input type="number" name="ano" class="form-control form-control-sm font-monospace"
            value="<%= orcamento ? orcamento.ano : new Date().getFullYear() %>" min="1900" max="9999" required>
        <% } %>
      </div>
      <div class="col-8 mb-2">
        <label class="form-label small fw-semibold">Lei nº</label>
        <input type="text" name="leiNumero" class="form-control form-control-sm"
          value="<%= orcamento && orcamento.leiNumero ? orcamento.leiNumero : '' %>"
          placeholder="ex.: Lei Municipal 1234/2025" maxlength="60">
      </div>
      <div class="col-12 mb-2">
        <label class="form-label small fw-semibold">Data da Aprovação</label>
        <input type="date" name="dataAprovacao" class="form-control form-control-sm"
          value="<%= orcamento && orcamento.dataAprovacao ? new Date(orcamento.dataAprovacao).toISOString().slice(0,10) : '' %>">
      </div>
      <div class="col-12 mb-2">
        <label class="form-label small fw-semibold">Observações</label>
        <textarea name="observacoes" class="form-control form-control-sm" rows="3" maxlength="1000"><%= orcamento && orcamento.observacoes ? orcamento.observacoes : '' %></textarea>
      </div>
    </div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="submit" class="btn btn-sm btn-primary">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>
