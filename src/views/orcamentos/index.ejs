<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Orçamentos (LOA)</h2>
  <% if (entidade) { %>
    <button class="btn btn-primary btn-sm"
      hx-get="/admin/orcamentos/form?entidadeId=<%= entidade.id %>"
      hx-target="#modal-body"
      hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Novo Orçamento
    </button>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/orcamentos">
  <div class="col-md-2">
    <label class="form-label small fw-semibold mb-1">Estado</label>
    <select name="estadoId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= estadoSelecionadoId === e.id ? 'selected' : '' %>>
          <%= e.sigla %> — <%= e.nome %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Município</label>
    <select name="municipioId" class="form-select form-select-sm"
      <%= estadoSelecionadoId ? '' : 'disabled' %>
      onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% municipios.forEach(function(m) { %>
        <option value="<%= m.id %>" <%= municipioSelecionadoId === m.id ? 'selected' : '' %>>
          <%= m.nome %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Entidade</label>
    <select name="entidadeId" class="form-select form-select-sm"
      <%= municipioSelecionadoId ? '' : 'disabled' %>
      onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% entidades.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= entidade && e.id === entidade.id ? 'selected' : '' %>>
          <%= e.nome %>
        </option>
      <% }) %>
    </select>
  </div>
</form>

<% if (!entidade) { %>
  <div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle me-1"></i>Selecione estado, município e entidade para listar os orçamentos.
  </div>
<% } else { %>
  <div class="small text-muted mb-2">
    <strong><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> · <%= entidade.nome %></strong>
    · <%= orcamentos.length %> orçamento(s)
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:90px">Exercício</th>
            <th>Lei / Observações</th>
            <th style="width:140px">Status</th>
            <th class="text-center" style="width:100px">Dotações</th>
            <th class="text-center" style="width:100px">Previsões</th>
            <th class="text-end pe-3" style="width:180px">&nbsp;</th>
          </tr>
        </thead>
        <tbody>
          <% if (orcamentos.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum orçamento cadastrado para esta entidade.
            </td></tr>
          <% } %>
          <% orcamentos.forEach(function(o) { %>
            <tr id="orc-<%= o.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= o.ano %></td>
              <td>
                <% if (o.leiNumero) { %><div><%= o.leiNumero %></div><% } %>
                <% if (o.observacoes) { %><div class="small text-muted"><%= o.observacoes %></div><% } %>
              </td>
              <td class="small">
                <%
                  var sb = ({
                    RASCUNHO: ['secondary', 'Rascunho'],
                    ENVIADO_AO_LEGISLATIVO: ['info', 'No Legislativo'],
                    APROVADO: ['primary', 'Aprovado'],
                    PUBLICADO: ['warning', 'Publicado'],
                    EM_EXECUCAO: ['success', 'Em Execução'],
                  })[o.status] || ['secondary', o.status]
                %>
                <span class="badge bg-<%= sb[0] %> bg-opacity-10 text-<%= sb[0] %>"><%= sb[1] %></span>
              </td>
              <td class="text-center"><span class="badge bg-light text-dark"><%= o._count.dotacoes %></span></td>
              <td class="text-center"><span class="badge bg-light text-dark"><%= o._count.previsoes %></span></td>
              <td class="text-end pe-3">
                <a class="btn btn-sm btn-outline-primary me-1"
                  href="/admin/orcamentos/<%= o.id %>" title="Abrir">
                  <i class="bi bi-box-arrow-up-right"></i>
                </a>
                <button class="btn btn-sm btn-outline-secondary me-1"
                  hx-get="/admin/orcamentos/<%= o.id %>/form"
                  hx-target="#modal-body" hx-swap="innerHTML"
                  title="Editar cabeçalho">
                  <i class="bi bi-pencil"></i>
                </button>
                <% if (o.status === 'RASCUNHO' && o._count.dotacoes === 0 && o._count.previsoes === 0) { %>
                  <button class="btn btn-sm btn-outline-danger"
                    data-id="<%= o.id %>" data-nome="Orçamento <%= o.ano %>"
                    onclick="confirmarExclusaoAsync('orçamento', this.dataset.id, this.dataset.nome, { url: '/admin/orcamentos/' + this.dataset.id, target: '#orc-' + this.dataset.id, swap: 'outerHTML' })"
                    title="Excluir">
                    <i class="bi bi-trash"></i>
                  </button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
