<% contas.forEach(function(c) { %>
  <tr id="conta-<%= c.id %>" data-nivel="<%= c.nivel %>">
    <td class="expand-cell text-center">
      <% if (c.temFilhos) { %>
        <button type="button"
          class="btn btn-sm btn-link p-0 btn-exp"
          hx-get="/admin/contas/<%= c.id %>/filhos"
          hx-target="#conta-<%= c.id %>"
          hx-swap="afterend"
          hx-on::after-request="marcarExpandido(this)"
          title="Expandir">
          <i class="bi bi-plus-square"></i>
        </button>
        <button type="button"
          class="btn btn-sm btn-link p-0 btn-col"
          style="display:none"
          onclick="colapsarConta(this)"
          title="Recolher">
          <i class="bi bi-dash-square"></i>
        </button>
      <% } %>
    </td>
    <td class="ps-3 font-monospace small" style="padding-left: calc(<%= (c.nivel - 1) * 1.25 %>rem + 0.75rem) !important">
      <%= c.codigo %>
    </td>
    <td><%= c.descricao %></td>
    <td class="text-center">
      <%
        const NAT_INFO = { PATRIMONIAL: ['Patrimonial','bg-primary'], ORCAMENTARIA: ['Orçamentária','bg-info'], CONTROLE: ['Controle','bg-secondary'] }
        const NAT_SALDO = { DEVEDORA: ['D','Devedora'], CREDORA: ['C','Credora'], MISTA: ['X','Mista (admite inversão)'] }
        const SUP_FIN = { FINANCEIRO: 'Financeiro', PATRIMONIAL: 'Patrimonial', MISTA: 'Mista/Híbrida', OUTROS_CONTROLES: 'Outros controles' }
      %>
      <% if (c.naturezaInformacao) { const ni = NAT_INFO[c.naturezaInformacao] %>
        <span class="badge rounded-pill <%= ni[1] %> bg-opacity-75" title="Natureza da informação"><%= ni[0] %></span>
        <% if (c.naturezaSaldo) { const ns = NAT_SALDO[c.naturezaSaldo] %>
          <span class="badge rounded-pill bg-light text-dark border" title="Natureza de saldo: <%= ns[1] %>"><%= ns[0] %></span>
        <% } %>
        <% if (c.superavitFinanceiro) { %>
          <i class="bi bi-droplet-half text-muted small" title="Superávit: <%= SUP_FIN[c.superavitFinanceiro] %>"></i>
        <% } %>
        <% if (c.funcao) { %>
          <i class="bi bi-info-circle text-muted small" title="<%= c.funcao %>"></i>
        <% } %>
      <% } else { %>
        <span class="text-muted">—</span>
      <% } %>
    </td>
    <td class="text-center">
      <% if (c.admiteMovimento) { %>
        <span class="badge rounded-pill bg-success bg-opacity-75">Analítica</span>
      <% } else { %>
        <span class="badge rounded-pill bg-secondary bg-opacity-50">Sintética</span>
      <% } %>
    </td>
    <td class="text-end pe-3">
      <% if (!c.admiteMovimento) { %>
        <button class="btn btn-sm btn-outline-primary me-1"
          hx-get="/admin/contas/form?planoId=<%= c.planoId %>&parentId=<%= c.id %>"
          hx-target="#modal-body"
          hx-swap="innerHTML"
          title="Adicionar filha">
          <i class="bi bi-plus"></i>
        </button>
      <% } %>
      <button class="btn btn-sm btn-outline-secondary me-1"
        hx-get="/admin/contas/<%= c.id %>/form"
        hx-target="#modal-body"
        hx-swap="innerHTML"
        title="Editar">
        <i class="bi bi-pencil"></i>
      </button>
      <button class="btn btn-sm btn-outline-danger"
        data-id="<%= c.id %>" data-nome="<%= c.codigo %> — <%= c.descricao %>"
        onclick="confirmarExclusaoAsync('conta', this.dataset.id, this.dataset.nome, { url: '/admin/contas/' + this.dataset.id, target: '#conta-' + this.dataset.id, swap: 'outerHTML' })"
        title="Excluir">
        <i class="bi bi-trash"></i>
      </button>
    </td>
  </tr>
<% }) %>
