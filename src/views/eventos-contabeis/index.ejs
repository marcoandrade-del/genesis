<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Eventos Contábeis</h2>
  <% if (modeloSelecionado) { %>
    <a href="/admin/eventos-contabeis/novo?modeloContabilId=<%= modeloSelecionado %>" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>Novo Evento
    </a>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/eventos-contabeis">
  <div class="col-md-5">
    <label class="form-label small fw-semibold mb-1">Modelo Contábil</label>
    <select name="modeloContabilId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% modelos.forEach(function(m) { %>
        <option value="<%= m.id %>" <%= modeloSelecionado === m.id ? 'selected' : '' %>>
          <%= m.descricao %><%= m.ativo ? '' : ' (inativo)' %>
        </option>
      <% }) %>
    </select>
  </div>
</form>

<% if (!modeloSelecionado) { %>
  <div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle me-1"></i>Selecione um modelo contábil para listar os eventos.
  </div>
<% } else { %>
  <div class="small text-muted mb-2">
    <%= eventos.length %> evento(s) cadastrado(s).
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:100px">Código</th>
            <th>Descrição</th>
            <th class="text-center" style="width:120px">Lançamentos</th>
            <th class="text-center" style="width:90px">Status</th>
            <th class="text-end pe-3" style="width:120px">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (eventos.length === 0) { %>
            <tr><td colspan="5" class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum evento cadastrado neste modelo.
            </td></tr>
          <% } %>
          <% eventos.forEach(function(ev) { %>
            <tr id="evento-<%= ev.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= ev.codigo %></td>
              <td>
                <%= ev.descricao %>
                <% if (ev.tipoInscricao) { %>
                  <div class="small text-muted">Inscrição: <%= ev.tipoInscricao %></div>
                <% } %>
              </td>
              <td class="text-center">
                <span class="badge bg-light text-dark fw-semibold"><%= ev.lancamentos.length %> par(es)</span>
              </td>
              <td class="text-center">
                <% if (ev.ativo) { %>
                  <span class="badge rounded-pill bg-success bg-opacity-75">Ativo</span>
                <% } else { %>
                  <span class="badge rounded-pill bg-secondary bg-opacity-75">Inativo</span>
                <% } %>
              </td>
              <td class="text-end pe-3">
                <a class="btn btn-sm btn-outline-secondary me-1"
                  href="/admin/eventos-contabeis/<%= ev.id %>/editar"
                  title="Editar">
                  <i class="bi bi-pencil"></i>
                </a>
                <button class="btn btn-sm btn-outline-danger"
                  data-id="<%= ev.id %>" data-nome="<%= ev.codigo %> — <%= ev.descricao %>"
                  onclick="confirmarExclusaoAsync('evento contábil', this.dataset.id, this.dataset.nome, { url: '/admin/eventos-contabeis/' + this.dataset.id, target: '#evento-' + this.dataset.id, swap: 'outerHTML' })"
                  title="Excluir">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
