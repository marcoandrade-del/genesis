<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-bank me-2 text-primary"></i><%= fonte ? 'Editar Fonte de Recurso' : 'Nova Fonte de Recurso' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (fonte) { %>
    hx-put="/admin/fontes-recurso/<%= fonte.id %>"
  <% } else { %>
    hx-post="/admin/fontes-recurso"
  <% } %>
  hx-target="#modal-body"
  hx-swap="innerHTML"
  hx-trigger="submit-confirmed">

  <div class="modal-body">
    <% if (erro) { %>
      <div class="alert alert-danger py-2 small"><%= erro %></div>
    <% } %>

    <% if (fonte) { %>
      <div class="mb-3 small text-muted">
        <strong>Modelo:</strong> <%= fonte.modeloContabil.descricao %> · <strong>Ano:</strong> <%= fonte.ano %>
        · <strong>Código:</strong> <span class="font-monospace"><%= fonte.codigo %></span>
        <div class="form-text">Modelo, ano e código são imutáveis após a criação.</div>
      </div>
    <% } else { %>
      <div class="row g-2">
        <div class="col-12 mb-2">
          <label class="form-label small fw-semibold">Modelo Contábil <span class="text-danger">*</span></label>
          <select name="modeloContabilId" class="form-select form-select-sm" required>
            <option value="">— Selecione —</option>
            <% modelos.forEach(function(m) { %>
              <option value="<%= m.id %>"><%= m.descricao %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 mb-2">
          <label class="form-label small fw-semibold">Ano <span class="text-danger">*</span></label>
          <input type="number" name="ano" class="form-control form-control-sm"
            value="<%= new Date().getFullYear() %>" min="1900" max="9999" required>
        </div>
        <div class="col-6 mb-2">
          <label class="form-label small fw-semibold">Código <span class="text-danger">*</span></label>
          <input type="text" name="codigo" class="form-control form-control-sm font-monospace"
            placeholder="ex.: 500" required maxlength="10">
        </div>
      </div>
    <% } %>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Nomenclatura <span class="text-danger">*</span></label>
      <input type="text" name="nomenclatura" class="form-control form-control-sm"
        value="<%= fonte ? fonte.nomenclatura : '' %>" required maxlength="200">
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Especificação</label>
      <textarea name="especificacao" class="form-control form-control-sm" rows="2" maxlength="1000"><%= fonte && fonte.especificacao ? fonte.especificacao : '' %></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-semibold">Grupo</label>
      <input type="text" name="grupo" class="form-control form-control-sm"
        value="<%= fonte && fonte.grupo ? fonte.grupo : '' %>"
        placeholder="ex.: Livres, Educação, Saúde…" maxlength="100">
    </div>

    <div class="form-check">
      <input type="hidden" name="vinculada" id="fr-vinc-val"
        value="<%= !fonte || fonte.vinculada ? 'true' : 'false' %>">
      <input type="checkbox" class="form-check-input" id="fr-chk-vinc"
        <%= !fonte || fonte.vinculada ? 'checked' : '' %>
        onchange="document.getElementById('fr-vinc-val').value = this.checked ? 'true' : 'false'">
      <label for="fr-chk-vinc" class="form-check-label small">
        Vinculada (recurso com destinação específica)
      </label>
    </div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="button" class="btn btn-sm btn-primary"
      onclick="confirmarGravacao(this.closest('form'), this.closest('form').querySelector('[name=codigo]')?.value || this.closest('form').querySelector('[name=nomenclatura]')?.value)">
      <i class="bi bi-check-lg me-1"></i>Salvar
    </button>
  </div>
</form>
