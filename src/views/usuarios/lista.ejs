<% if (usuarios.length === 0) { %>
  <tr><td colspan="7" class="text-center text-muted py-5">
    <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum usuário encontrado.
  </td></tr>
<% } %>
<% usuarios.forEach(function(u) { %>
  <tr id="usuario-<%= u.id %>">
    <td class="ps-3">
      <div class="fw-semibold small"><%= u.nomeCompleto %></div>
      <div class="text-muted" style="font-size:.75rem"><%= u.nomeSocial %></div>
    </td>
    <td class="small"><%= u.emailPrincipal %></td>
    <td class="small font-monospace text-muted">
      <%= u.cpf ? u.cpf : (u.idEstrangeiro || '—') %>
    </td>
    <td>
      <div class="d-flex flex-column gap-1">
        <% if (u.emailValidado) { %>
          <span class="small text-success" title="E-mail validado">
            <i class="bi bi-envelope-check-fill me-1"></i>E-mail validado
          </span>
        <% } else { %>
          <button class="btn btn-sm btn-outline-warning py-0 px-2" style="font-size:.75rem"
            hx-post="/admin/usuarios/<%= u.id %>/enviar-codigo-email"
            hx-swap="none"
            hx-confirm="Enviar e-mail com link e código de validação para este usuário?"
            data-confirm-titulo="Enviar E-mail de Validação"
            data-confirm-tipo="primary"
            data-confirm-destaque="Usuário: <%= u.nomeCompleto %>"
            data-confirm-detalhe="O usuário receberá um link e um código de 6 dígitos. A validação só ocorre quando o usuário informar o código."
            data-confirm-ok="Enviar">
            <i class="bi bi-envelope-exclamation me-1"></i>Enviar e-mail de validação
          </button>
        <% } %>
        <% if (u.celularValidado) { %>
          <span class="small text-success" title="Celular validado">
            <i class="bi bi-phone-vibrate-fill me-1"></i>Celular validado
          </span>
        <% } else { %>
          <button class="btn btn-sm btn-outline-warning py-0 px-2" style="font-size:.75rem"
            hx-post="/admin/usuarios/<%= u.id %>/enviar-codigo-celular"
            hx-swap="none"
            hx-confirm="Enviar SMS com código de validação para este usuário?"
            data-confirm-titulo="Enviar SMS de Validação"
            data-confirm-tipo="primary"
            data-confirm-destaque="Usuário: <%= u.nomeCompleto %>"
            data-confirm-detalhe="O usuário receberá um código de 6 dígitos por SMS. A validação só ocorre quando o usuário informar o código."
            data-confirm-ok="Enviar">
            <i class="bi bi-phone-flip me-1"></i>Enviar SMS de validação
          </button>
        <% } %>
      </div>
    </td>
    <td>
      <% if (u.ativo) { %>
        <span class="badge rounded-pill bg-success bg-opacity-75">Ativo</span>
      <% } else if (u.emailValidado || u.celularValidado) { %>
        <span class="badge rounded-pill bg-warning bg-opacity-75 text-dark">Pendente</span>
      <% } else { %>
        <span class="badge rounded-pill bg-secondary bg-opacity-75">Inativo</span>
      <% } %>
    </td>
    <td>
      <% if (u._count.adminSistemas > 0) { %>
        <span class="badge bg-primary bg-opacity-75" title="Admin de <%= u._count.adminSistemas %> sistema(s)">
          <i class="bi bi-shield-fill-check me-1"></i><%= u._count.adminSistemas %>
        </span>
      <% } else { %>
        <span class="text-muted small">—</span>
      <% } %>
    </td>
    <td class="text-end pe-3">
      <a class="btn btn-sm btn-outline-primary me-1"
        href="/admin/acessos-entidade/usuario/<%= u.id %>"
        title="Acessos a entidades">
        <i class="bi bi-key"></i>
      </a>
      <button class="btn btn-sm btn-outline-secondary me-1"
        hx-get="/admin/usuarios/<%= u.id %>/form"
        hx-target="#modal-body"
        hx-swap="innerHTML"
        title="Editar">
        <i class="bi bi-pencil"></i>
      </button>
      <button class="btn btn-sm btn-outline-danger"
        hx-delete="/admin/usuarios/<%= u.id %>"
        hx-target="#usuario-<%= u.id %>"
        hx-swap="outerHTML"
        hx-confirm="O usuário será movido para a Lixeira. Favoritos e pastas vinculados também serão removidos."
        data-confirm-titulo="Confirmar Exclusão"
        data-confirm-tipo="danger"
        data-confirm-ok="Excluir"
        data-confirm-destaque="Excluir: <%= u.nomeCompleto %>"
        title="Excluir">
        <i class="bi bi-trash"></i>
      </button>
    </td>
  </tr>
<% }) %>
<span id="total-usuarios" hx-swap-oob="true"><%= total %> usuário(s) cadastrado(s)</span>
