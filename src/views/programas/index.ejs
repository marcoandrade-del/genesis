<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Programas (PPA-LOA)</h2>
  <% if (entidade) { %>
    <button class="btn btn-primary btn-sm"
      hx-get="/admin/programas/form?entidadeId=<%= entidade.id %>&ano=<%= ano %>"
      hx-target="#modal-body"
      hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Novo Programa
    </button>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/programas">
  <div class="col-md-2">
    <label class="form-label small fw-semibold mb-1">Estado</label>
    <select name="estadoId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= estadoSelecionadoId === e.id ? 'selected' : '' %>>
          <%= e.sigla %> — <%= e.nome %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Município</label>
    <select name="municipioId" class="form-select form-select-sm"
      <%= estadoSelecionadoId ? '' : 'disabled' %>
      onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% municipios.forEach(function(m) { %>
        <option value="<%= m.id %>" <%= municipioSelecionadoId === m.id ? 'selected' : '' %>>
          <%= m.nome %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Entidade</label>
    <select name="entidadeId" class="form-select form-select-sm"
      <%= municipioSelecionadoId ? '' : 'disabled' %>
      onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% entidades.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= entidade && e.id === entidade.id ? 'selected' : '' %>>
          <%= e.nome %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-2">
    <label class="form-label small fw-semibold mb-1">Exercício</label>
    <input type="number" name="ano" class="form-control form-control-sm" min="1900" max="9999"
      value="<%= ano %>" onchange="this.form.submit()">
  </div>
</form>

<% if (!entidade) { %>
  <div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle me-1"></i>Selecione estado, município e entidade para listar os programas.
  </div>
<% } else { %>
  <div class="small text-muted mb-2">
    <strong><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> · <%= entidade.nome %></strong>
    · Exercício <strong><%= ano %></strong> · <%= programas.length %> programa(s)
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:90px">Código</th>
            <th>Nome</th>
            <th style="width:170px">Tipo</th>
            <th class="text-center" style="width:90px">Ações</th>
            <th class="text-center" style="width:80px">Status</th>
            <th class="text-end pe-3" style="width:150px">&nbsp;</th>
          </tr>
        </thead>
        <tbody>
          <% if (programas.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum programa cadastrado para este exercício.
            </td></tr>
          <% } %>
          <% programas.forEach(function(p) { %>
            <tr id="prog-<%= p.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= p.codigo %></td>
              <td>
                <%= p.nome %>
                <% if (p.objetivo) { %>
                  <div class="small text-muted"><%= p.objetivo %></div>
                <% } %>
              </td>
              <td class="small">
                <% if (p.tipo === 'FINALISTICO') { %>
                  <span class="badge bg-primary bg-opacity-10 text-primary">Finalístico</span>
                <% } else if (p.tipo === 'GESTAO') { %>
                  <span class="badge bg-secondary bg-opacity-10 text-secondary">Gestão</span>
                <% } else { %>
                  <span class="badge bg-warning bg-opacity-10 text-warning">Op. Especiais</span>
                <% } %>
              </td>
              <td class="text-center">
                <a class="badge bg-light text-dark text-decoration-none"
                  href="/admin/programas/<%= p.id %>/acoes" title="Ver ações">
                  <i class="bi bi-list-ul me-1"></i><%= p._count.acoes %>
                </a>
              </td>
              <td class="text-center">
                <% if (p.ativo) { %>
                  <span class="badge rounded-pill bg-success bg-opacity-75">Ativo</span>
                <% } else { %>
                  <span class="badge rounded-pill bg-secondary bg-opacity-75">Inativo</span>
                <% } %>
              </td>
              <td class="text-end pe-3">
                <button class="btn btn-sm btn-outline-secondary me-1"
                  hx-get="/admin/programas/<%= p.id %>/form"
                  hx-target="#modal-body"
                  hx-swap="innerHTML"
                  title="Editar">
                  <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger"
                  data-id="<%= p.id %>" data-nome="<%= p.codigo %> — <%= p.nome %>"
                  onclick="confirmarExclusaoAsync('programa', this.dataset.id, this.dataset.nome, { url: '/admin/programas/' + this.dataset.id, target: '#prog-' + this.dataset.id, swap: 'outerHTML' })"
                  title="Excluir">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
