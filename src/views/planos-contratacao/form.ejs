<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-card-checklist me-2 text-primary"></i><%= pca && pca.id ? 'Editar PCA' : 'Novo PCA' %>
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form
  <% if (pca && pca.id) { %>hx-put="/admin/planos-contratacao/<%= pca.id %>"<% } else { %>hx-post="/admin/planos-contratacao"<% } %>
  hx-target="#modal-body" hx-swap="innerHTML"
  hx-on::config-request="pcaSerialize()"
  data-modal-size="modal-lg">

  <div class="modal-body">
    <% if (erro) { %><div class="alert alert-danger py-2 small"><%= erro %></div><% } %>
    <% if (!pca || !pca.id) { %><input type="hidden" name="entidadeId" value="<%= entidadeId %>"><% } %>
    <input type="hidden" name="itensJson" id="pca-itens-json" value="">

    <div class="row g-2 mb-3">
      <div class="col-4">
        <label class="form-label small fw-semibold">ExercĂ­cio <span class="text-danger">*</span></label>
        <% if (pca && pca.id) { %>
          <input type="text" class="form-control form-control-sm font-monospace" value="<%= pca.ano %>" disabled>
        <% } else { %>
          <input type="number" name="ano" class="form-control form-control-sm font-monospace"
            value="<%= pca ? pca.ano : new Date().getFullYear() %>" min="1900" max="9999" required>
        <% } %>
      </div>
      <div class="col-8">
        <label class="form-label small fw-semibold">ObservaĂ§Ăµes</label>
        <input type="text" name="observacoes" class="form-control form-control-sm"
          value="<%= pca && pca.observacoes ? pca.observacoes : '' %>" maxlength="500">
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-1">
      <label class="form-label small fw-semibold mb-0">Itens planejados</label>
      <button type="button" class="btn btn-sm btn-outline-primary" onclick="pcaAddRow()">
        <i class="bi bi-plus-lg me-1"></i>Adicionar item
      </button>
    </div>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Item do catĂˇlogo</th>
            <th style="width:120px">Qtd.</th>
            <th style="width:140px">Valor unit. R$</th>
            <th style="width:40px"></th>
          </tr>
        </thead>
        <tbody id="pca-itens-body"></tbody>
      </table>
    </div>
    <div id="pca-itens-vazio" class="text-muted small text-center py-2" style="display:none">Nenhum item â€” clique em "Adicionar item".</div>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
  </div>
</form>

<script>
  // Editor de itens construĂ­do via DOM API (sem innerHTML) â€” texto de catĂˇlogo
  // nunca Ă© interpretado como HTML.
  var PCA_CATALOGO = <%- JSON.stringify(catalogo) %>;
  var PCA_ITENS = <%- JSON.stringify(itens) %>;

  function pcaCatSelect(selId) {
    var sel = document.createElement('select');
    sel.className = 'form-select form-select-sm pca-cat';
    sel.addEventListener('change', pcaSerialize);
    sel.add(new Option('â€” Selecione â€”', ''));
    PCA_CATALOGO.forEach(function(c) {
      var rotulo = (c.tipo === 'MATERIAL' ? 'Mat.' : 'Serv.') + ' ' + c.codigo + ' â€” ' + c.descricao + ' (' + c.unidadeMedida + ')';
      var o = new Option(rotulo, c.id);
      if (c.id === selId) o.selected = true;
      sel.add(o);
    });
    return sel;
  }

  function pcaNumInput(cls, val, step) {
    var inp = document.createElement('input');
    inp.type = 'number'; inp.step = step; inp.min = '0';
    inp.className = 'form-control form-control-sm font-monospace ' + cls;
    if (val != null && val !== '') inp.value = val;
    inp.addEventListener('input', pcaSerialize);
    return inp;
  }

  function pcaCell(child) { var td = document.createElement('td'); td.appendChild(child); return td; }

  function pcaAddRow(item) {
    item = item || {};
    var tr = document.createElement('tr');
    tr.appendChild(pcaCell(pcaCatSelect(item.itemCatalogoId)));
    tr.appendChild(pcaCell(pcaNumInput('pca-qtd', item.quantidadeEstimada, 'any')));
    tr.appendChild(pcaCell(pcaNumInput('pca-val', item.valorUnitarioEstimado, '0.01')));
    var btn = document.createElement('button');
    btn.type = 'button'; btn.className = 'btn btn-sm btn-outline-danger';
    btn.addEventListener('click', function() { pcaRemoveRow(btn); });
    var ic = document.createElement('i'); ic.className = 'bi bi-x'; btn.appendChild(ic);
    var tdX = document.createElement('td'); tdX.className = 'text-end'; tdX.appendChild(btn);
    tr.appendChild(tdX);
    document.getElementById('pca-itens-body').appendChild(tr);
    pcaSerialize();
  }

  function pcaRemoveRow(btn) { btn.closest('tr').remove(); pcaSerialize(); }

  function pcaSerialize() {
    var linhas = [];
    document.querySelectorAll('#pca-itens-body tr').forEach(function(tr) {
      var id = tr.querySelector('.pca-cat').value;
      if (!id) return;
      linhas.push({
        itemCatalogoId: id,
        quantidadeEstimada: tr.querySelector('.pca-qtd').value || '0',
        valorUnitarioEstimado: tr.querySelector('.pca-val').value || '0',
      });
    });
    document.getElementById('pca-itens-json').value = JSON.stringify(linhas);
    document.getElementById('pca-itens-vazio').style.display =
      document.querySelectorAll('#pca-itens-body tr').length ? 'none' : 'block';
  }

  PCA_ITENS.forEach(function(i) { pcaAddRow(i); });
  pcaSerialize();
</script>
