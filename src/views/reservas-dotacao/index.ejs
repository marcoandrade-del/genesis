<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Reservas de Dotação</h2>
  <% if (entidade) { %>
    <button class="btn btn-primary btn-sm"
      hx-get="/admin/reservas-dotacao/form?entidadeId=<%= entidade.id %>"
      hx-target="#modal-body"
      hx-swap="innerHTML">
      <i class="bi bi-plus-lg me-1"></i>Nova Reserva
    </button>
  <% } %>
</div>

<form class="mb-3 row g-2 align-items-end" method="get" action="/admin/reservas-dotacao">
  <div class="col-md-2">
    <label class="form-label small fw-semibold mb-1">Estado</label>
    <select name="estadoId" class="form-select form-select-sm" onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% estados.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= estadoSelecionadoId === e.id ? 'selected' : '' %>><%= e.sigla %> — <%= e.nome %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Município</label>
    <select name="municipioId" class="form-select form-select-sm" <%= estadoSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% municipios.forEach(function(m) { %>
        <option value="<%= m.id %>" <%= municipioSelecionadoId === m.id ? 'selected' : '' %>><%= m.nome %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label small fw-semibold mb-1">Entidade</label>
    <select name="entidadeId" class="form-select form-select-sm" <%= municipioSelecionadoId ? '' : 'disabled' %> onchange="this.form.submit()">
      <option value="">— Selecione —</option>
      <% entidades.forEach(function(e) { %>
        <option value="<%= e.id %>" <%= entidade && e.id === entidade.id ? 'selected' : '' %>><%= e.nome %></option>
      <% }) %>
    </select>
  </div>
</form>

<% if (!entidade) { %>
  <div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle me-1"></i>Selecione estado, município e entidade para listar as reservas.
  </div>
<% } else { %>
  <div class="small text-muted mb-2">
    <strong><%= entidade.municipio.estado.sigla %> · <%= entidade.municipio.nome %> · <%= entidade.nome %></strong>
    · <%= reservas.length %> reserva(s)
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:110px">Número</th>
            <th>Dotação</th>
            <th>Termo de Referência</th>
            <th class="text-end" style="width:140px">Valor (R$)</th>
            <th style="width:110px">Status</th>
            <th class="text-end pe-3" style="width:120px">&nbsp;</th>
          </tr>
        </thead>
        <tbody>
          <% if (reservas.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhuma reserva para esta entidade.
            </td></tr>
          <% } %>
          <% reservas.forEach(function(r) { %>
            <tr id="reserva-<%= r.id %>">
              <td class="ps-3 font-monospace fw-semibold"><%= r.numero %></td>
              <td class="small font-monospace">
                <%= r.dotacaoDespesa.unidadeOrcamentaria.codigo %> ·
                <%= r.dotacaoDespesa.contaDespesa.codigo %> ·
                Fonte <%= r.dotacaoDespesa.fonteRecurso.codigo %>
              </td>
              <td class="small text-muted"><%= r.termoReferencia ? r.termoReferencia.objeto : '—' %></td>
              <td class="text-end font-monospace"><%= Number(r.valor).toFixed(2) %></td>
              <td>
                <% if (r.status === 'ATIVA') { %>
                  <span class="badge bg-success bg-opacity-10 text-success">Ativa</span>
                <% } else if (r.status === 'BAIXADA') { %>
                  <span class="badge bg-primary bg-opacity-10 text-primary">Baixada</span>
                <% } else { %>
                  <span class="badge bg-secondary bg-opacity-10 text-secondary">Cancelada</span>
                <% } %>
              </td>
              <td class="text-end pe-3">
                <% if (r.status === 'ATIVA') { %>
                  <button class="btn btn-sm btn-outline-danger"
                    hx-post="/admin/reservas-dotacao/<%= r.id %>/cancelar"
                    hx-confirm="Cancelar a reserva <%= r.numero %>? O valor será estornado ao saldo da dotação."
                    data-confirm-titulo="Cancelar reserva" data-confirm-tipo="danger" data-confirm-ok="Cancelar reserva"
                    title="Cancelar">
                    <i class="bi bi-x-circle me-1"></i>Cancelar
                  </button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
