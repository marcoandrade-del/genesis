<div class="modal-header">
  <h5 class="modal-title fw-semibold">
    <i class="bi bi-bookmark-check me-2 text-primary"></i>Nova Reserva de Dotação
  </h5>
  <button type="button" class="btn-close" onclick="fecharModal()"></button>
</div>

<form hx-post="/admin/reservas-dotacao" hx-target="#modal-body" hx-swap="innerHTML">
  <div class="modal-body">
    <% if (erro) { %><div class="alert alert-danger py-2 small"><%= erro %></div><% } %>
    <input type="hidden" name="entidadeId" value="<%= entidadeId %>">

    <div class="row g-2">
      <div class="col-5 mb-2">
        <label class="form-label small fw-semibold">Número <span class="text-danger">*</span></label>
        <input type="text" name="numero" class="form-control form-control-sm font-monospace"
          value="<%= reserva ? reserva.numero : '' %>" placeholder="ex.: R-2026/0001" maxlength="30" required>
      </div>
      <div class="col-7 mb-2">
        <label class="form-label small fw-semibold">Valor (R$) <span class="text-danger">*</span></label>
        <input type="number" name="valor" step="0.01" min="0.01" class="form-control form-control-sm font-monospace"
          value="<%= reserva ? reserva.valor : '' %>" required>
      </div>

      <div class="col-12 mb-1">
        <label class="form-label small fw-semibold">Dotação <span class="text-danger">*</span></label>
        <% if (dotacoes.length === 0) { %>
          <div class="alert alert-warning py-2 small mb-1">
            Nenhuma dotação disponível — é preciso um orçamento APROVADO ou EM EXECUÇÃO com dotações.
          </div>
        <% } %>
        <select name="dotacaoDespesaId" class="form-select form-select-sm" required
          onchange="document.getElementById('reserva-saldo-hint').textContent = this.options[this.selectedIndex].dataset.disp ? ('Saldo disponível: R$ ' + this.options[this.selectedIndex].dataset.disp) : ''">
          <option value="" data-disp="">— Selecione a dotação —</option>
          <% dotacoes.forEach(function(d) { %>
            <option value="<%= d.id %>" data-disp="<%= d.disponivel %>"
              <%= reserva && reserva.dotacaoDespesaId === d.id ? 'selected' : '' %>>
              <%= d.rotulo %> (<%= d.ano %>) — disp. R$ <%= d.disponivel %>
            </option>
          <% }) %>
        </select>
        <div id="reserva-saldo-hint" class="form-text text-success fw-semibold"></div>
      </div>

      <div class="col-12 mb-2">
        <label class="form-label small fw-semibold">Termo de Referência (opcional)</label>
        <select name="termoReferenciaId" class="form-select form-select-sm">
          <option value="">— Nenhum —</option>
          <% termos.forEach(function(t) { %>
            <option value="<%= t.id %>" <%= reserva && reserva.termoReferenciaId === t.id ? 'selected' : '' %>>
              DOD <%= t.documentoDemanda.numero %> — <%= t.objeto %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-12 mb-2">
        <label class="form-label small fw-semibold">Observações</label>
        <textarea name="observacoes" class="form-control form-control-sm" rows="2" maxlength="500"><%= reserva && reserva.observacoes ? reserva.observacoes : '' %></textarea>
      </div>
    </div>

    <p class="small text-muted mb-0">
      <i class="bi bi-info-circle me-1"></i>A reserva bloqueia o saldo da dotação (pré-empenho). O valor não pode exceder o saldo disponível.
    </p>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-sm btn-secondary" onclick="fecharModal()">Cancelar</button>
    <button type="submit" class="btn btn-sm btn-primary">
      <i class="bi bi-check-lg me-1"></i>Reservar
    </button>
  </div>
</form>
