<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="h5 fw-bold mb-0">Sistemas</h2>
  <button class="btn btn-primary btn-sm"
    hx-get="/admin/sistemas/form"
    hx-target="#modal-body"
    hx-swap="innerHTML">
    <i class="bi bi-plus-lg me-1"></i>Novo Sistema
  </button>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Nome</th>
          <th>Descrição</th>
          <th>Módulos</th>
          <th>Status</th>
          <th class="text-end pe-3">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (sistemas.length === 0) { %>
          <tr><td colspan="5" class="text-center text-muted py-5">
            <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum sistema cadastrado.
          </td></tr>
        <% } %>
        <% sistemas.forEach(function(s) { %>
          <tr id="sistema-<%= s.id %>">
            <td class="ps-3 fw-semibold"><%= s.nome %></td>
            <td class="text-muted small"><%= s.descricao || '—' %></td>
            <td class="text-muted small"><%= s._count.modulos %></td>
            <td>
              <span class="badge rounded-pill <%= s.ativo ? 'bg-success' : 'bg-secondary' %> bg-opacity-75">
                <%= s.ativo ? 'Ativo' : 'Inativo' %>
              </span>
            </td>
            <td class="text-end pe-3">
              <button class="btn btn-sm btn-outline-secondary me-1"
                hx-get="/admin/sistemas/<%= s.id %>/form"
                hx-target="#modal-body"
                hx-swap="innerHTML"
                title="Editar">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-sm btn-outline-danger"
                data-id="<%= s.id %>" data-nome="<%= s.nome %>"
                onclick="confirmarExclusaoAsync('sistema', this.dataset.id, this.dataset.nome, { url: '/admin/sistemas/' + this.dataset.id, target: '#sistema-' + this.dataset.id, swap: 'outerHTML' })"
                title="Excluir">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
