<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="h5 fw-bold mb-1">Classificação Funcional</h2>
    <div class="small text-muted">Portaria MOG nº 42/1999 — tabela de referência (somente leitura)</div>
  </div>
</div>

<div class="alert alert-info py-2 small">
  <i class="bi bi-info-circle me-1"></i>
  Lista fechada por lei federal: <strong><%= funcoes.length %></strong> funções
  e <strong><%= funcoes.reduce(function(s, f) { return s + f.subfuncoes.length }, 0) %></strong> subfunções.
</div>

<div class="accordion" id="acc-funcoes">
  <% funcoes.forEach(function(f, i) { %>
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button <%= i === 0 ? '' : 'collapsed' %>"
          type="button" data-bs-toggle="collapse"
          data-bs-target="#col-<%= f.codigo %>">
          <span class="font-monospace fw-semibold me-2"><%= f.codigo %></span>
          <%= f.nome %>
          <span class="badge bg-light text-muted ms-2"><%= f.subfuncoes.length %> subfunç<%= f.subfuncoes.length === 1 ? 'ão' : 'ões' %></span>
        </button>
      </h2>
      <div id="col-<%= f.codigo %>" class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>"
        data-bs-parent="#acc-funcoes">
        <div class="accordion-body p-0">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-3" style="width:90px">Código</th>
                <th>Subfunção</th>
              </tr>
            </thead>
            <tbody>
              <% if (f.subfuncoes.length === 0) { %>
                <tr><td colspan="2" class="text-center text-muted small py-3">Sem subfunções vinculadas.</td></tr>
              <% } %>
              <% f.subfuncoes.forEach(function(s) { %>
                <tr>
                  <td class="ps-3 font-monospace small"><%= s.codigo %></td>
                  <td class="small"><%= s.nome %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% }) %>
</div>
